/-! ## Computable basis array -/

/-- The 9295-element basis array. Each entry encodes one size-8 flag
    in the 36-bit format documented at the top of this file. -/
def basisAdjArr : Array Nat := parseHexArr basisHexStr

/-- Sanity check: the basis array has the expected size. -/
theorem basisAdjArr_size : basisAdjArr.size = basisSize := by native_decide

/-! ## Bit-extraction helpers

For a packed entry `e : Nat`:
* `extractEdge i j e` (with `i < j < 8`) returns the boolean adjacency.
* `extractColour v e` (with `v < 8`) returns the colour bit as `Fin 2`.
-/

/-- Edge index (u, v) with u < v in the SymNonRefl layout. -/
def edgeIndexNat (u v : Nat) : Nat := v * (v - 1) / 2 + u

/-- Decode a bit of the packed encoding. -/
def bitAt (n : Nat) (pos : Nat) : Bool := (n >>> pos) &&& 1 == 1

/-- Decode the adjacency bit between vertices `u` and `v` (need not be ordered). -/
def extractEdge (e : Nat) (u v : Fin flagOrder) : Bool :=
  if u.val < v.val then
    bitAt e (edgeIndexNat u.val v.val)
  else if v.val < u.val then
    bitAt e (edgeIndexNat v.val u.val)
  else
    false

/-- Decode the colour of vertex `v` as a `Fin 2`. -/
def extractColour (e : Nat) (v : Fin flagOrder) : Fin 2 :=
  if bitAt e (edgeBits + v.val) then 1 else 0

/-! ## Basis as `CGraph 8` and `GenFlag` -/

/-- The `k`-th basis flag, as a computable `CGraph 8`. -/
def flagBasisCGraph (k : Fin basisSize) : CGraph flagOrder where
  adj u v := extractEdge (basisAdjArr[k.val]!) u v
  col v := extractColour (basisAdjArr[k.val]!) v

/-- The `k`-th basis flag, as a `GenFlag CG2 (GenFlagType.empty CG2)`.

This is the public entry point used by `PentagonQBridge.O_Q_alg`. -/
noncomputable def flagBasis (k : Fin basisSize) :
    GenFlag CG2 (GenFlagType.empty CG2) :=
  (flagBasisCGraph k).toGenFlag

/-- The size of every basis flag is 8. -/
theorem flagBasis_size (k : Fin basisSize) : (flagBasis k).size = flagOrder := rfl

/-! ## Smoke tests -/

/-- The basis really has 9295 entries (verified via `native_decide`). -/
theorem basisAdjArr_card : basisAdjArr.size = 9295 := by native_decide

/-- Spot check: the first basis flag is the all-red empty graph
    (matches the Rust enumeration's `flag[0]`). -/
theorem basisAdjArr_first_entry : basisAdjArr[0]! = 0 := by native_decide

end Davey2024.PentagonQBasis
