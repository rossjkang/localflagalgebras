/-! ## Computable basis array -/

/-- The 3808-element basis array. Each entry is a 30-bit packed
    integer per the encoding documented at the top of this file. -/
def basisAdjArr : Array Nat := parseHexArr basisHexStr

/-- Sanity check: the basis array has the expected size. -/
theorem basisAdjArr_size : basisAdjArr.size = basisSize := by native_decide

/-! ## Bit-extraction helpers

For a packed entry `e : Nat`:
* `extractEdgeRaw e i` (0 ≤ i < 10) returns the raw 2-bit edge value (0/1/2).
* `extractVertexRaw e v` (0 ≤ v < 5) returns the raw 2-bit vertex colour.
* `extractAdj` projects raw-edge → adjacency `Bool` (raw value > 0).
* `extractEdgeCol22` projects raw-edge → `Fin 2` edge colour (1 if value = 1
  (F_EDGE), 0 otherwise; this is the CG22 edge-colour interpretation).
* `extractVertexCol22` projects raw-vertex → `Fin 2` vertex colour.
  Bipartite SEC: raw vertex value ∈ {0, 1, 2, 3}; X = {0, 1} → 0, Y = {2, 3} → 1 (project to high bit).
-/

/-- Edge index (u, v) with u < v in the SymNonRefl layout (matches Rust). -/
def edgeIndexNat (u v : Nat) : Nat := v * (v - 1) / 2 + u

/-- Extract a 2-bit window at `pos` from `n`. -/
def twoBitsAt (n : Nat) (pos : Nat) : Nat := (n >>> pos) &&& 3

/-- Decode the raw 2-bit edge value at index `i` (assume `i < 10`). -/
def extractEdgeRaw (e : Nat) (i : Nat) : Nat := twoBitsAt e (i * edgeBitsPer)

/-- Decode the raw 2-bit vertex-colour value at vertex `v` (assume `v < 5`). -/
def extractVertexRaw (e : Nat) (v : Nat) : Nat :=
  twoBitsAt e (edgeBitsTotal + v * vertexBitsPer)

/-- Decode the adjacency between vertices `u` and `v` (need not be ordered). -/
def extractAdj (e : Nat) (u v : Fin flagOrder) : Bool :=
  if u.val < v.val then
    extractEdgeRaw e (edgeIndexNat u.val v.val) > 0
  else if v.val < u.val then
    extractEdgeRaw e (edgeIndexNat v.val u.val) > 0
  else
    false

/-- Decode the CG22 edge colour as `Fin 2`. Convention: `1` if F_EDGE (raw
    value 1), `0` otherwise (raw 0 or 2 = NON_F_EDGE). On non-edges this is `0`. -/
def extractEdgeCol22 (e : Nat) (u v : Fin flagOrder) : Fin 2 :=
  let raw : Nat :=
    if u.val < v.val then extractEdgeRaw e (edgeIndexNat u.val v.val)
    else if v.val < u.val then extractEdgeRaw e (edgeIndexNat v.val u.val)
    else 0
  if raw = 1 then 1 else 0

/-- Decode the CG22 vertex colour. Bipartite SEC: raw vertex value ∈ {0, 1, 2, 3}; X = {0, 1} → 0, Y = {2, 3} → 1 (project to high bit). -/
def extractVertexCol22 (e : Nat) (v : Fin flagOrder) : Fin 2 :=
  let raw := extractVertexRaw e v.val
  if raw &&& 2 = 2 then 1 else 0

/-! ## Basis as `CGraph22 5` and `GenFlag CG22` -/

/-- The `k`-th basis flag, as a computable `CGraph22 5`. -/
def flagBasisCGraph22 (k : Fin basisSize) : CGraph22 flagOrder where
  adj u v := extractAdj (basisAdjArr[k.val]!) u v
  vertexCol v := extractVertexCol22 (basisAdjArr[k.val]!) v
  edgeCol u v := extractEdgeCol22 (basisAdjArr[k.val]!) u v

/-- The `k`-th basis flag, as a `GenFlag CG22 (GenFlagType.empty CG22)`.

    This is the public entry point used by `SecBridge` (Phase S). -/
noncomputable def flagBasis_sec (k : Fin basisSize) :
    GenFlag CG22 (GenFlagType.empty CG22) :=
  (flagBasisCGraph22 k).toGenFlag

/-- The size of every basis flag is 5. -/
theorem flagBasis_sec_size (k : Fin basisSize) : (flagBasis_sec k).size = flagOrder := rfl

/-! ## Smoke tests -/

/-- The basis really has the expected number of entries (verified via `native_decide`). -/
theorem basisAdjArr_card : basisAdjArr.size = 3808 := by native_decide

/-- Spot check: the first basis flag is the empty graph with all-zero colours
    (matches the canonical-form enumeration's `flag[0]`). -/
theorem basisAdjArr_first_entry : basisAdjArr[0]! = 0 := by native_decide

/-- Smoke test: the first basis flag's decoder really sees an empty graph. -/
theorem flagBasisCGraph22_zero_no_adj : ∀ u v : Fin flagOrder,
    (flagBasisCGraph22 ⟨0, by native_decide⟩).adj u v = false := by native_decide

/-- Smoke test: the first basis flag's vertex colours are all 0. -/
theorem flagBasisCGraph22_zero_vertexCol_zero : ∀ v : Fin flagOrder,
    (flagBasisCGraph22 ⟨0, by native_decide⟩).vertexCol v = 0 := by native_decide

end Davey2024.SecBipartiteBasis
