/-- σ-info records: one per block, indexed by Fin 278. -/
def sigmaInfoArr : Array SigmaInfo :=
  (sigmaInfoStr.splitOn ",").foldl (fun arr s => arr.push (parseSigmaInfoDec s)) #[]

/-- σ-flag basis bit arrays: one per block, indexed by Fin 278. -/
def sigmaBasisArr : Array (Array Nat) :=
  (sigmaBasisStr.splitOn ",").foldl
    (fun arr s => arr.push (parseBasisHexList s)) #[]

/-! ## Parametric block lookups -/

/-- σ-type size of block `i` (∈ {2, 4, 6}). -/
def csBlockSigmaSize (i : Fin blockCount) : Nat :=
  (sigmaInfoArr[i.val]!).sigmaSize

/-- σ-type ID (Rust-side enumeration index of the σ-type). -/
def csBlockSigmaId (i : Fin blockCount) : Nat :=
  (sigmaInfoArr[i.val]!).sigmaId

/-- Outer flag size of block `i` (∈ {5, 6, 7}). -/
def csBlockOuterSize (i : Fin blockCount) : Nat :=
  (sigmaInfoArr[i.val]!).outerSize

/-- σ-typed basis dimension of block `i` (= matrix size). -/
def csBlockDim (i : Fin blockCount) : Nat :=
  (sigmaInfoArr[i.val]!).dim

/-- Packed σ-type structure as a `Nat` (encoding: low bits = edges in
    SymNonRefl<bool> order, high bits = colours). -/
def csBlockSigmaHex (i : Fin blockCount) : Nat :=
  (sigmaInfoArr[i.val]!).sigmaHex

/-- The σ-flag basis bits for block `i` (Array of `dim` packed-bit flags). -/
def csBlockBasisAdj (i : Fin blockCount) : Array Nat :=
  sigmaBasisArr[i.val]!

/-! ## σ-type construction -/

/-- σ-type edge index (u, v) with u < v in SymNonRefl<bool> layout. -/
def sigmaEdgeIdx (u v : Nat) : Nat := v * (v - 1) / 2 + u

/-- Decode the σ-type adjacency between vertices `u` and `v`. -/
def csBlockSigmaAdj (i : Fin blockCount) (u v : Nat) : Bool :=
  if u < v then PentagonQBasis.bitAt (csBlockSigmaHex i) (sigmaEdgeIdx u v)
  else if v < u then PentagonQBasis.bitAt (csBlockSigmaHex i) (sigmaEdgeIdx v u)
  else false

/-- Decode the σ-type colour of vertex `v`. -/
def csBlockSigmaColRaw (i : Fin blockCount) (v : Nat) : Fin 2 :=
  let edgeBits := csBlockSigmaSize i * (csBlockSigmaSize i - 1) / 2
  if PentagonQBasis.bitAt (csBlockSigmaHex i) (edgeBits + v) then 1 else 0

/-- The σ-type for block `i`, as a `GenFlagType CG2`.

For Phase 3.1 Tier 2, we ship the σ-data parametrically. The σ-type's
graph structure is `SimpleGraph.fromRel` over the adjacency decoded from
the σ-hex bits, and the colouring reads off the colour bits.

The vertex set is `Fin (csBlockSigmaSize i)`. Because we use
`fromRel`, the universe `(SimpleGraph (Fin _), Fin _ → Fin 2)` is
automatically symmetric and irreflexive (consistent with `CG2.Str`).

Note: this is `noncomputable` because `SimpleGraph.fromRel` is. -/
noncomputable def csBlockSigma (i : Fin blockCount) : GenFlagType CG2 where
  size := csBlockSigmaSize i
  str :=
    (SimpleGraph.fromRel
      (fun u v : Fin (csBlockSigmaSize i) =>
        csBlockSigmaAdj i u.val v.val),
     fun v : Fin (csBlockSigmaSize i) =>
       csBlockSigmaColRaw i v.val)

/-! ## Smoke tests on parametric lookups -/

/-- The first block has σ-info derived from the cert's SDPA mapping. -/
theorem csBlockSigmaSize_block0 :
    csBlockSigmaSize ⟨0, by decide⟩ = 6 := by native_decide

theorem csBlockOuterSize_block0 :
    csBlockOuterSize ⟨0, by decide⟩ = 7 := by native_decide

theorem csBlockDim_block0 :
    csBlockDim ⟨0, by decide⟩ = 22 := by native_decide


end Davey2024.PentagonQSigmaBasis
