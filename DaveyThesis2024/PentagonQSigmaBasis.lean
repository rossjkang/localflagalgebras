/-- Decode the σ-info record format `σ_size-σ_id-outer_size-dim-σ_hex`. -/
structure SigmaInfo where
  sigmaSize : Nat
  sigmaId : Nat
  outerSize : Nat
  dim : Nat
  sigmaHex : Nat
deriving Inhabited

/-- Parse a single info record. -/
def parseSigmaInfo (s : String) : SigmaInfo :=
  let parts := s.splitOn "-"
  match parts with
  | [ss, sid, os, d, sh] =>
    { sigmaSize := PentagonQBasis.parseHexStr ss
      sigmaId := PentagonQBasis.parseHexStr sid
      outerSize := PentagonQBasis.parseHexStr os
      dim := PentagonQBasis.parseHexStr d
      sigmaHex := PentagonQBasis.parseHexStr sh }
  | _ => { sigmaSize := 0, sigmaId := 0, outerSize := 0, dim := 0, sigmaHex := 0 }

private def parseDecCharToNat (c : Char) : Nat :=
  let v := c.toNat
  if v ≥ '0'.toNat ∧ v ≤ '9'.toNat then v - '0'.toNat
  else 0

private def parseDecStr (s : String) : Nat :=
  s.foldl (fun acc c => acc * 10 + parseDecCharToNat c) 0

/-- Re-parse the info record using decimal for the first 4 fields and hex for σ_hex. -/
def parseSigmaInfoDec (s : String) : SigmaInfo :=
  let parts := s.splitOn "-"
  match parts with
  | [ss, sid, os, d, sh] =>
    { sigmaSize := parseDecStr ss
      sigmaId := parseDecStr sid
      outerSize := parseDecStr os
      dim := parseDecStr d
      sigmaHex := PentagonQBasis.parseHexStr sh }
  | _ => { sigmaSize := 0, sigmaId := 0, outerSize := 0, dim := 0, sigmaHex := 0 }

/-- Parse the basis hex record `h0|h1|...|h_{dim-1}`. -/
def parseBasisHexList (s : String) : Array Nat :=
  (s.splitOn "|").foldl (fun arr tok => arr.push (PentagonQBasis.parseHexStr tok)) #[]

