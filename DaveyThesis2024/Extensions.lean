  rw [extSum_apply]
  split
  · exact Nat.cast_nonneg _
  · exact le_refl 0

/-- Locality of `(c • v).support` follows from `v.support` locality.

    `c • v`'s support is a subset of `v.support` (smaller for `c = 0`).

    **Status**: Intentional standalone — foundational locality fact;
    no consumer expected. -/
theorem support_smul_local {σ : GenFlagType CG2}
    {𝒢 : GenGraphClass CG2} {Δ : GenGraphParam CG2}
    (c : ℝ) (v : GenFlagAlg CG2 σ)
    (hv : ∀ cls ∈ v.support, GenIsLocalFlag σ cls.out 𝒢 Δ) :
    ∀ cls ∈ (c • v).support, GenIsLocalFlag σ cls.out 𝒢 Δ := by
  intro cls hcls
  exact hv cls (Finsupp.support_smul hcls)

/-- Locality of `(v + w).support` follows from both `v.support` and `w.support`
    being local.

    **Status**: Intentional standalone — foundational locality fact;
    no consumer expected. -/
theorem support_add_local {σ : GenFlagType CG2}
    {𝒢 : GenGraphClass CG2} {Δ : GenGraphParam CG2}
    (v w : GenFlagAlg CG2 σ)
    (hv : ∀ cls ∈ v.support, GenIsLocalFlag σ cls.out 𝒢 Δ)
    (hw : ∀ cls ∈ w.support, GenIsLocalFlag σ cls.out 𝒢 Δ) :
    ∀ cls ∈ (v + w).support, GenIsLocalFlag σ cls.out 𝒢 Δ := by
  intro cls hcls
  have h_sub : (v + w).support ⊆ v.support ∪ w.support := Finsupp.support_add
  have hmem := h_sub hcls
  rw [Finset.mem_union] at hmem
  rcases hmem with h | h
  · exact hv cls h
  · exact hw cls h

