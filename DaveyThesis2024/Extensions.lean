/-! ### Non-canonical σ-position-1 helpers via composed swaps

The next three theorems handle non-canonical leaf configurations at σ-position-1.
Each composes the σ-pos-1 swap (`swap(0,1)`) with a leaf-frame transposition
on T-positions {1, 2, 3} to produce a permutation φ : Fin 4 ≃ Fin 4 with
φ ⟨1, _⟩ = ⟨0, _⟩ that aligns G's σ-vertex (at G-pos-1) with T's σ-vertex
(at T-pos-0) while permuting the leaves.

- `size4_sigma1_swap01_swap23_iso`: ψ on T-frame is swap(2,3).
  φ : 0↦1, 1↦0, 2↦3, 3↦2.
- `size4_sigma1_swap01_swap13_iso`: ψ on T-frame is swap(1,3).
  φ : 0↦3, 1↦0, 2↦2, 3↦1.
- `size4_sigma1_swap01_swap12_iso`: ψ on T-frame is swap(1,2).
  φ : 0↦2, 1↦0, 2↦1, 3↦3. -/

/-- σ-position-1 non-canonical iso via composite φ = swap(0,1) ∘ swap(2,3). -/
private theorem size4_sigma1_swap01_swap23_iso
    (G_str T_str : CG2.Str 4)
    (G_emb T_emb : Fin vertexBlackType.size ↪ Fin 4)
    (G_isInd : CG2.comap G_emb G_str = vertexBlackType.str)
    (T_isInd : CG2.comap T_emb T_str = vertexBlackType.str)
    (G_hsize T_hsize : vertexBlackType.size ≤ 4)
    (h_emb_G : (G_emb ⟨0, Nat.zero_lt_one⟩).val = 1)
    (h_emb_T : (T_emb ⟨0, Nat.zero_lt_one⟩).val = 0)
    -- φ : 0↦1, 1↦0, 2↦3, 3↦2.
    (h_adj_01 : G_str.1.Adj ⟨0, by decide⟩ ⟨1, by decide⟩ ↔
                T_str.1.Adj ⟨1, by decide⟩ ⟨0, by decide⟩)
    (h_adj_02 : G_str.1.Adj ⟨0, by decide⟩ ⟨2, by decide⟩ ↔
                T_str.1.Adj ⟨1, by decide⟩ ⟨3, by decide⟩)
    (h_adj_03 : G_str.1.Adj ⟨0, by decide⟩ ⟨3, by decide⟩ ↔
                T_str.1.Adj ⟨1, by decide⟩ ⟨2, by decide⟩)
    (h_adj_12 : G_str.1.Adj ⟨1, by decide⟩ ⟨2, by decide⟩ ↔
                T_str.1.Adj ⟨0, by decide⟩ ⟨3, by decide⟩)
    (h_adj_13 : G_str.1.Adj ⟨1, by decide⟩ ⟨3, by decide⟩ ↔
                T_str.1.Adj ⟨0, by decide⟩ ⟨2, by decide⟩)
    (h_adj_23 : G_str.1.Adj ⟨2, by decide⟩ ⟨3, by decide⟩ ↔
                T_str.1.Adj ⟨3, by decide⟩ ⟨2, by decide⟩)
    -- Colours: G(0) = T(1), G(2) = T(3), G(3) = T(2).
    (h_col_0 : G_str.2 ⟨0, by decide⟩ = T_str.2 ⟨1, by decide⟩)
    (h_col_2 : G_str.2 ⟨2, by decide⟩ = T_str.2 ⟨3, by decide⟩)
