/-- Outside-witnessSet contribution lemma for v0-side. 2 witnesses. -/
theorem t4_v0_extSum_outside_witnessSet_zero
    (phi : GenLimitFunctional CG2 (GenFlagType.empty CG2)
      brrbGenGraphClass brrbGenDelta)
    (witnessSet : Finset (GenFlagClass CG2 thesisType4))
    (h_a : GenFlagClass.mk t4_v0_a ∈ witnessSet)
    (h_b : GenFlagClass.mk t4_v0_b ∈ witnessSet) :
    ∀ cls ∈ ((genClassesOfSize CG2 thesisType4
        (thesisType4.size + 1) (Nat.le_succ _)).filter
        (fun cls => extAdjacencyClass thesisType4 cls ⟨0, by decide⟩)),
        cls ∉ witnessSet →
        (extSum thesisType4 ⟨0, by decide⟩) cls *
          (genNormalisationFactor thesisType4 cls.out *
            phi.eval cls.out.forget) = 0 := by
  intro cls hcls_filter hcls_notin
  simp only [Finset.mem_filter, genClassesOfSize, Finset.mem_image,
    Finset.mem_univ, true_and] at hcls_filter
  obtain ⟨⟨p, h_eq⟩, h_adj⟩ := hcls_filter
  have h_size : cls.out.size = 5 := by
    have hiso : (Quotient.out cls : GenFlag CG2 thesisType4) ≈
        ⟨thesisType4.size + 1, p.1, p.2.1, p.2.2, Nat.le_succ _⟩ := by
      rw [← h_eq]
      exact Quotient.exact (Quotient.out_eq _)
    exact genFlagIso_size_eq hiso
  rcases t4_extAdj_v0_dichotomy cls h_size h_adj phi with ha | hb | hzero
  · exfalso; apply hcls_notin; rw [ha]; exact h_a
  · exfalso; apply hcls_notin; rw [hb]; exact h_b
  · rw [hzero, mul_zero, mul_zero]

