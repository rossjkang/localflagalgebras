/-! ## B₁ per-graph IC formulas (Phase 1 of `b1_nonneg` discharge)

For any `ColouredGraphClass` G (Δ-regular, triangle-free, black-independent,
with `|black| = Δ`), we compute exact IC values:

* `IC_certF1_eq_descFactorial`: `IC(certF1, G) = (Δ)_5`.
  certF1 is the 5-vertex all-black empty flag; embeddings correspond to
  ordered 5-tuples of distinct black vertices, automatically inducing the
  empty subgraph by `blackIndependent`.

* `IC_certF6_eq_blackCount_mul_descFactorial`: `IC(certF6, G) = |black| · (Δ)_4`.
  certF6 is K_{1,4} with black centre + 4 red leaves; embeddings correspond
  to a black centre + 4 ordered distinct neighbours of the centre, with
  pairwise non-adjacency among leaves coming from triangle-freeness.
-/

/-- The set of neighbors of a vertex `c` in G, as a subtype. -/
private def vertexNeighbors (G : ColouredGraphClass) (c : Fin G.graph.size) :=
  {v : Fin G.graph.size // G.graph.graph.Adj c v}

private noncomputable instance vertexNeighbors_fintype (G : ColouredGraphClass)
    (c : Fin G.graph.size) : Fintype (vertexNeighbors G c) := by
  unfold vertexNeighbors
  exact Subtype.fintype _

/-- For a black vertex `c`, all its neighbors are red (colour = 0).
    This is the contrapositive of `blackIndependent`. -/
private theorem black_neighbor_is_red (G : ColouredGraphClass)
    (c v : Fin G.graph.size) (hc : G.colouring c = 1) (hadj : G.graph.graph.Adj c v) :
    G.colouring v = 0 := by
  by_contra h
  have : G.colouring v = 1 := by
    have hlt : (G.colouring v).val < 2 := (G.colouring v).isLt
    have hne : (G.colouring v).val ≠ 0 := by intro he; apply h; apply Fin.ext; exact he
    apply Fin.ext; omega
  exact G.blackIndependent c v hc this hadj

/-- |N(c)| = maxDegree G.graph for any vertex c (regularity). -/
private theorem vertexNeighbors_card_eq_maxDegree (G : ColouredGraphClass)
    (c : Fin G.graph.size) :
    Fintype.card (vertexNeighbors G c) = maxDegree G.graph := by
  unfold vertexNeighbors
  rw [Fintype.card_subtype]
  exact G.regular c

/-! ### certF1 IC formula -/

/-- The IC formula for `certF1`: equals `(Δ)_5` where Δ = maxDegree G.graph.

    Proof strategy: build an Equiv to `Fin 5 ↪ {v // colouring v = 1}` then
    apply `Fintype.card_embedding_eq` and `G.blackCount`. -/
theorem IC_certF1_eq_descFactorial (G : ColouredGraphClass) :
    genInducedCount CG2 (GenFlagType.empty CG2) certF1 G.toGenFlag.forget
    = Nat.descFactorial (maxDegree G.graph) 5 := by
  unfold genInducedCount
  -- Step 1: build Equiv to Fin 5 ↪ {v // colouring v = 1}.
  rw [show Fintype.card
        (GenInducedEmbedding CG2 (GenFlagType.empty CG2) certF1 G.toGenFlag.forget) =
      Fintype.card (Fin 5 ↪ {v : Fin G.graph.size // G.colouring v = 1}) from ?_]
  · rw [Fintype.card_embedding_eq, Fintype.card_fin]
    rw [show Fintype.card {v : Fin G.graph.size // G.colouring v = 1} =
      (Finset.univ.filter (fun v : Fin G.graph.size => G.colouring v = 1)).card from
      Fintype.card_subtype _]
    rw [G.blackCount]
  · apply Fintype.card_congr
    -- Forward: e ↦ (i ↦ ⟨e.toFun i, hcol⟩); the colour condition comes from isInduced.
    refine {
      toFun := fun e => ⟨fun i => ⟨e.toFun i, ?_⟩, ?_⟩
      invFun := fun emb => ⟨Subtype.val ∘ emb, ?_, ?_, fun i => Fin.elim0 i⟩
      left_inv := fun e => ?_
      right_inv := fun emb => ?_ }
    · -- colour of e.toFun i is 1
      have h := e.isInduced
      have hcol : (G.toGenFlag.forget.str.2 ∘ e.toFun) = certF1.str.2 :=
        congr_arg Prod.snd h
      have := congr_fun hcol i
      exact this
    · -- forward map is injective
      intro i j hij
      exact e.injective (Subtype.mk.injEq .. |>.mp hij)
    · -- invFun: injective
      intro i j hij
      exact emb.inj' (Subtype.ext hij)
    · -- invFun: comap = certF1.str
      change ((⟨SimpleGraph.comap (Subtype.val ∘ emb) G.graph.graph,
        G.colouring ∘ (Subtype.val ∘ emb)⟩) : CG2.Str 5) =
        (SimpleGraph.fromRel (fun _ _ : Fin 5 => False), fun _ : Fin 5 => (1 : Fin 2))
      apply Prod.ext
      · ext u v
        simp only [SimpleGraph.comap_adj, SimpleGraph.fromRel_adj]
        constructor
        · intro hadj
          rcases eq_or_ne u v with rfl | hne
          · exact absurd hadj (G.graph.graph.irrefl)
          · exfalso
            exact G.blackIndependent _ _ (emb u).property (emb v).property hadj
        · rintro ⟨_, h⟩; exact h.elim False.elim False.elim
      · funext i; change G.colouring (emb i).val = 1; exact (emb i).property
    · -- left_inv
      cases e
      rfl
    · -- right_inv
      apply Function.Embedding.ext
      intro i
      apply Subtype.ext
      rfl

/-! ### certF6 IC formula -/

/-- The Finset of `Fin 5 → Fin n` functions corresponding to certF6 induced
    embeddings (those satisfying injective + structural conditions). -/
private noncomputable def certF6_funFinset (G : ColouredGraphClass) :
    Finset (Fin 5 → Fin G.graph.size) :=
  (Finset.univ : Finset (Fin 5 → Fin G.graph.size)).filter (fun f =>
    Function.Injective f ∧
    G.colouring (f 4) = 1 ∧
    (∀ i : Fin 4, G.colouring (f ⟨i.val, by omega⟩) = 0) ∧
    (∀ i : Fin 4, G.graph.graph.Adj (f ⟨i.val, by omega⟩) (f 4)))

/-- Equiv from `GenInducedEmbedding ... certF6 G.toGenFlag.forget` to
    `{f // f ∈ certF6_funFinset G}`. The forward direction reads off the
    structure: centre at index 4 is black, leaves at 0..3 are red and adj
    to centre. The inverse rebuilds the embedding from a function in the
    Finset, using `triangleFree` for "no edges among leaves". -/
private noncomputable def certF6_emb_equiv_funFinset (G : ColouredGraphClass) :
    GenInducedEmbedding CG2 (GenFlagType.empty CG2) certF6 G.toGenFlag.forget ≃
      {f // f ∈ certF6_funFinset G} where
  toFun e := by
    -- certF6.size = 5 definitionally, so e.toFun : Fin 5 → Fin G.graph.size.
    let f : Fin 5 → Fin G.graph.size := e.toFun
    refine ⟨f, ?_⟩
    simp only [certF6_funFinset, Finset.mem_filter, Finset.mem_univ, true_and]
    have h := e.isInduced
    have hcol_full : (G.toGenFlag.forget.str.2 ∘ e.toFun) = certF6.str.2 :=
      congr_arg Prod.snd h
    have hgraph : SimpleGraph.comap e.toFun G.toGenFlag.forget.str.1 = certF6.str.1 :=
      congr_arg Prod.fst h
    have hcol : ∀ i : Fin 5, G.colouring (f i) =
        (if i.val = 4 then (1 : Fin 2) else 0) := by
      intro i
      have := congr_fun hcol_full i
      exact this
    refine ⟨e.injective, ?_, ?_, ?_⟩
    · -- f 4 black
      have := hcol 4
      simpa using this
    · intro i
      have := hcol ⟨i.val, by omega⟩
      have hne : i.val ≠ 4 := by omega
      simp [hne] at this
      exact this
    · intro i
      -- certF6.str.1 has edge (i, 4) for i ∈ {0,1,2,3}
      have hadj_pre : (certF6.str.1).Adj
          (⟨i.val, by omega⟩ : Fin 5) (⟨4, by omega⟩ : Fin 5) := by
        change (SimpleGraph.fromRel _).Adj _ _
        rw [SimpleGraph.fromRel_adj]
        refine ⟨?_, Or.inl ?_⟩
        · intro h; have := Fin.mk.inj_iff.mp h; omega
        · fin_cases i <;> simp
      have h2 : G.toGenFlag.forget.str.1.Adj
          (f ⟨i.val, by omega⟩) (f ⟨4, by omega⟩) := by
        have h_i_lt : i.val < 5 := by omega
        have h_4_lt : (4 : ℕ) < 5 := by decide
        have := (hgraph ▸ hadj_pre :
          (SimpleGraph.comap e.toFun G.toGenFlag.forget.str.1).Adj
            (⟨i.val, h_i_lt⟩ : Fin 5) (⟨4, h_4_lt⟩ : Fin 5))
        simp only [SimpleGraph.comap_adj] at this
        exact this
      have heq : (⟨4, by omega⟩ : Fin 5) = (4 : Fin 5) := rfl
      rw [heq] at h2
      exact h2
  invFun p := by
    -- Avoid `obtain` so the term remains defeq to the toFun result for left/right_inv.
    set f := p.val with hf_def
    have hp : f ∈ certF6_funFinset G := p.property
    have hf : Function.Injective f ∧ G.colouring (f 4) = 1 ∧
        (∀ i : Fin 4, G.colouring (f ⟨i.val, by omega⟩) = 0) ∧
        (∀ i : Fin 4, G.graph.graph.Adj (f ⟨i.val, by omega⟩) (f 4)) := by
      simp only [certF6_funFinset, Finset.mem_filter, Finset.mem_univ, true_and] at hp
      exact hp
    have hinj := hf.1
    have hc4 := hf.2.1
    have hcL := hf.2.2.1
    have hadj := hf.2.2.2
    refine {
      toFun := f
      injective := hinj
      isInduced := ?_
      compat := fun i => Fin.elim0 i }
    -- Need: comap f G.str = certF6.str (componentwise)
    change ((⟨SimpleGraph.comap f G.graph.graph, G.colouring ∘ f⟩) : CG2.Str 5) =
      certF6.str
    -- Unfold certF6.str
    change ((⟨SimpleGraph.comap f G.graph.graph, G.colouring ∘ f⟩) : CG2.Str 5) =
      (SimpleGraph.fromRel (fun u v : Fin 5 =>
        (u.val = 0 ∧ v.val = 4) ∨ (u.val = 1 ∧ v.val = 4) ∨
        (u.val = 2 ∧ v.val = 4) ∨ (u.val = 3 ∧ v.val = 4)),
       fun v : Fin 5 => if v.val = 4 then (1 : Fin 2) else 0)
    apply Prod.ext
    · -- Graph equality
      ext u v
      simp only [SimpleGraph.comap_adj, SimpleGraph.fromRel_adj]
      constructor
      · intro hadj_uv
        rcases eq_or_ne u v with rfl | hne
        · exact absurd hadj_uv (G.graph.graph.irrefl)
        · refine ⟨hne, ?_⟩
          rcases lt_or_ge u.val 4 with hu | hu
          · rcases lt_or_ge v.val 4 with hv | hv
            · -- both leaves: would form triangle with f 4
              exfalso
              have hu_adj : G.graph.graph.Adj (f u) (f 4) := by
                have := hadj ⟨u.val, hu⟩
                have heq : (⟨u.val, by omega⟩ : Fin 5) = u := Fin.ext rfl
                rwa [heq] at this
              have hv_adj : G.graph.graph.Adj (f v) (f 4) := by
                have := hadj ⟨v.val, hv⟩
                have heq : (⟨v.val, by omega⟩ : Fin 5) = v := Fin.ext rfl
                rwa [heq] at this
              exact G.triangleFree (f u) (f v) (f 4) hadj_uv hv_adj hu_adj
            · -- u leaf, v centre (v.val = 4); structure: R u v ∨ R v u
              -- pick R u v branch and one of its 4 disjuncts based on u.val.
              have hv4 : v.val = 4 := by have := v.isLt; omega
              left
              interval_cases hu_val : u.val
              · left; exact ⟨rfl, hv4⟩
              · right; left; exact ⟨rfl, hv4⟩
              · right; right; left; exact ⟨rfl, hv4⟩
              · right; right; right; exact ⟨rfl, hv4⟩
          · rcases lt_or_ge v.val 4 with hv | hv
            · -- u centre, v leaf; pick R v u branch.
              have hu4 : u.val = 4 := by have := u.isLt; omega
              right
              interval_cases hv_val : v.val
              · left; exact ⟨rfl, hu4⟩
              · right; left; exact ⟨rfl, hu4⟩
              · right; right; left; exact ⟨rfl, hu4⟩
              · right; right; right; exact ⟨rfl, hu4⟩
            · -- both u.val ≥ 4 and < 5 means both = 4: contradicts hne
              exfalso; apply hne; apply Fin.ext
              have := u.isLt; have := v.isLt; omega
      · -- Reverse: from R u v ∨ R v u, derive Adj (f u) (f v).
        -- 8 cases: (u.val=k ∧ v.val=4) for k∈{0,1,2,3} or swapped.
        rintro ⟨_hne, h⟩
        -- Reduce to producing Adj (f u) (f v) for each leaf disjunct.
        -- Use hadj : ∀ i : Fin 4, Adj (f ⟨i, _⟩) (f 4) and graph.symm.
        have hf4_eq : ∀ k : Fin 5, k.val = 4 → f k = f 4 := fun k hk => by
          congr 1; apply Fin.ext; exact hk
        have hfk_eq : ∀ k : Fin 5, ∀ i : Fin 4, k.val = i.val → f k = f ⟨i.val, by omega⟩ :=
          fun k i hk => by congr 1; apply Fin.ext; exact hk
        rcases h with (h | h | h | h) | (h | h | h | h)
        · -- u.val=0, v.val=4: Adj (f u) (f v) ← Adj (f ⟨0,_⟩) (f 4) via hadj 0
          obtain ⟨hu, hv⟩ := h
          rw [hfk_eq u 0 hu, hf4_eq v hv]
          exact hadj 0
        · obtain ⟨hu, hv⟩ := h
          rw [hfk_eq u 1 hu, hf4_eq v hv]
          exact hadj 1
        · obtain ⟨hu, hv⟩ := h
          rw [hfk_eq u 2 hu, hf4_eq v hv]
          exact hadj 2
        · obtain ⟨hu, hv⟩ := h
          rw [hfk_eq u 3 hu, hf4_eq v hv]
          exact hadj 3
        · obtain ⟨hv, hu⟩ := h
          rw [hf4_eq u hu, hfk_eq v 0 hv]
          exact G.graph.graph.symm (hadj 0)
        · obtain ⟨hv, hu⟩ := h
          rw [hf4_eq u hu, hfk_eq v 1 hv]
          exact G.graph.graph.symm (hadj 1)
        · obtain ⟨hv, hu⟩ := h
          rw [hf4_eq u hu, hfk_eq v 2 hv]
          exact G.graph.graph.symm (hadj 2)
        · obtain ⟨hv, hu⟩ := h
          rw [hf4_eq u hu, hfk_eq v 3 hv]
          exact G.graph.graph.symm (hadj 3)
    · -- Colouring equality
      funext v
      change G.colouring (f v) = if v.val = 4 then (1 : Fin 2) else 0
      rcases lt_or_ge v.val 4 with hv | hv
      · have hne : v.val ≠ 4 := by omega
        rw [if_neg hne]
        have := hcL ⟨v.val, hv⟩
        have heq : (⟨v.val, by omega⟩ : Fin 5) = v := Fin.ext rfl
        rwa [heq] at this
      · have h5 : v.val < 5 := v.isLt
        have heq : v.val = 4 := by omega
        have hieq : v = 4 := Fin.ext heq
        rw [hieq]
        simpa using hc4
  left_inv e := by
    -- After both round-trips, the underlying function is unchanged. Use ext.
    cases e with
    | mk toFun injective isInduced compat =>
      -- Result is a GenInducedEmbedding with the same toFun. compat is (i : Fin 0).
      rfl
  right_inv p := by
    -- Same: round-trip preserves the underlying function.
    rcases p with ⟨f, hf⟩
    rfl

/-- The IC formula for `certF6`: equals `|black| · (Δ)_4`.

    Strategy: cardinality of induced embeddings → cardinality of `certF6_funFinset`
    via `certF6_emb_equiv_funFinset`, then partition by `f 4` (centre), and each
    fiber over a black centre `c` is in bijection with `Fin 4 ↪ N(c)` whose
    cardinality is `descFactorial (maxDegree G.graph) 4` by regularity. -/
theorem IC_certF6_eq_blackCount_mul_descFactorial (G : ColouredGraphClass) :
    genInducedCount CG2 (GenFlagType.empty CG2) certF6 G.toGenFlag.forget
    = (Finset.univ.filter (fun v : Fin G.graph.size => G.colouring v = 1)).card *
      Nat.descFactorial (maxDegree G.graph) 4 := by
  unfold genInducedCount
  rw [Fintype.card_congr (certF6_emb_equiv_funFinset G)]
  rw [Fintype.card_coe]
  -- Partition certF6_funFinset by f 4 (the centre).
  rw [Finset.card_eq_sum_card_fiberwise (f := fun f : Fin 5 → Fin G.graph.size => f 4)
    (t := Finset.univ.filter (fun v : Fin G.graph.size => G.colouring v = 1))
    (by
      intro f hf
      have hc4 : G.colouring (f 4) = 1 := by
        rw [Finset.mem_coe] at hf
        unfold certF6_funFinset at hf
        rw [Finset.mem_filter] at hf
        exact hf.2.2.1
      rw [Finset.mem_coe, Finset.mem_filter]
      exact ⟨Finset.mem_univ _, hc4⟩)]
  -- Σ_{c : black} |fiber c| where each fiber has cardinality descFactorial Δ 4.
  have hfiber : ∀ c ∈ Finset.univ.filter (fun v : Fin G.graph.size => G.colouring v = 1),
      ((certF6_funFinset G).filter (fun f : Fin 5 → Fin G.graph.size => f 4 = c)).card =
        Nat.descFactorial (maxDegree G.graph) 4 := by
    intro c hc
    simp only [Finset.mem_filter, Finset.mem_univ, true_and] at hc
    -- Build Equiv: fiber over c ≃ Fin 4 ↪ N(c)
    have hcard : ((certF6_funFinset G).filter (fun f => f 4 = c)).card =
        Fintype.card (Fin 4 ↪ vertexNeighbors G c) := by
      rw [← Fintype.card_coe]
      apply Fintype.card_congr
      refine {
        toFun := fun p => ?_
        invFun := fun emb => ?_
        left_inv := ?_
        right_inv := ?_ }
      · -- p : {f // f ∈ filter (· 4 = c) (certF6_funFinset G)}
        -- Build embedding Fin 4 ↪ N(c) from p.val.
        -- Avoid `obtain`/`rcases` to keep the toFun term clean for left/right_inv.
        let f := p.val
        have hp : f ∈ certF6_funFinset G ∧ f 4 = c := by
          have hp' := p.property
          rw [Finset.mem_filter] at hp'
          exact hp'
        have hf_mem : f ∈ certF6_funFinset G := hp.1
        have hf4 : f 4 = c := hp.2
        have hf_unfold : Function.Injective f ∧ G.colouring (f 4) = 1 ∧
            (∀ i : Fin 4, G.colouring (f ⟨i.val, by omega⟩) = 0) ∧
            (∀ i : Fin 4, G.graph.graph.Adj (f ⟨i.val, by omega⟩) (f 4)) := by
          unfold certF6_funFinset at hf_mem
          rw [Finset.mem_filter] at hf_mem
          exact hf_mem.2
        have hinj : Function.Injective f := hf_unfold.1
        have hadj : ∀ i : Fin 4, G.graph.graph.Adj (f ⟨i.val, by omega⟩) (f 4) :=
          hf_unfold.2.2.2
        refine {
          toFun := fun i => ⟨f ⟨i.val, by omega⟩, ?_⟩
          inj' := ?_ }
        · -- Goal: G.graph.graph.Adj c (f ⟨i.val, _⟩). From f 4 = c, this is Adj (f 4) ⋯.
          have h1 : G.graph.graph.Adj (f 4) (f ⟨i.val, by omega⟩) :=
            G.graph.graph.symm (hadj i)
          rw [hf4] at h1
          exact h1
        · intro i j hij
          have hval : f ⟨i.val, by omega⟩ = f ⟨j.val, by omega⟩ :=
            congr_arg Subtype.val hij
          have := hinj hval
          exact Fin.ext (Fin.mk.inj_iff.mp this)
      · -- embedding → f-in-fiber
        let f : Fin 5 → Fin G.graph.size := fun i =>
          if hi : i.val < 4 then (emb ⟨i.val, hi⟩).val else c
        have hcentre := hc
        have hleaves : ∀ i : Fin 4, G.graph.graph.Adj c (emb i).val :=
          fun i => (emb i).property
        have hf_lt : ∀ i : Fin 5, ∀ hi : i.val < 4,
            f i = (emb ⟨i.val, hi⟩).val := by
          intros; simp [f]; rw [dif_pos]
        have hf_4 : f 4 = c := by
          change (if h : ((4:Fin 5)).val < 4 then (emb ⟨(4:Fin 5).val, h⟩).val else c) = c
          rw [dif_neg (by decide)]
        refine ⟨f, ?_⟩
        simp only [certF6_funFinset, Finset.mem_filter, Finset.mem_univ, true_and]
        have hadj_centre : ∀ i : Fin 4,
            G.graph.graph.Adj (f ⟨i.val, by omega⟩) (f 4) := by
          intro i
          rw [hf_lt ⟨i.val, by omega⟩ i.isLt, hf_4]
          exact G.graph.graph.symm (hleaves ⟨i.val, i.isLt⟩)
        have hcol_leaf : ∀ i : Fin 4, G.colouring (f ⟨i.val, by omega⟩) = 0 := by
          intro i
          rw [hf_lt ⟨i.val, by omega⟩ i.isLt]
          exact black_neighbor_is_red G c (emb ⟨i.val, i.isLt⟩).val hcentre
            (hleaves ⟨i.val, i.isLt⟩)
        have hcol_4 : G.colouring (f 4) = 1 := by rw [hf_4]; exact hcentre
        have hinj : Function.Injective f := by
          intro i j hij
          rcases lt_or_ge i.val 4 with hi | hi
          · rcases lt_or_ge j.val 4 with hj | hj
            · rw [hf_lt i hi, hf_lt j hj] at hij
              have hl : emb ⟨i.val, hi⟩ = emb ⟨j.val, hj⟩ := Subtype.ext hij
              have hk := emb.inj' hl
              exact Fin.ext (Fin.mk.inj_iff.mp hk)
            · rw [hf_lt i hi] at hij
              have hj4 : j.val = 4 := by have := j.isLt; omega
              have hjeq : j = 4 := Fin.ext hj4
              rw [hjeq, hf_4] at hij
              exfalso
              exact (G.graph.graph.irrefl) (hij ▸ hleaves ⟨i.val, hi⟩)
          · rcases lt_or_ge j.val 4 with hj | hj
            · rw [hf_lt j hj] at hij
              have hi4 : i.val = 4 := by have := i.isLt; omega
              have hieq : i = 4 := Fin.ext hi4
              rw [hieq, hf_4] at hij
              exfalso
              exact (G.graph.graph.irrefl) (hij.symm ▸ hleaves ⟨j.val, hj⟩)
            · have hi4 : i.val = 4 := by have := i.isLt; omega
              have hj4 : j.val = 4 := by have := j.isLt; omega
              exact Fin.ext (hi4.trans hj4.symm)
        exact ⟨⟨hinj, hcol_4, hcol_leaf, hadj_centre⟩, hf_4⟩
      · -- left_inv: f-in-fiber → emb → f-in-fiber
        intro p
        apply Subtype.ext
        funext i
        -- Extract f and hf4 from p without `obtain` to keep the term clean.
        have hp_mem : p.val ∈ certF6_funFinset G ∧ p.val 4 = c := by
          have := p.property
          simp only [Finset.mem_filter] at this
          exact this
        have hf4 : p.val 4 = c := hp_mem.2
        change (if h : i.val < 4 then _ else _) = p.val i
        by_cases hi : i.val < 4
        · rw [dif_pos hi]
          -- Goal: ↑(toFun p ⟨i.val, hi⟩) = p.val i = p.val ⟨i.val, _⟩.
          change p.val ⟨i.val, by omega⟩ = p.val i
          congr 1
        · rw [dif_neg hi]
          have hi4 : i.val = 4 := by have := i.isLt; omega
          have hieq : i = 4 := Fin.ext hi4
          rw [hieq, hf4]
      · -- right_inv: emb → f → emb
        intro emb
        apply Function.Embedding.ext
        intro i
        apply Subtype.ext
        change (if h : (⟨i.val, by omega⟩ : Fin 5).val < 4 then _ else _) = _
        rw [dif_pos i.isLt]
    rw [hcard, Fintype.card_embedding_eq, Fintype.card_fin,
        vertexNeighbors_card_eq_maxDegree]
  -- Apply Finset.sum_congr to fold each fiber to descFactorial Δ 4, then sum_const.
  rw [Finset.sum_congr rfl hfiber, Finset.sum_const, smul_eq_mul]

/-! ### σ₁ ext-witness extAdjacency lemmas (Phase 5 σ₁-3 forward direction)

For each thesisType1 ext witness (defined in PentagonConjecture.lean), prove
its iso class is in the relevant extAdjacency filter (extAdj-v1 for `t1_v1_*`,
extAdj-v0 for `t1_v0_*`). The backward direction (every class in the filter
is iso to one of these 6 witnesses) is σ₁-4 work.

Each proof: transport via iso to the witness rep, then exhibit the ext vertex
v=⟨4, _⟩ and verify it's outside the σ-image and adj F.embedding(target_vertex). -/

/-- `t1_v1_a` is in extAdj-v1 filter. -/
theorem t1_v1_a_extAdj_v1 :
    extAdjacencyClass thesisType1 (GenFlagClass.mk t1_v1_a) ⟨1, by decide⟩ :=
  extAdjacencyClass_of_raw _ (by
    refine ⟨⟨4, by decide⟩, ?_, ?_⟩
    · rintro ⟨⟨j, hj⟩, hjeq⟩
      have : j < 4 := hj
      have hsize : thesisType1.size = 4 := rfl
      interval_cases j <;>
        simp [t1_v1_a, Fin.castLE, Fin.ext_iff, hsize] at hjeq
    · simp [t1_v1_a, SimpleGraph.fromRel_adj])

/-- `t1_v1_b` is in extAdj-v1 filter. -/
theorem t1_v1_b_extAdj_v1 :
    extAdjacencyClass thesisType1 (GenFlagClass.mk t1_v1_b) ⟨1, by decide⟩ :=
  extAdjacencyClass_of_raw _ (by
    refine ⟨⟨4, by decide⟩, ?_, ?_⟩
    · rintro ⟨⟨j, hj⟩, hjeq⟩
      have : j < 4 := hj
      have hsize : thesisType1.size = 4 := rfl
      interval_cases j <;>
        simp [t1_v1_b, Fin.castLE, Fin.ext_iff, hsize] at hjeq
    · simp [t1_v1_b, SimpleGraph.fromRel_adj])

/-- `t1_v1_c` is in extAdj-v1 filter. -/
theorem t1_v1_c_extAdj_v1 :
    extAdjacencyClass thesisType1 (GenFlagClass.mk t1_v1_c) ⟨1, by decide⟩ :=
  extAdjacencyClass_of_raw _ (by
    refine ⟨⟨4, by decide⟩, ?_, ?_⟩
    · rintro ⟨⟨j, hj⟩, hjeq⟩
      have : j < 4 := hj
      have hsize : thesisType1.size = 4 := rfl
      interval_cases j <;>
        simp [t1_v1_c, Fin.castLE, Fin.ext_iff, hsize] at hjeq
    · simp [t1_v1_c, SimpleGraph.fromRel_adj])

/-- `t1_v1_d` is in extAdj-v1 filter. -/
theorem t1_v1_d_extAdj_v1 :
    extAdjacencyClass thesisType1 (GenFlagClass.mk t1_v1_d) ⟨1, by decide⟩ :=
  extAdjacencyClass_of_raw _ (by
    refine ⟨⟨4, by decide⟩, ?_, ?_⟩
    · rintro ⟨⟨j, hj⟩, hjeq⟩
      have : j < 4 := hj
      have hsize : thesisType1.size = 4 := rfl
      interval_cases j <;>
        simp [t1_v1_d, Fin.castLE, Fin.ext_iff, hsize] at hjeq
    · simp [t1_v1_d, SimpleGraph.fromRel_adj])

/-- `t1_v0_R` is in extAdj-v0 filter. -/
theorem t1_v0_R_extAdj_v0 :
