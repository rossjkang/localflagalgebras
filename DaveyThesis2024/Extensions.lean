/-! ### Universal σ-position-1 helper for size-4 cases

`size4_sigma1_swap01_iso` is the analogue of `size4_sigma0_id_iso` for the case
where the σ-vertex is at G-position 1 instead of 0. Uses φ = swap(0,1) so the
permutation maps G-pos-1 ↦ T-pos-0 (σ), and G-pos-0 ↦ T-pos-1 (the leaf-0 swap).
G-positions 2 and 3 are unchanged.

Hypotheses are 6 adjacency biconditionals (G-side ↔ T-side under swap) and 3
leaf colour equalities. -/

/-- Universal σ-position-1 iso for size-4 σ-flags via leaf swap(0,1)
    permutation. All u-v adjacencies and v colours specified pairwise. -/
private theorem size4_sigma1_swap01_iso
    (G_str T_str : CG2.Str 4)
    (G_emb T_emb : Fin vertexBlackType.size ↪ Fin 4)
    (G_isInd : CG2.comap G_emb G_str = vertexBlackType.str)
    (T_isInd : CG2.comap T_emb T_str = vertexBlackType.str)
    (G_hsize T_hsize : vertexBlackType.size ≤ 4)
    (h_emb_G : (G_emb ⟨0, Nat.zero_lt_one⟩).val = 1)
    (h_emb_T : (T_emb ⟨0, Nat.zero_lt_one⟩).val = 0)
    -- φ : 0 ↔ 1, 2 fixed, 3 fixed.
    -- G(0,1) ↔ T(1,0), G(0,2) ↔ T(1,2), G(0,3) ↔ T(1,3),
    -- G(1,2) ↔ T(0,2), G(1,3) ↔ T(0,3), G(2,3) ↔ T(2,3).
    (h_adj_01 : G_str.1.Adj ⟨0, by decide⟩ ⟨1, by decide⟩ ↔
                T_str.1.Adj ⟨1, by decide⟩ ⟨0, by decide⟩)
    (h_adj_02 : G_str.1.Adj ⟨0, by decide⟩ ⟨2, by decide⟩ ↔
                T_str.1.Adj ⟨1, by decide⟩ ⟨2, by decide⟩)
    (h_adj_03 : G_str.1.Adj ⟨0, by decide⟩ ⟨3, by decide⟩ ↔
                T_str.1.Adj ⟨1, by decide⟩ ⟨3, by decide⟩)
    (h_adj_12 : G_str.1.Adj ⟨1, by decide⟩ ⟨2, by decide⟩ ↔
                T_str.1.Adj ⟨0, by decide⟩ ⟨2, by decide⟩)
    (h_adj_13 : G_str.1.Adj ⟨1, by decide⟩ ⟨3, by decide⟩ ↔
                T_str.1.Adj ⟨0, by decide⟩ ⟨3, by decide⟩)
    (h_adj_23 : G_str.1.Adj ⟨2, by decide⟩ ⟨3, by decide⟩ ↔
                T_str.1.Adj ⟨2, by decide⟩ ⟨3, by decide⟩)
    -- Colours: G(0) = T(1), G(2) = T(2), G(3) = T(3).
    (h_col_0 : G_str.2 ⟨0, by decide⟩ = T_str.2 ⟨1, by decide⟩)
    (h_col_2 : G_str.2 ⟨2, by decide⟩ = T_str.2 ⟨2, by decide⟩)
    (h_col_3 : G_str.2 ⟨3, by decide⟩ = T_str.2 ⟨3, by decide⟩) :
    GenFlagIso vertexBlackType
