set_option maxHeartbeats 4000000 in
set_option maxRecDepth 4000 in
/-- **`extSum × extSum` Finsupp expansion at vertexBlackType**:

    `(extSum vertexBlackType ⟨0,_⟩).mul (extSum vertexBlackType ⟨0,_⟩) =`
    `single ⟦vbExt2_RR_indep⟧ 1 + single ⟦vbExt2_RR_edge⟧ 1 +`
    `single ⟦vbExt2_RB_indep⟧ 1 + single ⟦vbExt2_RB_edge⟧ 1 +`
    `single ⟦vbExt2_BB_indep⟧ 1 + single ⟦vbExt2_BB_edge⟧ 1`. -/
theorem extSum_vertexBlackType_mul_self :
    (extSum vertexBlackType (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size)).mul
      (extSum vertexBlackType (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size)) =
      Finsupp.single (GenFlagClass.mk vbExt2_RR_indep) 1 +
      Finsupp.single (GenFlagClass.mk vbExt2_RR_edge) 1 +
      Finsupp.single (GenFlagClass.mk vbExt2_RB_indep) 1 +
      Finsupp.single (GenFlagClass.mk vbExt2_RB_edge) 1 +
      Finsupp.single (GenFlagClass.mk vbExt2_BB_indep) 1 +
      Finsupp.single (GenFlagClass.mk vbExt2_BB_edge) 1 := by
  -- 1. Rewrite extSum as `single ⟦vbExtRed⟧ 1 + single ⟦vbExtBlack⟧ 1`.
  rw [extSum_vertexBlackType_eq_two_singles]
  -- 2. Distribute the product into 4 single×single products.
  rw [GenFlagAlg.add_mul, GenFlagAlg.mul_add, GenFlagAlg.mul_add,
      show Finsupp.single (GenFlagClass.mk vbExtRed) (1 : ℝ) = GenFlagAlg.single vbExtRed from rfl,
      show Finsupp.single (GenFlagClass.mk vbExtBlack) (1 : ℝ) = GenFlagAlg.single vbExtBlack from rfl,
      GenFlagAlg.mul_single, GenFlagAlg.mul_single, GenFlagAlg.mul_single, GenFlagAlg.mul_single]
  -- 3. Now LHS = sum of 4 genLocalFlagProduct terms. Use Finsupp.ext.
  ext cls
  -- Helper: (genLocalFlagProduct A B) cls = aut⁻¹ * (if cls ∈ S₃ then jointDensity ... else 0)
  -- where S₃ = genClassesOfSize CG2 vertexBlackType 3.
  -- Apply lfp_apply specialised to our four products and to the size-3 Finset.
  have hsz_RR : vbExtRed.size + vbExtRed.size - vertexBlackType.size = 3 := by decide
  have hsz_RB : vbExtRed.size + vbExtBlack.size - vertexBlackType.size = 3 := by decide
  have hsz_BR : vbExtBlack.size + vbExtRed.size - vertexBlackType.size = 3 := by decide
  have hsz_BB : vbExtBlack.size + vbExtBlack.size - vertexBlackType.size = 3 := by decide
  have h3 : vertexBlackType.size ≤ 3 := by decide
  -- Concrete lfp_apply for our specific size-3 case.
  have lfp_at_cls : ∀ (A B : GenFlag CG2 vertexBlackType)
      (hAB : vertexBlackType.size ≤ A.size + B.size - vertexBlackType.size)
      (hsz : A.size + B.size - vertexBlackType.size = 3),
      (genLocalFlagProduct CG2 vertexBlackType A B) cls =
        ((genFlagAutCount CG2 vertexBlackType A : ℝ) *
          (genFlagAutCount CG2 vertexBlackType B : ℝ))⁻¹ *
        (if cls ∈ genClassesOfSize CG2 vertexBlackType 3 h3
         then genJointInducedDensity CG2 vertexBlackType A B cls.out else 0) := by
    intro A B hAB hsz
    simp only [genLocalFlagProduct, dif_pos hAB, Finsupp.smul_apply, smul_eq_mul,
      Finsupp.finset_sum_apply, Finsupp.single_apply]
    -- Substitute the size to 3
    have hAB' := hAB
    have hSet_eq : genClassesOfSize CG2 vertexBlackType (A.size + B.size - vertexBlackType.size) hAB =
        genClassesOfSize CG2 vertexBlackType 3 h3 := by
      -- Use the dependent equality: when n₁ = n₂, the Finsets agree (subsingleton on proofs).
      generalize_proofs at *
      congr 1
    rw [hSet_eq]
    rw [Finset.sum_ite_eq' (genClassesOfSize CG2 vertexBlackType 3 h3) cls
      (fun c => genJointInducedDensity CG2 vertexBlackType A B c.out)]
  -- Expand both sides using Finsupp.add_apply
  simp only [Finsupp.add_apply]
  rw [lfp_at_cls vbExtRed vbExtRed (by decide) hsz_RR,
      lfp_at_cls vbExtRed vbExtBlack (by decide) hsz_RB,
      lfp_at_cls vbExtBlack vbExtRed (by decide) hsz_BR,
      lfp_at_cls vbExtBlack vbExtBlack (by decide) hsz_BB]
  rw [vbExtRed_aut, vbExtBlack_aut]
  push_cast
  simp only [mul_one, one_mul, inv_one]
  simp only [Finsupp.single_apply]
  -- Case split on cls ∈ genClassesOfSize ... 3 ...
  by_cases h_in_S : cls ∈ genClassesOfSize CG2 vertexBlackType 3 h3
  · simp only [if_pos h_in_S]
    -- For cls ∈ S₃: cls.out has size 3.
    have h_out_size : (Quotient.out cls).size = 3 := by
      have := genClassesOfSize_out_size h_in_S
      exact this
    -- 7-way case split: cls iso to one of 6 vbExt2_X, or none.
    -- We use the "ne or iso" disjunction: cls = mk_X for some X iff cls.out iso to X.
    by_cases h_X : cls = GenFlagClass.mk vbExt2_RR_indep ∨
                   cls = GenFlagClass.mk vbExt2_RR_edge ∨
                   cls = GenFlagClass.mk vbExt2_RB_indep ∨
                   cls = GenFlagClass.mk vbExt2_RB_edge ∨
                   cls = GenFlagClass.mk vbExt2_BB_indep ∨
                   cls = GenFlagClass.mk vbExt2_BB_edge
    · -- One of the 6 named cases: iso transports the joint counts.
      rcases h_X with h_RR_i | h_RR_e | h_RB_i | h_RB_e | h_BB_i | h_BB_e
      · -- cls = mk vbExt2_RR_indep
        have hiso : GenFlagIso vertexBlackType cls.out vbExt2_RR_indep := by
          rw [h_RR_i]
          exact Quotient.exact (Quotient.out_eq (GenFlagClass.mk vbExt2_RR_indep))
        have h_RR : genJointInducedDensity CG2 vertexBlackType vbExtRed vbExtRed cls.out = 1 := by
          rw [genJointInducedDensity_flagIso_target' hiso]
          unfold genJointInducedDensity
          rw [genJointCount_vbExtRed_vbExtRed_vbExt2_RR_indep]
          show ((2:ℕ):ℝ) / _ = 1; norm_num
        have h_RB : genJointInducedDensity CG2 vertexBlackType vbExtRed vbExtBlack cls.out = 0 := by
          rw [genJointInducedDensity_flagIso_target' hiso]; unfold genJointInducedDensity
          rw [genJointCount_vbExtRed_vbExtBlack_vbExt2_RR_indep]; push_cast; ring
        have h_BR : genJointInducedDensity CG2 vertexBlackType vbExtBlack vbExtRed cls.out = 0 := by
          rw [genJointInducedDensity_flagIso_target' hiso]; unfold genJointInducedDensity
          rw [genJointCount_vbExtBlack_vbExtRed_vbExt2_RR_indep]; push_cast; ring
        have h_BB : genJointInducedDensity CG2 vertexBlackType vbExtBlack vbExtBlack cls.out = 0 := by
          rw [genJointInducedDensity_flagIso_target' hiso]; unfold genJointInducedDensity
          rw [genJointCount_vbExtBlack_vbExtBlack_vbExt2_RR_indep]; push_cast; ring
        rw [h_RR, h_RB, h_BR, h_BB, h_RR_i]
        rw [if_pos rfl, if_neg (Ne.symm vbExt2_RR_indep_ne_RR_edge),
            if_neg (Ne.symm vbExt2_RR_indep_ne_RB_indep),
            if_neg (Ne.symm vbExt2_RR_indep_ne_RB_edge),
            if_neg (Ne.symm vbExt2_RR_indep_ne_BB_indep),
            if_neg (Ne.symm vbExt2_RR_indep_ne_BB_edge)]
        ring
      · -- cls = mk vbExt2_RR_edge
        have hiso : GenFlagIso vertexBlackType cls.out vbExt2_RR_edge := by
          rw [h_RR_e]
          exact Quotient.exact (Quotient.out_eq (GenFlagClass.mk vbExt2_RR_edge))
        have h_RR : genJointInducedDensity CG2 vertexBlackType vbExtRed vbExtRed cls.out = 1 := by
