/-! ### LFP(vbExt3_RRR_e0, vbExtRed)(⟦vbExt4_RRRR_e0⟧) = 1

The unique nonzero contribution. Uses the joint count = 24 (sub-task 2),
`vbExt3_RRR_e0_aut = 6` (sub-task 1), and `vbExtRed_aut = 1`.

Density = 24 / (C(4, 3) · C(1, 1)) = 24 / 4 = 6.
Coefficient = (6 · 1)⁻¹ · 6 = 1. -/

theorem lfp_vbExt3_RRR_e0_vbExtRed_at_RRRR_e0 :
    (genLocalFlagProduct CG2 vertexBlackType vbExt3_RRR_e0 vbExtRed)
      (GenFlagClass.mk vbExt4_RRRR_e0) = 1 := by
  rw [lfp_apply_at_RRRR_e0 vbExt3_RRR_e0 vbExtRed rfl rfl]
  rw [vbExt3_RRR_e0_aut, vbExtRed_aut]
  unfold genJointInducedDensity
  rw [genJointCount_vbExt3_RRR_e0_vbExtRed_vbExt4_RRRR_e0]
  -- vbExt4_RRRR_e0.size = 5, σ.size = 1, vbExt3_RRR_e0.size = 4, vbExtRed.size = 2.
  -- G - σ = 4. F₁ - σ = 3. C(4, 3) = 4. G - F₁ = 1. F₂ - σ = 1. C(1, 1) = 1.
  -- Density = 24 / (4 * 1) = 6. Coeff = (6 * 1)⁻¹ * 6 = 1.
  have h1 : (Nat.choose (vbExt4_RRRR_e0.size - vertexBlackType.size)
              (vbExt3_RRR_e0.size - vertexBlackType.size) : ℝ) = 4 := by
    change ((Nat.choose (5 - 1) (4 - 1) : ℕ) : ℝ) = 4
    norm_num
  have h2 : (Nat.choose (vbExt4_RRRR_e0.size - vertexBlackType.size -
              (vbExt3_RRR_e0.size - vertexBlackType.size))
              (vbExtRed.size - vertexBlackType.size) : ℝ) = 1 := by
    change ((Nat.choose (5 - 1 - (4 - 1)) (2 - 1) : ℕ) : ℝ) = 1
    norm_num
  rw [h1, h2]
  norm_num

/-! ### Iso-transport for the size-4 master classification at ⟦RRRR_e0⟧

For any size-4 σ-flag G with σ adjacent to all 3 leaves, we know G is iso to
one of the 20 named flags. We characterize `LFP(G, vbExtRed)(⟦RRRR_e0⟧)`:
it equals 1 if G iso to vbExt3_RRR_e0, else 0. -/

/-- Iso-invariance: `LFP(F₁, B)(cls) = LFP(F₂, B)(cls)` if `F₁ ≈ F₂`. -/
private theorem lfp_apply_flagIso_left {σ : GenFlagType CG2} {F₁ F₂ B : GenFlag CG2 σ}
    (h : GenFlagIso σ F₁ F₂) (cls : GenFlagClass CG2 σ) :
    (genLocalFlagProduct CG2 σ F₁ B) cls = (genLocalFlagProduct CG2 σ F₂ B) cls := by
  rw [genLocalFlagProduct_flagIso_left h]

/-- For any size-4 σ-flag G with σ-vertex adjacent to all 3 leaves,
    `LFP(G, vbExtRed)(⟦RRRR_e0⟧) = if G iso to vbExt3_RRR_e0 then 1 else 0`. -/
private theorem lfp_size4_vbExtRed_at_RRRR_e0
    (G : GenFlag CG2 vertexBlackType) (hsize : G.size = 4)
    (hadj_all : ∀ v : Fin G.size, v ≠ G.embedding ⟨0, Nat.zero_lt_one⟩ →
                G.str.1.Adj (G.embedding ⟨0, Nat.zero_lt_one⟩) v) :
    (GenFlagIso vertexBlackType G vbExt3_RRR_e0 ∧
      (genLocalFlagProduct CG2 vertexBlackType G vbExtRed)
        (GenFlagClass.mk vbExt4_RRRR_e0) = 1) ∨
    (genLocalFlagProduct CG2 vertexBlackType G vbExtRed)
      (GenFlagClass.mk vbExt4_RRRR_e0) = 0 := by
  rcases any_size4_extAdjAll_iso G hsize hadj_all with
    h | h | h | h | h | h | h | h | h | h | h | h | h | h | h | h | h | h | h | h
  · left; refine ⟨h, ?_⟩
    rw [lfp_apply_flagIso_left h]
    exact lfp_vbExt3_RRR_e0_vbExtRed_at_RRRR_e0
  all_goals (right; rw [lfp_apply_flagIso_left h])
  · exact lfp_vbExt3_RRR_e1_vbExtRed_at_RRRR_e0
  · exact lfp_vbExt3_RRR_e2_vbExtRed_at_RRRR_e0
  · exact lfp_vbExt3_RRR_e3_vbExtRed_at_RRRR_e0
  · exact lfp_vbExt3_BBB_e0_vbExtRed_at_RRRR_e0
  · exact lfp_vbExt3_BBB_e1_vbExtRed_at_RRRR_e0
  · exact lfp_vbExt3_BBB_e2_vbExtRed_at_RRRR_e0
  · exact lfp_vbExt3_BBB_e3_vbExtRed_at_RRRR_e0
  · exact lfp_vbExt3_RRB_e0_vbExtRed_at_RRRR_e0
  · exact lfp_vbExt3_RRB_e1_RR_vbExtRed_at_RRRR_e0
  · exact lfp_vbExt3_RRB_e1_RB_vbExtRed_at_RRRR_e0
  · exact lfp_vbExt3_RRB_e2_RRRB_vbExtRed_at_RRRR_e0
  · exact lfp_vbExt3_RRB_e2_RBRB_vbExtRed_at_RRRR_e0
  · exact lfp_vbExt3_RRB_e3_vbExtRed_at_RRRR_e0
  · exact lfp_vbExt3_RBB_e0_vbExtRed_at_RRRR_e0
  · exact lfp_vbExt3_RBB_e1_RB_vbExtRed_at_RRRR_e0
  · exact lfp_vbExt3_RBB_e1_BB_vbExtRed_at_RRRR_e0
  · exact lfp_vbExt3_RBB_e2_RBBB_vbExtRed_at_RRRR_e0
  · exact lfp_vbExt3_RBB_e2_RBRB_vbExtRed_at_RRRR_e0
  · exact lfp_vbExt3_RBB_e3_vbExtRed_at_RRRR_e0

/-! ### Main theorem: `extPow_four_apply_RRRR_e0 = 1`

`extPow⁴(⟦RRRR_e0⟧) = (extPow³ · extSum)(⟦RRRR_e0⟧)`. Decompose extSum into
`single vbExtRed + single vbExtBlack`. Each term computed via Finsupp.sum
expansion + per-summand classification. -/

/-- Generic helper: `(v · single Y)(cls)` unfolded as a Finsupp.sum. -/
private theorem mul_single_apply
    (v : GenFlagAlg CG2 vertexBlackType)
    (Y : GenFlag CG2 vertexBlackType)
    (cls : GenFlagClass CG2 vertexBlackType) :
    (v.mul (GenFlagAlg.single Y)) cls =
      v.sum (fun c k => k *
        ((genLocalFlagProduct CG2 vertexBlackType c.out Y) cls)) := by
  unfold GenFlagAlg.mul
  -- Outer sum: v.sum (fun cls₁ c₁ => (single Y).sum (fun cls₂ c₂ => (c₁ * c₂) • LFP_class(cls₁, cls₂))).
  simp only [GenFlagAlg.single]
  -- Inner sum on `single Y`: collapses via Finsupp.sum_single_index.
  conv_lhs => rw [show (fun (cls₁ : GenFlagClass CG2 vertexBlackType) (c₁ : ℝ) =>
      (Finsupp.single (GenFlagClass.mk Y) (1:ℝ)).sum (fun cls₂ c₂ =>
        (c₁ * c₂) • genLocalFlagProduct_class CG2 vertexBlackType cls₁ cls₂)) =
      (fun (cls₁ : GenFlagClass CG2 vertexBlackType) (c₁ : ℝ) =>
        (c₁ * 1) • genLocalFlagProduct_class CG2 vertexBlackType cls₁
          (GenFlagClass.mk Y)) from by
      funext cls₁ c₁
      rw [Finsupp.sum_single_index (by simp)]]
  -- Now LHS is v.sum (fun cls₁ c₁ => (c₁ * 1) • LFP_class(cls₁, ⟦Y⟧)) cls.
  rw [Finsupp.sum, Finsupp.sum, Finsupp.finset_sum_apply]
  apply Finset.sum_congr rfl
  intro cls₁ _hcls₁
  simp only [Finsupp.smul_apply, smul_eq_mul, mul_one]
  rw [genLocalFlagProduct_class_out]
  -- Goal: v cls₁ * LFP(cls₁.out, (mk Y).out)(cls) = v cls₁ * LFP(cls₁.out, Y)(cls)
  congr 1
  -- Goal: LFP(cls₁.out, (mk Y).out)(cls) = LFP(cls₁.out, Y)(cls)
  -- Use iso (mk Y).out ≈ Y.
  have hiso : GenFlagIso vertexBlackType (Quotient.out (GenFlagClass.mk Y)) Y :=
    Quotient.exact (Quotient.out_eq (GenFlagClass.mk Y))
  rw [genLocalFlagProduct_flagIso_right hiso]

/-- For any size-4 σ-flag `cls.out` in supp(extPow³),
    `LFP(cls.out, vbExtBlack)(⟦RRRR_e0⟧) = 0`. -/
private theorem extPow_three_supp_lfp_vbExtBlack_at_RRRR_e0
    (cls : GenFlagClass CG2 vertexBlackType)
    (hcls : cls ∈ (extPow vertexBlackType
      (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) 3).support) :
    (genLocalFlagProduct CG2 vertexBlackType cls.out vbExtBlack)
      (GenFlagClass.mk vbExt4_RRRR_e0) = 0 := by
  have hsize : cls.out.size = 4 := extPow_three_support_size_eq_four cls hcls
  exact lfp_F_vbExtBlack_at_RRRR_e0_eq_zero cls.out hsize

/-- `(extPow³ · single vbExtBlack)(⟦RRRR_e0⟧) = 0`. -/
private theorem extPow_three_mul_single_vbExtBlack_at_RRRR_e0 :
    ((extPow vertexBlackType
      (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) 3).mul
      (GenFlagAlg.single vbExtBlack)) (GenFlagClass.mk vbExt4_RRRR_e0) = 0 := by
  rw [mul_single_apply]
  rw [Finsupp.sum]
  apply Finset.sum_eq_zero
  intro cls hcls
  rw [extPow_three_supp_lfp_vbExtBlack_at_RRRR_e0 cls hcls, mul_zero]

/-- For any cls in supp(extPow³),
    `LFP(cls.out, vbExtRed)(⟦RRRR_e0⟧) = if cls = ⟦vbExt3_RRR_e0⟧ then 1 else 0`. -/
private theorem extPow_three_supp_lfp_vbExtRed_at_RRRR_e0
    (cls : GenFlagClass CG2 vertexBlackType)
    (hcls : cls ∈ (extPow vertexBlackType
      (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) 3).support) :
    (genLocalFlagProduct CG2 vertexBlackType cls.out vbExtRed)
      (GenFlagClass.mk vbExt4_RRRR_e0) =
      if cls = GenFlagClass.mk vbExt3_RRR_e0 then 1 else 0 := by
  have hsize : cls.out.size = 4 := extPow_three_support_size_eq_four cls hcls
  have hadjC := extPow_three_support_extAdjAllClass cls hcls
  -- Translate ExtAdjAllClass to "∀ v, v ≠ emb 0 → adj"
  have hadj_form : ∀ v : Fin cls.out.size,
      v ≠ cls.out.embedding ⟨0, Nat.zero_lt_one⟩ →
      cls.out.str.1.Adj (cls.out.embedding ⟨0, Nat.zero_lt_one⟩) v := by
    intro v hne
    apply hadjC
    intro ⟨j, hj⟩
    apply hne
    have hj_val : j.val = 0 := by
      have hjlt : j.val < 1 := j.isLt
      omega
    have hj_zero : j = (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) :=
      Fin.ext hj_val
    rw [hj_zero] at hj
    exact hj.symm
  rcases lfp_size4_vbExtRed_at_RRRR_e0 cls.out hsize hadj_form with
    ⟨h_iso, h_eq⟩ | h_zero
  · -- cls.out iso to vbExt3_RRR_e0; cls = ⟦vbExt3_RRR_e0⟧
    rw [h_eq]
    have hmk : GenFlagClass.mk cls.out = GenFlagClass.mk vbExt3_RRR_e0 :=
      (GenFlagClass.mk_eq _ _).mpr h_iso
    have hcls_eq : cls = GenFlagClass.mk vbExt3_RRR_e0 := by
      rw [← Quotient.out_eq cls]; exact hmk
    rw [if_pos hcls_eq]
  · -- cls.out NOT iso to vbExt3_RRR_e0; LFP = 0
    rw [h_zero]
    -- We need: 0 = if cls = ⟦RRR_e0⟧ then 1 else 0
    by_cases hcls_eq : cls = GenFlagClass.mk vbExt3_RRR_e0
    · -- If cls = ⟦RRR_e0⟧, then cls.out is iso to vbExt3_RRR_e0, contradicting h_zero
      exfalso
      have h_iso : GenFlagIso vertexBlackType cls.out vbExt3_RRR_e0 := by
        have hmk_out : GenFlagClass.mk cls.out = cls := Quotient.out_eq cls
        have hmk : GenFlagClass.mk cls.out = GenFlagClass.mk vbExt3_RRR_e0 := by
          rw [hmk_out]; exact hcls_eq
        exact (GenFlagClass.mk_eq _ _).mp hmk
      have h_lfp_one : (genLocalFlagProduct CG2 vertexBlackType cls.out vbExtRed)
          (GenFlagClass.mk vbExt4_RRRR_e0) = 1 := by
        rw [lfp_apply_flagIso_left h_iso]
        exact lfp_vbExt3_RRR_e0_vbExtRed_at_RRRR_e0
      rw [h_lfp_one] at h_zero
      exact one_ne_zero h_zero
    · rw [if_neg hcls_eq]

/-- `(extPow³ · single vbExtRed)(⟦RRRR_e0⟧) = extPow³(⟦vbExt3_RRR_e0⟧)`. -/
private theorem extPow_three_mul_single_vbExtRed_at_RRRR_e0 :
    ((extPow vertexBlackType
      (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) 3).mul
      (GenFlagAlg.single vbExtRed)) (GenFlagClass.mk vbExt4_RRRR_e0) =
    (extPow vertexBlackType
      (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) 3)
      (GenFlagClass.mk vbExt3_RRR_e0) := by
  rw [mul_single_apply]
  set v := extPow vertexBlackType
    (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) 3 with hv_def
  -- Rewrite each summand using extPow_three_supp_lfp_vbExtRed_at_RRRR_e0.
  have h_rewrite : ∀ cls ∈ v.support,
      v cls * (genLocalFlagProduct CG2 vertexBlackType cls.out vbExtRed)
        (GenFlagClass.mk vbExt4_RRRR_e0) =
      if cls = GenFlagClass.mk vbExt3_RRR_e0 then v cls else 0 := by
    intro cls hcls
    rw [extPow_three_supp_lfp_vbExtRed_at_RRRR_e0 cls hcls]
    by_cases h : cls = GenFlagClass.mk vbExt3_RRR_e0
    · rw [if_pos h, if_pos h, mul_one]
    · rw [if_neg h, if_neg h, mul_zero]
  -- Apply Finsupp.sum_congr to use h_rewrite.
  rw [show v.sum (fun c k => k * (genLocalFlagProduct CG2 vertexBlackType c.out vbExtRed)
        (GenFlagClass.mk vbExt4_RRRR_e0)) =
      v.sum (fun c _ => if c = GenFlagClass.mk vbExt3_RRR_e0 then v c else 0) from by
    apply Finsupp.sum_congr
    intro cls hcls
    change v cls * (genLocalFlagProduct CG2 vertexBlackType cls.out vbExtRed)
        (GenFlagClass.mk vbExt4_RRRR_e0) =
      if cls = GenFlagClass.mk vbExt3_RRR_e0 then v cls else 0
    exact h_rewrite cls hcls]
  -- Collapse the sum to a single value.
  rw [Finsupp.sum]
  by_cases hmem : GenFlagClass.mk vbExt3_RRR_e0 ∈ v.support
  · rw [Finset.sum_eq_single (GenFlagClass.mk vbExt3_RRR_e0)
      (fun cls _ hne => by simp [hne]) (fun h => absurd hmem h)]
    rw [if_pos rfl]
  · have h_zero : v (GenFlagClass.mk vbExt3_RRR_e0) = 0 :=
      Finsupp.notMem_support_iff.mp hmem
    rw [h_zero]
    apply Finset.sum_eq_zero
    intro cls hcls
    by_cases hcls_eq : cls = GenFlagClass.mk vbExt3_RRR_e0
    · rw [hcls_eq] at hcls; exact absurd hcls hmem
    · rw [if_neg hcls_eq]

/-- **The size-5 v5 coefficient identity**: `extPow⁴(⟦vbExt4_RRRR_e0⟧) = 1`. -/
theorem extPow_four_apply_RRRR_e0 :
    (extPow vertexBlackType (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) 4)
      (GenFlagClass.mk vbExt4_RRRR_e0) = 1 := by
  -- extPow⁴ = extPow³ · extSum
  rw [show extPow vertexBlackType
      (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) 4 =
      (extPow vertexBlackType
        (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) 3).mul
        (extSum vertexBlackType
          (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size)) from rfl]
  -- Substitute extSum = single Red + single Black.
  rw [extSum_vertexBlackType_eq_two_singles]
  -- Distribute: (extPow³) · (single Red + single Black) = extPow³ · single Red + extPow³ · single Black.
  rw [show (Finsupp.single (GenFlagClass.mk vbExtRed) (1:ℝ) :
        GenFlagAlg CG2 vertexBlackType) = GenFlagAlg.single vbExtRed from rfl]
  rw [show (Finsupp.single (GenFlagClass.mk vbExtBlack) (1:ℝ) :
        GenFlagAlg CG2 vertexBlackType) = GenFlagAlg.single vbExtBlack from rfl]
  rw [GenFlagAlg.mul_add]
  rw [Finsupp.add_apply]
  rw [extPow_three_mul_single_vbExtRed_at_RRRR_e0,
      extPow_three_mul_single_vbExtBlack_at_RRRR_e0]
  rw [extPow_three_apply_RRR_e0]
  ring

/-! ### Unconditional master closure for size-5 v5 phase

Combines `extPow_four_apply_RRRR_e0 = 1` with the conditional
`evalAlg_single_vbExt4_RRRR_e0_eq_one_of_coeff` to discharge the size-5 v5
identity unconditionally. -/

/-! ### F₆ identification: `vbExt4_RRRR_e0.forget ≃ certF6`

The forgotten σ-flag `vbExt4_RRRR_e0.forget` (K_{1,4} centred at vertex 0) is
isomorphic as an ∅-flag to `certF6` (K_{1,4} centred at vertex 4) — both are
star graphs on 5 vertices with one black centre and 4 red leaves; only the
labelling of the centre differs.

The permutation `0 → 4, 1 → 0, 2 → 1, 3 → 2, 4 → 3` (a 5-cycle) maps
`vbExt4_RRRR_e0.forget` onto `certF6`, sending the σ-vertex (position 0,
black) to position 4 (the black centre of `certF6`). -/

set_option maxHeartbeats 800000 in
-- 25 fin_cases combinations on Fin 5 × Fin 5 plus simp per case exceeds the default budget.
/-- **Goal 1**: `vbExt4_RRRR_e0.forget ≃ certF6` as ∅-flags in CG2.

The two flags differ only in which Fin 5 index hosts the black centre:
- `vbExt4_RRRR_e0.forget`: centre at vertex 0, leaves at 1,2,3,4.
- `certF6`: centre at vertex 4, leaves at 0,1,2,3.

The 5-cycle permutation `i ↦ i-1 mod 5` (equivalently `0→4, 1→0, 2→1, 3→2, 4→3`)
realises the isomorphism. -/
theorem vbExt4_RRRR_e0_forget_iso_certF6 :
    GenFlagIso (GenFlagType.empty CG2) vbExt4_RRRR_e0.forget certF6 := by
  let fwd : Fin 5 → Fin 5 := fun x => match x.val with
    | 0 => 4 | 1 => 0 | 2 => 1 | 3 => 2 | _ => 3
  let inv : Fin 5 → Fin 5 := fun x => match x.val with
    | 0 => 1 | 1 => 2 | 2 => 3 | 3 => 4 | _ => 0
  have hli : ∀ x, inv (fwd x) = x := by intro x; fin_cases x <;> rfl
  have hri : ∀ x, fwd (inv x) = x := by intro x; fin_cases x <;> rfl
  refine ⟨⟨fwd, inv, hli, hri⟩, ?_, fun i => Fin.elim0 i⟩
  -- Need: CG2.comap equiv certF6.str = vbExt4_RRRR_e0.forget.str
  simp only [colouredGraphUniverse, vbExt4_RRRR_e0, certF6, GenFlag.forget]
  apply Prod.ext
  · ext u v
    simp only [SimpleGraph.comap_adj, SimpleGraph.fromRel_adj]
    fin_cases u <;> fin_cases v <;> simp [fwd, inv]
  · ext i; fin_cases i <;> simp [fwd, inv]

/-- Corollary: any ∅-functional `phi` evaluates `vbExt4_RRRR_e0.forget` and
    `certF6` to the same value. -/
theorem phi_eval_vbExt4_RRRR_e0_forget_eq_certF6
    {𝒢 : GenGraphClass CG2} {Δ : GenGraphParam CG2}
    (phi : GenLimitFunctional CG2 (GenFlagType.empty CG2) 𝒢 Δ) :
    phi.eval vbExt4_RRRR_e0.forget = phi.eval certF6 :=
  phi.eval_iso _ _ vbExt4_RRRR_e0_forget_iso_certF6

/-! ### σ → ∅ Forbidden lifting

For a σ-flag `F` that is forbidden in graph class `𝒢`, the forgotten ∅-flag
`F.forget` is also forbidden. By the counting equality
`genForget_count_eq_sigma_sum`, the ∅-induced count of `F.forget` decomposes
as a sum of σ-induced counts (one per σ-marker choice), all of which vanish
by σ-IsForbidden. -/

/-- **σ → ∅ Forbidden lifting**: a σ-IsForbidden flag has ∅-forbidden forget.

    Strategy: `genForget_count_eq_sigma_sum` decomposes the ∅-induced count
    of `F.forget` into `H` as `Σ θ : SigmaEmb σ H, c(F; (H, θ))`. For each
    `θ`, the σ-flag `genSigmaFlagOfEmb' θ` has forget = `H` (modulo trivial
    embedding equality), and we need `𝒢 H.forget` to apply σ-IsForbidden.
    For an ∅-flag `H`, `H.forget` and `H` have identical structure data.

    The hypothesis takes `𝒢 H.forget`, since IsForbidden of an ∅-flag is stated
    over G with `𝒢 G.forget`. -/
theorem isForbidden_forget {σ : GenFlagType CG2}
    {F : GenFlag CG2 σ} {𝒢 : GenGraphClass CG2}
    (h : IsForbidden σ F 𝒢) :
    IsForbidden (GenFlagType.empty CG2) F.forget 𝒢 := by
  intro H hH
  rw [genForget_count_eq_sigma_sum σ F H]
  apply Finset.sum_eq_zero
  intro θ _
  -- IsForbidden σ F 𝒢 takes G : GenFlag σ + 𝒢 G.forget, returns count = 0.
  -- After `apply h`, goal becomes `𝒢 (genSigmaFlagOfEmb' θ).forget`.
  -- `genSigmaFlagOfEmb'_forget` rewrites this to `𝒢 H`.
  -- For ∅-flag H, `H.forget = H` via `GenFlag.empty_ext`, so hH transports.
  apply h
  rw [genSigmaFlagOfEmb'_forget]
  exact (GenFlag.empty_ext H.forget H rfl rfl) ▸ hH

/-- **Forbidden ∅-flag eval is zero**: for any ∅-functional `phi` and σ-flag
    `F` that is σ-IsForbidden in `𝒢`, `phi.eval F.forget = 0`.

    Combines `isForbidden_forget` with `evalAlg_single_zero_of_forbidden`. -/
theorem phi_eval_forget_zero_of_isForbidden {σ : GenFlagType CG2}
    {F : GenFlag CG2 σ} {𝒢 : GenGraphClass CG2} {Δ : GenGraphParam CG2}
    (h : IsForbidden σ F 𝒢)
    (phi : GenLimitFunctional CG2 (GenFlagType.empty CG2) 𝒢 Δ) :
    phi.eval F.forget = 0 := by
  have h_forget := isForbidden_forget h
  have h_zero := evalAlg_single_zero_of_forbidden h_forget phi
  rw [GenLimitFunctional.evalAlg_single] at h_zero
  exact h_zero

/-! ### ∅-functional dichotomy at size 5 (vbType, ExtAdjAll)

The σ-functional dichotomy `evalAlg_single_size5_extAdjAll_dichotomy_sharp`
gives: for size-5 ExtAdjAll classes `cls`, either `cls = ⟦vbExt4_RRRR_e0⟧`
or `cls.out` is σ-IsForbidden in BRRB. This lifts to the ∅-functional level
via `phi_eval_forget_zero_of_isForbidden`. -/

/-- **∅-functional dichotomy at size 5 ExtAdjAll**: for any class `cls` of
    size-5 σ-flags with ExtAdjAll, either `cls = ⟦vbExt4_RRRR_e0⟧`, or for
    any ∅-functional `phi`, `phi.eval cls.out.forget = 0`.

    This is the ∅-functional analog of
    `evalAlg_single_size5_extAdjAll_dichotomy_sharp`. The forbidden case
    transfers via `phi_eval_forget_zero_of_isForbidden`. -/
theorem phi_eval_size5_extAdjAll_dichotomy
    (cls : GenFlagClass CG2 vertexBlackType)
    (h_size : IsClassOfSize 5 cls)
    (h_extAdjAll : ExtAdjAllClass cls
      (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size))
    (phi : GenLimitFunctional CG2 (GenFlagType.empty CG2)
      brrbGenGraphClass brrbGenDelta) :
    cls = GenFlagClass.mk vbExt4_RRRR_e0 ∨ phi.eval cls.out.forget = 0 := by
  -- Inline the structural part of `any_size5_extAdjAll_iso_or_forbidden`
  -- (which is class-level), avoiding the σ-functional indirection.
  have hsize : cls.out.size = 5 := h_size
  have hadj_all : ∀ v : Fin cls.out.size,
      v ≠ cls.out.embedding (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) →
      cls.out.str.1.Adj
        (cls.out.embedding (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size)) v := by
    intro v hv_ne
    have h_extAdjAll' : ExtAdjAll cls.out
        (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) := h_extAdjAll
    apply h_extAdjAll'
    intro hv_in
    apply hv_ne
    obtain ⟨j, hj⟩ := hv_in
    have hj_eq : j = (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) := by
      obtain ⟨jv, jhv⟩ := j
      have h_size_vb : vertexBlackType.size = 1 := rfl
      have hjv' : jv < 1 := h_size_vb ▸ jhv
      have : jv = 0 := by omega
      ext; exact this
    rw [hj_eq] at hj
    exact hj.symm
  rcases any_size5_extAdjAll_iso_or_forbidden cls.out hsize hadj_all with h_iso | h_forbidden
  · left
    have hmk : GenFlagClass.mk cls.out = GenFlagClass.mk vbExt4_RRRR_e0 :=
      (GenFlagClass.mk_eq _ _).mpr h_iso
    rw [← Quotient.out_eq cls]; exact hmk
  · right
    exact phi_eval_forget_zero_of_isForbidden h_forbidden phi

/-! ### ∅-functional collapse of `genAveragingAlg(extPow vbType ⟨0,_⟩ 4)`

Combines `evalAlg_genAveragingAlg` (algebraic decomposition over support) with
`phi_eval_size5_extAdjAll_dichotomy` (∅-functional dichotomy lifted from the
σ-IsForbidden infrastructure) to collapse the σ-averaged 4th extension power
into a single non-zero term: the `vbExt4_RRRR_e0` (forget = certF6) component.

Crucially this needs ONLY:
* `extPow_four_apply_RRRR_e0` (= 1, the coefficient hypothesis)
* `extPow_four_support_size_eq_five` and `extPow_four_support_extAdjAllClass`
  (support classification, established earlier)
* `phi_eval_size5_extAdjAll_dichotomy` (the new ∅-dichotomy)

It does NOT need `IsRegularClass`, only the algebraic identities. Used as the
first half of the b1_nonneg chain. -/

set_option maxHeartbeats 800000 in
/-- **∅-functional collapse**: For any ∅-functional `phi` over BRRB, the σ-
    averaging of `extPow vbType ⟨0,_⟩ 4` evaluates as a single term involving
    `phi.eval certF6`.

    `phi.evalAlg(⟦extPow vbType ⟨0,_⟩ 4⟧) = q(vbExt4_RRRR_e0) · phi.eval certF6`. -/
theorem phi_eval_genAveragingAlg_extPow_four_collapsed
    (phi : GenLimitFunctional CG2 (GenFlagType.empty CG2)
      brrbGenGraphClass brrbGenDelta) :
    phi.evalAlg (genAveragingAlg vertexBlackType
      (extPow vertexBlackType (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) 4)) =
    genNormalisationFactor vertexBlackType vbExt4_RRRR_e0 * phi.eval certF6 := by
  -- Step 1: expand via evalAlg_genAveragingAlg.
  rw [evalAlg_genAveragingAlg phi _]
  -- Goal: (extPow vbType ⟨0,_⟩ 4).sum (fun cls c =>
  --   c * (q cls.out * phi.eval cls.out.forget)) = q(vbExt4_RRRR_e0) · phi.eval certF6
  set v := extPow vertexBlackType
    (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) 4 with hv_def
  -- Step 2: rewrite each support term using the dichotomy.
  -- For cls = ⟦vbExt4_RRRR_e0⟧: contributes `c · q(out) · phi.eval(out.forget)`.
  --   By iso, q(out) = q(vbExt4_RRRR_e0) and phi.eval(out.forget) = phi.eval certF6.
  -- For other cls: phi.eval(cls.out.forget) = 0 by the dichotomy.
  have h_sum_rewrite : v.sum (fun cls c =>
        c * (genNormalisationFactor vertexBlackType cls.out * phi.eval cls.out.forget)) =
      v.sum (fun cls c =>
        if cls = GenFlagClass.mk vbExt4_RRRR_e0
        then c * (genNormalisationFactor vertexBlackType vbExt4_RRRR_e0 *
                  phi.eval certF6)
        else 0) := by
    apply Finsupp.sum_congr
    intro cls hcls
    have hcls_supp : cls ∈ v.support := hcls
    have hsize_class : IsClassOfSize 5 cls :=
      extPow_four_support_size_eq_five cls hcls_supp
    have hadjC := extPow_four_support_extAdjAllClass cls hcls_supp
    change v cls * (genNormalisationFactor vertexBlackType cls.out *
        phi.eval cls.out.forget) =
      if cls = GenFlagClass.mk vbExt4_RRRR_e0
      then v cls * (genNormalisationFactor vertexBlackType vbExt4_RRRR_e0 *
                    phi.eval certF6)
      else 0
    rcases phi_eval_size5_extAdjAll_dichotomy cls hsize_class hadjC phi with
      h_eq_RRRR | h_eval_zero
    · -- cls = ⟦vbExt4_RRRR_e0⟧
      rw [if_pos h_eq_RRRR]
      have h_iso_out : GenFlagIso vertexBlackType cls.out vbExt4_RRRR_e0 := by
        have hmk_out : GenFlagClass.mk cls.out = cls := Quotient.out_eq cls
        have hmk : GenFlagClass.mk cls.out = GenFlagClass.mk vbExt4_RRRR_e0 := by
          rw [hmk_out]; exact h_eq_RRRR
        exact (GenFlagClass.mk_eq _ _).mp hmk
      rw [genNormalisationFactor_flagIso h_iso_out]
      have h_iso_forget : GenFlagIso (GenFlagType.empty CG2)
          cls.out.forget vbExt4_RRRR_e0.forget := by
        obtain ⟨φ_iso, hstr, _⟩ := h_iso_out
        exact ⟨φ_iso, hstr, fun i => Fin.elim0 i⟩
      rw [phi.eval_iso _ _ h_iso_forget]
      rw [phi_eval_vbExt4_RRRR_e0_forget_eq_certF6]
    · -- phi.eval cls.out.forget = 0
      rw [h_eval_zero, mul_zero, mul_zero]
      split_ifs with hcls_eq
      · -- cls = ⟦vbExt4_RRRR_e0⟧ but eval is zero. Then iso gives
        -- phi.eval vbExt4_RRRR_e0.forget = 0 and certF6 → 0.
        have h_iso_out : GenFlagIso vertexBlackType cls.out vbExt4_RRRR_e0 := by
          have hmk_out : GenFlagClass.mk cls.out = cls := Quotient.out_eq cls
          have hmk : GenFlagClass.mk cls.out = GenFlagClass.mk vbExt4_RRRR_e0 := by
            rw [hmk_out]; exact hcls_eq
          exact (GenFlagClass.mk_eq _ _).mp hmk
        have h_iso_forget : GenFlagIso (GenFlagType.empty CG2)
            cls.out.forget vbExt4_RRRR_e0.forget := by
          obtain ⟨φ_iso, hstr, _⟩ := h_iso_out
          exact ⟨φ_iso, hstr, fun i => Fin.elim0 i⟩
        have h_eval_RRRR_zero : phi.eval vbExt4_RRRR_e0.forget = 0 := by
          rw [← phi.eval_iso _ _ h_iso_forget]; exact h_eval_zero
        have h_eval_certF6_zero : phi.eval certF6 = 0 := by
          rw [← phi_eval_vbExt4_RRRR_e0_forget_eq_certF6]; exact h_eval_RRRR_zero
        rw [h_eval_certF6_zero, mul_zero, mul_zero]
      · rfl
  rw [h_sum_rewrite]
  -- Step 3: collapse the sum to a single term (RRRR_e0 has coefficient 1).
  rw [Finsupp.sum]
  by_cases hmem : GenFlagClass.mk vbExt4_RRRR_e0 ∈ v.support
  · rw [Finset.sum_eq_single (GenFlagClass.mk vbExt4_RRRR_e0)
      (fun cls _ hne => by simp [hne]) (fun h => absurd hmem h)]
    simp only [if_true]
    rw [extPow_four_apply_RRRR_e0]; ring
  · -- coefficient is 1 ≠ 0, so RRRR_e0 must be in support → contradiction.
    exfalso
    apply hmem
    have h1 : v (GenFlagClass.mk vbExt4_RRRR_e0) = 1 := extPow_four_apply_RRRR_e0
    rw [Finsupp.mem_support_iff, h1]
    norm_num

/-! ## Per-functional `genAveraging_preserves_positivity` and master chain

`IsRegularClass` is FALSE for BRRB (it has only per-functional regularity).
The chain `unlabel_extPow_explicit` (and `vertexBlackType_master_chain`) bakes
in `IsRegularClass`, so cannot apply directly to BRRB phi.

This section provides per-functional reformulations:
* `genAveraging_preserves_positivity_perfunc_phi` — preservation of σ-cone
  positivity through ⟦·⟧, restricted to a specific phi with regular sequence
  and σ-cone hypothesis quantified only over ψ with regular sequence.
* `extPow_diff_unit_isPositive_perfunc` / `unit_diff_extPow_isPositive_perfunc`
  — σ-cone positivity of `extPow - single` for ψ with regular seq.
* `unlabel_extPow_eq_unit_perfunc` / `unlabel_extPow_explicit_perfunc` —
  per-functional master equality.
* `vertexBlackType_master_chain_perfunc` — master chain at vbType.

The key observation that unlocks this: in `genAveraging_preserves_positivity`,
the σ-functional φ constructed inside the contradiction proof has its
underlying graph sequence built from `phi.seq` via `genSigmaFlagOfEmb'`, which
preserves graph size and adjacency. Hence if `phi.seq` is regular, so is
`φ.seq`, and the σ-cone hypothesis only needs to hold for σ-functionals with
regular sequence. -/

/-- **Per-functional σ-cone positivity of `extPow - single σ.toFlag`**:
    for any specific σ-functional ψ whose underlying sequence is regular,
    `0 ≤ ψ.evalAlg(extPow σ i k - single σ.toFlag)`. Direct application of
    `evalAlg_extPow`; no `IsRegularClass` needed. -/
theorem extPow_diff_unit_isPositive_perfunc (σ : GenFlagType CG2)
    {𝒢 : GenGraphClass CG2} {Δ : GenGraphParam CG2}
    (ψ : GenLimitFunctional CG2 σ 𝒢 Δ)
    (h_reg_psi : ∀ k, ∀ v : Fin (ψ.seq.seq k).size,
      (Finset.univ.filter ((ψ.seq.seq k).str.1.Adj v)).card =
        Δ (ψ.seq.seq k).forget)
    (i : Fin σ.size)
    (hσ_toFlag : GenIsLocalFlag σ σ.toFlag 𝒢 Δ)
    (h_ext_local : ∀ cls ∈ ((genClassesOfSize CG2 σ (σ.size + 1)
      (Nat.le_succ _)).filter (fun cls => extAdjacencyClass σ cls i)),
      GenIsLocalFlag σ cls.out 𝒢 Δ)
    (k : ℕ) :
    0 ≤ ψ.evalAlg (extPow σ i k - GenFlagAlg.single σ.toFlag) := by
  have h_Δ_to_inf : Filter.Tendsto (fun k => Δ (ψ.seq.seq (ψ.sub k)).forget)
      Filter.atTop Filter.atTop :=
    (ψ.seq.increasing.comp ψ.sub_strictMono).tendsto_atTop
  have h_pow := evalAlg_extPow σ ψ i hσ_toFlag h_ext_local h_reg_psi h_Δ_to_inf k
  have h_unit : ψ.evalAlg (GenFlagAlg.single σ.toFlag) = 1 := by
    rw [GenLimitFunctional.evalAlg_single]; exact ψ.eval_type
  rw [sub_eq_add_neg, ← neg_one_smul ℝ,
      GenLimitFunctional.evalAlg_add, GenLimitFunctional.evalAlg_smul]
  rw [h_pow, h_unit]; linarith

/-- **Per-functional σ-cone positivity of `single σ.toFlag - extPow`**: symmetric. -/
theorem unit_diff_extPow_isPositive_perfunc (σ : GenFlagType CG2)
    {𝒢 : GenGraphClass CG2} {Δ : GenGraphParam CG2}
    (ψ : GenLimitFunctional CG2 σ 𝒢 Δ)
    (h_reg_psi : ∀ k, ∀ v : Fin (ψ.seq.seq k).size,
      (Finset.univ.filter ((ψ.seq.seq k).str.1.Adj v)).card =
        Δ (ψ.seq.seq k).forget)
    (i : Fin σ.size)
    (hσ_toFlag : GenIsLocalFlag σ σ.toFlag 𝒢 Δ)
    (h_ext_local : ∀ cls ∈ ((genClassesOfSize CG2 σ (σ.size + 1)
      (Nat.le_succ _)).filter (fun cls => extAdjacencyClass σ cls i)),
      GenIsLocalFlag σ cls.out 𝒢 Δ)
    (k : ℕ) :
    0 ≤ ψ.evalAlg (GenFlagAlg.single σ.toFlag - extPow σ i k) := by
  have h_Δ_to_inf : Filter.Tendsto (fun k => Δ (ψ.seq.seq (ψ.sub k)).forget)
      Filter.atTop Filter.atTop :=
    (ψ.seq.increasing.comp ψ.sub_strictMono).tendsto_atTop
  have h_pow := evalAlg_extPow σ ψ i hσ_toFlag h_ext_local h_reg_psi h_Δ_to_inf k
  have h_unit : ψ.evalAlg (GenFlagAlg.single σ.toFlag) = 1 := by
    rw [GenLimitFunctional.evalAlg_single]; exact ψ.eval_type
  rw [sub_eq_add_neg, ← neg_one_smul ℝ,
      GenLimitFunctional.evalAlg_add, GenLimitFunctional.evalAlg_smul]
  rw [h_pow, h_unit]; linarith

/-- **Per-functional preservation of positivity through ⟦·⟧**: for a specific
    ∅-functional `phi` with regular underlying sequence, `0 ≤ phi.evalAlg(⟦v⟧)`
    follows from σ-cone positivity quantified only over σ-functionals ψ whose
    sequence is regular.

    The standard `genAveraging_preserves_positivity` requires `v.isPositive`
    quantified over ALL σ-functionals; this version only needs σ-functionals
    with regular sequence, which is the natural setting when working with a
    specific `phi`+regularity (e.g. BRRB).

    Proof: same contradiction strategy as `genAveraging_preserves_positivity`,
    using `phi` (instead of an arbitrary ∅-functional) to build a σ-functional
    whose sequence is constructed from `phi.seq` via `genSigmaFlagOfEmb'`,
    which preserves graph size/adjacency and hence regularity. -/
theorem genAveraging_preserves_positivity_perfunc_phi
    {σ : GenFlagType CG2} {𝒢 : GenGraphClass CG2} {Δ : GenGraphParam CG2}
    (hσ : GenIsLocalType σ 𝒢 Δ)
    (v : GenFlagAlg CG2 σ)
    (hlocal : ∀ cls ∈ v.support, GenIsLocalFlag σ cls.out 𝒢 Δ)
    (phi : GenLimitFunctional CG2 (GenFlagType.empty CG2) 𝒢 Δ)
    (hreg_phi : ∀ k, ∀ u : Fin (phi.seq.seq k).size,
      (Finset.univ.filter ((phi.seq.seq k).str.1.Adj u)).card =
        Δ (phi.seq.seq k).forget)
    (h_pos_perfunc : ∀ ψ : GenLimitFunctional CG2 σ 𝒢 Δ,
      (∀ k, ∀ u : Fin (ψ.seq.seq k).size,
        (Finset.univ.filter ((ψ.seq.seq k).str.1.Adj u)).card =
          Δ (ψ.seq.seq k).forget) →
      0 ≤ ψ.evalAlg v) :
    0 ≤ phi.evalAlg (genAveragingAlg σ v) := by
  -- Strategy: contradiction. If 0 > phi.evalAlg(⟦v⟧), build σ-functional with
  -- regular sequence (inherited from phi) and v evaluating < 0, contradicting
  -- `h_pos_perfunc`.
  by_contra hψ_neg
  push_neg at hψ_neg
  -- Step 1: density identity → eventually average σ-density ≤ c < 0 along phi.seq
  obtain ⟨c, hc_neg, N₀, hN₀⟩ :=
    genAveraging_eventually_neg' hσ v hlocal phi hψ_neg
  -- Step 2: pigeonhole → for k ≥ N₀, ∃ θ : σ-emb at phi.seq.seq(phi.sub k)
  -- with v's σ-density ≤ c
  have hexists_neg : ∀ k, N₀ ≤ k →
      ∃ θ : GenSigmaEmb' σ (phi.seq.seq (phi.sub k)),
        genEvalAlgOf (fun F => genUnlabelledDensity CG2 σ F
          (genSigmaFlagOfEmb' θ) Δ) v ≤ c := by
    intro k hk
    have havg := hN₀ k hk
    simp only [genExpectedEvalDensity'] at havg
    by_cases hN : Fintype.card (GenSigmaEmb' σ (phi.seq.seq (phi.sub k))) = 0
    · simp [hN] at havg; linarith
    · have hN_pos : (0 : ℝ) <
          (Fintype.card (GenSigmaEmb' σ (phi.seq.seq (phi.sub k))) : ℝ) :=
        Nat.cast_pos.mpr (Nat.pos_of_ne_zero hN)
      rw [if_neg hN, div_le_iff₀ hN_pos] at havg
      have hnonempty : (Finset.univ :
          Finset (GenSigmaEmb' σ (phi.seq.seq (phi.sub k)))).Nonempty :=
        Finset.univ_nonempty_iff.mpr (Fintype.card_pos_iff.mp (Nat.pos_of_ne_zero hN))
      have hsum_const : ∑ _ : GenSigmaEmb' σ (phi.seq.seq (phi.sub k)), c =
          (Fintype.card (GenSigmaEmb' σ (phi.seq.seq (phi.sub k))) : ℝ) * c := by
        simp [Finset.sum_const, Finset.card_univ, nsmul_eq_mul]
      rw [mul_comm] at havg; rw [← hsum_const] at havg
      obtain ⟨θ, _, hθ⟩ := Finset.exists_le_of_sum_le hnonempty havg
      exact ⟨θ, hθ⟩
  -- Step 3: build the shifted σ-flag sequence — for each k, choose θ_{k+N₀}.
  classical
  have hchoice : ∀ k, ∃ θ : GenSigmaEmb' σ (phi.seq.seq (phi.sub (k + N₀))),
      genEvalAlgOf (fun F => genUnlabelledDensity CG2 σ F
        (genSigmaFlagOfEmb' θ) Δ) v ≤ c :=
    fun k => hexists_neg (k + N₀) (Nat.le_add_left N₀ k)
  let θ_seq : (k : ℕ) → GenSigmaEmb' σ (phi.seq.seq (phi.sub (k + N₀))) :=
    fun k => (hchoice k).choose
  have hθ_bound : ∀ k, genEvalAlgOf (fun F => genUnlabelledDensity CG2 σ F
      (genSigmaFlagOfEmb' (θ_seq k)) Δ) v ≤ c :=
    fun k => (hchoice k).choose_spec
  -- Step 4: build σ-level GenDeltaIncreasingSeq. Same as in
  -- `genAveraging_preserves_positivity`.
  let seq_sigma : GenDeltaIncreasingSeq CG2 σ Δ := {
    seq := fun k => genSigmaFlagOfEmb' (θ_seq k)
    increasing := by
      intro a b hab
      change Δ (genSigmaFlagOfEmb' (θ_seq a)).forget <
           Δ (genSigmaFlagOfEmb' (θ_seq b)).forget
      convert phi.seq.increasing (phi.sub_strictMono (show a + N₀ < b + N₀ by omega))
        using 2
  }
  have hclass_sigma : ∀ k, 𝒢 (seq_sigma.seq k).forget := by
    intro k
    have hfk : (genSigmaFlagOfEmb' (θ_seq k)).forget = phi.seq.seq (phi.sub (k + N₀)) :=
      genSigmaFlagOfEmb'_forget (θ_seq k)
    have hforget : (phi.seq.seq (phi.sub (k + N₀))).forget = phi.seq.seq (phi.sub (k + N₀)) :=
      GenFlag.empty_ext _ _ rfl rfl
    change 𝒢 (genSigmaFlagOfEmb' (θ_seq k)).forget
    rw [hfk, ← hforget]
    exact phi.seq_in_class (phi.sub (k + N₀))
  -- Step 5: build σ-level limit functional ψ from this seq.
  let ψ := genLimit_functional_construction CG2 σ 𝒢 Δ seq_sigma hclass_sigma
  -- Step 6: ψ's seq inherits regularity from phi.seq (via genSigmaFlagOfEmb',
  -- which preserves graph adjacency).
  have hreg_psi : ∀ k, ∀ u : Fin (ψ.seq.seq k).size,
      (Finset.univ.filter ((ψ.seq.seq k).str.1.Adj u)).card =
        Δ (ψ.seq.seq k).forget := by
    intro k u
    -- ψ.seq = seq_sigma; ψ.seq.seq k = genSigmaFlagOfEmb' (θ_seq k)
    -- (genSigmaFlagOfEmb' θ).size = G.size, .str = G.str by rfl
    -- (genSigmaFlagOfEmb' θ).forget = G via genSigmaFlagOfEmb'_forget
    change (Finset.univ.filter
        ((genSigmaFlagOfEmb' (θ_seq k)).str.1.Adj u)).card =
      Δ (genSigmaFlagOfEmb' (θ_seq k)).forget
    -- LHS: by rfl-defn of genSigmaFlagOfEmb', .str = (phi.seq.seq m).str
    -- RHS: (genSigmaFlagOfEmb' θ).forget vs (phi.seq.seq m).forget — both are
    -- ∅-flags built by .forget; agree on .size and .str = phi.seq.seq m's data;
    -- equal by GenFlag.empty_ext.
    have h_forget_eq : (genSigmaFlagOfEmb' (θ_seq k)).forget =
        (phi.seq.seq (phi.sub (k + N₀))).forget := by
      apply GenFlag.empty_ext
      · rfl
      · rfl
    rw [h_forget_eq]
    -- Goal: (Finset.univ.filter ((genSigmaFlagOfEmb' θ).str.1.Adj u)).card
    --       = Δ (phi.seq.seq m).forget
    -- (genSigmaFlagOfEmb' θ).str = (phi.seq.seq m).str by rfl, u type unchanged
    exact hreg_phi (phi.sub (k + N₀)) u
  -- Step 7: invoke σ-cone hypothesis at ψ + hreg_psi
  have hψ_pos : 0 ≤ ψ.evalAlg v := h_pos_perfunc ψ hreg_psi
  -- Step 8: derive ψ.evalAlg v ≤ c < 0, contradiction.
  have hψ_neg' : ψ.evalAlg v < 0 := by
    change genEvalAlgOf ψ.eval v < 0
    have hconv : ∀ cls ∈ v.support, Filter.Tendsto
        (fun k => genUnlabelledDensity CG2 σ cls.out (seq_sigma.seq (ψ.sub k)) Δ)
        Filter.atTop (nhds (ψ.eval cls.out)) :=
      fun cls hcls => ψ.convergence cls.out (hlocal cls hcls)
    have htend : Filter.Tendsto
        (fun k => genEvalAlgOf
          (fun F => genUnlabelledDensity CG2 σ F (seq_sigma.seq (ψ.sub k)) Δ) v)
        Filter.atTop (nhds (genEvalAlgOf ψ.eval v)) := by
      simp only [genEvalAlgOf, Finsupp.sum]
      exact tendsto_finset_sum v.support
        (fun cls hcls => (hconv cls hcls).const_mul (v cls))
    have hle : ∀ k, genEvalAlgOf
        (fun F => genUnlabelledDensity CG2 σ F (seq_sigma.seq (ψ.sub k)) Δ) v ≤ c :=
      fun k => hθ_bound (ψ.sub k)
    exact lt_of_le_of_lt (le_of_tendsto htend (Filter.Eventually.of_forall hle))
      hc_neg
  exact absurd hψ_pos (not_le.mpr hψ_neg')

/-- **Per-functional `unlabel_extPow_eq_unit`**: for a specific phi+hreg_phi,
    `phi.evalAlg(⟦(extSum σ i)^k⟧) = phi.evalAlg(⟦σ.toFlag⟧)` without
    `IsRegularClass`. -/
theorem unlabel_extPow_eq_unit_perfunc (σ : GenFlagType CG2)
    {𝒢 : GenGraphClass CG2} {Δ : GenGraphParam CG2}
    (hσ : GenIsLocalType σ 𝒢 Δ)
    (i : Fin σ.size)
    (hσ_toFlag : GenIsLocalFlag σ σ.toFlag 𝒢 Δ)
    (h_ext_local : ∀ cls ∈ ((genClassesOfSize CG2 σ (σ.size + 1)
      (Nat.le_succ _)).filter (fun cls => extAdjacencyClass σ cls i)),
      GenIsLocalFlag σ cls.out 𝒢 Δ)
    (h_local_supp_diff : ∀ k,
      ∀ cls ∈ (extPow σ i k - GenFlagAlg.single σ.toFlag).support,
      GenIsLocalFlag σ cls.out 𝒢 Δ)
    (h_local_supp_diff' : ∀ k,
      ∀ cls ∈ (GenFlagAlg.single σ.toFlag - extPow σ i k).support,
      GenIsLocalFlag σ cls.out 𝒢 Δ)
    (phi : GenLimitFunctional CG2 (GenFlagType.empty CG2) 𝒢 Δ)
    (hreg_phi : ∀ k, ∀ u : Fin (phi.seq.seq k).size,
      (Finset.univ.filter ((phi.seq.seq k).str.1.Adj u)).card =
        Δ (phi.seq.seq k).forget)
    (k : ℕ) :
    phi.evalAlg (genAveragingAlg σ (extPow σ i k)) =
    phi.evalAlg (genAveragingAlg σ (GenFlagAlg.single σ.toFlag)) := by
  -- Apply per-functional positivity in both directions, then linarith.
  have h1 : 0 ≤ phi.evalAlg
      (genAveragingAlg σ (extPow σ i k - GenFlagAlg.single σ.toFlag)) :=
    genAveraging_preserves_positivity_perfunc_phi hσ _
      (h_local_supp_diff k) phi hreg_phi
      (fun ψ hreg_psi =>
        extPow_diff_unit_isPositive_perfunc σ ψ hreg_psi i hσ_toFlag h_ext_local k)
  have h2 : 0 ≤ phi.evalAlg
      (genAveragingAlg σ (GenFlagAlg.single σ.toFlag - extPow σ i k)) :=
    genAveraging_preserves_positivity_perfunc_phi hσ _
      (h_local_supp_diff' k) phi hreg_phi
      (fun ψ hreg_psi =>
        unit_diff_extPow_isPositive_perfunc σ ψ hreg_psi i hσ_toFlag h_ext_local k)
  rw [show extPow σ i k - GenFlagAlg.single σ.toFlag =
      extPow σ i k + (-1 : ℝ) • GenFlagAlg.single σ.toFlag by
    rw [neg_one_smul, ← sub_eq_add_neg]] at h1
  rw [show GenFlagAlg.single σ.toFlag - extPow σ i k =
      GenFlagAlg.single σ.toFlag + (-1 : ℝ) • extPow σ i k by
    rw [neg_one_smul, ← sub_eq_add_neg]] at h2
  rw [genAveragingAlg_add, genAveragingAlg_smul, GenLimitFunctional.evalAlg_add,
      GenLimitFunctional.evalAlg_smul] at h1
  rw [genAveragingAlg_add, genAveragingAlg_smul, GenLimitFunctional.evalAlg_add,
      GenLimitFunctional.evalAlg_smul] at h2
  linarith

/-- **Per-functional master chain**: combines `unlabel_extPow_eq_unit_perfunc`
    with `evalAlg_genAveraging_unit`. For specific phi+hreg_phi:

      `phi.evalAlg(⟦(extSum σ i)^k⟧) = q(σ.toFlag) · phi.eval(σ.toFlag.forget)` -/
theorem unlabel_extPow_explicit_perfunc (σ : GenFlagType CG2)
    {𝒢 : GenGraphClass CG2} {Δ : GenGraphParam CG2}
    (hσ : GenIsLocalType σ 𝒢 Δ)
    (i : Fin σ.size)
    (hσ_toFlag : GenIsLocalFlag σ σ.toFlag 𝒢 Δ)
    (h_ext_local : ∀ cls ∈ ((genClassesOfSize CG2 σ (σ.size + 1)
      (Nat.le_succ _)).filter (fun cls => extAdjacencyClass σ cls i)),
      GenIsLocalFlag σ cls.out 𝒢 Δ)
    (h_local_supp_diff : ∀ k,
      ∀ cls ∈ (extPow σ i k - GenFlagAlg.single σ.toFlag).support,
      GenIsLocalFlag σ cls.out 𝒢 Δ)
    (h_local_supp_diff' : ∀ k,
      ∀ cls ∈ (GenFlagAlg.single σ.toFlag - extPow σ i k).support,
      GenIsLocalFlag σ cls.out 𝒢 Δ)
    (phi : GenLimitFunctional CG2 (GenFlagType.empty CG2) 𝒢 Δ)
    (hreg_phi : ∀ k, ∀ u : Fin (phi.seq.seq k).size,
      (Finset.univ.filter ((phi.seq.seq k).str.1.Adj u)).card =
        Δ (phi.seq.seq k).forget)
    (k : ℕ) :
    phi.evalAlg (genAveragingAlg σ (extPow σ i k)) =
    genNormalisationFactor σ σ.toFlag * phi.eval σ.toFlag.forget := by
  rw [unlabel_extPow_eq_unit_perfunc σ hσ i hσ_toFlag h_ext_local
    h_local_supp_diff h_local_supp_diff' phi hreg_phi k]
  exact evalAlg_genAveraging_unit σ phi

/-- Clean variant of `unlabel_extPow_explicit_perfunc` discharging the
    diff-support locality hypotheses via `support_sub_local` /
    `support_single_local`. -/
theorem unlabel_extPow_explicit_perfunc_clean (σ : GenFlagType CG2)
    {𝒢 : GenGraphClass CG2} {Δ : GenGraphParam CG2}
    (hσ : GenIsLocalType σ 𝒢 Δ)
    (i : Fin σ.size)
    (hσ_toFlag : GenIsLocalFlag σ σ.toFlag 𝒢 Δ)
    (h_ext_local : ∀ cls ∈ ((genClassesOfSize CG2 σ (σ.size + 1)
      (Nat.le_succ _)).filter (fun cls => extAdjacencyClass σ cls i)),
      GenIsLocalFlag σ cls.out 𝒢 Δ)
    (phi : GenLimitFunctional CG2 (GenFlagType.empty CG2) 𝒢 Δ)
    (hreg_phi : ∀ k, ∀ u : Fin (phi.seq.seq k).size,
      (Finset.univ.filter ((phi.seq.seq k).str.1.Adj u)).card =
        Δ (phi.seq.seq k).forget)
    (k : ℕ) :
    phi.evalAlg (genAveragingAlg σ (extPow σ i k)) =
    genNormalisationFactor σ σ.toFlag * phi.eval σ.toFlag.forget := by
  refine unlabel_extPow_explicit_perfunc σ hσ i hσ_toFlag h_ext_local
    (fun k => support_sub_local _ _
      (extPow_local_support σ i hσ_toFlag h_ext_local k)
      (support_single_local _ hσ_toFlag))
    (fun k => support_sub_local _ _ (support_single_local _ hσ_toFlag)
      (extPow_local_support σ i hσ_toFlag h_ext_local k))
    phi hreg_phi k

/-- **Per-functional master chain at vertexBlackType**: for specific phi+hreg_phi
    over a vbType-local class, `phi.evalAlg(⟦(extSum vbType ⟨0,_⟩)^k⟧) =
    phi.eval vertexBlackFlag.forget`. -/
theorem vertexBlackType_master_chain_perfunc
    {𝒢 : GenGraphClass CG2} {Δ : GenGraphParam CG2}
    (hσ : GenIsLocalType vertexBlackType 𝒢 Δ)
    (hσ_toFlag : GenIsLocalFlag vertexBlackType vertexBlackType.toFlag 𝒢 Δ)
    (h_ext_local : ∀ cls ∈ ((genClassesOfSize CG2 vertexBlackType
      (vertexBlackType.size + 1) (Nat.le_succ _)).filter
      (fun cls => extAdjacencyClass vertexBlackType cls
        ⟨0, by change 0 < 1; omega⟩)),
      GenIsLocalFlag vertexBlackType cls.out 𝒢 Δ)
    (phi : GenLimitFunctional CG2 (GenFlagType.empty CG2) 𝒢 Δ)
    (hreg_phi : ∀ k, ∀ u : Fin (phi.seq.seq k).size,
      (Finset.univ.filter ((phi.seq.seq k).str.1.Adj u)).card =
        Δ (phi.seq.seq k).forget)
    (k : ℕ) :
    phi.evalAlg (genAveragingAlg vertexBlackType
      (extPow vertexBlackType ⟨0, by change 0 < 1; omega⟩ k)) =
    phi.eval vertexBlackFlag.forget := by
  rw [unlabel_extPow_explicit_perfunc_clean vertexBlackType hσ
    ⟨0, by change 0 < 1; omega⟩ hσ_toFlag h_ext_local phi hreg_phi k]
  rw [show vertexBlackType.toFlag = vertexBlackFlag from rfl]
  rw [vertexBlackFlag_normFactor, one_mul]

/-! ### Per-functional σᵢ closure templates (Phase 5 σ₁-4-A)

For BRRB, we have only per-functional regularity (not class-wide `IsRegularClass`).
This section provides per-functional variants of the σᵢ closure templates,
analogous to `unlabel_extPow_explicit_perfunc` (commit f56bf32). These enable
σᵢ_nonneg closures uniformly without requiring class-wide regularity. -/

/-- **Per-functional σ-cone positivity of `extSum a − extSum b`**: at any
    σ-functional ψ with regular sequence, the extension difference is positive. -/
theorem extSum_diff_isPositive_perfunc (σ : GenFlagType CG2)
    {𝒢 : GenGraphClass CG2} {Δ : GenGraphParam CG2}
    (ψ : GenLimitFunctional CG2 σ 𝒢 Δ)
    (h_reg_psi : ∀ k, ∀ v : Fin (ψ.seq.seq k).size,
      (Finset.univ.filter ((ψ.seq.seq k).str.1.Adj v)).card =
        Δ (ψ.seq.seq k).forget)
    (i j : Fin σ.size)
    (h_local_i : ∀ cls ∈ ((genClassesOfSize CG2 σ (σ.size + 1) (Nat.le_succ _)).filter
      (fun cls => extAdjacencyClass σ cls i)),
      GenIsLocalFlag σ cls.out 𝒢 Δ)
    (h_local_j : ∀ cls ∈ ((genClassesOfSize CG2 σ (σ.size + 1) (Nat.le_succ _)).filter
      (fun cls => extAdjacencyClass σ cls j)),
      GenIsLocalFlag σ cls.out 𝒢 Δ) :
    0 ≤ ψ.evalAlg (extSum σ i - extSum σ j) := by
  have h_Δ_to_inf : Filter.Tendsto (fun k => Δ (ψ.seq.seq (ψ.sub k)).forget)
      Filter.atTop Filter.atTop :=
    (ψ.seq.increasing.comp ψ.sub_strictMono).tendsto_atTop
  have h_i := extSum_eval_one σ ψ i h_local_i h_reg_psi h_Δ_to_inf
  have h_j := extSum_eval_one σ ψ j h_local_j h_reg_psi h_Δ_to_inf
  rw [sub_eq_add_neg, ← neg_one_smul ℝ (extSum σ j),
      GenLimitFunctional.evalAlg_add, GenLimitFunctional.evalAlg_smul]
  rw [h_i, h_j]; linarith

/-- **Per-functional unlabel of ext-difference**: `0 ≤ φ.evalAlg(⟦ext_a − ext_b⟧)`
    given per-functional regularity for `phi` (no `IsRegularClass` needed). -/
theorem unlabel_extDiff_nonneg_perfunc (σ : GenFlagType CG2)
    {𝒢 : GenGraphClass CG2} {Δ : GenGraphParam CG2}
    (hσ : GenIsLocalType σ 𝒢 Δ)
    (i j : Fin σ.size)
    (h_local_i : ∀ cls ∈ ((genClassesOfSize CG2 σ (σ.size + 1) (Nat.le_succ _)).filter
      (fun cls => extAdjacencyClass σ cls i)),
      GenIsLocalFlag σ cls.out 𝒢 Δ)
    (h_local_j : ∀ cls ∈ ((genClassesOfSize CG2 σ (σ.size + 1) (Nat.le_succ _)).filter
      (fun cls => extAdjacencyClass σ cls j)),
      GenIsLocalFlag σ cls.out 𝒢 Δ)
    (phi : GenLimitFunctional CG2 (GenFlagType.empty CG2) 𝒢 Δ)
    (h_reg_phi : ∀ k, ∀ v : Fin (phi.seq.seq k).size,
      (Finset.univ.filter ((phi.seq.seq k).str.1.Adj v)).card =
        Δ (phi.seq.seq k).forget) :
    0 ≤ phi.evalAlg (genAveragingAlg σ (extSum σ i - extSum σ j)) := by
  have hi_supp : ∀ cls ∈ (extSum σ i).support, GenIsLocalFlag σ cls.out 𝒢 Δ := by
    intro cls hcls; rw [extSum_support_eq] at hcls; exact h_local_i cls hcls
  have hj_supp : ∀ cls ∈ (extSum σ j).support, GenIsLocalFlag σ cls.out 𝒢 Δ := by
    intro cls hcls; rw [extSum_support_eq] at hcls; exact h_local_j cls hcls
  apply genAveraging_preserves_positivity_perfunc_phi hσ _
    (support_sub_local _ _ hi_supp hj_supp) phi h_reg_phi
  intro ψ h_reg_psi
  exact extSum_diff_isPositive_perfunc σ ψ h_reg_psi i j h_local_i h_local_j

/-- **Per-functional `unlabel_extDiff_eq_zero`**: `phi.evalAlg(⟦ext_a − ext_b⟧) = 0`
    via symmetric application of `_nonneg_perfunc`. -/
theorem unlabel_extDiff_eq_zero_perfunc (σ : GenFlagType CG2)
    {𝒢 : GenGraphClass CG2} {Δ : GenGraphParam CG2}
    (hσ : GenIsLocalType σ 𝒢 Δ)
    (i j : Fin σ.size)
    (h_local_i : ∀ cls ∈ ((genClassesOfSize CG2 σ (σ.size + 1) (Nat.le_succ _)).filter
      (fun cls => extAdjacencyClass σ cls i)),
      GenIsLocalFlag σ cls.out 𝒢 Δ)
    (h_local_j : ∀ cls ∈ ((genClassesOfSize CG2 σ (σ.size + 1) (Nat.le_succ _)).filter
      (fun cls => extAdjacencyClass σ cls j)),
      GenIsLocalFlag σ cls.out 𝒢 Δ)
    (phi : GenLimitFunctional CG2 (GenFlagType.empty CG2) 𝒢 Δ)
    (h_reg_phi : ∀ k, ∀ v : Fin (phi.seq.seq k).size,
      (Finset.univ.filter ((phi.seq.seq k).str.1.Adj v)).card =
        Δ (phi.seq.seq k).forget) :
    phi.evalAlg (genAveragingAlg σ (extSum σ i - extSum σ j)) = 0 := by
  have h_ij := unlabel_extDiff_nonneg_perfunc σ hσ i j h_local_i h_local_j phi h_reg_phi
  have h_ji := unlabel_extDiff_nonneg_perfunc σ hσ j i h_local_j h_local_i phi h_reg_phi
  rw [show (extSum σ j - extSum σ i : GenFlagAlg CG2 σ) =
      (-1 : ℝ) • (extSum σ i - extSum σ j) by
    rw [neg_smul, one_smul]; abel] at h_ji
  rw [genAveragingAlg_smul, GenLimitFunctional.evalAlg_smul] at h_ji
  linarith

/-- **Per-functional σᵢ nonneg template**: from the combinatorial identity
    `120·φ.evalAlg(⟦extSum a − extSum b⟧) = named_flag_combo` and per-functional
    regularity of `phi`, derive `0 ≤ named_flag_combo`. No `IsRegularClass` required. -/
theorem sigma_nonneg_template_perfunc (σ : GenFlagType CG2)
    {𝒢 : GenGraphClass CG2} {Δ : GenGraphParam CG2}
    (hσ : GenIsLocalType σ 𝒢 Δ)
    (a b : Fin σ.size)
    (h_local_a : ∀ cls ∈ ((genClassesOfSize CG2 σ (σ.size + 1) (Nat.le_succ _)).filter
      (fun cls => extAdjacencyClass σ cls a)),
      GenIsLocalFlag σ cls.out 𝒢 Δ)
    (h_local_b : ∀ cls ∈ ((genClassesOfSize CG2 σ (σ.size + 1) (Nat.le_succ _)).filter
      (fun cls => extAdjacencyClass σ cls b)),
      GenIsLocalFlag σ cls.out 𝒢 Δ)
    (phi : GenLimitFunctional CG2 (GenFlagType.empty CG2) 𝒢 Δ)
    (h_reg_phi : ∀ k, ∀ v : Fin (phi.seq.seq k).size,
      (Finset.univ.filter ((phi.seq.seq k).str.1.Adj v)).card =
        Δ (phi.seq.seq k).forget)
    (named_flag_combo : ℝ)
    (combinatorial_identity :
      120 * phi.evalAlg (genAveragingAlg σ (extSum σ a - extSum σ b)) =
        named_flag_combo) :
    0 ≤ named_flag_combo := by
  rw [← combinatorial_identity,
      unlabel_extDiff_eq_zero_perfunc σ hσ a b h_local_a h_local_b phi h_reg_phi]
  linarith

/-! ### Per-functional σᵢ closure templates — WEAKENED locality (σ₁-4-E.B)

These variants weaken the cls-level locality hypothesis to a disjunction:
either `cls.out` is σ-local OR `phi.eval cls.out.forget = 0`. This allows
applications such as BRRB σ = thesisType1 with cert pair (v1, v0) where the
extension filter contains non-BRRB-local classes (e.g. BB-edges, triangles)
whose ∅-density vanishes via `eval_zero_of_adj_black` / `eval_zero_of_triangle`.

**Strategy.** Restrict v to its σ-local part v_local via `Finsupp.filter`. Two
algebraic facts make this work:
1. For any σ-functional ψ, `ψ.evalAlg(v) = ψ.evalAlg(v_local)` since non-local
   cls have `ψ.eval cls.out = 0` (by `ψ.eval_nonlocal`). Hence σ-positivity
   of `v_local` follows from σ-positivity of `v`.
2. For the ∅-functional φ, `φ.evalAlg(genAveragingAlg σ v) =
   φ.evalAlg(genAveragingAlg σ v_local) + (zero terms)` via the algebraic
   expansion of `genAveragingAlg`. The non-local terms vanish under the
   disjunction hypothesis (their phi-eval is 0). Hence the strong
   `_perfunc_phi` applies to `v_local`. -/

/-- **Algebraic identity** for `evalAlg ∘ genAveragingAlg`: for any
    ∅-functional `phi` and `v : GenFlagAlg CG2 σ`,
    `phi.evalAlg(genAveragingAlg σ v) =
       ∑ cls ∈ v.support, v cls * (nf σ cls.out * phi.eval cls.out.forget)`.
    Purely algebraic; no locality or convergence needed. -/
theorem evalAlg_genAveragingAlg_expand {σ : GenFlagType CG2}
    {𝒢 : GenGraphClass CG2} {Δ : GenGraphParam CG2}
    (phi : GenLimitFunctional CG2 (GenFlagType.empty CG2) 𝒢 Δ)
    (v : GenFlagAlg CG2 σ) :
    phi.evalAlg (genAveragingAlg σ v) =
      ∑ cls ∈ v.support, v cls *
        (genNormalisationFactor σ cls.out * phi.eval cls.out.forget) := by
  simp only [genAveragingAlg, Finsupp.sum]
  -- evalAlg distributes over Finset.sum
  have evalAlg_sum : ∀ (S : Finset (GenFlagClass CG2 σ))
      (f : GenFlagClass CG2 σ → GenFlagAlg CG2 (GenFlagType.empty CG2)),
      phi.evalAlg (∑ x ∈ S, f x) = ∑ x ∈ S, phi.evalAlg (f x) := by
    intro S f; induction S using Finset.induction with
    | empty => simp [Finset.sum_empty, GenLimitFunctional.evalAlg, genEvalAlgOf,
                     Finsupp.sum_zero_index]
    | insert _ _ hna ih =>
      rw [Finset.sum_insert hna, phi.evalAlg_add, ih, Finset.sum_insert hna]
  rw [evalAlg_sum]
  apply Finset.sum_congr rfl
  intro cls _
  rw [phi.evalAlg_smul]
  simp only [genClassAveraging, genAveraging]
  rw [phi.evalAlg_smul, phi.evalAlg_single]

/-- **Algebraic identity** for `evalAlg` over a σ-functional:
    `ψ.evalAlg(v) = ∑ cls ∈ v.support, v cls * ψ.eval cls.out`.
    Pure unfolding of `genEvalAlgOf` over `Finsupp.sum`. -/
theorem evalAlg_expand {σ : GenFlagType CG2}
    {𝒢 : GenGraphClass CG2} {Δ : GenGraphParam CG2}
    (ψ : GenLimitFunctional CG2 σ 𝒢 Δ) (v : GenFlagAlg CG2 σ) :
    ψ.evalAlg v = ∑ cls ∈ v.support, v cls * ψ.eval cls.out := by
  change genEvalAlgOf ψ.eval v = _
  simp only [genEvalAlgOf, Finsupp.sum]

/-- For any σ-functional ψ, the part of v supported on σ-non-local cls
    evaluates to 0, because non-local cls have `ψ.eval cls.out = 0`. -/
theorem evalAlg_filter_nonlocal_eq_zero {σ : GenFlagType CG2}
    {𝒢 : GenGraphClass CG2} {Δ : GenGraphParam CG2}
    (ψ : GenLimitFunctional CG2 σ 𝒢 Δ) (v : GenFlagAlg CG2 σ) :
    ψ.evalAlg (v.filter (fun cls => ¬ GenIsLocalFlag σ cls.out 𝒢 Δ)) = 0 := by
  classical
  rw [evalAlg_expand]
  apply Finset.sum_eq_zero
  intro cls hcls
  rw [Finsupp.support_filter, Finset.mem_filter] at hcls
  rw [ψ.eval_nonlocal cls.out hcls.2, mul_zero]

/-- For any σ-functional ψ, restricting `v` to its σ-local cls preserves `ψ.evalAlg`. -/
theorem evalAlg_filter_local {σ : GenFlagType CG2}
    {𝒢 : GenGraphClass CG2} {Δ : GenGraphParam CG2}
    (ψ : GenLimitFunctional CG2 σ 𝒢 Δ) (v : GenFlagAlg CG2 σ) :
    ψ.evalAlg (v.filter (fun cls => GenIsLocalFlag σ cls.out 𝒢 Δ)) =
    ψ.evalAlg v := by
  classical
  -- v = v.filter local + v.filter (¬local)
  have hv : v = v.filter (fun cls => GenIsLocalFlag σ cls.out 𝒢 Δ) +
              v.filter (fun cls => ¬ GenIsLocalFlag σ cls.out 𝒢 Δ) :=
    (Finsupp.filter_pos_add_filter_neg v
      (fun cls => GenIsLocalFlag σ cls.out 𝒢 Δ)).symm
  conv_rhs => rw [hv]
  rw [ψ.evalAlg_add, evalAlg_filter_nonlocal_eq_zero, add_zero]

/-- For an ∅-functional `phi`, given the disjunction "cls is σ-local or
    `phi.eval cls.out.forget = 0`" for every cls ∈ v.support, restricting `v`
    to its σ-local part preserves `phi.evalAlg ∘ genAveragingAlg σ`. -/
theorem evalAlg_genAveragingAlg_filter_local {σ : GenFlagType CG2}
    {𝒢 : GenGraphClass CG2} {Δ : GenGraphParam CG2}
    (phi : GenLimitFunctional CG2 (GenFlagType.empty CG2) 𝒢 Δ)
    (v : GenFlagAlg CG2 σ)
    (hloz : ∀ cls ∈ v.support,
      GenIsLocalFlag σ cls.out 𝒢 Δ ∨ phi.eval cls.out.forget = 0) :
    phi.evalAlg (genAveragingAlg σ
      (v.filter (fun cls => GenIsLocalFlag σ cls.out 𝒢 Δ))) =
    phi.evalAlg (genAveragingAlg σ v) := by
  classical
  -- v = v.filter local + v.filter (¬local); apply genAveragingAlg_add and evalAlg_add.
  have hv : v = v.filter (fun cls => GenIsLocalFlag σ cls.out 𝒢 Δ) +
              v.filter (fun cls => ¬ GenIsLocalFlag σ cls.out 𝒢 Δ) :=
    (Finsupp.filter_pos_add_filter_neg v
      (fun cls => GenIsLocalFlag σ cls.out 𝒢 Δ)).symm
  conv_rhs => rw [hv]
  rw [genAveragingAlg_add, phi.evalAlg_add]
  -- Show the non-local part contributes 0 to phi.evalAlg(genAveragingAlg σ ·)
  -- via the algebraic expansion: each non-local cls has phi.eval cls.out.forget = 0.
  have hnon : phi.evalAlg (genAveragingAlg σ
      (v.filter (fun cls => ¬ GenIsLocalFlag σ cls.out 𝒢 Δ))) = 0 := by
    rw [evalAlg_genAveragingAlg_expand]
    apply Finset.sum_eq_zero
    intro cls hcls
    rw [Finsupp.support_filter, Finset.mem_filter] at hcls
    rcases hloz cls hcls.1 with hloc | hzero
    · exact absurd hloc hcls.2
    · rw [hzero, mul_zero, mul_zero]
  rw [hnon, add_zero]

/-- **Weakened per-functional preservation of positivity**: same as
    `genAveraging_preserves_positivity_perfunc_phi` but with the cls-locality
    hypothesis weakened to a disjunction:
      `∀ cls ∈ v.support, GenIsLocalFlag σ cls.out 𝒢 Δ ∨ phi.eval cls.out.forget = 0`.

    Proof strategy: restrict v to its σ-local part `v_local := v.filter local`.
    By `evalAlg_genAveragingAlg_filter_local`, this preserves
    `phi.evalAlg ∘ genAveragingAlg σ` (since non-local cls have `phi.eval` = 0).
    By construction, `v_local.support` is all σ-local. The σ-positivity of
    `v_local` at any regular σ-functional ψ follows from σ-positivity of v
    via `evalAlg_filter_local` (`ψ.evalAlg(v_local) = ψ.evalAlg(v)`). Then
    apply the strong `_perfunc_phi`. -/
theorem genAveraging_preserves_positivity_perfunc_phi_weakened
    {σ : GenFlagType CG2} {𝒢 : GenGraphClass CG2} {Δ : GenGraphParam CG2}
    (hσ : GenIsLocalType σ 𝒢 Δ)
    (v : GenFlagAlg CG2 σ)
    (phi : GenLimitFunctional CG2 (GenFlagType.empty CG2) 𝒢 Δ)
    (hreg_phi : ∀ k, ∀ u : Fin (phi.seq.seq k).size,
      (Finset.univ.filter ((phi.seq.seq k).str.1.Adj u)).card =
        Δ (phi.seq.seq k).forget)
    (hloz : ∀ cls ∈ v.support,
      GenIsLocalFlag σ cls.out 𝒢 Δ ∨ phi.eval cls.out.forget = 0)
    (h_pos_perfunc : ∀ ψ : GenLimitFunctional CG2 σ 𝒢 Δ,
      (∀ k, ∀ u : Fin (ψ.seq.seq k).size,
        (Finset.univ.filter ((ψ.seq.seq k).str.1.Adj u)).card =
          Δ (ψ.seq.seq k).forget) →
      0 ≤ ψ.evalAlg v) :
    0 ≤ phi.evalAlg (genAveragingAlg σ v) := by
  classical
  -- Reduce to local part of v.
  rw [← evalAlg_genAveragingAlg_filter_local phi v hloz]
  -- Apply strong theorem to v_local with all-local support.
  set v_local := v.filter (fun cls => GenIsLocalFlag σ cls.out 𝒢 Δ) with hv_local_def
  refine genAveraging_preserves_positivity_perfunc_phi hσ v_local ?_ phi hreg_phi ?_
  · -- v_local.support ⊆ {cls | local}
    intro cls hcls
    rw [hv_local_def, Finsupp.support_filter, Finset.mem_filter] at hcls
    exact hcls.2
  · -- σ-positivity of v_local at any regular ψ: derive from σ-positivity of v
    -- via evalAlg_filter_local.
    intro ψ h_reg_psi
    rw [hv_local_def, evalAlg_filter_local]
    exact h_pos_perfunc ψ h_reg_psi

/-- **Weakened per-functional unlabel of ext-difference**: same as
    `unlabel_extDiff_nonneg_perfunc` but with the cls-locality hypothesis
    weakened to a disjunction. The σ-positivity at any regular ψ is
    hypothesized directly (caller discharges it; for BRRB this uses
    construction-specific facts about ψ.eval = 0 on non-local cls). -/
theorem unlabel_extDiff_nonneg_perfunc_weakened (σ : GenFlagType CG2)
    {𝒢 : GenGraphClass CG2} {Δ : GenGraphParam CG2}
    (hσ : GenIsLocalType σ 𝒢 Δ)
    (i j : Fin σ.size)
    (phi : GenLimitFunctional CG2 (GenFlagType.empty CG2) 𝒢 Δ)
    (h_reg_phi : ∀ k, ∀ v : Fin (phi.seq.seq k).size,
      (Finset.univ.filter ((phi.seq.seq k).str.1.Adj v)).card =
        Δ (phi.seq.seq k).forget)
    (h_loz_i : ∀ cls ∈ ((genClassesOfSize CG2 σ (σ.size + 1) (Nat.le_succ _)).filter
      (fun cls => extAdjacencyClass σ cls i)),
      GenIsLocalFlag σ cls.out 𝒢 Δ ∨ phi.eval cls.out.forget = 0)
    (h_loz_j : ∀ cls ∈ ((genClassesOfSize CG2 σ (σ.size + 1) (Nat.le_succ _)).filter
      (fun cls => extAdjacencyClass σ cls j)),
      GenIsLocalFlag σ cls.out 𝒢 Δ ∨ phi.eval cls.out.forget = 0)
    (h_sigma_pos : ∀ ψ : GenLimitFunctional CG2 σ 𝒢 Δ,
      (∀ k, ∀ u : Fin (ψ.seq.seq k).size,
        (Finset.univ.filter ((ψ.seq.seq k).str.1.Adj u)).card =
          Δ (ψ.seq.seq k).forget) →
      0 ≤ ψ.evalAlg (extSum σ i - extSum σ j)) :
    0 ≤ phi.evalAlg (genAveragingAlg σ (extSum σ i - extSum σ j)) := by
  classical
  -- Derive ∨-hypothesis on (extSum σ i - extSum σ j).support from h_loz_i/j.
  have hi_loz : ∀ cls ∈ (extSum σ i).support,
      GenIsLocalFlag σ cls.out 𝒢 Δ ∨ phi.eval cls.out.forget = 0 := by
    intro cls hcls; rw [extSum_support_eq] at hcls; exact h_loz_i cls hcls
  have hj_loz : ∀ cls ∈ (extSum σ j).support,
      GenIsLocalFlag σ cls.out 𝒢 Δ ∨ phi.eval cls.out.forget = 0 := by
    intro cls hcls; rw [extSum_support_eq] at hcls; exact h_loz_j cls hcls
  have h_loz_sub : ∀ cls ∈ (extSum σ i - extSum σ j).support,
      GenIsLocalFlag σ cls.out 𝒢 Δ ∨ phi.eval cls.out.forget = 0 := by
    intro cls hcls
    have h_sub : (extSum σ i - extSum σ j).support ⊆
        (extSum σ i).support ∪ (extSum σ j).support := Finsupp.support_sub
    have hmem := h_sub hcls
    rw [Finset.mem_union] at hmem
    rcases hmem with h | h
    · exact hi_loz cls h
    · exact hj_loz cls h
  -- Apply weakened preservation theorem.
  exact genAveraging_preserves_positivity_perfunc_phi_weakened
    hσ (extSum σ i - extSum σ j) phi h_reg_phi h_loz_sub h_sigma_pos

/-- **Weakened per-functional `unlabel_extDiff_eq_zero`**: symmetric application
    of `unlabel_extDiff_nonneg_perfunc_weakened`. -/
theorem unlabel_extDiff_eq_zero_perfunc_weakened (σ : GenFlagType CG2)
    {𝒢 : GenGraphClass CG2} {Δ : GenGraphParam CG2}
    (hσ : GenIsLocalType σ 𝒢 Δ)
    (i j : Fin σ.size)
    (phi : GenLimitFunctional CG2 (GenFlagType.empty CG2) 𝒢 Δ)
    (h_reg_phi : ∀ k, ∀ v : Fin (phi.seq.seq k).size,
      (Finset.univ.filter ((phi.seq.seq k).str.1.Adj v)).card =
        Δ (phi.seq.seq k).forget)
    (h_loz_i : ∀ cls ∈ ((genClassesOfSize CG2 σ (σ.size + 1) (Nat.le_succ _)).filter
      (fun cls => extAdjacencyClass σ cls i)),
      GenIsLocalFlag σ cls.out 𝒢 Δ ∨ phi.eval cls.out.forget = 0)
    (h_loz_j : ∀ cls ∈ ((genClassesOfSize CG2 σ (σ.size + 1) (Nat.le_succ _)).filter
      (fun cls => extAdjacencyClass σ cls j)),
      GenIsLocalFlag σ cls.out 𝒢 Δ ∨ phi.eval cls.out.forget = 0)
    (h_sigma_pos_ij : ∀ ψ : GenLimitFunctional CG2 σ 𝒢 Δ,
      (∀ k, ∀ u : Fin (ψ.seq.seq k).size,
        (Finset.univ.filter ((ψ.seq.seq k).str.1.Adj u)).card =
          Δ (ψ.seq.seq k).forget) →
      0 ≤ ψ.evalAlg (extSum σ i - extSum σ j))
    (h_sigma_pos_ji : ∀ ψ : GenLimitFunctional CG2 σ 𝒢 Δ,
      (∀ k, ∀ u : Fin (ψ.seq.seq k).size,
        (Finset.univ.filter ((ψ.seq.seq k).str.1.Adj u)).card =
          Δ (ψ.seq.seq k).forget) →
      0 ≤ ψ.evalAlg (extSum σ j - extSum σ i)) :
    phi.evalAlg (genAveragingAlg σ (extSum σ i - extSum σ j)) = 0 := by
  have h_ij := unlabel_extDiff_nonneg_perfunc_weakened σ hσ i j phi h_reg_phi
    h_loz_i h_loz_j h_sigma_pos_ij
  have h_ji := unlabel_extDiff_nonneg_perfunc_weakened σ hσ j i phi h_reg_phi
    h_loz_j h_loz_i h_sigma_pos_ji
  rw [show (extSum σ j - extSum σ i : GenFlagAlg CG2 σ) =
      (-1 : ℝ) • (extSum σ i - extSum σ j) by
    rw [neg_smul, one_smul]; abel] at h_ji
  rw [genAveragingAlg_smul, GenLimitFunctional.evalAlg_smul] at h_ji
  linarith

/-- **Weakened per-functional σᵢ nonneg template**: same as
    `sigma_nonneg_template_perfunc` but with the cls-locality hypothesis on
    extension classes weakened to a disjunction. The σ-positivity at every
    regular σ-functional is hypothesized directly. -/
theorem sigma_nonneg_template_perfunc_weakened (σ : GenFlagType CG2)
    {𝒢 : GenGraphClass CG2} {Δ : GenGraphParam CG2}
    (hσ : GenIsLocalType σ 𝒢 Δ)
    (a b : Fin σ.size)
    (phi : GenLimitFunctional CG2 (GenFlagType.empty CG2) 𝒢 Δ)
    (h_reg_phi : ∀ k, ∀ v : Fin (phi.seq.seq k).size,
      (Finset.univ.filter ((phi.seq.seq k).str.1.Adj v)).card =
        Δ (phi.seq.seq k).forget)
    (h_loz_a : ∀ cls ∈ ((genClassesOfSize CG2 σ (σ.size + 1) (Nat.le_succ _)).filter
      (fun cls => extAdjacencyClass σ cls a)),
      GenIsLocalFlag σ cls.out 𝒢 Δ ∨ phi.eval cls.out.forget = 0)
    (h_loz_b : ∀ cls ∈ ((genClassesOfSize CG2 σ (σ.size + 1) (Nat.le_succ _)).filter
      (fun cls => extAdjacencyClass σ cls b)),
      GenIsLocalFlag σ cls.out 𝒢 Δ ∨ phi.eval cls.out.forget = 0)
    (h_sigma_pos_ab : ∀ ψ : GenLimitFunctional CG2 σ 𝒢 Δ,
      (∀ k, ∀ u : Fin (ψ.seq.seq k).size,
        (Finset.univ.filter ((ψ.seq.seq k).str.1.Adj u)).card =
          Δ (ψ.seq.seq k).forget) →
      0 ≤ ψ.evalAlg (extSum σ a - extSum σ b))
    (h_sigma_pos_ba : ∀ ψ : GenLimitFunctional CG2 σ 𝒢 Δ,
      (∀ k, ∀ u : Fin (ψ.seq.seq k).size,
        (Finset.univ.filter ((ψ.seq.seq k).str.1.Adj u)).card =
          Δ (ψ.seq.seq k).forget) →
      0 ≤ ψ.evalAlg (extSum σ b - extSum σ a))
    (named_flag_combo : ℝ)
    (combinatorial_identity :
      120 * phi.evalAlg (genAveragingAlg σ (extSum σ a - extSum σ b)) =
        named_flag_combo) :
    0 ≤ named_flag_combo := by
  rw [← combinatorial_identity,
      unlabel_extDiff_eq_zero_perfunc_weakened σ hσ a b phi h_reg_phi
        h_loz_a h_loz_b h_sigma_pos_ab h_sigma_pos_ba]
  linarith

/-- **Generic σ-aut count = 1 for size-σ.size+1 flags**: any σ-flag `F` with
    `F.size = σ.size + 1` has `genFlagAutCount σ F = 1`. The identity is the
    only σ-induced self-embedding: σ.size embedding-image vertices are fixed
    pointwise by `compat`, the unique remaining vertex is forced to itself by
    injectivity (its image must lie outside the embedding image, which has
    cardinality 1, so it equals itself). -/
theorem genFlagAutCount_eq_one_of_singleExt {σ : GenFlagType CG2}
    (F : GenFlag CG2 σ) (h_size : F.size = σ.size + 1) :
    genFlagAutCount CG2 σ F = 1 := by
  unfold genFlagAutCount genInducedCount
  rw [Fintype.card_eq_one_iff]
  let idE : GenInducedEmbedding CG2 σ F F :=
    ⟨id, Function.injective_id, CG2.comap_id _, fun _ => rfl⟩
  refine ⟨idE, fun e => ?_⟩
  apply GIE_ext
  funext x
  change e.toFun x = x
  set embImage : Finset (Fin F.size) := Finset.univ.image F.embedding with hembImage
  have h_emb_card : embImage.card = σ.size := by
    rw [hembImage, Finset.card_image_of_injective _ F.embedding.injective,
        Finset.card_univ, Fintype.card_fin]
  have h_compl_card : (Finset.univ \ embImage).card = 1 := by
    rw [Finset.card_sdiff_of_subset (Finset.subset_univ _),
        Finset.card_univ, Fintype.card_fin, h_emb_card, h_size]
    omega
  have h_fix : ∀ j : Fin σ.size, e.toFun (F.embedding j) = F.embedding j := e.compat
  have h_map_compl : ∀ y, y ∉ embImage → e.toFun y ∉ embImage := by
    intro y hy h_ein
    rw [hembImage, Finset.mem_image] at h_ein
    obtain ⟨j, _, hj⟩ := h_ein
    apply hy
    rw [hembImage, Finset.mem_image]
    refine ⟨j, Finset.mem_univ _, ?_⟩
    have heq : e.toFun y = e.toFun (F.embedding j) := by rw [h_fix j]; exact hj.symm
    exact (e.injective heq).symm
  by_cases hx : x ∈ embImage
  · rw [hembImage, Finset.mem_image] at hx
    obtain ⟨j, _, hj⟩ := hx
    rw [← hj, h_fix j]
  · obtain ⟨ext, h_ext⟩ := Finset.card_eq_one.mp h_compl_card
    have hx_compl : x ∈ Finset.univ \ embImage :=
      Finset.mem_sdiff.mpr ⟨Finset.mem_univ _, hx⟩
    have hex_compl : e.toFun x ∈ Finset.univ \ embImage :=
      Finset.mem_sdiff.mpr ⟨Finset.mem_univ _, h_map_compl x hx⟩
    rw [h_ext] at hx_compl hex_compl
    have hx_eq : x = ext := Finset.mem_singleton.mp hx_compl
    have hex_eq : e.toFun x = ext := Finset.mem_singleton.mp hex_compl
    rw [hex_eq, hx_eq]

/-! ## B₁ chain bridge: `phi.eval certF6 = 5 · phi.eval vertexBlackFlag.forget`

Combines `vertexBlackType_master_chain_perfunc` (LHS = `phi.eval vbFlag.forget`)
with `phi_eval_genAveragingAlg_extPow_four_collapsed` (LHS =
`q(vbExt4_RRRR_e0) · phi.eval certF6`) to derive the B₁ identity. -/

/-- **The combinatorial coefficient**: `q(vbExt4_RRRR_e0)`: needed for the
    final B₁ chain. Defined here (concrete) to avoid circular dependency. -/
private noncomputable def b1_chain_coefficient : ℝ :=
  genNormalisationFactor vertexBlackType vbExt4_RRRR_e0

/-- Explicit form of the B₁ identity: from per-functional regularity,
    `q(vbExt4_RRRR_e0) · phi.eval certF6 = phi.eval vertexBlackFlag.forget`. -/
theorem b1_chain_eq
    (phi : GenLimitFunctional CG2 (GenFlagType.empty CG2)
      brrbGenGraphClass brrbGenDelta)
    (hreg_phi : ∀ k, ∀ u : Fin (phi.seq.seq k).size,
      (Finset.univ.filter ((phi.seq.seq k).str.1.Adj u)).card =
        brrbGenDelta (phi.seq.seq k).forget)
    (hσ : GenIsLocalType vertexBlackType brrbGenGraphClass brrbGenDelta)
    (hσ_toFlag : GenIsLocalFlag vertexBlackType vertexBlackType.toFlag
      brrbGenGraphClass brrbGenDelta)
    (h_ext_local : ∀ cls ∈ ((genClassesOfSize CG2 vertexBlackType
      (vertexBlackType.size + 1) (Nat.le_succ _)).filter
      (fun cls => extAdjacencyClass vertexBlackType cls
        ⟨0, by change 0 < 1; omega⟩)),
      GenIsLocalFlag vertexBlackType cls.out brrbGenGraphClass brrbGenDelta) :
    genNormalisationFactor vertexBlackType vbExt4_RRRR_e0 * phi.eval certF6 =
    phi.eval vertexBlackFlag.forget := by
  rw [← phi_eval_genAveragingAlg_extPow_four_collapsed phi]
  exact vertexBlackType_master_chain_perfunc hσ hσ_toFlag h_ext_local
    phi hreg_phi 4

/-! ## Aut counts for `vbExt4_RRRR_e0` and `vbExt4_RRRR_e0.forget`

Both auts equal `S_4 = 24` (permute the four red leaves):
* σ-aut: σ-vertex (position 0) fixed by σ-compat, leaves at {1,2,3,4} permute freely.
* ∅-aut: σ-vertex (position 0) fixed because it is the unique black vertex (colour 1).

We build an explicit `Equiv` from each Aut to `Equiv.Perm (Fin 4)` (cardinality
`4! = 24` by `Fintype.card_perm`), reusing the existing `fin4_skip0` /
`fin4_skip0_inv` machinery to translate between {1,2,3,4} ⊆ Fin 5 and Fin 4.
Mirrors the `vbExt3_RRR_e0_aut` (S₃ = 6) construction at size 4 → size 5. -/

/-- Symmetric companion to `vbExt4_RRRR_e0_adj_0_skip`: leaf is adjacent to σ. -/
private theorem vbExt4_RRRR_e0_skip_adj_zero (c : Fin 4) :
    vbExt4_RRRR_e0.str.1.Adj (fin4_skip0 c) (⟨0, by omega⟩ : Fin 5) :=
  (vbExt4_RRRR_e0_adj_0_skip c).symm

/-! ### σ-aut for `vbExt4_RRRR_e0`: 24 -/

/-- For any σ-iso `f` of `vbExt4_RRRR_e0`, `f` fixes the σ-vertex `⟨0⟩`. -/
private theorem vbExt4_RRRR_e0_aut_fix0
    (e : GenInducedEmbedding CG2 vertexBlackType vbExt4_RRRR_e0 vbExt4_RRRR_e0) :
    e.toFun (⟨0, by omega⟩ : Fin 5) = (⟨0, by omega⟩ : Fin 5) := by
  have h_emb : vbExt4_RRRR_e0.embedding (⟨0, Nat.zero_lt_one⟩ : Fin 1) =
      (⟨0, by omega⟩ : Fin 5) := rfl
  have := e.compat (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size)
  rw [h_emb] at this
  exact this

/-- For any σ-iso `e`, `(e.toFun ⟨k⟩).val ≠ 0` for `k ∈ {1,2,3,4}`. -/
private theorem vbExt4_RRRR_e0_aut_image_ne_zero
    (e : GenInducedEmbedding CG2 vertexBlackType vbExt4_RRRR_e0 vbExt4_RRRR_e0)
    (c : Fin 4) :
    (e.toFun (fin4_skip0 c)).val ≠ 0 := by
  intro hval
  have h_eq : e.toFun (fin4_skip0 c) = (⟨0, by omega⟩ : Fin 5) := Fin.ext hval
  have h0 := vbExt4_RRRR_e0_aut_fix0 e
  have h_inj : fin4_skip0 c = (⟨0, by omega⟩ : Fin 5) :=
    e.injective (h_eq.trans h0.symm)
  exact fin4_skip0_ne_zero c h_inj

/-- Forward map: σ-iso ↦ `Fin 4 → Fin 4` permutation of leaves. -/
private noncomputable def vbExt4_RRRR_e0_to_perm_fn
    (e : GenInducedEmbedding CG2 vertexBlackType vbExt4_RRRR_e0 vbExt4_RRRR_e0) :
    Fin 4 → Fin 4 :=
  fun c => fin4_skip0_inv (e.toFun (fin4_skip0 c))
    (vbExt4_RRRR_e0_aut_image_ne_zero e c)

private theorem vbExt4_RRRR_e0_to_perm_fn_inj
    (e : GenInducedEmbedding CG2 vertexBlackType vbExt4_RRRR_e0 vbExt4_RRRR_e0) :
    Function.Injective (vbExt4_RRRR_e0_to_perm_fn e) := by
  intro a b h
  unfold vbExt4_RRRR_e0_to_perm_fn at h
  have h1 := congr_arg fin4_skip0 h
  rw [fin4_skip0_apply_inv, fin4_skip0_apply_inv] at h1
  have h2 : fin4_skip0 a = fin4_skip0 b := e.injective h1
  exact fin4_skip0_inj h2

private noncomputable def vbExt4_RRRR_e0_to_perm
    (e : GenInducedEmbedding CG2 vertexBlackType vbExt4_RRRR_e0 vbExt4_RRRR_e0) :
    Equiv.Perm (Fin 4) :=
  Equiv.ofBijective (vbExt4_RRRR_e0_to_perm_fn e)
    ⟨vbExt4_RRRR_e0_to_perm_fn_inj e,
     Finite.injective_iff_surjective.mp (vbExt4_RRRR_e0_to_perm_fn_inj e)⟩

/-- Backward map: `Perm (Fin 4)` ↦ a function `Fin 5 → Fin 5` fixing `⟨0⟩` and
    permuting the leaves via `π`. -/
private def vbExt4_RRRR_e0_of_perm_fn (π : Equiv.Perm (Fin 4)) : Fin 5 → Fin 5 :=
  fun x => if h : x.val = 0 then (⟨0, by omega⟩ : Fin 5)
    else fin4_skip0 (π (fin4_skip0_inv x h))

@[simp] private theorem vbExt4_RRRR_e0_of_perm_fn_zero (π : Equiv.Perm (Fin 4)) :
    vbExt4_RRRR_e0_of_perm_fn π (⟨0, by omega⟩ : Fin 5) = (⟨0, by omega⟩ : Fin 5) := by
  unfold vbExt4_RRRR_e0_of_perm_fn; simp

private theorem vbExt4_RRRR_e0_of_perm_fn_skip
    (π : Equiv.Perm (Fin 4)) (c : Fin 4) :
    vbExt4_RRRR_e0_of_perm_fn π (fin4_skip0 c) = fin4_skip0 (π c) := by
  unfold vbExt4_RRRR_e0_of_perm_fn
  have hne : (fin4_skip0 c).val ≠ 0 := by change (c.val + 1) ≠ 0; omega
  rw [dif_neg hne, fin4_skip0_inv_apply]

private theorem vbExt4_RRRR_e0_of_perm_fn_inj (π : Equiv.Perm (Fin 4)) :
    Function.Injective (vbExt4_RRRR_e0_of_perm_fn π) := by
  intro a b h
  unfold vbExt4_RRRR_e0_of_perm_fn at h
  by_cases ha : a.val = 0
  · by_cases hb : b.val = 0
    · exact Fin.ext (ha.trans hb.symm)
    · exfalso
      rw [dif_pos ha, dif_neg hb] at h
      exact fin4_skip0_ne_zero _ h.symm
  · by_cases hb : b.val = 0
    · exfalso
      rw [dif_neg ha, dif_pos hb] at h
      exact fin4_skip0_ne_zero _ h
    · rw [dif_neg ha, dif_neg hb] at h
      have h1 : π (fin4_skip0_inv a ha) = π (fin4_skip0_inv b hb) := fin4_skip0_inj h
      have h2 : fin4_skip0_inv a ha = fin4_skip0_inv b hb := π.injective h1
      have h3 := congr_arg fin4_skip0 h2
      rw [fin4_skip0_apply_inv, fin4_skip0_apply_inv] at h3
      exact h3

/-- Backward map preserves the structure (graph + colour) of `vbExt4_RRRR_e0`. -/
private theorem vbExt4_RRRR_e0_of_perm_fn_isInduced (π : Equiv.Perm (Fin 4)) :
    CG2.comap (vbExt4_RRRR_e0_of_perm_fn π) vbExt4_RRRR_e0.str = vbExt4_RRRR_e0.str := by
  apply Prod.ext
  · ext u v
    change vbExt4_RRRR_e0.str.1.Adj
      (vbExt4_RRRR_e0_of_perm_fn π u) (vbExt4_RRRR_e0_of_perm_fn π v)
      ↔ vbExt4_RRRR_e0.str.1.Adj u v
    by_cases hu : u.val = 0
    · by_cases hv : v.val = 0
      · have hu' : u = (⟨0, by omega⟩ : Fin 5) := Fin.ext hu
        have hv' : v = (⟨0, by omega⟩ : Fin 5) := Fin.ext hv
        rw [hu', hv']; simp
      · have hu' : u = (⟨0, by omega⟩ : Fin 5) := Fin.ext hu
        rw [hu', vbExt4_RRRR_e0_of_perm_fn_zero]
        set c := fin4_skip0_inv v hv with hc_def
        have hv_eq : v = fin4_skip0 c := (fin4_skip0_apply_inv v hv).symm
        rw [hv_eq, vbExt4_RRRR_e0_of_perm_fn_skip]
        constructor
        · intro _; exact vbExt4_RRRR_e0_adj_0_skip c
        · intro _; exact vbExt4_RRRR_e0_adj_0_skip (π c)
    · by_cases hv : v.val = 0
      · have hv' : v = (⟨0, by omega⟩ : Fin 5) := Fin.ext hv
        rw [hv', vbExt4_RRRR_e0_of_perm_fn_zero]
        set c := fin4_skip0_inv u hu with hc_def
        have hu_eq : u = fin4_skip0 c := (fin4_skip0_apply_inv u hu).symm
        rw [hu_eq, vbExt4_RRRR_e0_of_perm_fn_skip]
        constructor
        · intro _; exact vbExt4_RRRR_e0_skip_adj_zero c
        · intro _; exact vbExt4_RRRR_e0_skip_adj_zero (π c)
      · set c := fin4_skip0_inv u hu with hc_def
        set d := fin4_skip0_inv v hv with hd_def
        have hu_eq : u = fin4_skip0 c := (fin4_skip0_apply_inv u hu).symm
        have hv_eq : v = fin4_skip0 d := (fin4_skip0_apply_inv v hv).symm
        rw [hu_eq, hv_eq, vbExt4_RRRR_e0_of_perm_fn_skip,
            vbExt4_RRRR_e0_of_perm_fn_skip]
        constructor
        · intro h; exact absurd h (vbExt4_RRRR_e0_not_adj_skip_skip _ _)
        · intro h; exact absurd h (vbExt4_RRRR_e0_not_adj_skip_skip _ _)
  · funext v
    change vbExt4_RRRR_e0.str.2 (vbExt4_RRRR_e0_of_perm_fn π v) = vbExt4_RRRR_e0.str.2 v
    by_cases hv : v.val = 0
    · have hv' : v = (⟨0, by omega⟩ : Fin 5) := Fin.ext hv
      rw [hv', vbExt4_RRRR_e0_of_perm_fn_zero]
    · set c := fin4_skip0_inv v hv with hc_def
      have hv_eq : v = fin4_skip0 c := (fin4_skip0_apply_inv v hv).symm
      rw [hv_eq, vbExt4_RRRR_e0_of_perm_fn_skip]
      rw [vbExt4_RRRR_e0_col_skip (π c), vbExt4_RRRR_e0_col_skip c]

private noncomputable def vbExt4_RRRR_e0_of_perm (π : Equiv.Perm (Fin 4)) :
    GenInducedEmbedding CG2 vertexBlackType vbExt4_RRRR_e0 vbExt4_RRRR_e0 where
  toFun := vbExt4_RRRR_e0_of_perm_fn π
  injective := vbExt4_RRRR_e0_of_perm_fn_inj π
  isInduced := vbExt4_RRRR_e0_of_perm_fn_isInduced π
  compat := by
    intro i
    have hi : i = (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) := by
      obtain ⟨v, hv⟩ := i
      have h_size : vertexBlackType.size = 1 := rfl
      have hv' : v < 1 := h_size ▸ hv
      have : v = 0 := by omega
      ext; exact this
    rw [hi]
    have h_emb : vbExt4_RRRR_e0.embedding (⟨0, Nat.zero_lt_one⟩ : Fin 1) =
        (⟨0, by omega⟩ : Fin 5) := rfl
    rw [h_emb, vbExt4_RRRR_e0_of_perm_fn_zero]

private noncomputable def vbExt4_RRRR_e0_aut_equiv :
    GenInducedEmbedding CG2 vertexBlackType vbExt4_RRRR_e0 vbExt4_RRRR_e0 ≃
      Equiv.Perm (Fin 4) where
  toFun := vbExt4_RRRR_e0_to_perm
  invFun := vbExt4_RRRR_e0_of_perm
  left_inv := by
    intro e
    have h_funext : ∀ x : Fin 5,
        (vbExt4_RRRR_e0_of_perm (vbExt4_RRRR_e0_to_perm e)).toFun x = e.toFun x := by
      intro x
      change vbExt4_RRRR_e0_of_perm_fn (vbExt4_RRRR_e0_to_perm e) x = e.toFun x
      by_cases hx : x.val = 0
      · have hx' : x = (⟨0, by omega⟩ : Fin 5) := Fin.ext hx
        rw [hx', vbExt4_RRRR_e0_of_perm_fn_zero, vbExt4_RRRR_e0_aut_fix0 e]
      · apply Fin.ext
        change (vbExt4_RRRR_e0_of_perm_fn (vbExt4_RRRR_e0_to_perm e) x).val = (e.toFun x).val
        unfold vbExt4_RRRR_e0_of_perm_fn
        rw [dif_neg hx]
        change (fin4_skip0 (vbExt4_RRRR_e0_to_perm_fn e (fin4_skip0_inv x hx))).val =
          (e.toFun x).val
        have h_inv_skip : fin4_skip0 (fin4_skip0_inv x hx) = x := fin4_skip0_apply_inv x hx
        have h_e_eq : e.toFun (fin4_skip0 (fin4_skip0_inv x hx)) = e.toFun x := by
          rw [h_inv_skip]
        unfold vbExt4_RRRR_e0_to_perm_fn
        change ((e.toFun (fin4_skip0 (fin4_skip0_inv x hx))).val - 1) + 1 =
          (e.toFun x).val
        have h_val : (e.toFun (fin4_skip0 (fin4_skip0_inv x hx))).val = (e.toFun x).val :=
          congr_arg Fin.val h_e_eq
        rw [h_val]
        have h_pos : 1 ≤ (e.toFun x).val := by
          by_contra h
          push_neg at h
          have h_zero : (e.toFun x).val = 0 := by omega
          have h_eq : e.toFun x = (⟨0, by omega⟩ : Fin 5) := Fin.ext h_zero
          have h_inj : x = (⟨0, by omega⟩ : Fin 5) :=
            e.injective (h_eq.trans (vbExt4_RRRR_e0_aut_fix0 e).symm)
          have : x.val = 0 := congr_arg Fin.val h_inj
          exact hx this
        omega
    have h_toFun : (vbExt4_RRRR_e0_of_perm (vbExt4_RRRR_e0_to_perm e)).toFun = e.toFun :=
      funext h_funext
    rcases e with ⟨f, finj, find, fcompat⟩
    generalize h_lhs_def :
      vbExt4_RRRR_e0_of_perm (vbExt4_RRRR_e0_to_perm ⟨f, finj, find, fcompat⟩) = lhs
    rw [h_lhs_def] at h_toFun
    rcases lhs with ⟨f', finj', find', fcompat'⟩
    cases h_toFun
    rfl
  right_inv := by
    intro π
    apply Equiv.ext
    intro c
    change vbExt4_RRRR_e0_to_perm_fn (vbExt4_RRRR_e0_of_perm π) c = π c
    apply Fin.ext
    change (fin4_skip0_inv ((vbExt4_RRRR_e0_of_perm π).toFun (fin4_skip0 c))
          (vbExt4_RRRR_e0_aut_image_ne_zero (vbExt4_RRRR_e0_of_perm π) c)).val =
          (π c).val
    have h_apply : (vbExt4_RRRR_e0_of_perm π).toFun (fin4_skip0 c) = fin4_skip0 (π c) :=
      vbExt4_RRRR_e0_of_perm_fn_skip π c
    change ((vbExt4_RRRR_e0_of_perm π).toFun (fin4_skip0 c)).val - 1 = (π c).val
    rw [h_apply]
    change (fin4_skip0 (π c)).val - 1 = (π c).val
    change (π c).val + 1 - 1 = (π c).val
    omega

/-- **The S₄ automorphism count for `vbExt4_RRRR_e0`.**
    The σ-flag is K_{1,4} with σ at vertex 0 and 4 red leaves at {1,2,3,4}. Any
    σ-iso fixes vertex 0 and permutes the leaves; adjacency and colour preserved.
    Hence Aut = S₄ = 24. -/
theorem vbExt4_RRRR_e0_aut :
    genFlagAutCount CG2 vertexBlackType vbExt4_RRRR_e0 = 24 := by
  unfold genFlagAutCount genInducedCount
  rw [Fintype.card_congr vbExt4_RRRR_e0_aut_equiv]
  rw [Fintype.card_perm]
  decide

/-! ### ∅-aut for `vbExt4_RRRR_e0.forget`: 24

The forgotten flag has the same str (graph + colour). Vertex 0 is the unique
black vertex, so any structure-preserving permutation fixes it. The remaining
permutation of {1,2,3,4} is unconstrained — same Equiv to `Perm (Fin 4)`. -/

/-- For any ∅-iso of `vbExt4_RRRR_e0.forget`, vertex 0 is fixed because it
    is the unique black-coloured vertex. -/
private theorem vbExt4_RRRR_e0_forget_aut_fix0
    (e : GenInducedEmbedding CG2 (GenFlagType.empty CG2)
      vbExt4_RRRR_e0.forget vbExt4_RRRR_e0.forget) :
    e.toFun (⟨0, by omega⟩ : Fin 5) = (⟨0, by omega⟩ : Fin 5) := by
  -- Colour at 0 is 1 (black). Pull back: forget.str.2 (e.toFun ⟨0⟩) = 1.
  have h_isInd := e.isInduced
  -- isInduced : CG2.comap e.toFun forget.str = forget.str
  -- Apply to colour function at v=0.
  have h_col0 : vbExt4_RRRR_e0.forget.str.2 (⟨0, by omega⟩ : Fin 5) = 1 := rfl
  have h_pull : vbExt4_RRRR_e0.forget.str.2 (e.toFun (⟨0, by omega⟩ : Fin 5))
        = vbExt4_RRRR_e0.forget.str.2 (⟨0, by omega⟩ : Fin 5) := by
    have h_str_eq : (CG2.comap e.toFun vbExt4_RRRR_e0.forget.str).2
        = vbExt4_RRRR_e0.forget.str.2 := by
      rw [h_isInd]
    have := congr_fun h_str_eq (⟨0, by omega⟩ : Fin 5)
    change vbExt4_RRRR_e0.forget.str.2 (e.toFun (⟨0, by omega⟩ : Fin 5)) =
      vbExt4_RRRR_e0.forget.str.2 (⟨0, by omega⟩ : Fin 5)
    exact this
  rw [h_col0] at h_pull
  -- Now: forget.str.2 (e.toFun ⟨0⟩) = 1. The colour fn returns 1 only at val=0.
  -- forget.str.2 = vbExt4_RRRR_e0.str.2 = "if v=0 then 1 else 0".
  have h_eval : vbExt4_RRRR_e0.forget.str.2 (e.toFun (⟨0, by omega⟩ : Fin 5))
      = if (e.toFun (⟨0, by omega⟩ : Fin 5)).val = 0 then (1 : Fin 2) else 0 := rfl
  rw [h_eval] at h_pull
  by_contra h_ne
  -- e.toFun ⟨0⟩ ≠ ⟨0⟩ ⇒ val ≠ 0 ⇒ if-branch is 0 ≠ 1.
  have h_val_ne : (e.toFun (⟨0, by omega⟩ : Fin 5)).val ≠ 0 := by
    intro hval
    apply h_ne
    exact Fin.ext hval
  rw [if_neg h_val_ne] at h_pull
  exact absurd h_pull (by decide)

private theorem vbExt4_RRRR_e0_forget_aut_image_ne_zero
    (e : GenInducedEmbedding CG2 (GenFlagType.empty CG2)
      vbExt4_RRRR_e0.forget vbExt4_RRRR_e0.forget) (c : Fin 4) :
    (e.toFun (fin4_skip0 c)).val ≠ 0 := by
  intro hval
  have h_eq : e.toFun (fin4_skip0 c) = (⟨0, by omega⟩ : Fin 5) := Fin.ext hval
  have h0 := vbExt4_RRRR_e0_forget_aut_fix0 e
  have h_inj : fin4_skip0 c = (⟨0, by omega⟩ : Fin 5) :=
    e.injective (h_eq.trans h0.symm)
  exact fin4_skip0_ne_zero c h_inj

private noncomputable def vbExt4_RRRR_e0_forget_to_perm_fn
    (e : GenInducedEmbedding CG2 (GenFlagType.empty CG2)
      vbExt4_RRRR_e0.forget vbExt4_RRRR_e0.forget) :
    Fin 4 → Fin 4 :=
  fun c => fin4_skip0_inv (e.toFun (fin4_skip0 c))
    (vbExt4_RRRR_e0_forget_aut_image_ne_zero e c)

private theorem vbExt4_RRRR_e0_forget_to_perm_fn_inj
    (e : GenInducedEmbedding CG2 (GenFlagType.empty CG2)
      vbExt4_RRRR_e0.forget vbExt4_RRRR_e0.forget) :
    Function.Injective (vbExt4_RRRR_e0_forget_to_perm_fn e) := by
  intro a b h
  unfold vbExt4_RRRR_e0_forget_to_perm_fn at h
  have h1 := congr_arg fin4_skip0 h
  rw [fin4_skip0_apply_inv, fin4_skip0_apply_inv] at h1
  have h2 : fin4_skip0 a = fin4_skip0 b := e.injective h1
  exact fin4_skip0_inj h2

private noncomputable def vbExt4_RRRR_e0_forget_to_perm
    (e : GenInducedEmbedding CG2 (GenFlagType.empty CG2)
      vbExt4_RRRR_e0.forget vbExt4_RRRR_e0.forget) :
    Equiv.Perm (Fin 4) :=
  Equiv.ofBijective (vbExt4_RRRR_e0_forget_to_perm_fn e)
    ⟨vbExt4_RRRR_e0_forget_to_perm_fn_inj e,
     Finite.injective_iff_surjective.mp (vbExt4_RRRR_e0_forget_to_perm_fn_inj e)⟩

/-- The graph + colour structure of `vbExt4_RRRR_e0.forget` is the same as
    `vbExt4_RRRR_e0.str`. -/
private theorem vbExt4_RRRR_e0_forget_str_eq :
    vbExt4_RRRR_e0.forget.str = vbExt4_RRRR_e0.str := rfl

/-- Backward map for the ∅-version: same `vbExt4_RRRR_e0_of_perm_fn`, but viewed
    as an iso of the forget flag (compat is trivial since σ = empty). -/
private noncomputable def vbExt4_RRRR_e0_forget_of_perm (π : Equiv.Perm (Fin 4)) :
    GenInducedEmbedding CG2 (GenFlagType.empty CG2)
      vbExt4_RRRR_e0.forget vbExt4_RRRR_e0.forget where
  toFun := vbExt4_RRRR_e0_of_perm_fn π
  injective := vbExt4_RRRR_e0_of_perm_fn_inj π
  isInduced := by
    rw [vbExt4_RRRR_e0_forget_str_eq]
    exact vbExt4_RRRR_e0_of_perm_fn_isInduced π
  compat := fun i => Fin.elim0 i

private noncomputable def vbExt4_RRRR_e0_forget_aut_equiv :
    GenInducedEmbedding CG2 (GenFlagType.empty CG2)
      vbExt4_RRRR_e0.forget vbExt4_RRRR_e0.forget ≃
      Equiv.Perm (Fin 4) where
  toFun := vbExt4_RRRR_e0_forget_to_perm
  invFun := vbExt4_RRRR_e0_forget_of_perm
  left_inv := by
    intro e
    have h_funext : ∀ x : Fin 5,
        (vbExt4_RRRR_e0_forget_of_perm
          (vbExt4_RRRR_e0_forget_to_perm e)).toFun x = e.toFun x := by
      intro x
      change vbExt4_RRRR_e0_of_perm_fn (vbExt4_RRRR_e0_forget_to_perm e) x = e.toFun x
      by_cases hx : x.val = 0
      · have hx' : x = (⟨0, by omega⟩ : Fin 5) := Fin.ext hx
        rw [hx', vbExt4_RRRR_e0_of_perm_fn_zero,
            vbExt4_RRRR_e0_forget_aut_fix0 e]
      · apply Fin.ext
        change (vbExt4_RRRR_e0_of_perm_fn (vbExt4_RRRR_e0_forget_to_perm e) x).val =
          (e.toFun x).val
        unfold vbExt4_RRRR_e0_of_perm_fn
        rw [dif_neg hx]
        change (fin4_skip0 (vbExt4_RRRR_e0_forget_to_perm_fn e
          (fin4_skip0_inv x hx))).val = (e.toFun x).val
        have h_inv_skip : fin4_skip0 (fin4_skip0_inv x hx) = x := fin4_skip0_apply_inv x hx
        have h_e_eq : e.toFun (fin4_skip0 (fin4_skip0_inv x hx)) = e.toFun x := by
          rw [h_inv_skip]
        unfold vbExt4_RRRR_e0_forget_to_perm_fn
        change ((e.toFun (fin4_skip0 (fin4_skip0_inv x hx))).val - 1) + 1 =
          (e.toFun x).val
        have h_val : (e.toFun (fin4_skip0 (fin4_skip0_inv x hx))).val =
            (e.toFun x).val := congr_arg Fin.val h_e_eq
        rw [h_val]
        have h_pos : 1 ≤ (e.toFun x).val := by
          by_contra h
          push_neg at h
          have h_zero : (e.toFun x).val = 0 := by omega
          have h_eq : e.toFun x = (⟨0, by omega⟩ : Fin 5) := Fin.ext h_zero
          have h_inj : x = (⟨0, by omega⟩ : Fin 5) :=
            e.injective (h_eq.trans (vbExt4_RRRR_e0_forget_aut_fix0 e).symm)
          have : x.val = 0 := congr_arg Fin.val h_inj
          exact hx this
        omega
    have h_toFun : (vbExt4_RRRR_e0_forget_of_perm
          (vbExt4_RRRR_e0_forget_to_perm e)).toFun = e.toFun :=
      funext h_funext
    rcases e with ⟨f, finj, find, fcompat⟩
    generalize h_lhs_def :
      vbExt4_RRRR_e0_forget_of_perm (vbExt4_RRRR_e0_forget_to_perm
        ⟨f, finj, find, fcompat⟩) = lhs
    rw [h_lhs_def] at h_toFun
    rcases lhs with ⟨f', finj', find', fcompat'⟩
    cases h_toFun
    rfl
  right_inv := by
    intro π
    apply Equiv.ext
    intro c
    change vbExt4_RRRR_e0_forget_to_perm_fn (vbExt4_RRRR_e0_forget_of_perm π) c = π c
    apply Fin.ext
    change (fin4_skip0_inv ((vbExt4_RRRR_e0_forget_of_perm π).toFun (fin4_skip0 c))
          (vbExt4_RRRR_e0_forget_aut_image_ne_zero
            (vbExt4_RRRR_e0_forget_of_perm π) c)).val =
          (π c).val
    have h_apply : (vbExt4_RRRR_e0_forget_of_perm π).toFun (fin4_skip0 c)
        = fin4_skip0 (π c) := vbExt4_RRRR_e0_of_perm_fn_skip π c
    change ((vbExt4_RRRR_e0_forget_of_perm π).toFun (fin4_skip0 c)).val - 1 = (π c).val
    rw [h_apply]
