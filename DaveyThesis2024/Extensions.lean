/-! #### Zero induced count for vbExtBlack → vbExt4_RRRR_e0

`vbExtBlack` has size 2 with vertex 1 black. `vbExt4_RRRR_e0` has only one
black vertex (σ at position 0), but σ-compatibility forces position 0 of
`vbExtBlack` to map there, leaving the black leaf with no valid target. -/

/-- `vbExtBlack` does not embed into `vbExt4_RRRR_e0` (the only black vertex
    of `vbExt4_RRRR_e0` is σ, which is occupied). -/
theorem genInducedCount_vbExtBlack_vbExt4_RRRR_e0_eq_zero :
    genInducedCount CG2 vertexBlackType vbExtBlack vbExt4_RRRR_e0 = 0 := by
  unfold genInducedCount
  rw [Fintype.card_eq_zero_iff]
  refine ⟨fun ⟨f, finj, find, fcompat⟩ => ?_⟩
  -- σ-pinning: f ⟨0⟩ = ⟨0⟩.
  have h_f0 : f (⟨0, by omega⟩ : Fin 2) = (⟨0, by omega⟩ : Fin 5) := by
    have h := fcompat (⟨0, Nat.zero_lt_one⟩ : Fin 1)
    have h_F_emb : vbExtBlack.embedding (⟨0, Nat.zero_lt_one⟩ : Fin 1) =
        (⟨0, by omega⟩ : Fin 2) := rfl
    rw [h_F_emb] at h
    exact h
  -- vbExtBlack.str.2 ⟨1⟩ = 1 (black).
  have h_F_col1 : vbExtBlack.str.2 (⟨1, by omega⟩ : Fin 2) = 1 := rfl
  -- vbExt4_RRRR_e0.str.2 (f ⟨1⟩) = 1.
  have h_G_col1 : vbExt4_RRRR_e0.str.2 (f (⟨1, by omega⟩ : Fin 2)) = 1 := by
    rw [cg2_find_col f find]; exact h_F_col1
  -- f ⟨1⟩ must have val = 0 (only black vertex).
  have h_f1_zero : (f (⟨1, by omega⟩ : Fin 2)).val = 0 := by
    by_contra hne
    rw [vbExt4_RRRR_e0_col_ne_zero hne] at h_G_col1
    exact absurd h_G_col1 (by decide)
  -- f ⟨1⟩ = ⟨0⟩ contradicts injectivity (f ⟨0⟩ = ⟨0⟩).
  have h_eq : f (⟨1, by omega⟩ : Fin 2) = f (⟨0, by omega⟩ : Fin 2) := by
    rw [h_f0]; exact Fin.ext h_f1_zero
  have h_inj := finj h_eq
  have h_val : (1 : ℕ) = 0 := congr_arg Fin.val h_inj
  omega

/-! ### Apply lemma at `⟦vbExt4_RRRR_e0⟧`

For any size-4 σ-flag `A` and size-2 σ-flag `B`, the Finsupp coefficient of
`⟦vbExt4_RRRR_e0⟧` in `genLocalFlagProduct A B` is computed via the
`IsClassOfSize 5` apply lemma. -/

private theorem hsz5 (A B : GenFlag CG2 vertexBlackType)
    (hA : A.size = 4) (hB : B.size = 2) :
    A.size + B.size - vertexBlackType.size = 5 := by
  rw [hA, hB]; rfl

private theorem h_le_5 : vertexBlackType.size ≤ 5 := by decide

/-- `(genLocalFlagProduct A B) ⟦vbExt4_RRRR_e0⟧` for size-4 A and size-2 B. -/
private theorem lfp_apply_at_RRRR_e0
    (A B : GenFlag CG2 vertexBlackType)
    (hA : A.size = 4) (hB : B.size = 2) :
    (genLocalFlagProduct CG2 vertexBlackType A B) (GenFlagClass.mk vbExt4_RRRR_e0) =
      ((genFlagAutCount CG2 vertexBlackType A : ℝ) *
        (genFlagAutCount CG2 vertexBlackType B : ℝ))⁻¹ *
        genJointInducedDensity CG2 vertexBlackType A B vbExt4_RRRR_e0 := by
  have hsz : A.size + B.size - vertexBlackType.size = 5 := hsz5 A B hA hB
  have hn : vertexBlackType.size ≤ A.size + B.size - vertexBlackType.size := by
    rw [hsz]; decide
  have hcls : IsClassOfSize (A.size + B.size - vertexBlackType.size)
      (GenFlagClass.mk vbExt4_RRRR_e0) := by
    rw [hsz]; exact vbExt4_RRRR_e0_isClassOfSize
  rw [genLocalFlagProduct_apply_isClass A B hn (GenFlagClass.mk vbExt4_RRRR_e0) hcls]
  -- Transport the density along iso (Quotient.out (mk RRRR_e0)) ≈ RRRR_e0.
  have hiso : GenFlagIso vertexBlackType
      (Quotient.out (GenFlagClass.mk vbExt4_RRRR_e0)) vbExt4_RRRR_e0 :=
    Quotient.exact (Quotient.out_eq (GenFlagClass.mk vbExt4_RRRR_e0))
  rw [genJointInducedDensity_flagIso_target' hiso]

/-! ### Generic LFP zero lemma at ⟦vbExt4_RRRR_e0⟧ via _right helper

For ANY size-4 σ-flag F, `LFP(F, vbExtBlack)(⟦RRRR_e0⟧) = 0` because
`vbExtBlack` doesn't embed into `vbExt4_RRRR_e0`. -/

/-- `LFP(F, vbExtBlack)(⟦vbExt4_RRRR_e0⟧) = 0` for any size-4 σ-flag F.
    By _right helper applied to `genInducedCount_vbExtBlack_vbExt4_RRRR_e0_eq_zero`. -/
private theorem lfp_F_vbExtBlack_at_RRRR_e0_eq_zero
    (F : GenFlag CG2 vertexBlackType) (hF : F.size = 4) :
    (genLocalFlagProduct CG2 vertexBlackType F vbExtBlack)
      (GenFlagClass.mk vbExt4_RRRR_e0) = 0 := by
  rw [lfp_apply_at_RRRR_e0 F vbExtBlack hF rfl]
  unfold genJointInducedDensity
  have h_jc : genJointCount CG2 vertexBlackType F vbExtBlack vbExt4_RRRR_e0 = 0 :=
    genJointCount_zero_of_genInducedCount_zero_right
      genInducedCount_vbExtBlack_vbExt4_RRRR_e0_eq_zero
  rw [h_jc]
  push_cast; ring

