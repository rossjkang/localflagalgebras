      (u.val = 0 ∧ v.val = 2) ∨ (u.val = 2 ∧ v.val = 0)),
    fun _ : Fin 3 => 1)
  embedding := ⟨fun _ => (⟨0, by omega⟩ : Fin 3),
    fun a b _ => by
      have : a.val < 1 := a.isLt
      have : b.val < 1 := b.isLt
      ext; omega⟩
  isInduced := by
    have h_eq : ((SimpleGraph.fromRel
        (fun u v : Fin 3 =>
          (u.val = 0 ∧ v.val = 1) ∨ (u.val = 1 ∧ v.val = 0) ∨
          (u.val = 0 ∧ v.val = 2) ∨ (u.val = 2 ∧ v.val = 0))).comap
        (fun (_ : Fin 1) => (⟨0, by omega⟩ : Fin 3)),
        (fun _ : Fin 3 => (1 : Fin 2)) ∘
          (fun (_ : Fin 1) => (⟨0, by omega⟩ : Fin 3)))
        = ((⊥ : SimpleGraph (Fin 1)), fun _ : Fin 1 => (1 : Fin 2)) := by
      ext
      · simp [SimpleGraph.comap, SimpleGraph.fromRel]
      · rfl
    exact h_eq
  hsize := by change 1 ≤ 3; omega

@[simp] theorem vbExt2_BB_indep_size : vbExt2_BB_indep.size = 3 := rfl

