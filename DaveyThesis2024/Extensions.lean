/-! ### Conditional v5 size-4 identity

The thesis (Davey, Section 3) v5 sigma-functional argument uses the identity

  `psi.evalAlg ((extSum vertexBlackType ⟨0,_⟩)^3) = psi.evalAlg (single vbExt3_RRR_e0)`

for any sigma-functional `psi` on the regular BRRB class with `Δ → ∞` along the
convergent subsequence. The LHS evaluates to `1` by the iterated multiplicativity
identity `evalAlg_extPow`. The RHS = `1` requires the **algebra-level**
decomposition

  `extPow vertexBlackType ⟨0,_⟩ 3 = single vbExt3_RRR_e0 + (sum of 19 forbidden singletons)`,

which in turn requires a full size-4 enumeration (20 sigma-flag classes,
their pairwise non-isomorphism, and their joint counts). The 19 forbidden
classes vanish under any BRRB sigma-functional via
`evalAlg_single_zero_of_forbidden` together with the 19 `vbExt3_*_isForbidden_brrb`
proofs above.

The conditional theorems below codify the "if the algebra decomposition holds,
then the v5 identity follows" implication. Once the algebra decomposition is
proved, the v5 identity drops out as an immediate corollary. -/

/-- The list of all 19 forbidden size-4 sigma-flag singletons in BRRB.
    Each is the `GenFlagAlg.single` of a `vbExt3_*` class proved forbidden
    in BRRB above (`vbExt3_*_isForbidden_brrb`). -/
noncomputable def vbExt3_forbidden_singletons :
    List (GenFlagAlg CG2 vertexBlackType) :=
  [GenFlagAlg.single vbExt3_BBB_e0,
   GenFlagAlg.single vbExt3_BBB_e1,
   GenFlagAlg.single vbExt3_BBB_e2,
   GenFlagAlg.single vbExt3_BBB_e3,
   GenFlagAlg.single vbExt3_RRB_e0,
   GenFlagAlg.single vbExt3_RRB_e1_RR,
   GenFlagAlg.single vbExt3_RRB_e1_RB,
   GenFlagAlg.single vbExt3_RRB_e2_RRRB,
   GenFlagAlg.single vbExt3_RRB_e2_RBRB,
   GenFlagAlg.single vbExt3_RRB_e3,
   GenFlagAlg.single vbExt3_RBB_e0,
   GenFlagAlg.single vbExt3_RBB_e1_RB,
   GenFlagAlg.single vbExt3_RBB_e1_BB,
   GenFlagAlg.single vbExt3_RBB_e2_RBBB,
   GenFlagAlg.single vbExt3_RBB_e2_RBRB,
   GenFlagAlg.single vbExt3_RBB_e3,
   GenFlagAlg.single vbExt3_RRR_e1,
   GenFlagAlg.single vbExt3_RRR_e2,
   GenFlagAlg.single vbExt3_RRR_e3]

/-- Each forbidden singleton evaluates to `0` under any BRRB sigma-functional.

    Proof: each entry is `GenFlagAlg.single F` for a flag `F` whose BRRB
    `IsForbidden` is established as `vbExt3_*_isForbidden_brrb`; apply
    `evalAlg_single_zero_of_forbidden`. -/
theorem vbExt3_forbidden_singletons_evalAlg_zero
    (psi : GenLimitFunctional CG2 vertexBlackType brrbGenGraphClass brrbGenDelta) :
    ∀ s ∈ vbExt3_forbidden_singletons, psi.evalAlg s = 0 := by
  intro s hs
  simp only [vbExt3_forbidden_singletons, List.mem_cons, List.not_mem_nil, or_false] at hs
  rcases hs with h | h | h | h | h | h | h | h | h | h | h | h | h | h | h | h | h | h | h
  all_goals subst h
  · exact evalAlg_single_zero_of_forbidden vbExt3_BBB_e0_isForbidden_brrb psi
  · exact evalAlg_single_zero_of_forbidden vbExt3_BBB_e1_isForbidden_brrb psi
  · exact evalAlg_single_zero_of_forbidden vbExt3_BBB_e2_isForbidden_brrb psi
  · exact evalAlg_single_zero_of_forbidden vbExt3_BBB_e3_isForbidden_brrb psi
  · exact evalAlg_single_zero_of_forbidden vbExt3_RRB_e0_isForbidden_brrb psi
  · exact evalAlg_single_zero_of_forbidden vbExt3_RRB_e1_RR_isForbidden_brrb psi
  · exact evalAlg_single_zero_of_forbidden vbExt3_RRB_e1_RB_isForbidden_brrb psi
  · exact evalAlg_single_zero_of_forbidden vbExt3_RRB_e2_RRRB_isForbidden_brrb psi
  · exact evalAlg_single_zero_of_forbidden vbExt3_RRB_e2_RBRB_isForbidden_brrb psi
  · exact evalAlg_single_zero_of_forbidden vbExt3_RRB_e3_isForbidden_brrb psi
  · exact evalAlg_single_zero_of_forbidden vbExt3_RBB_e0_isForbidden_brrb psi
  · exact evalAlg_single_zero_of_forbidden vbExt3_RBB_e1_RB_isForbidden_brrb psi
  · exact evalAlg_single_zero_of_forbidden vbExt3_RBB_e1_BB_isForbidden_brrb psi
  · exact evalAlg_single_zero_of_forbidden vbExt3_RBB_e2_RBBB_isForbidden_brrb psi
  · exact evalAlg_single_zero_of_forbidden vbExt3_RBB_e2_RBRB_isForbidden_brrb psi
  · exact evalAlg_single_zero_of_forbidden vbExt3_RBB_e3_isForbidden_brrb psi
  · exact evalAlg_single_zero_of_forbidden vbExt3_RRR_e1_isForbidden_brrb psi
  · exact evalAlg_single_zero_of_forbidden vbExt3_RRR_e2_isForbidden_brrb psi
  · exact evalAlg_single_zero_of_forbidden vbExt3_RRR_e3_isForbidden_brrb psi

/-- The sum of all 19 forbidden singletons evaluates to `0` under any BRRB
    sigma-functional.

    Proof: unfold `vbExt3_forbidden_singletons` to a 19-fold `List.sum`, repeatedly
    apply `List.sum_cons` and `evalAlg_add` to distribute, and conclude by 19
    invocations of `vbExt3_forbidden_singletons_evalAlg_zero` (one per list entry). -/
theorem vbExt3_forbidden_singletons_sum_evalAlg_zero
    (psi : GenLimitFunctional CG2 vertexBlackType brrbGenGraphClass brrbGenDelta) :
    psi.evalAlg vbExt3_forbidden_singletons.sum = 0 := by
  -- Unfold the list and distribute evalAlg over List.sum.
  unfold vbExt3_forbidden_singletons
  simp only [List.sum_cons, List.sum_nil, add_zero,
    GenLimitFunctional.evalAlg_add]
  -- Each entry is now a `psi.evalAlg (single ...)`. Replace each with 0.
  rw [evalAlg_single_zero_of_forbidden vbExt3_BBB_e0_isForbidden_brrb psi,
      evalAlg_single_zero_of_forbidden vbExt3_BBB_e1_isForbidden_brrb psi,
      evalAlg_single_zero_of_forbidden vbExt3_BBB_e2_isForbidden_brrb psi,
      evalAlg_single_zero_of_forbidden vbExt3_BBB_e3_isForbidden_brrb psi,
      evalAlg_single_zero_of_forbidden vbExt3_RRB_e0_isForbidden_brrb psi,
      evalAlg_single_zero_of_forbidden vbExt3_RRB_e1_RR_isForbidden_brrb psi,
      evalAlg_single_zero_of_forbidden vbExt3_RRB_e1_RB_isForbidden_brrb psi,
      evalAlg_single_zero_of_forbidden vbExt3_RRB_e2_RRRB_isForbidden_brrb psi,
      evalAlg_single_zero_of_forbidden vbExt3_RRB_e2_RBRB_isForbidden_brrb psi,
      evalAlg_single_zero_of_forbidden vbExt3_RRB_e3_isForbidden_brrb psi,
      evalAlg_single_zero_of_forbidden vbExt3_RBB_e0_isForbidden_brrb psi,
      evalAlg_single_zero_of_forbidden vbExt3_RBB_e1_RB_isForbidden_brrb psi,
      evalAlg_single_zero_of_forbidden vbExt3_RBB_e1_BB_isForbidden_brrb psi,
      evalAlg_single_zero_of_forbidden vbExt3_RBB_e2_RBBB_isForbidden_brrb psi,
      evalAlg_single_zero_of_forbidden vbExt3_RBB_e2_RBRB_isForbidden_brrb psi,
      evalAlg_single_zero_of_forbidden vbExt3_RBB_e3_isForbidden_brrb psi,
      evalAlg_single_zero_of_forbidden vbExt3_RRR_e1_isForbidden_brrb psi,
      evalAlg_single_zero_of_forbidden vbExt3_RRR_e2_isForbidden_brrb psi,
      evalAlg_single_zero_of_forbidden vbExt3_RRR_e3_isForbidden_brrb psi]
  ring

/-- **Conditional v5 size-4 identity** (algebra version → evaluation version):

    Assuming the algebra-level decomposition

      `extPow vertexBlackType ⟨0,_⟩ 3 = single vbExt3_RRR_e0 +`
      `vbExt3_forbidden_singletons.sum`,

    we conclude `psi.evalAlg (single vbExt3_RRR_e0) = 1` for any BRRB
    sigma-functional `psi` satisfying the standard regularity / locality /
    `Δ → ∞` hypothesis bundle.

    Proof:
    * LHS of the assumed decomposition evaluates to `1` by `evalAlg_extPow` at
      `k = 3`.
    * RHS evaluates to `psi.evalAlg (single vbExt3_RRR_e0) +`
      `psi.evalAlg vbExt3_forbidden_singletons.sum` by `evalAlg_add`.
    * The forbidden-sum factor is `0` by `vbExt3_forbidden_singletons_sum_evalAlg_zero`.
    * Equating gives `psi.evalAlg (single vbExt3_RRR_e0) = 1`. -/
theorem evalAlg_vbExt3_RRR_e0_eq_one_of_decomp
    (psi : GenLimitFunctional CG2 vertexBlackType brrbGenGraphClass brrbGenDelta)
    (h_ext_local : ∀ cls ∈ ((genClassesOfSize CG2 vertexBlackType
      (vertexBlackType.size + 1) (Nat.le_succ _)).filter
      (fun cls => extAdjacencyClass vertexBlackType cls
        (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size))),
      GenIsLocalFlag vertexBlackType cls.out brrbGenGraphClass brrbGenDelta)
    (h_reg : ∀ k, ∀ v : Fin (psi.seq.seq k).size,
      (Finset.univ.filter ((psi.seq.seq k).str.1.Adj v)).card =
        brrbGenDelta (psi.seq.seq k).forget)
    (h_Δ_to_inf : Filter.Tendsto
      (fun k => brrbGenDelta (psi.seq.seq (psi.sub k)).forget)
      Filter.atTop Filter.atTop)
    (hσ_toFlag : GenIsLocalFlag vertexBlackType vertexBlackType.toFlag
      brrbGenGraphClass brrbGenDelta)
    (h_decomp : extPow vertexBlackType (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) 3 =
      GenFlagAlg.single vbExt3_RRR_e0 + vbExt3_forbidden_singletons.sum) :
    psi.evalAlg (GenFlagAlg.single vbExt3_RRR_e0) = 1 := by
  have h_lhs : psi.evalAlg (extPow vertexBlackType
      (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) 3) = 1 :=
    evalAlg_extPow vertexBlackType psi
      (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) hσ_toFlag h_ext_local
      h_reg h_Δ_to_inf 3
  rw [h_decomp] at h_lhs
  rw [GenLimitFunctional.evalAlg_add] at h_lhs
  rw [vbExt3_forbidden_singletons_sum_evalAlg_zero psi, add_zero] at h_lhs
  exact h_lhs

/-! ### Infrastructure for the nonzero size-4 joint count
    `genJointCount(vbExt2_RR_indep, vbExtRed, vbExt3_RRR_e0) = 6`

This section builds the 9 canonical induced embeddings needed to enumerate the
6 valid (e₁, e₂) embedding-pairs witnessing the joint count. Each pair has
`e₁ : vbExt2_RR_indep → vbExt3_RRR_e0` placing two leaves at distinct red
vertices in `{1,2,3}`, and `e₂ : vbExtRed → vbExt3_RRR_e0` placing its leaf at
the third red vertex. The 6 valid pairs are in bijection with
`Equiv.Perm (Fin 3)` (i.e. orderings (a,b,c) of `{1,2,3}`).

Canonical embeddings constructed below:

* For `vbExtRed → vbExt3_RRR_e0`: 3 embeddings sending the red leaf to vertex
  1, 2, or 3.
* For `vbExt2_RR_indep → vbExt3_RRR_e0`: 6 embeddings sending the two red
  leaves to ordered pairs `(a, b)` with `a ≠ b` in `{1, 2, 3}`.

The full enumeration and `Fintype.card = 6` proof remains as future work
(estimated ~1500 LOC). With the canonical embeddings in place, the final
proof is mechanical case-analysis on leaf placement combined with a
permutation bijection. -/

/-- Send `Fin 3` into `Fin 4` via `i ↦ i + 1` (skipping the σ vertex). -/
private def fin3_skip0 : Fin 3 → Fin 4 :=
  fun x => ⟨x.val + 1, by have h : x.val < 3 := x.isLt; omega⟩

@[simp] private theorem fin3_skip0_zero :
    fin3_skip0 (⟨0, by decide⟩ : Fin 3) = (⟨1, by decide⟩ : Fin 4) := rfl

@[simp] private theorem fin3_skip0_one :
    fin3_skip0 (⟨1, by decide⟩ : Fin 3) = (⟨2, by decide⟩ : Fin 4) := rfl

@[simp] private theorem fin3_skip0_two :
    fin3_skip0 (⟨2, by decide⟩ : Fin 3) = (⟨3, by decide⟩ : Fin 4) := rfl

private theorem fin3_skip0_inj : Function.Injective fin3_skip0 := by
  intro a b h
  have hv : a.val + 1 = b.val + 1 := congr_arg Fin.val h
  exact Fin.ext (Nat.add_right_cancel hv)

private theorem fin3_skip0_ne_zero (i : Fin 3) :
    fin3_skip0 i ≠ (⟨0, by decide⟩ : Fin 4) := by
  intro h
  have : (i.val + 1 : ℕ) = 0 := congr_arg Fin.val h
  omega

/-! #### Canonical embeddings vbExtRed → vbExt3_RRR_e0

Three embeddings, one for each choice of red-leaf target ⟨1⟩, ⟨2⟩, ⟨3⟩. -/

/-- Map `Fin 2 → Fin 4` sending ⟨0⟩ to ⟨0⟩ (σ) and ⟨1⟩ to ⟨c+1⟩ for `c : Fin 3`. -/
private def red_leaf_to (c : Fin 3) : Fin 2 → Fin 4 :=
  fun x => if x.val = 0 then (⟨0, by decide⟩ : Fin 4) else fin3_skip0 c

private theorem red_leaf_to_zero (c : Fin 3) :
    red_leaf_to c (⟨0, by decide⟩ : Fin 2) = (⟨0, by decide⟩ : Fin 4) := rfl

private theorem red_leaf_to_one (c : Fin 3) :
    red_leaf_to c (⟨1, by decide⟩ : Fin 2) = fin3_skip0 c := rfl

private theorem red_leaf_to_inj (c : Fin 3) : Function.Injective (red_leaf_to c) := by
  intro a b h
  rcases fin2_eq_zero_or_one a with ha | ha <;> rcases fin2_eq_zero_or_one b with hb | hb
  · exact Fin.ext (ha.trans hb.symm)
  · -- a = 0, b = 1; LHS = ⟨0⟩ but RHS = fin3_skip0 c ≠ ⟨0⟩
    exfalso
    have ha' : a = (⟨0, by decide⟩ : Fin 2) := Fin.ext ha
    have hb' : b = (⟨1, by decide⟩ : Fin 2) := Fin.ext hb
    rw [ha', hb', red_leaf_to_zero, red_leaf_to_one] at h
    exact fin3_skip0_ne_zero c h.symm
  · exfalso
    have ha' : a = (⟨1, by decide⟩ : Fin 2) := Fin.ext ha
    have hb' : b = (⟨0, by decide⟩ : Fin 2) := Fin.ext hb
    rw [ha', hb', red_leaf_to_one, red_leaf_to_zero] at h
    exact fin3_skip0_ne_zero c h
  · exact Fin.ext (ha.trans hb.symm)

/-- The induced-graph + colour structure pulls back correctly for `red_leaf_to c`. -/
private theorem red_leaf_to_str_eq (c : Fin 3) :
    CG2.comap (red_leaf_to c) vbExt3_RRR_e0.str = vbExtRed.str := by
  apply Prod.ext
  · -- Graph equality.
    ext u v
    change vbExt3_RRR_e0.str.1.Adj (red_leaf_to c u) (red_leaf_to c v) ↔
      vbExtRed.str.1.Adj u v
    rcases fin2_eq_zero_or_one u with hu | hu <;>
      rcases fin2_eq_zero_or_one v with hv | hv
    · have hu' : u = (⟨0, by decide⟩ : Fin 2) := Fin.ext hu
      have hv' : v = (⟨0, by decide⟩ : Fin 2) := Fin.ext hv
      rw [hu', hv', red_leaf_to_zero]
      simp [vbExt3_RRR_e0, vbExtRed]
    · have hu' : u = (⟨0, by decide⟩ : Fin 2) := Fin.ext hu
      have hv' : v = (⟨1, by decide⟩ : Fin 2) := Fin.ext hv
      rw [hu', hv', red_leaf_to_zero, red_leaf_to_one]
      -- Want: vbExt3_RRR_e0.adj ⟨0⟩ (fin3_skip0 c) ↔ vbExtRed.adj ⟨0⟩ ⟨1⟩
      -- vbExtRed.adj ⟨0⟩ ⟨1⟩ is true. fin3_skip0 c is one of ⟨1⟩, ⟨2⟩, ⟨3⟩, all
      -- adjacent to ⟨0⟩ in RRR_e0.
      have h_red : vbExtRed.str.1.Adj (⟨0, by decide⟩ : Fin 2) ⟨1, by decide⟩ := by
        simp [vbExtRed, SimpleGraph.fromRel_adj]
      rcases fin3_val_cases c with hc0 | hc1 | hc2
      · have hc' : c = (⟨0, by decide⟩ : Fin 3) := Fin.ext hc0
        rw [hc', fin3_skip0_zero]
        constructor
        · intro _; exact h_red
        · intro _; simp [vbExt3_RRR_e0, SimpleGraph.fromRel_adj]
      · have hc' : c = (⟨1, by decide⟩ : Fin 3) := Fin.ext hc1
        rw [hc', fin3_skip0_one]
        constructor
        · intro _; exact h_red
        · intro _; simp [vbExt3_RRR_e0, SimpleGraph.fromRel_adj]
      · have hc' : c = (⟨2, by decide⟩ : Fin 3) := Fin.ext hc2
        rw [hc', fin3_skip0_two]
        constructor
        · intro _; exact h_red
        · intro _; simp [vbExt3_RRR_e0, SimpleGraph.fromRel_adj]
    · have hu' : u = (⟨1, by decide⟩ : Fin 2) := Fin.ext hu
      have hv' : v = (⟨0, by decide⟩ : Fin 2) := Fin.ext hv
      rw [hu', hv', red_leaf_to_zero, red_leaf_to_one]
      have h_red : vbExtRed.str.1.Adj (⟨1, by decide⟩ : Fin 2) ⟨0, by decide⟩ := by
        simp [vbExtRed, SimpleGraph.fromRel_adj]
      rcases fin3_val_cases c with hc0 | hc1 | hc2
      · have hc' : c = (⟨0, by decide⟩ : Fin 3) := Fin.ext hc0
        rw [hc', fin3_skip0_zero]
        constructor
        · intro _; exact h_red
        · intro _; simp [vbExt3_RRR_e0, SimpleGraph.fromRel_adj]
      · have hc' : c = (⟨1, by decide⟩ : Fin 3) := Fin.ext hc1
        rw [hc', fin3_skip0_one]
        constructor
        · intro _; exact h_red
        · intro _; simp [vbExt3_RRR_e0, SimpleGraph.fromRel_adj]
      · have hc' : c = (⟨2, by decide⟩ : Fin 3) := Fin.ext hc2
        rw [hc', fin3_skip0_two]
        constructor
        · intro _; exact h_red
        · intro _; simp [vbExt3_RRR_e0, SimpleGraph.fromRel_adj]
    · have hu' : u = (⟨1, by decide⟩ : Fin 2) := Fin.ext hu
      have hv' : v = (⟨1, by decide⟩ : Fin 2) := Fin.ext hv
      rw [hu', hv', red_leaf_to_one]
      simp [vbExt3_RRR_e0, vbExtRed]
  · -- Colour equality.
    funext v
    rcases fin2_eq_zero_or_one v with hv | hv
    · have hv' : v = (⟨0, by decide⟩ : Fin 2) := Fin.ext hv
      rw [hv']
      change vbExt3_RRR_e0.str.2 (red_leaf_to c (⟨0, by decide⟩ : Fin 2)) =
        vbExtRed.str.2 (⟨0, by decide⟩ : Fin 2)
      rw [red_leaf_to_zero]; decide
    · have hv' : v = (⟨1, by decide⟩ : Fin 2) := Fin.ext hv
      rw [hv']
      change vbExt3_RRR_e0.str.2 (red_leaf_to c (⟨1, by decide⟩ : Fin 2)) =
        vbExtRed.str.2 (⟨1, by decide⟩ : Fin 2)
      rw [red_leaf_to_one]
      rcases fin3_val_cases c with hc0 | hc1 | hc2
      · have hc' : c = (⟨0, by decide⟩ : Fin 3) := Fin.ext hc0
        rw [hc', fin3_skip0_zero]; decide
      · have hc' : c = (⟨1, by decide⟩ : Fin 3) := Fin.ext hc1
        rw [hc', fin3_skip0_one]; decide
      · have hc' : c = (⟨2, by decide⟩ : Fin 3) := Fin.ext hc2
        rw [hc', fin3_skip0_two]; decide

/-- Canonical embedding `vbExtRed → vbExt3_RRR_e0` placing the red leaf at
    `fin3_skip0 c`, i.e. one of `{⟨1⟩, ⟨2⟩, ⟨3⟩}`. -/
noncomputable def vbExtRed_to_vbExt3_RRR_e0_canon (c : Fin 3) :
    GenInducedEmbedding CG2 vertexBlackType vbExtRed vbExt3_RRR_e0 where
  toFun := red_leaf_to c
  injective := red_leaf_to_inj c
  isInduced := red_leaf_to_str_eq c
  compat := fun i => by
    have hi : i = (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) := by
      obtain ⟨v, hv⟩ := i
      have h_size : vertexBlackType.size = 1 := rfl
      have hv' : v < 1 := h_size ▸ hv
      have : v = 0 := by omega
      ext; exact this
    rw [hi]
    change red_leaf_to c (⟨0, by decide⟩ : Fin 2) = (⟨0, by decide⟩ : Fin 4)
    rw [red_leaf_to_zero]

/-! #### Canonical embeddings vbExt2_RR_indep → vbExt3_RRR_e0

Six embeddings, parameterised by an ordered pair `(a, b)` of distinct vertices
in `Fin 3`. The two red leaves of `vbExt2_RR_indep` (positions ⟨1⟩, ⟨2⟩) map
to `fin3_skip0 a` and `fin3_skip0 b` respectively, and the σ-vertex maps to
⟨0⟩. -/

/-- Map `Fin 3 → Fin 4` sending ⟨0⟩ → ⟨0⟩ (σ), ⟨1⟩ → fin3_skip0 a,
    ⟨2⟩ → fin3_skip0 b. -/
private def rr_indep_to (a b : Fin 3) : Fin 3 → Fin 4 :=
  fun x => if x.val = 0 then (⟨0, by decide⟩ : Fin 4)
           else if x.val = 1 then fin3_skip0 a
           else fin3_skip0 b

private theorem rr_indep_to_zero (a b : Fin 3) :
    rr_indep_to a b (⟨0, by decide⟩ : Fin 3) = (⟨0, by decide⟩ : Fin 4) := rfl

private theorem rr_indep_to_one (a b : Fin 3) :
    rr_indep_to a b (⟨1, by decide⟩ : Fin 3) = fin3_skip0 a := rfl

private theorem rr_indep_to_two (a b : Fin 3) :
    rr_indep_to a b (⟨2, by decide⟩ : Fin 3) = fin3_skip0 b := rfl

private theorem rr_indep_to_inj (a b : Fin 3) (hab : a ≠ b) :
    Function.Injective (rr_indep_to a b) := by
  intro x y h
  rcases fin3_val_cases x with hx | hx | hx <;> rcases fin3_val_cases y with hy | hy | hy
  all_goals first
    | exact Fin.ext (hx.trans hy.symm)
    | (exfalso
       have hx' : x = (⟨0, by decide⟩ : Fin 3) := Fin.ext hx
       have hy' : y = (⟨1, by decide⟩ : Fin 3) := Fin.ext hy
       rw [hx', hy', rr_indep_to_zero, rr_indep_to_one] at h
       exact fin3_skip0_ne_zero a h.symm)
    | (exfalso
       have hx' : x = (⟨0, by decide⟩ : Fin 3) := Fin.ext hx
       have hy' : y = (⟨2, by decide⟩ : Fin 3) := Fin.ext hy
       rw [hx', hy', rr_indep_to_zero, rr_indep_to_two] at h
       exact fin3_skip0_ne_zero b h.symm)
    | (exfalso
       have hx' : x = (⟨1, by decide⟩ : Fin 3) := Fin.ext hx
       have hy' : y = (⟨0, by decide⟩ : Fin 3) := Fin.ext hy
       rw [hx', hy', rr_indep_to_one, rr_indep_to_zero] at h
       exact fin3_skip0_ne_zero a h)
    | (exfalso
       have hx' : x = (⟨2, by decide⟩ : Fin 3) := Fin.ext hx
       have hy' : y = (⟨0, by decide⟩ : Fin 3) := Fin.ext hy
       rw [hx', hy', rr_indep_to_two, rr_indep_to_zero] at h
       exact fin3_skip0_ne_zero b h)
    | (exfalso
       have hx' : x = (⟨1, by decide⟩ : Fin 3) := Fin.ext hx
       have hy' : y = (⟨2, by decide⟩ : Fin 3) := Fin.ext hy
       rw [hx', hy', rr_indep_to_one, rr_indep_to_two] at h
       exact hab (fin3_skip0_inj h))
    | (exfalso
       have hx' : x = (⟨2, by decide⟩ : Fin 3) := Fin.ext hx
       have hy' : y = (⟨1, by decide⟩ : Fin 3) := Fin.ext hy
       rw [hx', hy', rr_indep_to_two, rr_indep_to_one] at h
       exact hab.symm (fin3_skip0_inj h))

/-- vbExt3_RRR_e0 has the (0, fin3_skip0 c) edge for any c. -/
private theorem vbExt3_RRR_e0_adj_0_skip (c : Fin 3) :
    vbExt3_RRR_e0.str.1.Adj (⟨0, by decide⟩ : Fin 4) (fin3_skip0 c) := by
  rcases fin3_val_cases c with hc0 | hc1 | hc2
  · have : c = (⟨0, by decide⟩ : Fin 3) := Fin.ext hc0
    rw [this, fin3_skip0_zero]; simp [vbExt3_RRR_e0, SimpleGraph.fromRel_adj]
  · have : c = (⟨1, by decide⟩ : Fin 3) := Fin.ext hc1
    rw [this, fin3_skip0_one]; simp [vbExt3_RRR_e0, SimpleGraph.fromRel_adj]
  · have : c = (⟨2, by decide⟩ : Fin 3) := Fin.ext hc2
    rw [this, fin3_skip0_two]; simp [vbExt3_RRR_e0, SimpleGraph.fromRel_adj]

/-- vbExt3_RRR_e0 has NO leaf-leaf edges: between two distinct skip0 vertices, no edge. -/
private theorem vbExt3_RRR_e0_not_adj_skip_skip (a b : Fin 3) :
    ¬ vbExt3_RRR_e0.str.1.Adj (fin3_skip0 a) (fin3_skip0 b) := by
  rcases fin3_val_cases a with ha | ha | ha <;> rcases fin3_val_cases b with hb | hb | hb
  all_goals first
    | (have ha' : a = (⟨0, by decide⟩ : Fin 3) := Fin.ext ha
       have hb' : b = (⟨0, by decide⟩ : Fin 3) := Fin.ext hb
       rw [ha', hb', fin3_skip0_zero]
       simp [vbExt3_RRR_e0])
    | (have ha' : a = (⟨0, by decide⟩ : Fin 3) := Fin.ext ha
       have hb' : b = (⟨1, by decide⟩ : Fin 3) := Fin.ext hb
       rw [ha', hb', fin3_skip0_zero, fin3_skip0_one]
       simp [vbExt3_RRR_e0, SimpleGraph.fromRel_adj])
    | (have ha' : a = (⟨0, by decide⟩ : Fin 3) := Fin.ext ha
       have hb' : b = (⟨2, by decide⟩ : Fin 3) := Fin.ext hb
       rw [ha', hb', fin3_skip0_zero, fin3_skip0_two]
       simp [vbExt3_RRR_e0, SimpleGraph.fromRel_adj])
    | (have ha' : a = (⟨1, by decide⟩ : Fin 3) := Fin.ext ha
       have hb' : b = (⟨0, by decide⟩ : Fin 3) := Fin.ext hb
       rw [ha', hb', fin3_skip0_one, fin3_skip0_zero]
       simp [vbExt3_RRR_e0, SimpleGraph.fromRel_adj])
    | (have ha' : a = (⟨1, by decide⟩ : Fin 3) := Fin.ext ha
       have hb' : b = (⟨1, by decide⟩ : Fin 3) := Fin.ext hb
       rw [ha', hb', fin3_skip0_one]
       simp [vbExt3_RRR_e0])
    | (have ha' : a = (⟨1, by decide⟩ : Fin 3) := Fin.ext ha
       have hb' : b = (⟨2, by decide⟩ : Fin 3) := Fin.ext hb
       rw [ha', hb', fin3_skip0_one, fin3_skip0_two]
       simp [vbExt3_RRR_e0, SimpleGraph.fromRel_adj])
    | (have ha' : a = (⟨2, by decide⟩ : Fin 3) := Fin.ext ha
       have hb' : b = (⟨0, by decide⟩ : Fin 3) := Fin.ext hb
       rw [ha', hb', fin3_skip0_two, fin3_skip0_zero]
       simp [vbExt3_RRR_e0, SimpleGraph.fromRel_adj])
    | (have ha' : a = (⟨2, by decide⟩ : Fin 3) := Fin.ext ha
       have hb' : b = (⟨1, by decide⟩ : Fin 3) := Fin.ext hb
       rw [ha', hb', fin3_skip0_two, fin3_skip0_one]
       simp [vbExt3_RRR_e0, SimpleGraph.fromRel_adj])
    | (have ha' : a = (⟨2, by decide⟩ : Fin 3) := Fin.ext ha
       have hb' : b = (⟨2, by decide⟩ : Fin 3) := Fin.ext hb
       rw [ha', hb', fin3_skip0_two]
       simp [vbExt3_RRR_e0])

/-- vbExt3_RRR_e0 colour at fin3_skip0 c is 0 (red), since fin3_skip0 c.val ≥ 1. -/
private theorem vbExt3_RRR_e0_col_skip (c : Fin 3) :
    vbExt3_RRR_e0.str.2 (fin3_skip0 c) = 0 := by
  rcases fin3_val_cases c with hc0 | hc1 | hc2
  · have : c = (⟨0, by decide⟩ : Fin 3) := Fin.ext hc0
    rw [this, fin3_skip0_zero]; rfl
  · have : c = (⟨1, by decide⟩ : Fin 3) := Fin.ext hc1
    rw [this, fin3_skip0_one]; rfl
  · have : c = (⟨2, by decide⟩ : Fin 3) := Fin.ext hc2
    rw [this, fin3_skip0_two]; rfl

/-- The induced-graph + colour structure pulls back correctly for `rr_indep_to a b`
    when `a ≠ b`. -/
private theorem rr_indep_to_str_eq (a b : Fin 3) (_hab : a ≠ b) :
    CG2.comap (rr_indep_to a b) vbExt3_RRR_e0.str = vbExt2_RR_indep.str := by
  apply Prod.ext
  · -- Graph: vbExt2_RR_indep has edges {0,1}, {0,2} (no {1,2}).
    ext u v
    change vbExt3_RRR_e0.str.1.Adj (rr_indep_to a b u) (rr_indep_to a b v) ↔
      vbExt2_RR_indep.str.1.Adj u v
    rcases fin3_val_cases u with hu | hu | hu <;> rcases fin3_val_cases v with hv | hv | hv
    all_goals first
      | (have hu' : u = (⟨0, by decide⟩ : Fin 3) := Fin.ext hu
         have hv' : v = (⟨0, by decide⟩ : Fin 3) := Fin.ext hv
         rw [hu', hv', rr_indep_to_zero]
         simp [vbExt3_RRR_e0, vbExt2_RR_indep])
      | (have hu' : u = (⟨0, by decide⟩ : Fin 3) := Fin.ext hu
         have hv' : v = (⟨1, by decide⟩ : Fin 3) := Fin.ext hv
         rw [hu', hv', rr_indep_to_zero, rr_indep_to_one]
         constructor
         · intro _; simp [vbExt2_RR_indep, SimpleGraph.fromRel_adj]
         · intro _; exact vbExt3_RRR_e0_adj_0_skip a)
      | (have hu' : u = (⟨0, by decide⟩ : Fin 3) := Fin.ext hu
         have hv' : v = (⟨2, by decide⟩ : Fin 3) := Fin.ext hv
         rw [hu', hv', rr_indep_to_zero, rr_indep_to_two]
         constructor
         · intro _; simp [vbExt2_RR_indep, SimpleGraph.fromRel_adj]
         · intro _; exact vbExt3_RRR_e0_adj_0_skip b)
      | (have hu' : u = (⟨1, by decide⟩ : Fin 3) := Fin.ext hu
         have hv' : v = (⟨0, by decide⟩ : Fin 3) := Fin.ext hv
         rw [hu', hv', rr_indep_to_one, rr_indep_to_zero]
         constructor
         · intro _; simp [vbExt2_RR_indep, SimpleGraph.fromRel_adj]
         · intro _; exact (vbExt3_RRR_e0_adj_0_skip a).symm)
      | (have hu' : u = (⟨2, by decide⟩ : Fin 3) := Fin.ext hu
         have hv' : v = (⟨0, by decide⟩ : Fin 3) := Fin.ext hv
         rw [hu', hv', rr_indep_to_two, rr_indep_to_zero]
         constructor
         · intro _; simp [vbExt2_RR_indep, SimpleGraph.fromRel_adj]
         · intro _; exact (vbExt3_RRR_e0_adj_0_skip b).symm)
      | (have hu' : u = (⟨1, by decide⟩ : Fin 3) := Fin.ext hu
         have hv' : v = (⟨1, by decide⟩ : Fin 3) := Fin.ext hv
         rw [hu', hv', rr_indep_to_one]
         simp [vbExt3_RRR_e0, vbExt2_RR_indep])
      | (have hu' : u = (⟨1, by decide⟩ : Fin 3) := Fin.ext hu
         have hv' : v = (⟨2, by decide⟩ : Fin 3) := Fin.ext hv
         rw [hu', hv', rr_indep_to_one, rr_indep_to_two]
         constructor
         · intro h
           exact absurd h (vbExt3_RRR_e0_not_adj_skip_skip a b)
         · intro h
           exfalso
           simp [vbExt2_RR_indep, SimpleGraph.fromRel_adj] at h)
      | (have hu' : u = (⟨2, by decide⟩ : Fin 3) := Fin.ext hu
         have hv' : v = (⟨1, by decide⟩ : Fin 3) := Fin.ext hv
         rw [hu', hv', rr_indep_to_two, rr_indep_to_one]
         constructor
         · intro h
           exact absurd h (vbExt3_RRR_e0_not_adj_skip_skip b a)
         · intro h
           exfalso
           simp [vbExt2_RR_indep, SimpleGraph.fromRel_adj] at h)
      | (have hu' : u = (⟨2, by decide⟩ : Fin 3) := Fin.ext hu
         have hv' : v = (⟨2, by decide⟩ : Fin 3) := Fin.ext hv
         rw [hu', hv', rr_indep_to_two]
         simp [vbExt3_RRR_e0, vbExt2_RR_indep])
  · -- Colour.
    funext v
    rcases fin3_val_cases v with hv | hv | hv
    · have hv' : v = (⟨0, by decide⟩ : Fin 3) := Fin.ext hv
      rw [hv']
      change vbExt3_RRR_e0.str.2 (rr_indep_to a b (⟨0, by decide⟩ : Fin 3)) =
        vbExt2_RR_indep.str.2 (⟨0, by decide⟩ : Fin 3)
      rw [rr_indep_to_zero]; decide
    · have hv' : v = (⟨1, by decide⟩ : Fin 3) := Fin.ext hv
      rw [hv']
      change vbExt3_RRR_e0.str.2 (rr_indep_to a b (⟨1, by decide⟩ : Fin 3)) =
        vbExt2_RR_indep.str.2 (⟨1, by decide⟩ : Fin 3)
      rw [rr_indep_to_one, vbExt3_RRR_e0_col_skip]; rfl
    · have hv' : v = (⟨2, by decide⟩ : Fin 3) := Fin.ext hv
      rw [hv']
      change vbExt3_RRR_e0.str.2 (rr_indep_to a b (⟨2, by decide⟩ : Fin 3)) =
        vbExt2_RR_indep.str.2 (⟨2, by decide⟩ : Fin 3)
      rw [rr_indep_to_two, vbExt3_RRR_e0_col_skip]; rfl

/-- Canonical embedding `vbExt2_RR_indep → vbExt3_RRR_e0` with leaf₁ at `fin3_skip0 a`,
    leaf₂ at `fin3_skip0 b`, for distinct `a, b : Fin 3`. -/
noncomputable def vbExt2_RR_indep_to_vbExt3_RRR_e0_canon
    (a b : Fin 3) (hab : a ≠ b) :
    GenInducedEmbedding CG2 vertexBlackType vbExt2_RR_indep vbExt3_RRR_e0 where
  toFun := rr_indep_to a b
  injective := rr_indep_to_inj a b hab
  isInduced := rr_indep_to_str_eq a b hab
  compat := fun i => by
    have hi : i = (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) := by
      obtain ⟨v, hv⟩ := i
      have h_size : vertexBlackType.size = 1 := rfl
      have hv' : v < 1 := h_size ▸ hv
      have : v = 0 := by omega
      ext; exact this
    rw [hi]
    change rr_indep_to a b (⟨0, by decide⟩ : Fin 3) = (⟨0, by decide⟩ : Fin 4)
    rw [rr_indep_to_zero]

/-! #### Leaf-placement lemmas

Each `e₂ : vbExtRed → vbExt3_RRR_e0` sends its red leaf to one of `{1, 2, 3}`.
Each `e₁ : vbExt2_RR_indep → vbExt3_RRR_e0` sends its two red leaves to two
distinct elements of `{1, 2, 3}`. -/

/-- For any `e : vbExtRed → vbExt3_RRR_e0`, the leaf goes to ⟨1⟩, ⟨2⟩, or ⟨3⟩. -/
private lemma vbExtRed_to_vbExt3_RRR_e0_leaf_cases
    (e : GenInducedEmbedding CG2 vertexBlackType vbExtRed vbExt3_RRR_e0) :
    e.toFun (⟨1, by decide⟩ : Fin 2) = (⟨1, by decide⟩ : Fin 4) ∨
    e.toFun (⟨1, by decide⟩ : Fin 2) = (⟨2, by decide⟩ : Fin 4) ∨
    e.toFun (⟨1, by decide⟩ : Fin 2) = (⟨3, by decide⟩ : Fin 4) := by
  obtain ⟨f, finj, find, fcompat⟩ := e
  have h_phi_0 : f (⟨0, by decide⟩ : Fin 2) = (⟨0, by decide⟩ : Fin 4) :=
    fcompat (⟨0, Nat.zero_lt_one⟩ : Fin 1)
  -- Leaf colour is 0 (red).
  have h_F_col1 : vbExtRed.str.2 (⟨1, by decide⟩ : Fin 2) = 0 := rfl
  have h_G_col1 : vbExt3_RRR_e0.str.2 (f (⟨1, by decide⟩ : Fin 2)) = 0 := by
    rw [cg2_find_col f find]; exact h_F_col1
  change f (⟨1, by decide⟩ : Fin 2) = (⟨1, by decide⟩ : Fin 4) ∨
       f (⟨1, by decide⟩ : Fin 2) = (⟨2, by decide⟩ : Fin 4) ∨
       f (⟨1, by decide⟩ : Fin 2) = (⟨3, by decide⟩ : Fin 4)
  rcases fin4_val_cases (f (⟨1, by decide⟩ : Fin 2)) with h0 | h1 | h2 | h3
  · exfalso
    have h_eq : f (⟨1, by decide⟩ : Fin 2) = (⟨0, by decide⟩ : Fin 4) := Fin.ext h0
    have : (⟨1, by decide⟩ : Fin 2) = (⟨0, by decide⟩ : Fin 2) :=
      finj (h_eq.trans h_phi_0.symm)
    have : (1 : ℕ) = 0 := congr_arg Fin.val this
    omega
  · left; exact Fin.ext h1
  · right; left; exact Fin.ext h2
  · right; right; exact Fin.ext h3

/-- For `e : vbExt2_RR_indep → vbExt3_RRR_e0`, leaf₁ ⟨1⟩ and leaf₂ ⟨2⟩ both go
    to one of `{⟨1⟩, ⟨2⟩, ⟨3⟩}` in `Fin 4`. -/
private lemma vbExt2_RR_indep_to_vbExt3_RRR_e0_leaf_cases
    (e : GenInducedEmbedding CG2 vertexBlackType vbExt2_RR_indep vbExt3_RRR_e0)
    (i : Fin 3) (hi : i.val ≠ 0) :
    e.toFun i = (⟨1, by decide⟩ : Fin 4) ∨
    e.toFun i = (⟨2, by decide⟩ : Fin 4) ∨
    e.toFun i = (⟨3, by decide⟩ : Fin 4) := by
  obtain ⟨f, finj, find, fcompat⟩ := e
  have h_phi_0 : f (⟨0, by decide⟩ : Fin 3) = (⟨0, by decide⟩ : Fin 4) :=
    fcompat (⟨0, Nat.zero_lt_one⟩ : Fin 1)
  -- Leaf colour: vbExt2_RR_indep at i ≠ 0 is 0 (red).
  have h_F_coli : vbExt2_RR_indep.str.2 i = 0 := by
    change (if i.val = 0 then (1 : Fin 2) else 0) = 0
    rw [if_neg hi]
  have h_G_coli : vbExt3_RRR_e0.str.2 (f i) = 0 := by
    rw [cg2_find_col f find]; exact h_F_coli
  change f i = (⟨1, by decide⟩ : Fin 4) ∨
       f i = (⟨2, by decide⟩ : Fin 4) ∨
       f i = (⟨3, by decide⟩ : Fin 4)
  rcases fin4_val_cases (f i) with h0 | h1 | h2 | h3
  · exfalso
    have h_eq : f i = (⟨0, by decide⟩ : Fin 4) := Fin.ext h0
    have : i = (⟨0, by decide⟩ : Fin 3) :=
      finj (h_eq.trans h_phi_0.symm)
    have : i.val = 0 := congr_arg Fin.val this
    exact hi this
  · left; exact Fin.ext h1
  · right; left; exact Fin.ext h2
  · right; right; exact Fin.ext h3

/-! #### Embedding equality lemmas

If two `vbExtRed → vbExt3_RRR_e0` embeddings agree on the leaf, they are equal.
If two `vbExt2_RR_indep → vbExt3_RRR_e0` embeddings agree on both leaves, they
are equal. -/

/-- Two `vbExtRed → vbExt3_RRR_e0` embeddings agreeing on the leaf are equal. -/
private theorem vbExtRed_to_vbExt3_RRR_e0_ext
    (e₁ e₂ : GenInducedEmbedding CG2 vertexBlackType vbExtRed vbExt3_RRR_e0)
    (h_leaf : e₁.toFun (⟨1, by decide⟩ : Fin 2) = e₂.toFun (⟨1, by decide⟩ : Fin 2)) :
    e₁ = e₂ := by
  obtain ⟨f₁, finj₁, find₁, fcompat₁⟩ := e₁
  obtain ⟨f₂, finj₂, find₂, fcompat₂⟩ := e₂
  congr 1
  funext x
  rcases fin2_eq_zero_or_one x with hx | hx
  · have hx' : x = (⟨0, by decide⟩ : Fin 2) := Fin.ext hx
    rw [hx']
    have h1 : f₁ (⟨0, by decide⟩ : Fin 2) = (⟨0, by decide⟩ : Fin 4) :=
      fcompat₁ (⟨0, Nat.zero_lt_one⟩ : Fin 1)
    have h2 : f₂ (⟨0, by decide⟩ : Fin 2) = (⟨0, by decide⟩ : Fin 4) :=
      fcompat₂ (⟨0, Nat.zero_lt_one⟩ : Fin 1)
    rw [h1, h2]
  · have hx' : x = (⟨1, by decide⟩ : Fin 2) := Fin.ext hx
    rw [hx']
    exact h_leaf

/-- Two `vbExt2_RR_indep → vbExt3_RRR_e0` embeddings agreeing on the leaves
    ⟨1⟩, ⟨2⟩ are equal. -/
private theorem vbExt2_RR_indep_to_vbExt3_RRR_e0_ext
    (e₁ e₂ : GenInducedEmbedding CG2 vertexBlackType vbExt2_RR_indep vbExt3_RRR_e0)
    (h_leaf1 : e₁.toFun (⟨1, by decide⟩ : Fin 3) = e₂.toFun (⟨1, by decide⟩ : Fin 3))
    (h_leaf2 : e₁.toFun (⟨2, by decide⟩ : Fin 3) = e₂.toFun (⟨2, by decide⟩ : Fin 3)) :
    e₁ = e₂ := by
  obtain ⟨f₁, finj₁, find₁, fcompat₁⟩ := e₁
  obtain ⟨f₂, finj₂, find₂, fcompat₂⟩ := e₂
  congr 1
  funext x
  rcases fin3_val_cases x with hx | hx | hx
  · have hx' : x = (⟨0, by decide⟩ : Fin 3) := Fin.ext hx
    rw [hx']
    have h1 : f₁ (⟨0, by decide⟩ : Fin 3) = (⟨0, by decide⟩ : Fin 4) :=
      fcompat₁ (⟨0, Nat.zero_lt_one⟩ : Fin 1)
    have h2 : f₂ (⟨0, by decide⟩ : Fin 3) = (⟨0, by decide⟩ : Fin 4) :=
      fcompat₂ (⟨0, Nat.zero_lt_one⟩ : Fin 1)
    rw [h1, h2]
  · have hx' : x = (⟨1, by decide⟩ : Fin 3) := Fin.ext hx
    rw [hx']; exact h_leaf1
  · have hx' : x = (⟨2, by decide⟩ : Fin 3) := Fin.ext hx
    rw [hx']; exact h_leaf2

/-! #### The nonzero joint count theorem

The proof builds an `Equiv` between the joint-pair set and
`{(a, b) : Fin 3 × Fin 3 // a ≠ b}`, then uses `Fintype.card_congr` plus
`decide` to conclude cardinality 6. -/

/-- Recover the unique `Fin 3` value `a` such that `fin3_skip0 a = v` for `v ≠ ⟨0⟩`. -/
private def fin3_skip0_inv (v : Fin 4) (_hv : v.val ≠ 0) : Fin 3 :=
  ⟨v.val - 1, by have h : v.val < 4 := v.isLt; omega⟩

private theorem fin3_skip0_inv_apply (c : Fin 3) :
    fin3_skip0_inv (fin3_skip0 c) (by simp [fin3_skip0]) = c := by
  apply Fin.ext
  change (c.val + 1) - 1 = c.val
  omega

private theorem fin3_skip0_apply_inv (v : Fin 4) (hv : v.val ≠ 0) :
    fin3_skip0 (fin3_skip0_inv v hv) = v := by
  apply Fin.ext
  change (v.val - 1) + 1 = v.val
  have hpos : 0 < v.val := Nat.pos_of_ne_zero hv
  omega

/-- The "third element" function: for `a ≠ b` in `Fin 3`, returns the unique
    `c : Fin 3` with `c ≠ a ∧ c ≠ b`. For `a = b`, returns junk (clamped). -/
private def fin3_third (a b : Fin 3) : Fin 3 :=
  ⟨if 1 ≤ a.val + b.val then 3 - a.val - b.val else 1, by
    have ha : a.val < 3 := a.isLt
    have hb : b.val < 3 := b.isLt
    by_cases h : 1 ≤ a.val + b.val <;> simp [h] <;> omega⟩

private theorem fin3_third_ne_left (a b : Fin 3) (hab : a ≠ b) :
    fin3_third a b ≠ a := by
  intro h
  have hv : (fin3_third a b).val = a.val := congr_arg Fin.val h
  have ha : a.val < 3 := a.isLt
  have hb : b.val < 3 := b.isLt
  have hab_val : a.val ≠ b.val := fun he => hab (Fin.ext he)
  unfold fin3_third at hv
  simp only at hv
  by_cases hsum : 1 ≤ a.val + b.val
  · simp [hsum] at hv
    omega
  · simp [hsum] at hv
    omega

private theorem fin3_third_ne_right (a b : Fin 3) (hab : a ≠ b) :
    fin3_third a b ≠ b := by
  intro h
  have hv : (fin3_third a b).val = b.val := congr_arg Fin.val h
  have ha : a.val < 3 := a.isLt
  have hb : b.val < 3 := b.isLt
  have hab_val : a.val ≠ b.val := fun he => hab (Fin.ext he)
  unfold fin3_third at hv
  simp only at hv
  by_cases hsum : 1 ≤ a.val + b.val
  · simp [hsum] at hv
    omega
  · simp [hsum] at hv
    omega

/-- For any `c : Fin 3` distinct from both `a` and `b` (with `a ≠ b`),
    `c = fin3_third a b`. -/
private theorem fin3_third_unique (a b c : Fin 3) (hab : a ≠ b) (hca : c ≠ a) (hcb : c ≠ b) :
    c = fin3_third a b := by
  apply Fin.ext
  have hav : a.val < 3 := a.isLt
  have hbv : b.val < 3 := b.isLt
  have hcv : c.val < 3 := c.isLt
  have hab_val : a.val ≠ b.val := fun he => hab (Fin.ext he)
  have hca_val : c.val ≠ a.val := fun he => hca (Fin.ext he)
  have hcb_val : c.val ≠ b.val := fun he => hcb (Fin.ext he)
  change c.val = (fin3_third a b).val
  unfold fin3_third
  simp only
  by_cases hsum : 1 ≤ a.val + b.val
  · simp [hsum]
    omega
  · simp [hsum]
    omega

/-- The three values fin3_skip0 0, fin3_skip0 1, fin3_skip0 2 are exactly
    {⟨1⟩, ⟨2⟩, ⟨3⟩} in `Fin 4`. -/
private theorem fin3_skip0_image_eq (v : Fin 4) (hv : v.val ≠ 0) :
    ∃ c : Fin 3, fin3_skip0 c = v := by
  exact ⟨fin3_skip0_inv v hv, fin3_skip0_apply_inv v hv⟩

/-- For a joint pair `(e₁, e₂)`, `e₁` sends ⟨1⟩ and ⟨2⟩ to distinct red leaves. -/
private theorem rr_joint_e1_distinct
    (e₁ : GenInducedEmbedding CG2 vertexBlackType vbExt2_RR_indep vbExt3_RRR_e0) :
    e₁.toFun (⟨1, by decide⟩ : Fin 3) ≠ e₁.toFun (⟨2, by decide⟩ : Fin 3) := by
  intro h
  have h12 : (⟨1, by decide⟩ : Fin 3) = (⟨2, by decide⟩ : Fin 3) := e₁.injective h
  have : (1 : ℕ) = 2 := congr_arg Fin.val h12
  omega

/-- The forward map: extract `(a, b)` such that `e₁ ⟨1⟩ = fin3_skip0 a`,
    `e₁ ⟨2⟩ = fin3_skip0 b`. -/
private noncomputable def joint_to_pair_fwd
    (p : { p : GenInducedEmbedding CG2 vertexBlackType vbExt2_RR_indep vbExt3_RRR_e0 ×
              GenInducedEmbedding CG2 vertexBlackType vbExtRed vbExt3_RRR_e0 //
            (∀ i : Fin vbExt3_RRR_e0.size,
              (i ∈ Set.range p.1.toFun ∧ i ∈ Set.range p.2.toFun) ↔
                i ∈ Set.range vbExt3_RRR_e0.embedding) ∧
            (∀ i : Fin vbExt3_RRR_e0.size,
              i ∈ Set.range p.1.toFun ∨ i ∈ Set.range p.2.toFun) }) :
    { ab : Fin 3 × Fin 3 // ab.1 ≠ ab.2 } :=
  let e₁ := p.val.1
  let v1 := e₁.toFun (⟨1, by decide⟩ : Fin 3)
  let v2 := e₁.toFun (⟨2, by decide⟩ : Fin 3)
  have hv1 : v1.val ≠ 0 := by
    rcases vbExt2_RR_indep_to_vbExt3_RRR_e0_leaf_cases e₁ (⟨1, by decide⟩ : Fin 3)
        (by decide) with h | h | h <;> rw [show v1 = e₁.toFun (⟨1, by decide⟩ : Fin 3) from rfl, h] <;> decide
  have hv2 : v2.val ≠ 0 := by
    rcases vbExt2_RR_indep_to_vbExt3_RRR_e0_leaf_cases e₁ (⟨2, by decide⟩ : Fin 3)
        (by decide) with h | h | h <;> rw [show v2 = e₁.toFun (⟨2, by decide⟩ : Fin 3) from rfl, h] <;> decide
  have hab : fin3_skip0_inv v1 hv1 ≠ fin3_skip0_inv v2 hv2 := by
    intro h
    have h1 : fin3_skip0 (fin3_skip0_inv v1 hv1) = v1 := fin3_skip0_apply_inv v1 hv1
    have h2 : fin3_skip0 (fin3_skip0_inv v2 hv2) = v2 := fin3_skip0_apply_inv v2 hv2
    rw [h] at h1
    have : v1 = v2 := h1.symm.trans h2
    exact rr_joint_e1_distinct e₁ this
  ⟨(fin3_skip0_inv v1 hv1, fin3_skip0_inv v2 hv2), hab⟩

/-- For a joint pair `(e₁, e₂)`, `e₂.toFun ⟨1⟩` is the third red leaf vertex,
    distinct from `e₁.toFun ⟨1⟩` and `e₁.toFun ⟨2⟩`. -/
private theorem rr_joint_e2_third
    (p : { p : GenInducedEmbedding CG2 vertexBlackType vbExt2_RR_indep vbExt3_RRR_e0 ×
              GenInducedEmbedding CG2 vertexBlackType vbExtRed vbExt3_RRR_e0 //
            (∀ i : Fin vbExt3_RRR_e0.size,
              (i ∈ Set.range p.1.toFun ∧ i ∈ Set.range p.2.toFun) ↔
                i ∈ Set.range vbExt3_RRR_e0.embedding) ∧
            (∀ i : Fin vbExt3_RRR_e0.size,
              i ∈ Set.range p.1.toFun ∨ i ∈ Set.range p.2.toFun) }) :
    p.val.2.toFun (⟨1, by decide⟩ : Fin 2) ≠ p.val.1.toFun (⟨1, by decide⟩ : Fin 3) ∧
    p.val.2.toFun (⟨1, by decide⟩ : Fin 2) ≠ p.val.1.toFun (⟨2, by decide⟩ : Fin 3) := by
  obtain ⟨⟨e₁, e₂⟩, hover, _hcover⟩ := p
  -- Overlap implies e₂'s leaf-image is not in e₁'s range (other than σ-image).
  have h_e2_zero : e₂.toFun (⟨0, by decide⟩ : Fin 2) = (⟨0, by decide⟩ : Fin 4) := by
    rw [vbExtRed_emb_zero e₂]; rfl
  have h_e1_zero : e₁.toFun (⟨0, by decide⟩ : Fin 3) = (⟨0, by decide⟩ : Fin 4) := by
    have h := e₁.compat (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size)
    -- h : e₁.toFun (vbExt2_RR_indep.embedding _) = vbExt3_RRR_e0.embedding _
    -- vbExt2_RR_indep.embedding _ = ⟨0, _⟩ definitionally; same for vbExt3_RRR_e0.
    exact h
  -- e₂ leaf at ⟨1⟩ is some red vertex.
  have h_e2_leaf := vbExtRed_to_vbExt3_RRR_e0_leaf_cases e₂
  -- e₂.toFun ⟨1⟩ ∈ {⟨1⟩, ⟨2⟩, ⟨3⟩} ⊂ Fin 4.
  -- Want: e₂.toFun ⟨1⟩ ≠ e₁.toFun ⟨1⟩ and ≠ e₁.toFun ⟨2⟩.
  -- Both directions follow from overlap: if e₂.toFun ⟨1⟩ = e₁.toFun i for some i ∈ {⟨1⟩,⟨2⟩},
  -- then e₂.toFun ⟨1⟩ ∈ range e₁ ∩ range e₂, so by overlap, ∈ range vbExt3_RRR_e0.embedding = {⟨0⟩}.
  -- But e₂.toFun ⟨1⟩ ≠ ⟨0⟩ (red, not black σ).
  have h_e2_leaf_ne_zero : e₂.toFun (⟨1, by decide⟩ : Fin 2) ≠ (⟨0, by decide⟩ : Fin 4) := by
    intro h
    have h_e1 : (⟨1, by decide⟩ : Fin 2) = (⟨0, by decide⟩ : Fin 2) :=
      e₂.injective (h.trans h_e2_zero.symm)
    have : (1 : ℕ) = 0 := congr_arg Fin.val h_e1
    omega
  have h_overlap_imp : ∀ v : Fin 4,
      v ∈ Set.range e₁.toFun → v ∈ Set.range e₂.toFun →
        v = (⟨0, by decide⟩ : Fin 4) := by
    intro v hv1 hv2
    have h := (hover v).mp ⟨hv1, hv2⟩
    obtain ⟨_, hj⟩ := h
    change v = (⟨0, by decide⟩ : Fin 4)
    rw [← hj]; rfl
  refine ⟨?_, ?_⟩
  · intro h
    -- e₂.toFun ⟨1⟩ = e₁.toFun ⟨1⟩, so it's in range e₁ ∩ range e₂.
    have hv1 : e₂.toFun (⟨1, by decide⟩ : Fin 2) ∈ Set.range e₁.toFun :=
      ⟨(⟨1, by decide⟩ : Fin 3), h.symm⟩
    have hv2 : e₂.toFun (⟨1, by decide⟩ : Fin 2) ∈ Set.range e₂.toFun :=
      ⟨(⟨1, by decide⟩ : Fin 2), rfl⟩
    have heq := h_overlap_imp _ hv1 hv2
    exact h_e2_leaf_ne_zero heq
  · intro h
    have hv1 : e₂.toFun (⟨1, by decide⟩ : Fin 2) ∈ Set.range e₁.toFun :=
      ⟨(⟨2, by decide⟩ : Fin 3), h.symm⟩
    have hv2 : e₂.toFun (⟨1, by decide⟩ : Fin 2) ∈ Set.range e₂.toFun :=
      ⟨(⟨1, by decide⟩ : Fin 2), rfl⟩
    have heq := h_overlap_imp _ hv1 hv2
    exact h_e2_leaf_ne_zero heq

/-- Auxiliary: build the joint-pair witness from `(a, b)` distinct in `Fin 3`. -/
private noncomputable def pair_witness (a b : Fin 3) (hab : a ≠ b) :
    { p : GenInducedEmbedding CG2 vertexBlackType vbExt2_RR_indep vbExt3_RRR_e0 ×
              GenInducedEmbedding CG2 vertexBlackType vbExtRed vbExt3_RRR_e0 //
            (∀ i : Fin vbExt3_RRR_e0.size,
              (i ∈ Set.range p.1.toFun ∧ i ∈ Set.range p.2.toFun) ↔
                i ∈ Set.range vbExt3_RRR_e0.embedding) ∧
            (∀ i : Fin vbExt3_RRR_e0.size,
              i ∈ Set.range p.1.toFun ∨ i ∈ Set.range p.2.toFun) } := by
  let c := fin3_third a b
  refine ⟨⟨vbExt2_RR_indep_to_vbExt3_RRR_e0_canon a b hab,
          vbExtRed_to_vbExt3_RRR_e0_canon c⟩, ?_, ?_⟩
  · -- Overlap.
    intro i
    -- σ-image of vbExt3_RRR_e0 is {⟨0⟩}.
    have hsigma : ∀ v : Fin 4, v ∈ Set.range vbExt3_RRR_e0.embedding ↔ v = (⟨0, by decide⟩ : Fin 4) := by
      intro v
      constructor
      · rintro ⟨j, hj⟩
        show v = (⟨0, by decide⟩ : Fin 4)
        rw [← hj]; rfl
      · intro hv; exact ⟨⟨0, Nat.zero_lt_one⟩, by change (⟨0, by decide⟩ : Fin 4) = v; rw [hv]⟩
    rw [hsigma]
    -- range e₁ = {⟨0⟩, fin3_skip0 a, fin3_skip0 b}; range e₂ = {⟨0⟩, fin3_skip0 c}.
    constructor
    · rintro ⟨⟨j₁, hj₁⟩, ⟨j₂, hj₂⟩⟩
      -- Decompose j₁ : Fin 3 cases.
      change rr_indep_to a b j₁ = i at hj₁
      change red_leaf_to c j₂ = i at hj₂
      rcases fin3_val_cases j₁ with hj₁0 | hj₁1 | hj₁2
      · have : j₁ = (⟨0, by decide⟩ : Fin 3) := Fin.ext hj₁0
        rw [this, rr_indep_to_zero] at hj₁
        exact hj₁.symm
      · have hj1' : j₁ = (⟨1, by decide⟩ : Fin 3) := Fin.ext hj₁1
        rw [hj1', rr_indep_to_one] at hj₁
        rcases fin2_eq_zero_or_one j₂ with hj₂0 | hj₂1
        · have : j₂ = (⟨0, by decide⟩ : Fin 2) := Fin.ext hj₂0
          rw [this, red_leaf_to_zero] at hj₂
          rw [← hj₁] at hj₂
          exact absurd hj₂.symm (fin3_skip0_ne_zero a)
        · have : j₂ = (⟨1, by decide⟩ : Fin 2) := Fin.ext hj₂1
          rw [this, red_leaf_to_one] at hj₂
          rw [← hj₁] at hj₂
          exfalso
          have heq : a = c := fin3_skip0_inj hj₂.symm
          exact (fin3_third_ne_left a b hab) heq.symm
      · have hj2' : j₁ = (⟨2, by decide⟩ : Fin 3) := Fin.ext hj₁2
        rw [hj2', rr_indep_to_two] at hj₁
        rcases fin2_eq_zero_or_one j₂ with hj₂0 | hj₂1
        · have : j₂ = (⟨0, by decide⟩ : Fin 2) := Fin.ext hj₂0
          rw [this, red_leaf_to_zero] at hj₂
          rw [← hj₁] at hj₂
          exact absurd hj₂.symm (fin3_skip0_ne_zero b)
        · have : j₂ = (⟨1, by decide⟩ : Fin 2) := Fin.ext hj₂1
          rw [this, red_leaf_to_one] at hj₂
          rw [← hj₁] at hj₂
          exfalso
          have heq : b = c := fin3_skip0_inj hj₂.symm
          exact (fin3_third_ne_right a b hab) heq.symm
    · intro hi
      refine ⟨⟨(⟨0, by decide⟩ : Fin 3), ?_⟩, ⟨(⟨0, by decide⟩ : Fin 2), ?_⟩⟩
      · change rr_indep_to a b (⟨0, by decide⟩ : Fin 3) = i
        rw [rr_indep_to_zero]; exact hi.symm
      · change red_leaf_to c (⟨0, by decide⟩ : Fin 2) = i
        rw [red_leaf_to_zero]; exact hi.symm
  · -- Cover.
    intro i
    rcases fin4_val_cases i with hi | hi | hi | hi
    · left
      refine ⟨(⟨0, by decide⟩ : Fin 3), ?_⟩
      change rr_indep_to a b (⟨0, by decide⟩ : Fin 3) = i
      rw [rr_indep_to_zero]; exact (Fin.ext hi).symm
    · -- i = ⟨1⟩. Either ∈ range e₁ or ∈ range e₂.
      -- It's in range e₁ if {a, b} contains 0 (fin3_skip0 0 = 1); else c = 0 so it's in range e₂.
      rcases fin3_val_cases a with ha0 | ha1 | ha2
      · -- a = 0, fin3_skip0 a = ⟨1⟩.
        left
        refine ⟨(⟨1, by decide⟩ : Fin 3), ?_⟩
        change rr_indep_to a b (⟨1, by decide⟩ : Fin 3) = i
        rw [rr_indep_to_one]
        have ha' : a = (⟨0, by decide⟩ : Fin 3) := Fin.ext ha0
        rw [ha', fin3_skip0_zero]
        exact (Fin.ext hi).symm
      · rcases fin3_val_cases b with hb0 | hb1 | hb2
        · left
          refine ⟨(⟨2, by decide⟩ : Fin 3), ?_⟩
          change rr_indep_to a b (⟨2, by decide⟩ : Fin 3) = i
          rw [rr_indep_to_two]
          have hb' : b = (⟨0, by decide⟩ : Fin 3) := Fin.ext hb0
          rw [hb', fin3_skip0_zero]
          exact (Fin.ext hi).symm
        · -- a = 1, b = 1: contradiction with hab.
          exfalso
          have ha' : a = (⟨1, by decide⟩ : Fin 3) := Fin.ext ha1
          have hb' : b = (⟨1, by decide⟩ : Fin 3) := Fin.ext hb1
          exact hab (ha'.trans hb'.symm)
        · -- a = 1, b = 2, c = 0.
          right
          refine ⟨(⟨1, by decide⟩ : Fin 2), ?_⟩
          change red_leaf_to c (⟨1, by decide⟩ : Fin 2) = i
          rw [red_leaf_to_one]
          have hc : c = (⟨0, by decide⟩ : Fin 3) := by
            change fin3_third a b = (⟨0, by decide⟩ : Fin 3)
            apply Fin.ext
            unfold fin3_third
            simp only
            rw [ha1, hb2]
            rfl
          rw [hc, fin3_skip0_zero]
          exact (Fin.ext hi).symm
      · rcases fin3_val_cases b with hb0 | hb1 | hb2
        · left
          refine ⟨(⟨2, by decide⟩ : Fin 3), ?_⟩
          change rr_indep_to a b (⟨2, by decide⟩ : Fin 3) = i
          rw [rr_indep_to_two]
          have hb' : b = (⟨0, by decide⟩ : Fin 3) := Fin.ext hb0
          rw [hb', fin3_skip0_zero]
          exact (Fin.ext hi).symm
        · -- a = 2, b = 1, c = 0.
          right
          refine ⟨(⟨1, by decide⟩ : Fin 2), ?_⟩
          change red_leaf_to c (⟨1, by decide⟩ : Fin 2) = i
          rw [red_leaf_to_one]
          have hc : c = (⟨0, by decide⟩ : Fin 3) := by
            change fin3_third a b = (⟨0, by decide⟩ : Fin 3)
            apply Fin.ext
            unfold fin3_third
            simp only
            rw [ha2, hb1]
            rfl
          rw [hc, fin3_skip0_zero]
          exact (Fin.ext hi).symm
        · exfalso
          have ha' : a = (⟨2, by decide⟩ : Fin 3) := Fin.ext ha2
          have hb' : b = (⟨2, by decide⟩ : Fin 3) := Fin.ext hb2
          exact hab (ha'.trans hb'.symm)
    · -- i = ⟨2⟩, similar.
      rcases fin3_val_cases a with ha0 | ha1 | ha2
      · rcases fin3_val_cases b with hb0 | hb1 | hb2
        · exfalso
          have ha' : a = (⟨0, by decide⟩ : Fin 3) := Fin.ext ha0
          have hb' : b = (⟨0, by decide⟩ : Fin 3) := Fin.ext hb0
          exact hab (ha'.trans hb'.symm)
        · -- a = 0, b = 1, c = 2.
          left
          refine ⟨(⟨2, by decide⟩ : Fin 3), ?_⟩
          change rr_indep_to a b (⟨2, by decide⟩ : Fin 3) = i
          rw [rr_indep_to_two]
          have hb' : b = (⟨1, by decide⟩ : Fin 3) := Fin.ext hb1
          rw [hb', fin3_skip0_one]
          exact (Fin.ext hi).symm
        · -- a = 0, b = 2, c = 1.
          right
          refine ⟨(⟨1, by decide⟩ : Fin 2), ?_⟩
          change red_leaf_to c (⟨1, by decide⟩ : Fin 2) = i
          rw [red_leaf_to_one]
          have hc : c = (⟨1, by decide⟩ : Fin 3) := by
            change fin3_third a b = (⟨1, by decide⟩ : Fin 3)
            apply Fin.ext
            unfold fin3_third
            simp only
            rw [ha0, hb2]
            rfl
          rw [hc, fin3_skip0_one]
          exact (Fin.ext hi).symm
      · -- a = 1, fin3_skip0 a = ⟨2⟩.
        left
        refine ⟨(⟨1, by decide⟩ : Fin 3), ?_⟩
        change rr_indep_to a b (⟨1, by decide⟩ : Fin 3) = i
        rw [rr_indep_to_one]
        have ha' : a = (⟨1, by decide⟩ : Fin 3) := Fin.ext ha1
        rw [ha', fin3_skip0_one]
        exact (Fin.ext hi).symm
      · rcases fin3_val_cases b with hb0 | hb1 | hb2
        · -- a = 2, b = 0, c = 1.
          right
          refine ⟨(⟨1, by decide⟩ : Fin 2), ?_⟩
          change red_leaf_to c (⟨1, by decide⟩ : Fin 2) = i
          rw [red_leaf_to_one]
          have hc : c = (⟨1, by decide⟩ : Fin 3) := by
            change fin3_third a b = (⟨1, by decide⟩ : Fin 3)
            apply Fin.ext
            unfold fin3_third
            simp only
            rw [ha2, hb0]
