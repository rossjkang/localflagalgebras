/-- Specialisation of `vertexRedType_master_chain_clean` to k=4. -/
theorem vertexRedType_master_chain_4
    {𝒢 : GenGraphClass CG2} {Δ : GenGraphParam CG2}
    (hσ : GenIsLocalType vertexRedType 𝒢 Δ)
    (h_reg : IsRegularClass 𝒢 Δ)
    (hσ_toFlag : GenIsLocalFlag vertexRedType vertexRedType.toFlag 𝒢 Δ)
    (h_ext_local : ∀ cls ∈ ((genClassesOfSize CG2 vertexRedType
      (vertexRedType.size + 1) (Nat.le_succ _)).filter
      (fun cls => extAdjacencyClass vertexRedType cls
        ⟨0, by change 0 < 1; omega⟩)),
      GenIsLocalFlag vertexRedType cls.out 𝒢 Δ)
    (φ : GenLimitFunctional CG2 (GenFlagType.empty CG2) 𝒢 Δ) :
    φ.evalAlg (genAveragingAlg vertexRedType
      (extPow vertexRedType ⟨0, by change 0 < 1; omega⟩ 4)) =
    φ.eval vertexRedFlag.forget :=
  vertexRedType_master_chain_clean hσ h_reg hσ_toFlag h_ext_local φ 4

/-- For any size-2 σ-flag F at vertexBlackType with extAdjacency at i=0,
    F.str.1 equals vbExtRed.str.1 (the unique (0,1)-edge graph on Fin 2). -/
private theorem size2_extAdj_graph_eq
    (F_str : CG2.Str 2)
    (F_emb : Fin vertexBlackType.size ↪ Fin 2)
    (F_isInd : CG2.comap F_emb F_str = vertexBlackType.str)
    (F_hsize : vertexBlackType.size ≤ 2)
    (hadj : extAdjacency vertexBlackType
      (⟨2, F_str, F_emb, F_isInd, F_hsize⟩ :
        GenFlag CG2 vertexBlackType) ⟨0, Nat.zero_lt_one⟩) :
    F_str.1 = vbExtRed.str.1 := by
  have h_edge : F_str.1.Adj (⟨0, Nat.zero_lt_two⟩ : Fin 2) ⟨1, Nat.one_lt_two⟩ :=
    size2_extAdj_has_edge ⟨2, F_str, F_emb, F_isInd, F_hsize⟩
      rfl hadj
  ext u v
  change F_str.1.Adj u v ↔ vbExtRed.str.1.Adj u v
  rw [fin2_adj_iff (G := F_str.1) u v, fin2_adj_iff (G := vbExtRed.str.1) u v]
  constructor
  · rintro ⟨h_or, _⟩; exact ⟨h_or, vbExtRed_adj_01⟩
  · rintro ⟨h_or, _⟩; exact ⟨h_or, h_edge⟩

/-- Same as `size2_extAdj_graph_eq` but with vbExtBlack. The two graphs are equal. -/
private theorem size2_extAdj_graph_eq_black
    (F_str : CG2.Str 2)
    (F_emb : Fin vertexBlackType.size ↪ Fin 2)
    (F_isInd : CG2.comap F_emb F_str = vertexBlackType.str)
    (F_hsize : vertexBlackType.size ≤ 2)
    (hadj : extAdjacency vertexBlackType
      (⟨2, F_str, F_emb, F_isInd, F_hsize⟩ :
        GenFlag CG2 vertexBlackType) ⟨0, Nat.zero_lt_one⟩) :
    F_str.1 = vbExtBlack.str.1 := by
  have h_red := size2_extAdj_graph_eq F_str F_emb F_isInd F_hsize hadj
  rw [h_red]; rfl

/-- Any size-2 σ-flag at vertexBlackType with extAdjacency at i=0 is iso
    to vbExtRed or vbExtBlack.

    Proof: rcases the GenFlag structure to expose explicit fields, then
    case-split on F_emb ⟨0,_⟩.val ∈ {0, 1} and on F_str.2 (the other vertex)
    ∈ {0, 1}. Each case applies one of the 4 iso theorems. -/
theorem any_size2_extAdj_iso (F : GenFlag CG2 vertexBlackType) (hsize : F.size = 2)
    (hadj : extAdjacency vertexBlackType F ⟨0, Nat.zero_lt_one⟩) :
    GenFlagIso vertexBlackType F vbExtRed ∨
    GenFlagIso vertexBlackType F vbExtBlack := by
  rcases F with ⟨size, F_str, F_emb, F_isInd, F_hsize⟩
  -- Now hsize : size = 2.
  subst hsize
  -- All `size` references in goals/hypotheses become 2.
  -- Get embedding cases.
  have hcase_emb : (F_emb ⟨0, Nat.zero_lt_one⟩).val = 0 ∨
      (F_emb ⟨0, Nat.zero_lt_one⟩).val = 1 :=
    fin2_eq_zero_or_one _
  rcases hcase_emb with hemb0 | hemb1
  · -- canonical case: F_emb val = 0
    -- Other vertex is at position 1. F_str.2 ⟨1,_⟩ ∈ {0, 1}.
    have hcase_col : F_str.2 (⟨1, Nat.one_lt_two⟩ : Fin 2) = (0 : Fin 2) ∨
        F_str.2 (⟨1, Nat.one_lt_two⟩ : Fin 2) = (1 : Fin 2) := by
      have h_lt : (F_str.2 (⟨1, Nat.one_lt_two⟩ : Fin 2)).val < 2 :=
        (F_str.2 _).isLt
      have h_or := fin2_eq_zero_or_one (F_str.2 (⟨1, Nat.one_lt_two⟩ : Fin 2))
      rcases h_or with h | h
      · left; exact Fin.ext h
      · right; exact Fin.ext h
    rcases hcase_col with hcol0 | hcol1
    · -- canonical red
      have h_graph : F_str.1 = vbExtRed.str.1 :=
        size2_extAdj_graph_eq F_str F_emb F_isInd F_hsize hadj
      exact Or.inl (genFlag_size2_canonical_red_iso_vbExtRed
        F_str F_emb F_isInd F_hsize hemb0 h_graph hcol0)
    · -- canonical black
      have h_graph : F_str.1 = vbExtBlack.str.1 :=
        size2_extAdj_graph_eq_black F_str F_emb F_isInd F_hsize hadj
      exact Or.inr (genFlag_size2_canonical_black_iso_vbExtBlack
        F_str F_emb F_isInd F_hsize hemb0 h_graph hcol1)
  · -- swap case: F_emb val = 1
    -- Other vertex is at position 0. F_str.2 ⟨0,_⟩ ∈ {0, 1}.
    have hcase_col : F_str.2 (⟨0, Nat.zero_lt_two⟩ : Fin 2) = (0 : Fin 2) ∨
        F_str.2 (⟨0, Nat.zero_lt_two⟩ : Fin 2) = (1 : Fin 2) := by
      have h_or := fin2_eq_zero_or_one (F_str.2 (⟨0, Nat.zero_lt_two⟩ : Fin 2))
      rcases h_or with h | h
      · left; exact Fin.ext h
      · right; exact Fin.ext h
    rcases hcase_col with hcol0 | hcol1
    · have h_graph : F_str.1 = vbExtRed.str.1 :=
        size2_extAdj_graph_eq F_str F_emb F_isInd F_hsize hadj
      exact Or.inl (genFlag_size2_swap_red_iso_vbExtRed
        F_str F_emb F_isInd F_hsize hemb1 h_graph hcol0)
    · have h_graph : F_str.1 = vbExtBlack.str.1 :=
        size2_extAdj_graph_eq_black F_str F_emb F_isInd F_hsize hadj
      exact Or.inr (genFlag_size2_swap_black_iso_vbExtBlack
        F_str F_emb F_isInd F_hsize hemb1 h_graph hcol1)

/-- **B₁ enumeration support equation**:

      (extSum vertexBlackType ⟨0,_⟩).support = {⟦vbExtRed⟧, ⟦vbExtBlack⟧}

    Combines the membership theorems (`mk_vbExt*_mem_extSum_support`) with
    the classification theorem (`any_size2_extAdj_iso`) and the distinctness
    fact (`mk_vbExtRed_ne_mk_vbExtBlack`). -/
theorem extSum_vertexBlackType_support :
    (extSum vertexBlackType (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size)).support =
      {GenFlagClass.mk vbExtRed, GenFlagClass.mk vbExtBlack} := by
  ext cls
  rw [extSum_support_eq, Finset.mem_filter]
  constructor
  · rintro ⟨hcls_size, hcls_adj⟩
    -- cls.out has size 2.
    have hsize_out : cls.out.size = vertexBlackType.size + 1 :=
      genClassesOfSize_out_size hcls_size
    -- Apply any_size2_extAdj_iso to cls.out.
    have hiso_or : GenFlagIso vertexBlackType cls.out vbExtRed ∨
        GenFlagIso vertexBlackType cls.out vbExtBlack :=
      any_size2_extAdj_iso cls.out hsize_out hcls_adj
    -- cls = mk cls.out (Quotient.out_eq)
    have h_cls_eq : cls = GenFlagClass.mk cls.out :=
      (Quotient.out_eq cls).symm
    rcases hiso_or with hiso_red | hiso_black
    · -- cls.out ≃ vbExtRed ⟹ mk cls.out = mk vbExtRed
      rw [Finset.mem_insert, Finset.mem_singleton]
      left
      rw [h_cls_eq]
      exact Quotient.sound hiso_red
    · rw [Finset.mem_insert, Finset.mem_singleton]
      right
      rw [h_cls_eq]
      exact Quotient.sound hiso_black
  · intro h
    rw [Finset.mem_insert, Finset.mem_singleton] at h
    rcases h with h_red | h_black
    · rw [h_red]
      have h_filter := mk_vbExtRed_mem_filter
      rw [Finset.mem_filter] at h_filter
      exact h_filter
    · rw [h_black]
      have h_filter := mk_vbExtBlack_mem_filter
      rw [Finset.mem_filter] at h_filter
      exact h_filter

/-! ### Aut counts: `Aut(vbExtRed) = Aut(vbExtBlack) = 1`

Each is a size-2 σ-flag with σ-vertex fixed (vertex 0). Any σ-iso must fix
vertex 0 (σ-compat). By injectivity on Fin 2, vertex 1 also fixed. So the
only σ-iso is id, giving Aut = 1. -/

theorem vbExtRed_aut : genFlagAutCount CG2 vertexBlackType vbExtRed = 1 := by
  unfold genFlagAutCount genInducedCount
  rw [Fintype.card_eq_one_iff]
  refine ⟨{ toFun := id, injective := Function.injective_id,
            isInduced := CG2.comap_id _, compat := fun _ => rfl }, ?_⟩
  rintro ⟨f, finj, find, fcompat⟩
  -- Show f = id on Fin 2.
  congr 1
  funext x
  -- compat: f ⟨0,_⟩ = ⟨0,_⟩ (since vbExtRed.embedding ⟨0,_⟩ = ⟨0,_⟩)
  have h_f0 : f (vbExtRed.embedding ⟨0, Nat.zero_lt_one⟩) =
      vbExtRed.embedding ⟨0, Nat.zero_lt_one⟩ := fcompat _
  -- vbExtRed.embedding ⟨0,_⟩ = ⟨0, _⟩ : Fin 2
  have h_emb : (vbExtRed.embedding ⟨0, Nat.zero_lt_one⟩) =
      (⟨0, Nat.zero_lt_two⟩ : Fin 2) := rfl
  rw [h_emb] at h_f0
  -- Cases on x.val.
  rcases fin2_eq_zero_or_one x with h0 | h1
  · -- x = ⟨0, _⟩, f x = ⟨0, _⟩ = id x.
    have hx_eq : x = (⟨0, Nat.zero_lt_two⟩ : Fin 2) := Fin.ext h0
    rw [hx_eq, h_f0]; rfl
  · -- x = ⟨1, _⟩.  f x ≠ ⟨0, _⟩ (else f not inj). So f x = ⟨1, _⟩ = id x.
    have hx_eq : x = (⟨1, Nat.one_lt_two⟩ : Fin 2) := Fin.ext h1
    rw [hx_eq]
    have h_ne : f (⟨1, Nat.one_lt_two⟩ : Fin 2) ≠ (⟨0, Nat.zero_lt_two⟩ : Fin 2) := by
      intro h_eq
      have h12_eq_0 : (⟨1, Nat.one_lt_two⟩ : Fin 2) = ⟨0, Nat.zero_lt_two⟩ :=
        finj (h_eq.trans h_f0.symm)
      have hval : (1 : ℕ) = 0 := congr_arg Fin.val h12_eq_0
      omega
    rcases fin2_eq_zero_or_one (f ⟨1, Nat.one_lt_two⟩) with h0' | h1'
    · exfalso; apply h_ne; ext; exact h0'
    · ext; exact h1'

/-- The value of `extSum vertexBlackType ⟨0,_⟩` at `mk vbExtRed` is 1. -/
theorem extSum_vertexBlackType_at_red :
    (extSum vertexBlackType (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size))
      (GenFlagClass.mk vbExtRed) = 1 := by
  rw [extSum_apply, if_pos mk_vbExtRed_mem_filter]
  -- Aut((mk vbExtRed).out) = Aut(vbExtRed) by iso.
  have hiso : GenFlagIso vertexBlackType (GenFlagClass.mk vbExtRed).out vbExtRed := by
    have : (GenFlagClass.mk vbExtRed).out ≈ vbExtRed :=
      Quotient.exact (Quotient.out_eq _)
    exact this
  have h_aut_eq : genFlagAutCount CG2 vertexBlackType (GenFlagClass.mk vbExtRed).out =
      genFlagAutCount CG2 vertexBlackType vbExtRed := genFlagAutCount_flagIso hiso
  rw [h_aut_eq, vbExtRed_aut]
  norm_cast

theorem vbExtBlack_aut : genFlagAutCount CG2 vertexBlackType vbExtBlack = 1 := by
  unfold genFlagAutCount genInducedCount
  rw [Fintype.card_eq_one_iff]
  refine ⟨{ toFun := id, injective := Function.injective_id,
            isInduced := CG2.comap_id _, compat := fun _ => rfl }, ?_⟩
  rintro ⟨f, finj, find, fcompat⟩
  congr 1
  funext x
  have h_f0 : f (vbExtBlack.embedding ⟨0, Nat.zero_lt_one⟩) =
      vbExtBlack.embedding ⟨0, Nat.zero_lt_one⟩ := fcompat _
  have h_emb : (vbExtBlack.embedding ⟨0, Nat.zero_lt_one⟩) =
      (⟨0, Nat.zero_lt_two⟩ : Fin 2) := rfl
  rw [h_emb] at h_f0
  rcases fin2_eq_zero_or_one x with h0 | h1
  · have hx_eq : x = (⟨0, Nat.zero_lt_two⟩ : Fin 2) := Fin.ext h0
    rw [hx_eq, h_f0]; rfl
  · have hx_eq : x = (⟨1, Nat.one_lt_two⟩ : Fin 2) := Fin.ext h1
    rw [hx_eq]
    have h_ne : f (⟨1, Nat.one_lt_two⟩ : Fin 2) ≠ (⟨0, Nat.zero_lt_two⟩ : Fin 2) := by
      intro h_eq
      have h12_eq_0 : (⟨1, Nat.one_lt_two⟩ : Fin 2) = ⟨0, Nat.zero_lt_two⟩ :=
        finj (h_eq.trans h_f0.symm)
      have hval : (1 : ℕ) = 0 := congr_arg Fin.val h12_eq_0
      omega
    rcases fin2_eq_zero_or_one (f ⟨1, Nat.one_lt_two⟩) with h0' | h1'
    · exfalso; apply h_ne; ext; exact h0'
    · ext; exact h1'

/-- The value of `extSum vertexBlackType ⟨0,_⟩` at `mk vbExtBlack` is 1. -/
theorem extSum_vertexBlackType_at_black :
    (extSum vertexBlackType (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size))
      (GenFlagClass.mk vbExtBlack) = 1 := by
  rw [extSum_apply, if_pos mk_vbExtBlack_mem_filter]
  have hiso : GenFlagIso vertexBlackType (GenFlagClass.mk vbExtBlack).out vbExtBlack := by
    have : (GenFlagClass.mk vbExtBlack).out ≈ vbExtBlack :=
      Quotient.exact (Quotient.out_eq _)
    exact this
  have h_aut_eq : genFlagAutCount CG2 vertexBlackType (GenFlagClass.mk vbExtBlack).out =
      genFlagAutCount CG2 vertexBlackType vbExtBlack := genFlagAutCount_flagIso hiso
  rw [h_aut_eq, vbExtBlack_aut]
  norm_cast

/-! ### Size-3 σ-flag classes for the (extSum)^2 expansion

The 2-fold product `extSum * extSum` produces size-3 σ-flag classes. The
natural classes are σ + 2 leaves with various structures. We start by
defining one explicitly: σ + 2 red leaves with no edge between them
(the "K_{1,2} pattern"). -/

/-- σ + 2 red leaves, no edge between leaves. -/
noncomputable def vbExt2_RR_indep : GenFlag CG2 vertexBlackType where
  size := 3
  str := (SimpleGraph.fromRel
    (fun u v : Fin 3 =>
      (u.val = 0 ∧ v.val = 1) ∨ (u.val = 1 ∧ v.val = 0) ∨
      (u.val = 0 ∧ v.val = 2) ∨ (u.val = 2 ∧ v.val = 0)),
    fun v : Fin 3 => if v.val = 0 then 1 else 0)
  embedding := ⟨fun _ => (⟨0, by omega⟩ : Fin 3),
    fun a b _ => by
      have : a.val < 1 := a.isLt
      have : b.val < 1 := b.isLt
      ext; omega⟩
  isInduced := by
    have h_eq : ((SimpleGraph.fromRel
        (fun u v : Fin 3 =>
          (u.val = 0 ∧ v.val = 1) ∨ (u.val = 1 ∧ v.val = 0) ∨
          (u.val = 0 ∧ v.val = 2) ∨ (u.val = 2 ∧ v.val = 0))).comap
        (fun (_ : Fin 1) => (⟨0, by omega⟩ : Fin 3)),
        (fun v : Fin 3 => if v.val = 0 then (1 : Fin 2) else 0) ∘
          (fun (_ : Fin 1) => (⟨0, by omega⟩ : Fin 3)))
        = ((⊥ : SimpleGraph (Fin 1)), fun _ : Fin 1 => (1 : Fin 2)) := by
      ext
      · simp [SimpleGraph.comap, SimpleGraph.fromRel]
      · rfl
    exact h_eq
  hsize := by change 1 ≤ 3; omega

