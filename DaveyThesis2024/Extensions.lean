/-! ### Size-4 σ-flag classes for the (extSum)^3 expansion

The 3-fold product `extSum * extSum * extSum` produces size-4 σ-flag classes.
The natural classes are σ + 3 leaves, all σ-adjacent (the only class shape
relevant for `(extSum)^3`). Vertex 0 is σ; vertices 1, 2, 3 are leaves.

Iso classes are characterised by:
* Leaf colour multiset: RRR, BBB, RRB, RBB (R = red = 0, B = black = 1).
* Leaf-leaf edge subset of {12, 13, 23}, modulo colour-preserving swap.

Counts (after iso reduction, taking into account symmetry of the colour pattern):
* RRR: leaves indistinguishable → edge counts 0/1/2/3 give 4 classes.
* BBB: same — 4 classes.
* RRB (leaves 1,2 red; leaf 3 black): swap of {1,2} preserves colour; 6 classes.
* RBB (leaf 1 red; leaves 2,3 black): swap of {2,3} preserves colour; 6 classes.

Total: 20 classes. -/

/-- Helper: any element of Fin 4 has val ∈ {0, 1, 2, 3}. -/
private theorem fin4_val_cases (x : Fin 4) :
    x.val = 0 ∨ x.val = 1 ∨ x.val = 2 ∨ x.val = 3 := by
  have hlt : x.val < 4 := x.isLt
  omega

/-! #### RRR classes (3 red leaves) -/

/-- σ + 3 red leaves, no leaf-leaf edges (star K_{1,3}). -/
noncomputable def vbExt3_RRR_e0 : GenFlag CG2 vertexBlackType where
  size := 4
  str := (SimpleGraph.fromRel
    (fun u v : Fin 4 =>
      (u.val = 0 ∧ v.val = 1) ∨ (u.val = 1 ∧ v.val = 0) ∨
      (u.val = 0 ∧ v.val = 2) ∨ (u.val = 2 ∧ v.val = 0) ∨
      (u.val = 0 ∧ v.val = 3) ∨ (u.val = 3 ∧ v.val = 0)),
    fun v : Fin 4 => if v.val = 0 then 1 else 0)
  embedding := ⟨fun _ => (⟨0, by omega⟩ : Fin 4),
    fun a b _ => by
      have : a.val < 1 := a.isLt
      have : b.val < 1 := b.isLt
      ext; omega⟩
  isInduced := by
    have h_eq : ((SimpleGraph.fromRel
        (fun u v : Fin 4 =>
          (u.val = 0 ∧ v.val = 1) ∨ (u.val = 1 ∧ v.val = 0) ∨
          (u.val = 0 ∧ v.val = 2) ∨ (u.val = 2 ∧ v.val = 0) ∨
          (u.val = 0 ∧ v.val = 3) ∨ (u.val = 3 ∧ v.val = 0))).comap
        (fun (_ : Fin 1) => (⟨0, by omega⟩ : Fin 4)),
        (fun v : Fin 4 => if v.val = 0 then (1 : Fin 2) else 0) ∘
          (fun (_ : Fin 1) => (⟨0, by omega⟩ : Fin 4)))
        = ((⊥ : SimpleGraph (Fin 1)), fun _ : Fin 1 => (1 : Fin 2)) := by
      ext
      · simp [SimpleGraph.comap, SimpleGraph.fromRel]
      · rfl
    exact h_eq
  hsize := by change 1 ≤ 4; omega

@[simp] theorem vbExt3_RRR_e0_size : vbExt3_RRR_e0.size = 4 := rfl

