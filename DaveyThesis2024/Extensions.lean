/-! ### `extSum × extSum` Finsupp expansion for vertexBlackType

The product `(extSum vertexBlackType ⟨0,_⟩).mul (extSum vertexBlackType ⟨0,_⟩)` is
the sum of the four basic products `single ⟦vbExt_a⟧ * single ⟦vbExt_b⟧` for
`a, b ∈ {Red, Black}`. Each of these is a `genLocalFlagProduct`, which sums
over size-3 σ-flag classes.

The mathematical claim: this sum equals
`single ⟦vbExt2_RR_indep⟧ 1 + single ⟦vbExt2_RR_edge⟧ 1 +`
`single ⟦vbExt2_RB_indep⟧ 1 + single ⟦vbExt2_RB_edge⟧ 1 +`
`single ⟦vbExt2_BB_indep⟧ 1 + single ⟦vbExt2_BB_edge⟧ 1`.

This is justified by:
- `vbExtRed_aut = vbExtBlack_aut = 1`
- For (a, b) ∈ {(R,R), (B,B)}: jointCount with the matching colour-pair vbExt2
  is 2, all others 0; (vbExt2_*_indep_aut = vbExt2_*_edge_aut = 2)
- For (a, b) ∈ {(R,B), (B,R)}: jointCount with vbExt2_RB_* is 1, others 0
- The C(2,1)·C(1,1) = 2 normalisation gives jointInducedDensity = jointCount/2,
  yielding density 1 for each of the 6 vbExt2_* classes.
- Adding (R,B) and (B,R) products doubles the RB contribution, which combined
  with the *2 from (R,R)/(B,B) jointCount = 2 gives unit coefficients.

**KEY BLOCKER (size-3 classification)**: To turn the sums-over-`genClassesOfSize`
into clean sums over the 6 named classes, we need the structural lemma:

  For any `cls : genClassesOfSize CG2 vertexBlackType 3` with
  `genJointCount vertexBlackType X Y cls.out > 0` for some
  `X, Y ∈ {vbExtRed, vbExtBlack}`, `cls` is iso to one of the 6 vbExt2_*.

This requires classifying all size-3 σ-flags whose σ-vertex (vertex 0) is
adjacent to both non-σ vertices, by colour configuration of leaves and the
optional leaf-leaf edge. Analogous to `any_size2_extAdj_iso` but with twice
the case work. We isolate this lemma so it can be filled in independently. -/

/-! ### Helper lemmas: jointCount > 0 implies σ-adjacent-both -/

/-- For any embedding `e : vbExtRed → G`, the σ-vertex `e ⟨0⟩ = G.embedding ⟨0⟩`
    is adjacent in `G` to the leaf image `e ⟨1⟩`. -/
private lemma vbExtRed_emb_sigma_adj_leaf
    {G : GenFlag CG2 vertexBlackType}
    (e : GenInducedEmbedding CG2 vertexBlackType vbExtRed G) :
    G.str.1.Adj (G.embedding ⟨0, Nat.zero_lt_one⟩) (e.toFun (⟨1, by decide⟩ : Fin 2)) := by
  obtain ⟨f, finj, find, fcompat⟩ := e
  -- f ⟨0⟩ = G.embedding ⟨0⟩
  have h0 : f (⟨0, by decide⟩ : Fin 2) = G.embedding ⟨0, Nat.zero_lt_one⟩ :=
    fcompat (⟨0, Nat.zero_lt_one⟩ : Fin 1)
  -- Adjacency in vbExtRed: (0,1) is an edge.
  have hAdj : vbExtRed.str.1.Adj (⟨0, by decide⟩ : Fin 2) (⟨1, by decide⟩ : Fin 2) :=
    vbExtRed_adj_01
  -- Pull back via comap: G.str.1.Adj (f 0) (f 1).
  have h_comap : (CG2.comap f G.str).1 = vbExtRed.str.1 := by rw [find]
  have hAdj' : G.str.1.Adj (f (⟨0, by decide⟩ : Fin 2)) (f (⟨1, by decide⟩ : Fin 2)) := by
    have : (CG2.comap f G.str).1.Adj (⟨0, by decide⟩ : Fin 2) (⟨1, by decide⟩ : Fin 2) := by
      rw [h_comap]; exact hAdj
    -- comap of SimpleGraph: adj on F ↔ adj on G via f.
    exact this
  rw [h0] at hAdj'
  exact hAdj'

/-- For any embedding `e : vbExtBlack → G`, the σ-vertex is adjacent to the leaf image. -/
private lemma vbExtBlack_emb_sigma_adj_leaf
    {G : GenFlag CG2 vertexBlackType}
    (e : GenInducedEmbedding CG2 vertexBlackType vbExtBlack G) :
    G.str.1.Adj (G.embedding ⟨0, Nat.zero_lt_one⟩) (e.toFun (⟨1, by decide⟩ : Fin 2)) := by
  obtain ⟨f, finj, find, fcompat⟩ := e
  have h0 : f (⟨0, by decide⟩ : Fin 2) = G.embedding ⟨0, Nat.zero_lt_one⟩ :=
    fcompat (⟨0, Nat.zero_lt_one⟩ : Fin 1)
  have hAdj : vbExtBlack.str.1.Adj (⟨0, by decide⟩ : Fin 2) (⟨1, by decide⟩ : Fin 2) :=
    vbExtBlack_adj_01
  have h_comap : (CG2.comap f G.str).1 = vbExtBlack.str.1 := by rw [find]
  have hAdj' : G.str.1.Adj (f (⟨0, by decide⟩ : Fin 2)) (f (⟨1, by decide⟩ : Fin 2)) := by
    have : (CG2.comap f G.str).1.Adj (⟨0, by decide⟩ : Fin 2) (⟨1, by decide⟩ : Fin 2) := by
      rw [h_comap]; exact hAdj
    exact this
  rw [h0] at hAdj'
  exact hAdj'

/-- Combined: for any GenInducedEmbedding from vbExtRed or vbExtBlack into G,
    the leaf image is adjacent to the σ-vertex of G. -/
private lemma vbExt_emb_sigma_adj_leaf
    {G : GenFlag CG2 vertexBlackType} (F : GenFlag CG2 vertexBlackType)
    (hF : F = vbExtRed ∨ F = vbExtBlack)
    (e : GenInducedEmbedding CG2 vertexBlackType F G) :
    ∃ v : Fin G.size, v ≠ G.embedding ⟨0, Nat.zero_lt_one⟩ ∧
      G.str.1.Adj (G.embedding ⟨0, Nat.zero_lt_one⟩) v ∧
      v = e.toFun (⟨1, by rcases hF with h | h <;> rw [h] <;> decide⟩ : Fin F.size) := by
  rcases hF with hRed | hBlack
  · subst hRed
    refine ⟨e.toFun (⟨1, by decide⟩ : Fin 2), ?_, vbExtRed_emb_sigma_adj_leaf e, rfl⟩
    -- e.toFun ⟨1⟩ ≠ G.embedding ⟨0⟩: by injectivity, e.toFun ⟨1⟩ ≠ e.toFun ⟨0⟩ = G.embedding ⟨0⟩.
    intro hcontra
    have h0 : e.toFun (⟨0, by decide⟩ : Fin 2) = G.embedding ⟨0, Nat.zero_lt_one⟩ :=
      e.compat (⟨0, Nat.zero_lt_one⟩ : Fin 1)
    have : e.toFun (⟨1, by decide⟩ : Fin 2) = e.toFun (⟨0, by decide⟩ : Fin 2) :=
      hcontra.trans h0.symm
    have h_eq : (⟨1, by decide⟩ : Fin 2) = (⟨0, by decide⟩ : Fin 2) := e.injective this
    have : (1 : ℕ) = 0 := congr_arg Fin.val h_eq
    omega
  · subst hBlack
    refine ⟨e.toFun (⟨1, by decide⟩ : Fin 2), ?_, vbExtBlack_emb_sigma_adj_leaf e, rfl⟩
    intro hcontra
    have h0 : e.toFun (⟨0, by decide⟩ : Fin 2) = G.embedding ⟨0, Nat.zero_lt_one⟩ :=
      e.compat (⟨0, Nat.zero_lt_one⟩ : Fin 1)
    have : e.toFun (⟨1, by decide⟩ : Fin 2) = e.toFun (⟨0, by decide⟩ : Fin 2) :=
      hcontra.trans h0.symm
    have h_eq : (⟨1, by decide⟩ : Fin 2) = (⟨0, by decide⟩ : Fin 2) := e.injective this
    have : (1 : ℕ) = 0 := congr_arg Fin.val h_eq
    omega

/-- If `genJointCount vbExt_a vbExt_b G > 0` then both non-σ vertices of G
    are adjacent to the σ-vertex of G. -/
private lemma genJointCount_pos_implies_extAdjBoth
    (Fa Fb : GenFlag CG2 vertexBlackType)
    (hFa : Fa = vbExtRed ∨ Fa = vbExtBlack) (hFb : Fb = vbExtRed ∨ Fb = vbExtBlack)
    (G : GenFlag CG2 vertexBlackType) (hsize : G.size = 3)
    (hpos : 0 < genJointCount CG2 vertexBlackType Fa Fb G) :
    ∀ v : Fin G.size, v ≠ G.embedding ⟨0, Nat.zero_lt_one⟩ →
      G.str.1.Adj (G.embedding ⟨0, Nat.zero_lt_one⟩) v := by
  -- Extract a witness pair
  unfold genJointCount at hpos
  rw [Fintype.card_pos_iff] at hpos
  obtain ⟨⟨⟨e₁, e₂⟩, hover, _hcov⟩⟩ := hpos
  -- Each leaf image is adj to σ-image and ≠ σ-image
  obtain ⟨v₁, hv₁_ne, hv₁_adj, hv₁_eq⟩ := vbExt_emb_sigma_adj_leaf Fa hFa e₁
  obtain ⟨v₂, hv₂_ne, hv₂_adj, hv₂_eq⟩ := vbExt_emb_sigma_adj_leaf Fb hFb e₂
  -- Now show v₁ ≠ v₂. Suppose v₁ = v₂. Then v₁ ∈ range e₁ ∩ range e₂.
  -- But hover says intersection range = range G.embedding = {σ-vertex}, contradicting v₁ ≠ σ.
  have hv₁_in_e₁ : v₁ ∈ Set.range e₁.toFun := by
    rw [hv₁_eq]; exact ⟨_, rfl⟩
  have hv₂_in_e₂ : v₂ ∈ Set.range e₂.toFun := by
    rw [hv₂_eq]; exact ⟨_, rfl⟩
  have hv_neq : v₁ ≠ v₂ := by
    intro hcontra
    -- v₁ = v₂ would be in both ranges, so ∈ range G.embedding
    have hv_in_both : v₁ ∈ Set.range e₁.toFun ∧ v₁ ∈ Set.range e₂.toFun := by
      refine ⟨hv₁_in_e₁, ?_⟩
      rw [hcontra]; exact hv₂_in_e₂
    have hv_in_emb : v₁ ∈ Set.range G.embedding := (hover v₁).mp hv_in_both
    obtain ⟨i, hi⟩ := hv_in_emb
    have hi_eq : i = ⟨0, Nat.zero_lt_one⟩ := by
      have : vertexBlackType.size = 1 := rfl
      ext; have hlt : i.val < 1 := this ▸ i.isLt; omega
    rw [hi_eq] at hi
    exact hv₁_ne hi.symm
  -- Now we have v₁ ≠ v₂, both ≠ σ, both adj to σ. So all non-σ vertices are adj to σ.
  -- G.size = 3, so there are exactly 2 non-σ vertices, namely v₁ and v₂.
  intro w hw_ne
  -- Show w = v₁ or w = v₂
  -- The σ-vertex e is G.embedding ⟨0⟩. Among Fin 3, w ≠ e gives 2 options.
  -- We have v₁ ≠ v₂ ≠ e, e ≠ v₁, v₂. So {v₁, v₂} = {x : Fin 3 | x ≠ e}.
  set σv := G.embedding ⟨0, Nat.zero_lt_one⟩ with hσv
  -- subst the hsize to make Fin 3 explicit
  -- Use card argument: in a 3-element set, removing 1 element leaves exactly 2.
  have hcard3 : (Finset.univ : Finset (Fin G.size)).card = 3 := by
    rw [Finset.card_univ, Fintype.card_fin, hsize]
  -- The complement of {σv} has size 2
  have h_compl_card : (Finset.univ.erase σv).card = 2 := by
    rw [Finset.card_erase_of_mem (Finset.mem_univ _), hcard3]
  -- {v₁, v₂} is a subset of size 2 of the complement
  have hv₁_mem : v₁ ∈ Finset.univ.erase σv := Finset.mem_erase.mpr ⟨hv₁_ne, Finset.mem_univ _⟩
  have hv₂_mem : v₂ ∈ Finset.univ.erase σv := Finset.mem_erase.mpr ⟨hv₂_ne, Finset.mem_univ _⟩
  have hsub : ({v₁, v₂} : Finset _) ⊆ Finset.univ.erase σv := by
    intro x hx
    simp at hx; rcases hx with rfl | rfl
    · exact hv₁_mem
    · exact hv₂_mem
  have h_pair_card : ({v₁, v₂} : Finset _).card = 2 := by
    rw [Finset.card_pair hv_neq]
  have h_eq_set : ({v₁, v₂} : Finset _) = Finset.univ.erase σv :=
    Finset.eq_of_subset_of_card_le hsub (h_compl_card.symm ▸ h_pair_card.ge)
  have hw_in : w ∈ Finset.univ.erase σv :=
    Finset.mem_erase.mpr ⟨hw_ne, Finset.mem_univ _⟩
  rw [← h_eq_set] at hw_in
  simp at hw_in
  rcases hw_in with rfl | rfl
  · exact hv₁_adj
  · exact hv₂_adj

/-- If `genJointInducedDensity vbExt_a vbExt_b G ≠ 0` then `G` is iso to one of
    the 6 vbExt2_* flags. -/
private lemma genJointInducedDensity_vbExt_nonzero_implies_iso
    (Fa Fb : GenFlag CG2 vertexBlackType)
    (hFa : Fa = vbExtRed ∨ Fa = vbExtBlack) (hFb : Fb = vbExtRed ∨ Fb = vbExtBlack)
    (G : GenFlag CG2 vertexBlackType) (hsize : G.size = 3)
    (hnonzero : genJointInducedDensity CG2 vertexBlackType Fa Fb G ≠ 0) :
    GenFlagIso vertexBlackType G vbExt2_RR_indep ∨
    GenFlagIso vertexBlackType G vbExt2_RR_edge ∨
    GenFlagIso vertexBlackType G vbExt2_RB_indep ∨
    GenFlagIso vertexBlackType G vbExt2_RB_edge ∨
    GenFlagIso vertexBlackType G vbExt2_BB_indep ∨
    GenFlagIso vertexBlackType G vbExt2_BB_edge := by
  have hpos : 0 < genJointCount CG2 vertexBlackType Fa Fb G := by
    by_contra h
    push_neg at h
    have h0 : genJointCount CG2 vertexBlackType Fa Fb G = 0 := Nat.le_zero.mp h
    apply hnonzero
    unfold genJointInducedDensity
    rw [h0]; push_cast; ring
  have hadj := genJointCount_pos_implies_extAdjBoth Fa Fb hFa hFb G hsize hpos
  exact any_size3_extAdjBoth_iso G hsize hadj

/-! ### Pairwise non-isomorphism of the 6 vbExt2_X classes

To extract clean Finsupp expansion, we need that the 6 named classes are
pairwise distinct as `GenFlagClass` (i.e., not iso). We distinguish:
- RR vs RB vs BB by colour multiset (via `genJointCount(R, B, _)`)
- indep vs edge within same colour pair via direct edge-Adj contradiction. -/

/-- Helper: distinguish via `genJointCount(R, B, _)`: 0 for RR/BB, 1 for RB. -/
private lemma vbExt2_classes_ne_via_jointCount
    {X Y : GenFlag CG2 vertexBlackType}
    (h_X_count : genJointCount CG2 vertexBlackType vbExtRed vbExtBlack X = 0)
    (h_Y_count : genJointCount CG2 vertexBlackType vbExtRed vbExtBlack Y = 1) :
    GenFlagClass.mk X ≠ GenFlagClass.mk Y := by
  intro h
  have hiso : GenFlagIso vertexBlackType X Y :=
    (GenFlagClass.mk_eq X Y).mp h
  have h_eq : genJointCount CG2 vertexBlackType vbExtRed vbExtBlack X =
      genJointCount CG2 vertexBlackType vbExtRed vbExtBlack Y :=
    genJointCount_flagIso_target' hiso
  rw [h_X_count, h_Y_count] at h_eq
  exact absurd h_eq (by decide)

