/-! ### σ₁-4-E.C.1: BRRB σ-locality of t1_v* witnesses (size-5 thesisType1-flags)

For each of the 6 `thesisType1` ext witnesses, we prove
`GenIsLocalFlag thesisType1 t1_v*_* brrbGenGraphClass brrbGenDelta` via:
1. A generic bounded-density helper for any size-`(σ.size+1)` σ-flag F whose
   ext vertex satisfies `extAdjacency σ F i`. The IC bound comes from the
   per-graph identity `Σ_cls IC = |neighbourSet|`, which gives IC ≤ Δ for
   each individual cls (since IC ≥ 0 and the bound `|neighbourSet| ≤ Δ`
   holds in any graph by `brrbGenDelta = max degree`).
2. Locality: at the next label extension level, the flag is fully-labelled
   (size = type.size), hence local trivially via
   `genIsLocalFlag_of_fully_labeled`.

This infrastructure is reusable for σ₂..σ₅ and provides Step 1 of the
σᵢ_nonneg proof template. -/

/-- **Per-cls IC bound**: for any size-`(σ.size+1)` σ-flag F satisfying
    `extAdjacency σ F i` (so its iso class is in the filter), the induced
    embedding count into any G is bounded by the neighbour set size at
    `G.embedding i`. Pure consequence of `extEmb_count_eq_neighbour_count`. -/
private theorem extAdj_IC_le_neighbour_count
    {σ : GenFlagType CG2} {F : GenFlag CG2 σ}
    (hsize : F.size = σ.size + 1)
    {i : Fin σ.size} (hadj : extAdjacency σ F i)
    (G : GenFlag CG2 σ) :
    genInducedCount CG2 σ F G ≤ (neighbourSet G i).card := by
  classical
  -- Reduce to the per-graph counting identity by destructing F.size.
  -- Use the casted form throughout: rewrite hsize at F's size component.
  -- The cleanest approach is to substitute F.size = σ.size + 1 directly.
  -- We work in two steps: (a) IC(F,G) ≤ Σ_cls IC(cls.out, G); (b) Σ = |neighbourSet|.
  -- Step (a) uses iso-invariance of IC and per-cls non-negativity.
  set cls := GenFlagClass.mk F
  have h_iso : GenFlagIso σ cls.out F := Quotient.exact (Quotient.out_eq cls)
  have hIC_eq : genInducedCount CG2 σ F G = genInducedCount CG2 σ cls.out G :=
    (genInducedCount_flagIso h_iso (G := G)).symm
  rw [hIC_eq]
  -- Now we need: IC(cls.out, G) ≤ |neighbourSet G i|.
  -- We use the per-graph identity Σ_{c ∈ filter at σ.size+1} IC(c.out, G) = |neighbourSet|.
  -- Membership of cls in this filter requires cls.out.size = σ.size + 1, which holds
  -- since cls = mk F, cls.out is iso to F (preserving size), and F.size = σ.size + 1.
  -- Membership of cls in the (σ.size + 1)-filter, via mk_F_mem at F's actual size.
  -- The trick: use `mk_F_mem_genClassesOfSize F` at F.size, then transport via hsize
  -- using a `Subsingleton`-style proof of equality.
  have hcls_size : cls ∈ genClassesOfSize CG2 σ (σ.size + 1) (Nat.le_succ _) := by
    have h_F_mem : GenFlagClass.mk F ∈ genClassesOfSize CG2 σ F.size (by omega) :=
      mk_F_mem_genClassesOfSize F (by omega)
    -- Goal: cls = mk F ∈ genClassesOfSize CG2 σ (σ.size+1) _
    -- Two finsets `genClassesOfSize CG2 σ a hab` and `genClassesOfSize CG2 σ b hab'`
    -- are equal when a = b (proof-irrelevant in `hab`). Use convert.
    have : genClassesOfSize CG2 σ F.size (by omega : σ.size ≤ F.size) =
        genClassesOfSize CG2 σ (σ.size + 1) (Nat.le_succ _) := by
      congr 1
    rw [this] at h_F_mem
    exact h_F_mem
  have hcls_adj : extAdjacencyClass σ cls i := by
    unfold extAdjacencyClass
    rw [extAdjacency_iso_invariant
      (Quotient.exact (Quotient.out_eq cls) : GenFlagIso σ _ F)]
    exact hadj
  have hmem :
      cls ∈ (genClassesOfSize CG2 σ (σ.size + 1) (Nat.le_succ _)).filter
        (fun c => extAdjacencyClass σ c i) :=
    Finset.mem_filter.mpr ⟨hcls_size, hcls_adj⟩
  have h_term_le :
      genInducedCount CG2 σ cls.out G ≤
      ((genClassesOfSize CG2 σ (σ.size + 1) (Nat.le_succ _)).filter
        (fun c => extAdjacencyClass σ c i)).sum
        (fun c => genInducedCount CG2 σ c.out G) :=
    Finset.single_le_sum (f := fun c => genInducedCount CG2 σ c.out G)
      (fun _ _ => Nat.zero_le _) hmem
  rw [extEmb_count_eq_neighbour_count σ G i] at h_term_le
  exact h_term_le

/-- **Neighbour set bound by max degree**: in any graph G, the neighbour set
    at `G.embedding i` has cardinality ≤ `brrbGenDelta G.forget`, since the
    latter is the max degree. -/
private theorem neighbourSet_card_le_brrbGenDelta
    {σ : GenFlagType CG2} (G : GenFlag CG2 σ) (i : Fin σ.size) :
    (neighbourSet G i).card ≤ brrbGenDelta G.forget := by
  -- neighbourSet G i ⊆ {w : Adj(G.embedding i, w)}; the latter has card =
  -- degree(G.embedding i) ≤ brrbGenDelta G.forget.
  have hsub : neighbourSet G i ⊆
      (Finset.univ : Finset (Fin G.size)).filter
        (G.str.1.Adj (G.embedding i)) := by
    intro w hw
    rw [mem_neighbourSet] at hw
    simp [hw.2]
  -- G.forget.size = G.size and G.forget.str.1 = G.str.1 by definition.
  have hdeg_le : ((Finset.univ : Finset (Fin G.size)).filter
        (G.str.1.Adj (G.embedding i))).card ≤ brrbGenDelta G.forget := by
    change ((Finset.univ : Finset (Fin G.forget.size)).filter
        (G.forget.str.1.Adj (G.embedding i))).card ≤
      Finset.sup Finset.univ (fun v : Fin G.forget.size =>
        (Finset.univ.filter (G.forget.str.1.Adj v)).card)
    exact Finset.le_sup
      (f := fun v => (Finset.univ.filter (G.forget.str.1.Adj v)).card)
      (Finset.mem_univ (G.embedding i))
  exact le_trans (Finset.card_le_card hsub) hdeg_le

/-- **Bounded density for size-`(σ.size+1)` extAdjacent σ-flags**: any such
    flag has bounded density in `brrbGenGraphClass`, with bound 1. -/
private theorem genBoundedDensity_extAdj_BRRB
    {σ : GenFlagType CG2} {F : GenFlag CG2 σ}
    (hsize : F.size = σ.size + 1)
    {i : Fin σ.size} (hadj : extAdjacency σ F i) :
    GenIsBoundedDensity σ F brrbGenGraphClass brrbGenDelta :=
  ⟨1, zero_le_one, fun G _hG => by
    unfold genLocalDensity
    rw [show F.size - σ.size = 1 from by omega, Nat.choose_one_right]
    have hIC_le_Δ : genInducedCount CG2 σ F G ≤ brrbGenDelta G.forget :=
      le_trans (extAdj_IC_le_neighbour_count hsize hadj G)
        (neighbourSet_card_le_brrbGenDelta G i)
    by_cases hΔ : brrbGenDelta G.forget = 0
    · simp [hΔ, Nat.le_zero.mp (hΔ ▸ hIC_le_Δ)]
    · rw [div_le_one (Nat.cast_pos.mpr (Nat.pos_of_ne_zero hΔ))]
      exact_mod_cast hIC_le_Δ⟩

/-- **Fully-labelled bounded density** (file-local copy): when `F.size = σ.size`,
    `IC ≤ 1` and `C(Δ,0) = 1`, giving density ≤ 1. Inlined since the
    PentagonConjecture version is private. -/
private theorem genBoundedDensity_fully_labeled' {R : RelUniverse}
    {σ : GenFlagType R} {F : GenFlag R σ}
    {𝒢 : GenGraphClass R} {Δ : GenGraphParam R}
    (hsz : F.size = σ.size) :
    GenIsBoundedDensity σ F 𝒢 Δ :=
  ⟨1, zero_le_one, fun G _hG => by
    unfold genLocalDensity
    rw [show F.size - σ.size = 0 from by omega, Nat.choose_zero_right,
        Nat.cast_one, div_one]
    unfold genInducedCount; rw [Nat.cast_le_one, Fintype.card_le_one_iff]
    intro a b
    have heq : a.toFun = b.toFun := funext fun v => by
      obtain ⟨j, rfl⟩ :=
        F.embedding.injective.surjective_of_finite (finCongr hsz.symm) v
      exact (a.compat j).trans (b.compat j).symm
    cases a; cases b; congr⟩

/-- **σ-locality for size-`(σ.size+1)` extAdjacent σ-flags**: combined with
    the trivial locality of fully-labelled extensions, gives
    `GenIsLocalFlag σ F brrbGenGraphClass brrbGenDelta`. **Public**: this is
    the key reusable helper for σ-locality at extension level, used by the
    σᵢ_nonneg proofs to discharge the locality side of the weakened template. -/
theorem genIsLocalFlag_extAdj_BRRB
    {σ : GenFlagType CG2} {F : GenFlag CG2 σ}
    (hsize : F.size = σ.size + 1)
    {i : Fin σ.size} (hadj : extAdjacency σ F i) :
    GenIsLocalFlag σ F brrbGenGraphClass brrbGenDelta := by
  apply GenIsLocalFlag.intro
  · exact genBoundedDensity_extAdj_BRRB hsize hadj
  · intro ext
    -- ext.extendedFlag has size F.size = σ.size + 1 = ext.extendedType.size
    -- (since extending labels increases type.size by 1). Hence fully labelled.
    have hsz : ext.extendedFlag.size = ext.extendedType.size := by
      change F.size = σ.size + 1
      exact hsize
    apply GenIsLocalFlag.intro
    · exact genBoundedDensity_fully_labeled' hsz
    · intro ext'
      exfalso
      exact ext'.unlabelled
        (ext.extendedFlag.embedding.injective.surjective_of_finite
          (finCongr hsz.symm) ext'.vertex)

