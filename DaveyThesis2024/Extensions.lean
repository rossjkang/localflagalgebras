@[simp] theorem vbExt2_BB_edge_size : vbExt2_BB_edge.size = 3 := rfl

/-- Helper: any element of Fin 3 has val ∈ {0, 1, 2}. -/
private theorem fin3_val_cases (x : Fin 3) :
    x.val = 0 ∨ x.val = 1 ∨ x.val = 2 := by
  have hlt : x.val < 3 := x.isLt
  omega

/-- The swap σ-iso of vbExt2_RR_indep: swaps the two red leaves. -/
noncomputable def vbExt2_RR_indep_swapIso :
    GenInducedEmbedding CG2 vertexBlackType vbExt2_RR_indep vbExt2_RR_indep := by
  classical
  refine {
    toFun := Equiv.swap (⟨1, by decide⟩ : Fin 3) ⟨2, by decide⟩
    injective := (Equiv.swap _ _).injective
    isInduced := ?_
    compat := ?_ }
  · -- comap (swap 1 2) vbExt2_RR_indep.str = vbExt2_RR_indep.str.
    -- Both graph and colour invariant under swap (1, 2): both red leaves with
    -- symmetric edges to σ-vertex.
    apply Prod.ext
    · -- Graph: swap maps edges (0,1)↔(0,2), preserving the graph.
      ext u v
      change vbExt2_RR_indep.str.1.Adj
        (Equiv.swap (⟨1, by decide⟩ : Fin 3) ⟨2, by decide⟩ u)
        (Equiv.swap (⟨1, by decide⟩ : Fin 3) ⟨2, by decide⟩ v)
        ↔ vbExt2_RR_indep.str.1.Adj u v
      have h01 : ((⟨0, by decide⟩ : Fin 3) : Fin 3) ≠ (⟨1, by decide⟩ : Fin 3) := by decide
      have h02 : ((⟨0, by decide⟩ : Fin 3) : Fin 3) ≠ (⟨2, by decide⟩ : Fin 3) := by decide
      have hs0 : Equiv.swap (⟨1, by decide⟩ : Fin 3) ⟨2, by decide⟩ ⟨0, by decide⟩
          = (⟨0, by decide⟩ : Fin 3) := Equiv.swap_apply_of_ne_of_ne h01 h02
      have hs1 : Equiv.swap (⟨1, by decide⟩ : Fin 3) ⟨2, by decide⟩ ⟨1, by decide⟩
          = (⟨2, by decide⟩ : Fin 3) := Equiv.swap_apply_left _ _
      have hs2 : Equiv.swap (⟨1, by decide⟩ : Fin 3) ⟨2, by decide⟩ ⟨2, by decide⟩
          = (⟨1, by decide⟩ : Fin 3) := Equiv.swap_apply_right _ _
      rcases fin3_val_cases u with hu | hu | hu <;>
        rcases fin3_val_cases v with hv | hv | hv
      · -- (0, 0)
        have hu' : u = (⟨0, by decide⟩ : Fin 3) := Fin.ext hu
        have hv' : v = (⟨0, by decide⟩ : Fin 3) := Fin.ext hv
        rw [hu', hv', hs0]
      · -- (0, 1)
        have hu' : u = (⟨0, by decide⟩ : Fin 3) := Fin.ext hu
        have hv' : v = (⟨1, by decide⟩ : Fin 3) := Fin.ext hv
        rw [hu', hv', hs0, hs1]
        change vbExt2_RR_indep.str.1.Adj ⟨0, _⟩ ⟨2, _⟩ ↔
          vbExt2_RR_indep.str.1.Adj ⟨0, _⟩ ⟨1, _⟩
        simp [vbExt2_RR_indep, SimpleGraph.fromRel_adj]
      · -- (0, 2)
        have hu' : u = (⟨0, by decide⟩ : Fin 3) := Fin.ext hu
        have hv' : v = (⟨2, by decide⟩ : Fin 3) := Fin.ext hv
        rw [hu', hv', hs0, hs2]
        change vbExt2_RR_indep.str.1.Adj ⟨0, _⟩ ⟨1, _⟩ ↔
          vbExt2_RR_indep.str.1.Adj ⟨0, _⟩ ⟨2, _⟩
        simp [vbExt2_RR_indep, SimpleGraph.fromRel_adj]
      · -- (1, 0)
        have hu' : u = (⟨1, by decide⟩ : Fin 3) := Fin.ext hu
        have hv' : v = (⟨0, by decide⟩ : Fin 3) := Fin.ext hv
        rw [hu', hv', hs1, hs0]
        change vbExt2_RR_indep.str.1.Adj ⟨2, _⟩ ⟨0, _⟩ ↔
          vbExt2_RR_indep.str.1.Adj ⟨1, _⟩ ⟨0, _⟩
        simp [vbExt2_RR_indep, SimpleGraph.fromRel_adj]
      · -- (1, 1) — both sides false (loop)
        have hu' : u = (⟨1, by decide⟩ : Fin 3) := Fin.ext hu
        have hv' : v = (⟨1, by decide⟩ : Fin 3) := Fin.ext hv
        rw [hu', hv', hs1]
        change vbExt2_RR_indep.str.1.Adj ⟨2, _⟩ ⟨2, _⟩ ↔
          vbExt2_RR_indep.str.1.Adj ⟨1, _⟩ ⟨1, _⟩
        simp [vbExt2_RR_indep]
      · -- (1, 2)
        have hu' : u = (⟨1, by decide⟩ : Fin 3) := Fin.ext hu
        have hv' : v = (⟨2, by decide⟩ : Fin 3) := Fin.ext hv
        rw [hu', hv', hs1, hs2]
        change vbExt2_RR_indep.str.1.Adj ⟨2, _⟩ ⟨1, _⟩ ↔
          vbExt2_RR_indep.str.1.Adj ⟨1, _⟩ ⟨2, _⟩
        simp [vbExt2_RR_indep, SimpleGraph.fromRel_adj]
      · -- (2, 0)
        have hu' : u = (⟨2, by decide⟩ : Fin 3) := Fin.ext hu
        have hv' : v = (⟨0, by decide⟩ : Fin 3) := Fin.ext hv
        rw [hu', hv', hs2, hs0]
        change vbExt2_RR_indep.str.1.Adj ⟨1, _⟩ ⟨0, _⟩ ↔
          vbExt2_RR_indep.str.1.Adj ⟨2, _⟩ ⟨0, _⟩
        simp [vbExt2_RR_indep, SimpleGraph.fromRel_adj]
      · -- (2, 1)
        have hu' : u = (⟨2, by decide⟩ : Fin 3) := Fin.ext hu
        have hv' : v = (⟨1, by decide⟩ : Fin 3) := Fin.ext hv
        rw [hu', hv', hs2, hs1]
        change vbExt2_RR_indep.str.1.Adj ⟨1, _⟩ ⟨2, _⟩ ↔
          vbExt2_RR_indep.str.1.Adj ⟨2, _⟩ ⟨1, _⟩
        simp [vbExt2_RR_indep, SimpleGraph.fromRel_adj]
      · -- (2, 2) — both sides false (loop)
        have hu' : u = (⟨2, by decide⟩ : Fin 3) := Fin.ext hu
        have hv' : v = (⟨2, by decide⟩ : Fin 3) := Fin.ext hv
        rw [hu', hv', hs2]
        change vbExt2_RR_indep.str.1.Adj ⟨1, _⟩ ⟨1, _⟩ ↔
          vbExt2_RR_indep.str.1.Adj ⟨2, _⟩ ⟨2, _⟩
        simp [vbExt2_RR_indep]
    · -- Colour: const 1 at vertex 0, 0 at vertices 1, 2.
      funext v
      change vbExt2_RR_indep.str.2 (Equiv.swap (⟨1, by decide⟩ : Fin 3) ⟨2, by decide⟩ v) =
        vbExt2_RR_indep.str.2 v
      have h01 : ((⟨0, by decide⟩ : Fin 3) : Fin 3) ≠ (⟨1, by decide⟩ : Fin 3) := by decide
      have h02 : ((⟨0, by decide⟩ : Fin 3) : Fin 3) ≠ (⟨2, by decide⟩ : Fin 3) := by decide
      rcases fin3_val_cases v with hv | hv | hv
      · have hv' : v = (⟨0, by decide⟩ : Fin 3) := Fin.ext hv
        rw [hv', Equiv.swap_apply_of_ne_of_ne h01 h02]
      · have hv' : v = (⟨1, by decide⟩ : Fin 3) := Fin.ext hv
        rw [hv', Equiv.swap_apply_left]
        change (if (2 : ℕ) = 0 then (1 : Fin 2) else 0)
          = (if (1 : ℕ) = 0 then (1 : Fin 2) else 0)
        rfl
      · have hv' : v = (⟨2, by decide⟩ : Fin 3) := Fin.ext hv
        rw [hv', Equiv.swap_apply_right]
        change (if (1 : ℕ) = 0 then (1 : Fin 2) else 0)
          = (if (2 : ℕ) = 0 then (1 : Fin 2) else 0)
        rfl
  · intro i
    have hi : i = (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) := by
      obtain ⟨v, hv⟩ := i
      have h_size : vertexBlackType.size = 1 := rfl
      have hv' : v < 1 := h_size ▸ hv
      have : v = 0 := by omega
      ext; exact this
    rw [hi]
    change Equiv.swap (⟨1, by decide⟩ : Fin 3) ⟨2, by decide⟩
      (vbExt2_RR_indep.embedding ⟨0, Nat.zero_lt_one⟩) = _
    have hemb : vbExt2_RR_indep.embedding (⟨0, Nat.zero_lt_one⟩ : Fin 1) =
      (⟨0, by decide⟩ : Fin 3) := rfl
    rw [hemb]
    simp [Equiv.swap_apply_of_ne_of_ne]

/-- For any σ-iso φ of vbExt2_RR_indep, σ-compat forces φ ⟨0,_⟩ = ⟨0,_⟩.
    By injectivity, φ either fixes ⟨1,_⟩, ⟨2,_⟩ (= id) or swaps them (= swapIso).
    Hence Aut = 2. -/
theorem vbExt2_RR_indep_aut :
    genFlagAutCount CG2 vertexBlackType vbExt2_RR_indep = 2 := by
  classical
  unfold genFlagAutCount genInducedCount
  rw [Fintype.card_eq_nat_card]
  let id_iso : GenInducedEmbedding CG2 vertexBlackType vbExt2_RR_indep vbExt2_RR_indep :=
    { toFun := id, injective := Function.injective_id,
      isInduced := CG2.comap_id _, compat := fun _ => rfl }
  rw [Nat.card_eq_two_iff' id_iso]
  refine ⟨vbExt2_RR_indep_swapIso, ?_, ?_⟩
  · -- swap ≠ id (toFun differs at ⟨1,_⟩)
    intro h
    have h1 : vbExt2_RR_indep_swapIso.toFun (⟨1, by decide⟩ : Fin 3) =
              id_iso.toFun (⟨1, by decide⟩ : Fin 3) :=
      congr_arg (fun e : GenInducedEmbedding CG2 vertexBlackType
                            vbExt2_RR_indep vbExt2_RR_indep =>
                  e.toFun (⟨1, by decide⟩ : Fin 3)) h
    -- LHS: swap ⟨1,_⟩ = ⟨2,_⟩.  RHS: id ⟨1,_⟩ = ⟨1,_⟩.
    change False
    simp only [id_iso, id_eq] at h1
    change Equiv.swap (⟨1, by decide⟩ : Fin 3) ⟨2, by decide⟩ ⟨1, by decide⟩ =
      (⟨1, by decide⟩ : Fin 3) at h1
    rw [Equiv.swap_apply_left] at h1
    have : (2 : ℕ) = 1 := congr_arg Fin.val h1
    omega
  · -- ∀ y ≠ id, y = swap
    rintro ⟨f, finj, find, fcompat⟩ hy
    -- σ-compat: f ⟨0,_⟩ = ⟨0,_⟩.
    have h_f0 : f (⟨0, by omega⟩ : Fin 3) = (⟨0, by omega⟩ : Fin 3) :=
      fcompat (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size)
    -- f ⟨1,_⟩ has val ∈ {0, 1, 2}. = 0 contradicts injectivity (with h_f0).
    -- So either = 1 (yielding id) or = 2 (yielding swap).
    rcases fin3_val_cases (f (⟨1, by decide⟩ : Fin 3)) with h0 | h1 | h2
    · -- f ⟨1,_⟩ = ⟨0,_⟩ contradicts injectivity
      exfalso
      have h_eq : f (⟨1, by omega⟩ : Fin 3) = (⟨0, by omega⟩ : Fin 3) := Fin.ext h0
      have h_inj : (⟨1, by omega⟩ : Fin 3) = (⟨0, by omega⟩ : Fin 3) :=
        finj (h_eq.trans h_f0.symm)
      have hval : (1 : ℕ) = 0 := congr_arg Fin.val h_inj
      omega
    · -- f ⟨1,_⟩ = ⟨1,_⟩ ⟹ f = id ⟹ y = id_iso, contradicting hy
      exfalso
      apply hy
      have h_f1 : f (⟨1, by omega⟩ : Fin 3) = (⟨1, by omega⟩ : Fin 3) := Fin.ext h1
      have h_f2 : f (⟨2, by omega⟩ : Fin 3) = (⟨2, by omega⟩ : Fin 3) := by
        rcases fin3_val_cases (f (⟨2, by decide⟩ : Fin 3)) with k0 | k1 | k2
        · exfalso
          have h_eq : f (⟨2, by omega⟩ : Fin 3) = (⟨0, by omega⟩ : Fin 3) := Fin.ext k0
          have h_inj : (⟨2, by omega⟩ : Fin 3) = (⟨0, by omega⟩ : Fin 3) :=
            finj (h_eq.trans h_f0.symm)
          have hval : (2 : ℕ) = 0 := congr_arg Fin.val h_inj
          omega
        · exfalso
          have h_eq : f (⟨2, by omega⟩ : Fin 3) = (⟨1, by omega⟩ : Fin 3) := Fin.ext k1
          have h_inj : (⟨2, by omega⟩ : Fin 3) = (⟨1, by omega⟩ : Fin 3) :=
            finj (h_eq.trans h_f1.symm)
          have hval : (2 : ℕ) = 1 := congr_arg Fin.val h_inj
          omega
        · ext; exact k2
      change ({ toFun := f, injective := finj, isInduced := find, compat := fcompat
              : GenInducedEmbedding _ _ _ _ } : _) = id_iso
      simp only [id_iso]
      congr 1
      funext x
      rcases fin3_val_cases x with k0 | k1 | k2
      · have : x = (⟨0, by omega⟩ : Fin 3) := Fin.ext k0
        rw [this, h_f0]; rfl
      · have : x = (⟨1, by omega⟩ : Fin 3) := Fin.ext k1
        rw [this, h_f1]; rfl
      · have : x = (⟨2, by omega⟩ : Fin 3) := Fin.ext k2
        rw [this, h_f2]; rfl
    · -- f ⟨1,_⟩ = ⟨2,_⟩, hence f ⟨2,_⟩ = ⟨1,_⟩, hence f = swap
      have h_f1 : f (⟨1, by omega⟩ : Fin 3) = (⟨2, by omega⟩ : Fin 3) := Fin.ext h2
      have h_f2 : f (⟨2, by omega⟩ : Fin 3) = (⟨1, by omega⟩ : Fin 3) := by
        rcases fin3_val_cases (f (⟨2, by decide⟩ : Fin 3)) with k0 | k1 | k2
        · exfalso
          have h_eq : f (⟨2, by omega⟩ : Fin 3) = (⟨0, by omega⟩ : Fin 3) := Fin.ext k0
          have h_inj : (⟨2, by omega⟩ : Fin 3) = (⟨0, by omega⟩ : Fin 3) :=
            finj (h_eq.trans h_f0.symm)
          have hval : (2 : ℕ) = 0 := congr_arg Fin.val h_inj
          omega
        · ext; exact k1
        · exfalso
          have h_eq : f (⟨2, by omega⟩ : Fin 3) = (⟨2, by omega⟩ : Fin 3) := Fin.ext k2
          have h_inj : (⟨2, by omega⟩ : Fin 3) = (⟨1, by omega⟩ : Fin 3) :=
            finj (h_eq.trans h_f1.symm)
          have hval : (2 : ℕ) = 1 := congr_arg Fin.val h_inj
          omega
      congr 1
      funext x
      rcases fin3_val_cases x with k0 | k1 | k2
      · have hx : x = (⟨0, by omega⟩ : Fin 3) := Fin.ext k0
        rw [hx, h_f0]
        change (⟨0, by decide⟩ : Fin 3) =
          Equiv.swap (⟨1, by decide⟩ : Fin 3) ⟨2, by decide⟩ ⟨0, by decide⟩
        rw [Equiv.swap_apply_of_ne_of_ne (by decide) (by decide)]
      · have hx : x = (⟨1, by omega⟩ : Fin 3) := Fin.ext k1
        rw [hx, h_f1]
        change (⟨2, by decide⟩ : Fin 3) =
          Equiv.swap (⟨1, by decide⟩ : Fin 3) ⟨2, by decide⟩ ⟨1, by decide⟩
        rw [Equiv.swap_apply_left]
      · have hx : x = (⟨2, by omega⟩ : Fin 3) := Fin.ext k2
        rw [hx, h_f2]
        change (⟨1, by decide⟩ : Fin 3) =
          Equiv.swap (⟨1, by decide⟩ : Fin 3) ⟨2, by decide⟩ ⟨2, by decide⟩
        rw [Equiv.swap_apply_right]

/-- vbExt2_RB_edge_aut = 1 (analogous to RB_indep, the leaf-leaf edge doesn't
    affect the σ-iso constraint — the colour distinction alone forces identity). -/
theorem vbExt2_RB_edge_aut :
    genFlagAutCount CG2 vertexBlackType vbExt2_RB_edge = 1 := by
  unfold genFlagAutCount genInducedCount
  rw [Fintype.card_eq_one_iff]
  refine ⟨{ toFun := id, injective := Function.injective_id,
            isInduced := CG2.comap_id _, compat := fun _ => rfl }, ?_⟩
  rintro ⟨f, finj, find, fcompat⟩
  congr 1
  have h_f0 : f (⟨0, by omega⟩ : Fin 3) = (⟨0, by omega⟩ : Fin 3) :=
    fcompat (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size)
  have h_col_1 := congr_arg
    (fun s : CG2.Str 3 => s.2 (⟨1, by omega⟩ : Fin 3)) find
  have h_red_at_1 : vbExt2_RB_edge.str.2 (⟨1, by omega⟩ : Fin 3) = (0 : Fin 2) := by
    change (if (1 : ℕ) = 0 then (1 : Fin 2) else if (1 : ℕ) = 1 then 0 else 1) = 0
    simp
  have h_f1 : f (⟨1, by omega⟩ : Fin 3) = (⟨1, by omega⟩ : Fin 3) := by
    rcases fin3_val_cases (f (⟨1, by decide⟩ : Fin 3)) with h0 | h1 | h2
    · exfalso
      have h_eq : f (⟨1, by omega⟩ : Fin 3) = (⟨0, by omega⟩ : Fin 3) := Fin.ext h0
      have h_inj : (⟨1, by omega⟩ : Fin 3) = (⟨0, by omega⟩ : Fin 3) :=
        finj (h_eq.trans h_f0.symm)
      have hval : (1 : ℕ) = 0 := congr_arg Fin.val h_inj
      omega
    · ext; exact h1
    · exfalso
      have h_f1_eq : f (⟨1, by omega⟩ : Fin 3) = (⟨2, by omega⟩ : Fin 3) := Fin.ext h2
      have h_LHS : (CG2.comap f vbExt2_RB_edge.str).2 (⟨1, by omega⟩ : Fin 3) =
          vbExt2_RB_edge.str.2 (⟨2, by omega⟩ : Fin 3) := by
        change vbExt2_RB_edge.str.2 (f ⟨1, by omega⟩) = _
        rw [h_f1_eq]
      have h_black_at_2 : vbExt2_RB_edge.str.2 (⟨2, by omega⟩ : Fin 3) = (1 : Fin 2) := by
        change (if (2 : ℕ) = 0 then (1 : Fin 2) else if (2 : ℕ) = 1 then 0 else 1) = 1
        simp
      have h_col_1' : (CG2.comap f vbExt2_RB_edge.str).2 (⟨1, by decide⟩ : Fin 3) =
          vbExt2_RB_edge.str.2 (⟨1, by decide⟩ : Fin 3) := h_col_1
      rw [h_LHS] at h_col_1'
      rw [h_red_at_1, h_black_at_2] at h_col_1'
      exact absurd h_col_1' (by decide)
  have h_f2 : f (⟨2, by omega⟩ : Fin 3) = (⟨2, by omega⟩ : Fin 3) := by
    rcases fin3_val_cases (f (⟨2, by decide⟩ : Fin 3)) with h0 | h1 | h2
    · exfalso
      have h_eq : f (⟨2, by omega⟩ : Fin 3) = (⟨0, by omega⟩ : Fin 3) := Fin.ext h0
      have h_inj : (⟨2, by omega⟩ : Fin 3) = (⟨0, by omega⟩ : Fin 3) :=
        finj (h_eq.trans h_f0.symm)
      have hval : (2 : ℕ) = 0 := congr_arg Fin.val h_inj
      omega
    · exfalso
      have h_eq : f (⟨2, by omega⟩ : Fin 3) = (⟨1, by omega⟩ : Fin 3) := Fin.ext h1
      have h_inj : (⟨2, by omega⟩ : Fin 3) = (⟨1, by omega⟩ : Fin 3) :=
        finj (h_eq.trans h_f1.symm)
      have hval : (2 : ℕ) = 1 := congr_arg Fin.val h_inj
      omega
    · ext; exact h2
  funext x
  rcases fin3_val_cases x with h0 | h1 | h2
