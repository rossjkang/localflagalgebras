/-! ### σ-position-3 master dispatch theorem `any_size4_sigma3_extAdjAll_iso`

Given a size-4 σ-flag at `vertexBlackType` whose σ-vertex sits at position 3 and
is adjacent to the three leaf positions 0, 1, 2, classify G into one of the 20
canonical `vbExt3_*` flags. The proof case-splits on:

* leaf colours `(c0, c1, c2) ∈ {0,1}³` (8 patterns), and
* leaf-leaf edges `({0,1}, {0,2}, {1,2})` (8 patterns).

For each of the 64 sub-cases, we apply one of the σ-position-3 helpers
(canonical/`swap03`, swap03_swap-12/13/23, or swap03_cycle 123/132) targeting the
appropriate canonical flag, then close the 20-way disjunction with `tauto`. -/

set_option maxHeartbeats 4000000 in
/-- Master classification: σ-position-3 size-4 σ-flag where σ is adjacent to all
three leaves is iso to one of the 20 `vbExt3_*` flags. -/
private theorem any_size4_sigma3_extAdjAll_iso
    (G_str : CG2.Str 4) (G_emb : Fin vertexBlackType.size ↪ Fin 4)
    (G_isInd : CG2.comap G_emb G_str = vertexBlackType.str)
    (G_hsize : vertexBlackType.size ≤ 4)
    (hemb3 : (G_emb ⟨0, Nat.zero_lt_one⟩).val = 3)
    (hadj_all : ∀ v : Fin 4, v ≠ G_emb ⟨0, Nat.zero_lt_one⟩ →
                 G_str.1.Adj (G_emb ⟨0, Nat.zero_lt_one⟩) v) :
    GenFlagIso vertexBlackType
      (⟨4, G_str, G_emb, G_isInd, G_hsize⟩ : GenFlag CG2 vertexBlackType)
      vbExt3_RRR_e0 ∨
    GenFlagIso vertexBlackType
      (⟨4, G_str, G_emb, G_isInd, G_hsize⟩ : GenFlag CG2 vertexBlackType)
      vbExt3_RRR_e1 ∨
    GenFlagIso vertexBlackType
      (⟨4, G_str, G_emb, G_isInd, G_hsize⟩ : GenFlag CG2 vertexBlackType)
      vbExt3_RRR_e2 ∨
    GenFlagIso vertexBlackType
      (⟨4, G_str, G_emb, G_isInd, G_hsize⟩ : GenFlag CG2 vertexBlackType)
      vbExt3_RRR_e3 ∨
    GenFlagIso vertexBlackType
      (⟨4, G_str, G_emb, G_isInd, G_hsize⟩ : GenFlag CG2 vertexBlackType)
      vbExt3_BBB_e0 ∨
    GenFlagIso vertexBlackType
      (⟨4, G_str, G_emb, G_isInd, G_hsize⟩ : GenFlag CG2 vertexBlackType)
      vbExt3_BBB_e1 ∨
    GenFlagIso vertexBlackType
      (⟨4, G_str, G_emb, G_isInd, G_hsize⟩ : GenFlag CG2 vertexBlackType)
      vbExt3_BBB_e2 ∨
    GenFlagIso vertexBlackType
      (⟨4, G_str, G_emb, G_isInd, G_hsize⟩ : GenFlag CG2 vertexBlackType)
      vbExt3_BBB_e3 ∨
    GenFlagIso vertexBlackType
      (⟨4, G_str, G_emb, G_isInd, G_hsize⟩ : GenFlag CG2 vertexBlackType)
      vbExt3_RRB_e0 ∨
    GenFlagIso vertexBlackType
      (⟨4, G_str, G_emb, G_isInd, G_hsize⟩ : GenFlag CG2 vertexBlackType)
      vbExt3_RRB_e1_RR ∨
    GenFlagIso vertexBlackType
      (⟨4, G_str, G_emb, G_isInd, G_hsize⟩ : GenFlag CG2 vertexBlackType)
      vbExt3_RRB_e1_RB ∨
    GenFlagIso vertexBlackType
      (⟨4, G_str, G_emb, G_isInd, G_hsize⟩ : GenFlag CG2 vertexBlackType)
      vbExt3_RRB_e2_RRRB ∨
    GenFlagIso vertexBlackType
      (⟨4, G_str, G_emb, G_isInd, G_hsize⟩ : GenFlag CG2 vertexBlackType)
      vbExt3_RRB_e2_RBRB ∨
    GenFlagIso vertexBlackType
      (⟨4, G_str, G_emb, G_isInd, G_hsize⟩ : GenFlag CG2 vertexBlackType)
      vbExt3_RRB_e3 ∨
    GenFlagIso vertexBlackType
      (⟨4, G_str, G_emb, G_isInd, G_hsize⟩ : GenFlag CG2 vertexBlackType)
      vbExt3_RBB_e0 ∨
    GenFlagIso vertexBlackType
      (⟨4, G_str, G_emb, G_isInd, G_hsize⟩ : GenFlag CG2 vertexBlackType)
      vbExt3_RBB_e1_RB ∨
    GenFlagIso vertexBlackType
      (⟨4, G_str, G_emb, G_isInd, G_hsize⟩ : GenFlag CG2 vertexBlackType)
      vbExt3_RBB_e1_BB ∨
    GenFlagIso vertexBlackType
      (⟨4, G_str, G_emb, G_isInd, G_hsize⟩ : GenFlag CG2 vertexBlackType)
      vbExt3_RBB_e2_RBBB ∨
    GenFlagIso vertexBlackType
      (⟨4, G_str, G_emb, G_isInd, G_hsize⟩ : GenFlag CG2 vertexBlackType)
      vbExt3_RBB_e2_RBRB ∨
    GenFlagIso vertexBlackType
      (⟨4, G_str, G_emb, G_isInd, G_hsize⟩ : GenFlag CG2 vertexBlackType)
      vbExt3_RBB_e3 := by
  -- σ-vertex at position 3; σ adjacent to leaves at positions 0, 1, 2.
  have h_emb_G : (G_emb ⟨0, Nat.zero_lt_one⟩).val = 3 := hemb3
  have h_emb_eq : G_emb (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) =
      (⟨3, by decide⟩ : Fin 4) := Fin.ext h_emb_G
  have h_emb_neq_0 : G_emb (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) ≠
      (⟨0, by decide⟩ : Fin 4) := by rw [h_emb_eq]; decide
  have h_emb_neq_1 : G_emb (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) ≠
      (⟨1, by decide⟩ : Fin 4) := by rw [h_emb_eq]; decide
  have h_emb_neq_2 : G_emb (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) ≠
      (⟨2, by decide⟩ : Fin 4) := by rw [h_emb_eq]; decide
  -- Recover σ-leaf adjacencies from `hadj_all`. σ-vertex sits at G-pos 3.
  have h_adj_03' : G_str.1.Adj (⟨3, by decide⟩ : Fin 4) (⟨0, by decide⟩ : Fin 4) := by
    have := hadj_all (⟨0, by decide⟩ : Fin 4) h_emb_neq_0.symm
    rwa [h_emb_eq] at this
  have h_adj_13' : G_str.1.Adj (⟨3, by decide⟩ : Fin 4) (⟨1, by decide⟩ : Fin 4) := by
    have := hadj_all (⟨1, by decide⟩ : Fin 4) h_emb_neq_1.symm
