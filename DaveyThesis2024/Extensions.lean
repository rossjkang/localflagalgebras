    refine ⟨⟨4, by decide⟩, ?_, ?_⟩
    · rintro ⟨⟨j, hj⟩, hjeq⟩
      have : j < 4 := hj
      have hsize : thesisType1.size = 4 := rfl
      interval_cases j <;>
        simp [t1_v0_R, Fin.castLE, Fin.ext_iff, hsize] at hjeq
    · simp [t1_v0_R, SimpleGraph.fromRel_adj])

