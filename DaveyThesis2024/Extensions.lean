/-! ### Completeness: every size-2 σ-flag with ext-adj is iso to vbExtRed or vbExtBlack

The support equation `(extSum vertexBlackType ⟨0,_⟩).support = {mk vbExtRed, mk vbExtBlack}`
requires showing that any class `cls` in the filter is iso to one of these two.

For F : GenFlag CG2 vertexBlackType with F.size = 2:
- F.embedding(0) = some α ∈ Fin 2.
- The other vertex w = the unique element ≠ α has colour ∈ {0, 1}.
- ext-adjacency forces F.str.1 to have the edge (α, w).
- F.isInduced forces F.str.2 α = 1 (black, the σ-colour).
- If F.str.2 w = 0, F is iso to vbExtRed (red leaf).
- If F.str.2 w = 1, F is iso to vbExtBlack (black leaf).

The iso construction is via Equiv.swap or Equiv.refl, depending on whether
α = ⟨0,_⟩ or ⟨1,_⟩. -/

/-- For F : size-2 σ-flag at vertexBlackType, F.embedding(0) is either
    ⟨0, _⟩ or ⟨1, _⟩ in Fin 2 (as nat values). -/
private theorem size2_embedding_cases (F : GenFlag CG2 vertexBlackType)
    (hsize : F.size = 2) :
    (F.embedding ⟨0, Nat.zero_lt_one⟩).val = 0 ∨
    (F.embedding ⟨0, Nat.zero_lt_one⟩).val = 1 := by
  have hlt : (F.embedding ⟨0, Nat.zero_lt_one⟩).val < F.size :=
    (F.embedding ⟨0, Nat.zero_lt_one⟩).isLt
  omega

/-- The σ-vertex of any size-2 σ-flag at vertexBlackType has colour 1 (black),
    forced by `F.isInduced`. -/
private theorem size2_sigmaVertex_black (F : GenFlag CG2 vertexBlackType) :
    F.str.2 (F.embedding ⟨0, Nat.zero_lt_one⟩) = 1 := by
  -- F.isInduced says CG2.comap F.embedding F.str = vertexBlackType.str
  -- vertexBlackType.str.2 ⟨0, _⟩ = 1 (black σ-vertex)
  have h := F.isInduced
  -- (CG2.comap F.embedding F.str).2 ⟨0, _⟩ = vertexBlackType.str.2 ⟨0, _⟩ = 1
  have h_col := congr_arg (fun s : CG2.Str vertexBlackType.size =>
    s.2 ⟨0, Nat.zero_lt_one⟩) h
  -- LHS: (F.str.2 ∘ F.embedding) ⟨0, _⟩ = F.str.2 (F.embedding ⟨0, _⟩)
  exact h_col

/-- The only edges possible in `Fin 2` are between vertices 0 and 1.
    For F of size 2, F.str.1 is determined by whether the (0,1)-edge exists. -/
private theorem fin2_adj_iff {G : SimpleGraph (Fin 2)} (u v : Fin 2) :
    G.Adj u v ↔
      ((u.val = 0 ∧ v.val = 1) ∨ (u.val = 1 ∧ v.val = 0)) ∧
      G.Adj ⟨0, Nat.zero_lt_two⟩ ⟨1, Nat.one_lt_two⟩ := by
  constructor
  · intro hadj
    have hne : u ≠ v := G.ne_of_adj hadj
    have hu : u.val = 0 ∨ u.val = 1 := fin2_eq_zero_or_one u
    have hv : v.val = 0 ∨ v.val = 1 := fin2_eq_zero_or_one v
    rcases hu with hu0 | hu1 <;> rcases hv with hv0 | hv1
    · -- both 0
      exfalso; apply hne; ext; rw [hu0, hv0]
    · -- u=0, v=1
      refine ⟨Or.inl ⟨hu0, hv1⟩, ?_⟩
      have h_eq : u = ⟨0, Nat.zero_lt_two⟩ := Fin.ext hu0
      have h_eq' : v = ⟨1, Nat.one_lt_two⟩ := Fin.ext hv1
      rw [← h_eq, ← h_eq']; exact hadj
    · -- u=1, v=0
      refine ⟨Or.inr ⟨hu1, hv0⟩, ?_⟩
      have h_eq : u = ⟨1, Nat.one_lt_two⟩ := Fin.ext hu1
      have h_eq' : v = ⟨0, Nat.zero_lt_two⟩ := Fin.ext hv0
      rw [← h_eq, ← h_eq']; exact hadj.symm
    · -- both 1
      exfalso; apply hne; ext; rw [hu1, hv1]
  · rintro ⟨h_or, hadj01⟩
    rcases h_or with ⟨hu0, hv1⟩ | ⟨hu1, hv0⟩
    · have h_eq : u = ⟨0, Nat.zero_lt_two⟩ := Fin.ext hu0
      have h_eq' : v = ⟨1, Nat.one_lt_two⟩ := Fin.ext hv1
      rw [h_eq, h_eq']; exact hadj01
    · have h_eq : u = ⟨1, Nat.one_lt_two⟩ := Fin.ext hu1
      have h_eq' : v = ⟨0, Nat.zero_lt_two⟩ := Fin.ext hv0
      rw [h_eq, h_eq']; exact hadj01.symm

/-- For any size-2 σ-flag F at vertexBlackType with extAdjacency at i=0,
    F.str.1 has the (0,1)-edge (when F.size = 2, viewed via Fin.cast). -/
private theorem size2_extAdj_has_edge (F : GenFlag CG2 vertexBlackType)
    (hsize : F.size = 2)
    (hadj : extAdjacency vertexBlackType F ⟨0, Nat.zero_lt_one⟩) :
    F.str.1.Adj (Fin.cast hsize.symm ⟨0, Nat.zero_lt_two⟩)
                (Fin.cast hsize.symm ⟨1, Nat.one_lt_two⟩) := by
  obtain ⟨v, hv_notin, hv_adj⟩ := hadj
  -- F.embedding ⟨0,_⟩ has val 0 or 1.
  have hcase := size2_embedding_cases F hsize
  -- v has val 0 or 1, opposite of F.embedding ⟨0,_⟩.
  have hv_lt : v.val < F.size := v.isLt
  -- v ∉ Im F.embedding means v ≠ F.embedding ⟨0,_⟩.
  have hv_ne : v ≠ F.embedding ⟨0, Nat.zero_lt_one⟩ := fun h_eq => by
    apply hv_notin
    exact ⟨⟨0, Nat.zero_lt_one⟩, h_eq.symm⟩
  -- Both v and F.embedding ⟨0,_⟩ are in Fin F.size = Fin 2, distinct.
  -- So {v, F.embedding ⟨0,_⟩} = {⟨0,_⟩, ⟨1,_⟩} (Fin F.size cast).
  rcases hcase with h0 | h1
  · -- F.embedding ⟨0,_⟩ has val 0; so v has val 1.
    have hv_val : v.val = 1 := by
      have hne_val : v.val ≠ 0 := fun h => hv_ne (by ext; rw [h]; exact h0.symm)
      have : v.val < 2 := hsize ▸ hv_lt
      omega
    -- hv_adj : F.str.1.Adj v (F.embedding ⟨0, _⟩)
    -- Need: F.str.1.Adj (Fin.cast .. ⟨0,_⟩) (Fin.cast .. ⟨1,_⟩)
    have h_emb_eq : (F.embedding ⟨0, Nat.zero_lt_one⟩) =
        Fin.cast hsize.symm ⟨0, Nat.zero_lt_two⟩ := Fin.ext (h0.trans rfl)
    have h_v_eq : v = Fin.cast hsize.symm ⟨1, Nat.one_lt_two⟩ := Fin.ext hv_val
    rw [h_emb_eq, h_v_eq] at hv_adj
    exact hv_adj.symm
  · -- F.embedding ⟨0,_⟩ has val 1; so v has val 0.
    have hv_val : v.val = 0 := by
      have hne_val : v.val ≠ 1 := fun h => hv_ne (by ext; rw [h]; exact h1.symm)
      have : v.val < 2 := hsize ▸ hv_lt
      omega
    have h_emb_eq : (F.embedding ⟨0, Nat.zero_lt_one⟩) =
        Fin.cast hsize.symm ⟨1, Nat.one_lt_two⟩ := Fin.ext (h1.trans rfl)
    have h_v_eq : v = Fin.cast hsize.symm ⟨0, Nat.zero_lt_two⟩ := Fin.ext hv_val
    rw [h_emb_eq, h_v_eq] at hv_adj
    exact hv_adj

/-- vbExtRed.str.1 has the (0,1) edge. -/
theorem vbExtRed_adj_01 :
    vbExtRed.str.1.Adj (⟨0, Nat.zero_lt_two⟩ : Fin 2) ⟨1, Nat.one_lt_two⟩ := by
  change (SimpleGraph.fromRel
    (fun u v : Fin 2 => (u.val = 0 ∧ v.val = 1) ∨ (u.val = 1 ∧ v.val = 0))).Adj _ _
  simp [SimpleGraph.fromRel]

/-- vbExtBlack.str.1 has the (0,1) edge. -/
theorem vbExtBlack_adj_01 :
    vbExtBlack.str.1.Adj (⟨0, Nat.zero_lt_two⟩ : Fin 2) ⟨1, Nat.one_lt_two⟩ := by
  change (SimpleGraph.fromRel
    (fun u v : Fin 2 => (u.val = 0 ∧ v.val = 1) ∨ (u.val = 1 ∧ v.val = 0))).Adj _ _
  simp [SimpleGraph.fromRel]

/-- A specialisation of the iso construction, working directly with size-2
    flags by `cases F; subst hsize` to eliminate Fin.cast complications.

    Statement: any GenFlag CG2 vertexBlackType with `size := 2` (literal 2)
    and the right structure (canonical embedding, edge (0,1), red leaf)
    is iso to vbExtRed. -/
theorem genFlag_size2_canonical_red_iso_vbExtRed
    (F_str : CG2.Str 2)
    (F_emb : Fin vertexBlackType.size ↪ Fin 2)
    (F_isInd : CG2.comap F_emb F_str = vertexBlackType.str)
    (F_hsize : vertexBlackType.size ≤ 2)
    (hemb_val : (F_emb ⟨0, Nat.zero_lt_one⟩).val = 0)
    (hgraph : F_str.1 = vbExtRed.str.1)
    (hcol1 : F_str.2 ⟨1, Nat.one_lt_two⟩ = 0) :
    GenFlagIso vertexBlackType
      (⟨2, F_str, F_emb, F_isInd, F_hsize⟩ : GenFlag CG2 vertexBlackType) vbExtRed := by
  -- φ = id : Fin 2 ≃ Fin 2.
  refine ⟨Equiv.refl (Fin 2), ?_, ?_⟩
  · -- comap (id) vbExtRed.str = F_str.
    change CG2.comap (Equiv.refl (Fin 2)) vbExtRed.str = F_str
    rw [show (Equiv.refl (Fin 2) : Fin 2 → Fin 2) = id from rfl, CG2.comap_id]
    -- Show vbExtRed.str = F_str. CG2.Str 2 = SimpleGraph (Fin 2) × (Fin 2 → Fin 2).
    apply Prod.ext
    · change vbExtRed.str.1 = F_str.1
      rw [hgraph]
    · change vbExtRed.str.2 = F_str.2
      funext v
      have hv : v.val = 0 ∨ v.val = 1 := fin2_eq_zero_or_one v
      rcases hv with h0 | h1
      · have hv_eq : v = ⟨0, Nat.zero_lt_two⟩ := Fin.ext h0
        rw [hv_eq]
        have hemb_eq : F_emb ⟨0, Nat.zero_lt_one⟩ = ⟨0, Nat.zero_lt_two⟩ :=
          Fin.ext hemb_val
        have h_F_at_0 : F_str.2 ⟨0, Nat.zero_lt_two⟩ = 1 := by
          rw [← hemb_eq]
          have := congr_arg (fun s : CG2.Str vertexBlackType.size =>
            s.2 ⟨0, Nat.zero_lt_one⟩) F_isInd
          exact this
        rw [h_F_at_0]; rfl
      · have hv_eq : v = ⟨1, Nat.one_lt_two⟩ := Fin.ext h1
        rw [hv_eq]
        rw [hcol1]
        rfl
  · -- σ-compat: φ (F_emb i) = vbExtRed.embedding i.
    intro i
    -- vertexBlackType.size = 1, so i is determined.
    have hi : i = (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) := by
      obtain ⟨v, hv⟩ := i
      have h_size : vertexBlackType.size = 1 := rfl
      have hv' : v < 1 := h_size ▸ hv
      have : v = 0 := by omega
      ext; exact this
    rw [hi]
    change (Equiv.refl (Fin 2)) (F_emb ⟨0, Nat.zero_lt_one⟩) =
      vbExtRed.embedding ⟨0, Nat.zero_lt_one⟩
    rw [show (Equiv.refl (Fin 2) : Fin 2 → Fin 2) = id from rfl]
    change F_emb ⟨0, Nat.zero_lt_one⟩ = ⟨0, Nat.zero_lt_two⟩
    exact Fin.ext hemb_val

/-- Swap-case iso: when F.embedding(0).val = 1 (σ-vertex at position 1) and
    F.str.2 ⟨0,_⟩ = 0 (red leaf at position 0), F is iso to vbExtRed via
    `Equiv.swap ⟨0,_⟩ ⟨1,_⟩`. -/
theorem genFlag_size2_swap_red_iso_vbExtRed
    (F_str : CG2.Str 2)
    (F_emb : Fin vertexBlackType.size ↪ Fin 2)
    (F_isInd : CG2.comap F_emb F_str = vertexBlackType.str)
    (F_hsize : vertexBlackType.size ≤ 2)
    (hemb_val : (F_emb ⟨0, Nat.zero_lt_one⟩).val = 1)
    (hgraph : F_str.1 = vbExtRed.str.1)
    (hcol0 : F_str.2 ⟨0, Nat.zero_lt_two⟩ = 0) :
    GenFlagIso vertexBlackType
      (⟨2, F_str, F_emb, F_isInd, F_hsize⟩ : GenFlag CG2 vertexBlackType) vbExtRed := by
  -- φ = swap of ⟨0, _⟩ and ⟨1, _⟩ in Fin 2.
  classical
  refine ⟨Equiv.swap (⟨0, Nat.zero_lt_two⟩ : Fin 2) ⟨1, Nat.one_lt_two⟩, ?_, ?_⟩
  · -- comap φ vbExtRed.str = F_str
    change CG2.comap (Equiv.swap (⟨0, Nat.zero_lt_two⟩ : Fin 2) ⟨1, Nat.one_lt_two⟩)
      vbExtRed.str = F_str
    apply Prod.ext
    · -- Graph: swap of vbExtRed.str.1 = F_str.1.
      -- vbExtRed.str.1 has (0,1) edge symmetrically; swap preserves it.
      change vbExtRed.str.1.comap (Equiv.swap _ _) = F_str.1
      rw [hgraph]
      -- F_str.1.comap (swap) = F_str.1 because F_str.1 = vbExtRed.str.1 has only (0,1) edge
      -- which swap maps to (1,0) (= same edge in undirected SimpleGraph).
      ext u v
      change vbExtRed.str.1.Adj _ _ ↔ vbExtRed.str.1.Adj _ _
      constructor <;> intro hadj
      · -- vbExtRed.str.1.Adj (swap u) (swap v) ⟹ vbExtRed.str.1.Adj u v
        rcases (fin2_adj_iff (Equiv.swap (⟨0, Nat.zero_lt_two⟩ : Fin 2)
          ⟨1, Nat.one_lt_two⟩ u) (Equiv.swap _ _ v)).mp hadj with ⟨h_or, _⟩
        rw [fin2_adj_iff]
        refine ⟨?_, vbExtRed_adj_01⟩
        -- Compute swap u .val and swap v .val based on u.val, v.val
        rcases h_or with ⟨hu, hv⟩ | ⟨hu, hv⟩
        · -- swap u has val 0 ⟹ u has val 1; swap v has val 1 ⟹ v has val 0.
          right
          refine ⟨?_, ?_⟩
          · have : u = (⟨1, Nat.one_lt_two⟩ : Fin 2) := by
              have h_swap_u : Equiv.swap (⟨0, Nat.zero_lt_two⟩ : Fin 2) ⟨1, Nat.one_lt_two⟩ u =
                ⟨0, Nat.zero_lt_two⟩ := Fin.ext hu
              -- swap is its own inverse
              have := congr_arg (Equiv.swap (⟨0, Nat.zero_lt_two⟩ : Fin 2) ⟨1, Nat.one_lt_two⟩)
                h_swap_u
              simp [Equiv.swap_apply_left] at this
              exact this
            rw [this]
          · have : v = (⟨0, Nat.zero_lt_two⟩ : Fin 2) := by
              have h_swap_v : Equiv.swap (⟨0, Nat.zero_lt_two⟩ : Fin 2) ⟨1, Nat.one_lt_two⟩ v =
                ⟨1, Nat.one_lt_two⟩ := Fin.ext hv
              have := congr_arg (Equiv.swap (⟨0, Nat.zero_lt_two⟩ : Fin 2) ⟨1, Nat.one_lt_two⟩)
                h_swap_v
              simp [Equiv.swap_apply_right] at this
              exact this
            rw [this]
        · -- analogous: swap u .val = 1 ⟹ u .val = 0; swap v .val = 0 ⟹ v .val = 1.
          left
          refine ⟨?_, ?_⟩
          · have : u = (⟨0, Nat.zero_lt_two⟩ : Fin 2) := by
              have h_swap_u : Equiv.swap (⟨0, Nat.zero_lt_two⟩ : Fin 2) ⟨1, Nat.one_lt_two⟩ u =
                ⟨1, Nat.one_lt_two⟩ := Fin.ext hu
              have := congr_arg (Equiv.swap (⟨0, Nat.zero_lt_two⟩ : Fin 2) ⟨1, Nat.one_lt_two⟩)
                h_swap_u
              simp [Equiv.swap_apply_right] at this
              exact this
            rw [this]
          · have : v = (⟨1, Nat.one_lt_two⟩ : Fin 2) := by
              have h_swap_v : Equiv.swap (⟨0, Nat.zero_lt_two⟩ : Fin 2) ⟨1, Nat.one_lt_two⟩ v =
                ⟨0, Nat.zero_lt_two⟩ := Fin.ext hv
              have := congr_arg (Equiv.swap (⟨0, Nat.zero_lt_two⟩ : Fin 2) ⟨1, Nat.one_lt_two⟩)
                h_swap_v
              simp [Equiv.swap_apply_left] at this
              exact this
            rw [this]
      · -- Reverse: vbExtRed.str.1.Adj u v ⟹ vbExtRed.str.1.Adj (swap u) (swap v)
        rcases (fin2_adj_iff u v).mp hadj with ⟨h_or, _⟩
        rw [fin2_adj_iff]
        refine ⟨?_, vbExtRed_adj_01⟩
        rcases h_or with ⟨hu, hv⟩ | ⟨hu, hv⟩
        · right
          refine ⟨?_, ?_⟩
          · have h_eq : u = (⟨0, Nat.zero_lt_two⟩ : Fin 2) := Fin.ext hu
            rw [h_eq]; simp [Equiv.swap_apply_left]
          · have h_eq : v = (⟨1, Nat.one_lt_two⟩ : Fin 2) := Fin.ext hv
            rw [h_eq]; simp [Equiv.swap_apply_right]
        · left
          refine ⟨?_, ?_⟩
          · have h_eq : u = (⟨1, Nat.one_lt_two⟩ : Fin 2) := Fin.ext hu
            rw [h_eq]; simp [Equiv.swap_apply_right]
          · have h_eq : v = (⟨0, Nat.zero_lt_two⟩ : Fin 2) := Fin.ext hv
            rw [h_eq]; simp [Equiv.swap_apply_left]
    · -- Colour: (vbExtRed.str.2 ∘ swap) = F_str.2
      change vbExtRed.str.2 ∘ (Equiv.swap (⟨0, Nat.zero_lt_two⟩ : Fin 2) ⟨1, Nat.one_lt_two⟩) =
        F_str.2
      funext v
      have hv : v.val = 0 ∨ v.val = 1 := fin2_eq_zero_or_one v
      rcases hv with h0 | h1
      · -- v = ⟨0, _⟩: swap → ⟨1, _⟩. vbExtRed.str.2 ⟨1, _⟩ = 0 = F_str.2 ⟨0, _⟩ (hcol0).
        have hv_eq : v = (⟨0, Nat.zero_lt_two⟩ : Fin 2) := Fin.ext h0
        rw [hv_eq]
        change vbExtRed.str.2 (Equiv.swap (⟨0, Nat.zero_lt_two⟩ : Fin 2)
          ⟨1, Nat.one_lt_two⟩ ⟨0, Nat.zero_lt_two⟩) = F_str.2 ⟨0, Nat.zero_lt_two⟩
        rw [Equiv.swap_apply_left]
        rw [show vbExtRed.str.2 (⟨1, Nat.one_lt_two⟩ : Fin 2) = (0 : Fin 2) from rfl]
        rw [hcol0]
      · -- v = ⟨1, _⟩: swap → ⟨0, _⟩. vbExtRed.str.2 ⟨0, _⟩ = 1 = F_str.2 ⟨1, _⟩ (σ-vertex).
        have hv_eq : v = (⟨1, Nat.one_lt_two⟩ : Fin 2) := Fin.ext h1
        rw [hv_eq]
        change vbExtRed.str.2 (Equiv.swap (⟨0, Nat.zero_lt_two⟩ : Fin 2)
          ⟨1, Nat.one_lt_two⟩ ⟨1, Nat.one_lt_two⟩) = F_str.2 ⟨1, Nat.one_lt_two⟩
        rw [Equiv.swap_apply_right]
        rw [show vbExtRed.str.2 (⟨0, Nat.zero_lt_two⟩ : Fin 2) = (1 : Fin 2) from rfl]
        -- F_str.2 ⟨1, _⟩ = 1 from F_isInd (σ-vertex is at position 1).
        have hemb_eq : F_emb ⟨0, Nat.zero_lt_one⟩ = ⟨1, Nat.one_lt_two⟩ :=
          Fin.ext hemb_val
        have h_F_at_1 : F_str.2 ⟨1, Nat.one_lt_two⟩ = 1 := by
          rw [← hemb_eq]
          exact congr_arg (fun s : CG2.Str vertexBlackType.size =>
            s.2 ⟨0, Nat.zero_lt_one⟩) F_isInd
        rw [h_F_at_1]
  · -- σ-compat: φ (F_emb ⟨0,_⟩) = vbExtRed.embedding ⟨0,_⟩
    intro i
    have hi : i = (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) := by
      obtain ⟨v, hv⟩ := i
      have h_size : vertexBlackType.size = 1 := rfl
      have hv' : v < 1 := h_size ▸ hv
      have : v = 0 := by omega
      ext; exact this
    rw [hi]
    change Equiv.swap (⟨0, Nat.zero_lt_two⟩ : Fin 2) ⟨1, Nat.one_lt_two⟩
      (F_emb ⟨0, Nat.zero_lt_one⟩) = vbExtRed.embedding ⟨0, Nat.zero_lt_one⟩
    have hemb_eq : F_emb ⟨0, Nat.zero_lt_one⟩ = (⟨1, Nat.one_lt_two⟩ : Fin 2) :=
      Fin.ext hemb_val
    rw [hemb_eq]
    rw [Equiv.swap_apply_right]
    rfl

/-- Swap-case iso for vbExtBlack: F.embedding(0).val = 1, F.str.2 ⟨0,_⟩ = 1
    (black leaf at position 0). -/
theorem genFlag_size2_swap_black_iso_vbExtBlack
    (F_str : CG2.Str 2)
    (F_emb : Fin vertexBlackType.size ↪ Fin 2)
    (F_isInd : CG2.comap F_emb F_str = vertexBlackType.str)
