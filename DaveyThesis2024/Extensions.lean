/-- `vbExt2_RR_edge` has leaf-leaf edge ⟨1⟩-⟨2⟩, but `vbExt3_RRR_e0` has no
    leaf-leaf edges (every edge in `vbExt3_RRR_e0` involves the σ-vertex
    ⟨0,_⟩). Pulling back forces one of f⟨1⟩, f⟨2⟩ to be ⟨0⟩, contradicting
    injectivity. -/
theorem genInducedCount_vbExt2_RR_edge_vbExt3_RRR_e0_eq_zero :
    genInducedCount CG2 vertexBlackType vbExt2_RR_edge vbExt3_RRR_e0 = 0 := by
  unfold genInducedCount
  rw [Fintype.card_eq_zero_iff]
  refine ⟨fun ⟨f, finj, find, fcompat⟩ => ?_⟩
  have h_f0 : f (⟨0, by omega⟩ : Fin 3) = (⟨0, by omega⟩ : Fin 4) :=
    fcompat (⟨0, Nat.zero_lt_one⟩ : Fin 1)
  -- Edge ⟨1⟩-⟨2⟩ in RR_edge.
  have h_F_adj : vbExt2_RR_edge.str.1.Adj
      (⟨1, by omega⟩ : Fin 3) (⟨2, by omega⟩ : Fin 3) := by
    simp [vbExt2_RR_edge, SimpleGraph.fromRel_adj]
  have h_G_adj : vbExt3_RRR_e0.str.1.Adj
      (f (⟨1, by omega⟩ : Fin 3)) (f (⟨2, by omega⟩ : Fin 3)) :=
    cg2_find_adj f find h_F_adj
  -- f ⟨1⟩ ≠ ⟨0⟩ (else 0=1 by injectivity vs h_f0).
  have h_f1_ne0 : f (⟨1, by omega⟩ : Fin 3) ≠ (⟨0, by omega⟩ : Fin 4) := by
    intro heq
    have : (⟨1, by omega⟩ : Fin 3) = (⟨0, by omega⟩ : Fin 3) := finj (heq.trans h_f0.symm)
    have : (1 : ℕ) = 0 := congr_arg Fin.val this; omega
  have h_f2_ne0 : f (⟨2, by omega⟩ : Fin 3) ≠ (⟨0, by omega⟩ : Fin 4) := by
    intro heq
    have : (⟨2, by omega⟩ : Fin 3) = (⟨0, by omega⟩ : Fin 3) := finj (heq.trans h_f0.symm)
    have : (2 : ℕ) = 0 := congr_arg Fin.val this; omega
  -- In RRR_e0, every edge has one endpoint = ⟨0⟩. Decode h_G_adj.
  rw [show vbExt3_RRR_e0.str.1 = SimpleGraph.fromRel _ from rfl] at h_G_adj
  rw [SimpleGraph.fromRel_adj] at h_G_adj
  obtain ⟨_, h_or⟩ := h_G_adj
  -- h_or is `r u v ∨ r v u` where each disjunct is a 6-way disjunction
  -- assigning val = 0 to one of {u, v} = {f⟨1⟩, f⟨2⟩}.
  rcases h_or with hrel | hrel
  · -- r (f⟨1⟩) (f⟨2⟩): every disjunct forces one of the vals to be 0.
    rcases hrel with ⟨ha, _⟩ | ⟨_, ha⟩ | ⟨ha, _⟩ | ⟨_, ha⟩ | ⟨ha, _⟩ | ⟨_, ha⟩
    · exact h_f1_ne0 (Fin.ext ha)
    · exact h_f2_ne0 (Fin.ext ha)
    · exact h_f1_ne0 (Fin.ext ha)
    · exact h_f2_ne0 (Fin.ext ha)
    · exact h_f1_ne0 (Fin.ext ha)
    · exact h_f2_ne0 (Fin.ext ha)
  · -- r (f⟨2⟩) (f⟨1⟩): symmetric.
    rcases hrel with ⟨ha, _⟩ | ⟨_, ha⟩ | ⟨ha, _⟩ | ⟨_, ha⟩ | ⟨ha, _⟩ | ⟨_, ha⟩
    · exact h_f2_ne0 (Fin.ext ha)
    · exact h_f1_ne0 (Fin.ext ha)
    · exact h_f2_ne0 (Fin.ext ha)
    · exact h_f1_ne0 (Fin.ext ha)
    · exact h_f2_ne0 (Fin.ext ha)
    · exact h_f1_ne0 (Fin.ext ha)

