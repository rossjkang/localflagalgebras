/-! #### Aut counts: cases with Aut = 1 (asymmetric)

These are σ-flag classes where every leaf is uniquely identifiable by some
colour-or-adjacency invariant, so the only σ-iso is the identity. -/

/-! ### Density-vanishing substrate for v5 of `linSum`

A flag `F` is **forbidden** in a graph class `𝒢` if every `𝒢`-graph has zero
induced embeddings of `F`. Forbidden flags evaluate to `0` under any
`𝒢`-functional. This lets us discard non-`𝒢`-allowed (e.g. non-BRRB-allowed)
flag classes in the `linSum` decomposition without enumerating them. -/

/-- A flag `F` is `IsForbidden` in graph class `𝒢` if `F` has zero induced
    embeddings into any `𝒢`-graph. -/
def IsForbidden {R : RelUniverse} (σ : GenFlagType R) (F : GenFlag R σ)
    (𝒢 : GenFlag R (GenFlagType.empty R) → Prop) : Prop :=
  ∀ G : GenFlag R σ, 𝒢 G.forget → genInducedCount R σ F G = 0

/-- A zero induced count makes the unlabelled density zero. -/
theorem genUnlabelledDensity_zero_of_count_zero {R : RelUniverse}
    {σ : GenFlagType R} {F G : GenFlag R σ}
    {Δ : GenFlag R (GenFlagType.empty R) → ℕ}
    (h : genInducedCount R σ F G = 0) :
    genUnlabelledDensity R σ F G Δ = 0 := by
  unfold genUnlabelledDensity
  rw [h]
  simp

/-- A forbidden flag has zero limit density in any `𝒢`-functional.

    Strategy: split on whether `F` is local for `𝒢, Δ`. If non-local,
    `eval_nonlocal` gives `eval F = 0` directly. If local, the convergence
    axiom of `GenLimitFunctional` says `genUnlabelledDensity F (seq.seq (sub k))`
    converges to `eval F`. Each `seq.seq (sub k)` lies in `𝒢` by `seq_in_class`,
    so by `IsForbidden` the count and hence the density is `0` for every `k`.
    A constant-`0` sequence forces the limit `eval F = 0`. -/
theorem evalAlg_single_zero_of_forbidden {R : RelUniverse} {σ : GenFlagType R}
    {F : GenFlag R σ} {𝒢 : GenFlag R (GenFlagType.empty R) → Prop}
    {Δ : GenFlag R (GenFlagType.empty R) → ℕ}
    (h : IsForbidden σ F 𝒢)
    (psi : GenLimitFunctional R σ 𝒢 Δ) :
    psi.evalAlg (GenFlagAlg.single F) = 0 := by
  rw [GenLimitFunctional.evalAlg_single]
  by_cases hloc : GenIsLocalFlag σ F 𝒢 Δ
  · -- F local: use convergence + constant-0 density sequence.
    have h_density_zero : ∀ k,
        genUnlabelledDensity R σ F (psi.seq.seq (psi.sub k)) Δ = 0 := by
      intro k
      apply genUnlabelledDensity_zero_of_count_zero
      exact h _ (psi.seq_in_class (psi.sub k))
    have h_conv := psi.convergence F hloc
    have h_const : Filter.Tendsto
        (fun k => genUnlabelledDensity R σ F (psi.seq.seq (psi.sub k)) Δ)
        Filter.atTop (nhds 0) := by
      have : (fun k => genUnlabelledDensity R σ F (psi.seq.seq (psi.sub k)) Δ) =
          (fun _ => (0 : ℝ)) := by
        funext k; exact h_density_zero k
      rw [this]
      exact tendsto_const_nhds
    exact tendsto_nhds_unique h_conv h_const
  · -- F non-local: `eval_nonlocal` gives `eval F = 0` directly.
    exact psi.eval_nonlocal F hloc

/-! ### IsForbidden proofs for size-4 σ-flag classes in BRRB

The 19 non-BRRB-local size-4 σ-flag classes (`vbExt3_*`) all violate either
triangle-freeness or black-independence in BRRB. We prove `IsForbidden` for
each: any embedding into a `brrbGenGraphClass` graph would either create a
triangle or a black-black edge.

Two pattern types:
* **Triangle violation** (3 classes — `vbExt3_RRR_e1`, `_e2`, `_e3`): pick a
  triangle in F (a triple of vertices with all 3 edges); its image under the
  embedding is a triangle in G, contradicting triangle-freeness.
* **Black-black violation** (16 classes — all other non-RRR_e0): pick a
  σ-leaf edge whose leaf is black (so both endpoints are black, since σ is
  always black); its image is a black-black edge in G, contradicting
  black-independence. -/

/-! #### Helper extraction from a CG2 induced embedding

For a CG2 induced embedding `f : F → G` we have `find : CG2.comap f G.str = F.str`,
which decomposes (definitionally) as:
* `(CG2.comap f G.str).1 = G.str.1.comap f`, so `F.str.1.Adj u v ↔ G.str.1.Adj (f u) (f v)`.
* `(CG2.comap f G.str).2 = G.str.2 ∘ f`, so `F.str.2 v = G.str.2 (f v)`.
-/

/-- Adjacency transport: `F.str.1.Adj u v → G.str.1.Adj (f u) (f v)`. -/
private lemma cg2_find_adj
    {n m : ℕ} (f : Fin n → Fin m) {sG : CG2.Str m} {sF : CG2.Str n}
    (find : CG2.comap f sG = sF) {u v : Fin n} (h : sF.1.Adj u v) :
    sG.1.Adj (f u) (f v) := by
  have h_eq : (CG2.comap f sG).1 = sF.1 := by rw [find]
  have h_pull : (CG2.comap f sG).1.Adj u v := h_eq ▸ h
  exact h_pull

/-- Colour transport: `G.str.2 (f v) = F.str.2 v`. -/
private lemma cg2_find_col
    {n m : ℕ} (f : Fin n → Fin m) {sG : CG2.Str m} {sF : CG2.Str n}
    (find : CG2.comap f sG = sF) (v : Fin n) :
    sG.2 (f v) = sF.2 v := by
  have h_eq : (CG2.comap f sG).2 = sF.2 := by rw [find]
  exact congr_fun h_eq v

/-! #### Black-black violation proofs (BBB classes) -/

/-- vbExt3_BBB_e0 forbidden in BRRB: σ-vertex (black) adjacent to leaf 1 (black). -/
theorem vbExt3_BBB_e0_isForbidden_brrb :
    IsForbidden vertexBlackType vbExt3_BBB_e0 brrbGenGraphClass := by
  intro G hG
  unfold genInducedCount
  rw [Fintype.card_eq_zero_iff]
  refine ⟨fun ⟨f, _, find, _⟩ => ?_⟩
  -- Edge (0,1) in F (σ-vertex 0 to black leaf 1).
  have h_F_adj : vbExt3_BBB_e0.str.1.Adj
      (⟨0, by omega⟩ : Fin 4) (⟨1, by omega⟩ : Fin 4) := by
    simp [vbExt3_BBB_e0, SimpleGraph.fromRel_adj]
  -- Both colours are 1 (black).
  have h_F_col0 : vbExt3_BBB_e0.str.2 (⟨0, by omega⟩ : Fin 4) = 1 := rfl
  have h_F_col1 : vbExt3_BBB_e0.str.2 (⟨1, by omega⟩ : Fin 4) = 1 := rfl
  have h_G_adj := cg2_find_adj f find h_F_adj
  have h_G_col0 := cg2_find_col f find (⟨0, by omega⟩ : Fin 4)
  have h_G_col1 := cg2_find_col f find (⟨1, by omega⟩ : Fin 4)
  rw [h_F_col0] at h_G_col0
  rw [h_F_col1] at h_G_col1
  exact brrbGenGraphClass_blackIndep G.forget hG _ _ h_G_col0 h_G_col1 h_G_adj

