      have hv_eq : v = (⟨1, by decide⟩ : Fin 3) := Fin.ext hv
      rw [hu_eq, hv_eq, hs0, hs1]
      exact h_adj_01_at_12
    · have hu_eq : u = (⟨0, by decide⟩ : Fin 3) := Fin.ext hu
      have hv_eq : v = (⟨2, by decide⟩ : Fin 3) := Fin.ext hv
      rw [hu_eq, hv_eq, hs0, hs2]
      exact h_adj_02_at_10
    · have hu_eq : u = (⟨1, by decide⟩ : Fin 3) := Fin.ext hu
      have hv_eq : v = (⟨0, by decide⟩ : Fin 3) := Fin.ext hv
      rw [hu_eq, hv_eq, hs1, hs0,
        SimpleGraph.adj_comm (G := G_str.1), SimpleGraph.adj_comm (G := T_str.1)]
      exact h_adj_01_at_12
    · have hu_eq : u = (⟨1, by decide⟩ : Fin 3) := Fin.ext hu
      have hv_eq : v = (⟨1, by decide⟩ : Fin 3) := Fin.ext hv
      rw [hu_eq, hv_eq, hs1]
      constructor <;> intro hadj <;> exact absurd hadj (SimpleGraph.irrefl _)
    · have hu_eq : u = (⟨1, by decide⟩ : Fin 3) := Fin.ext hu
      have hv_eq : v = (⟨2, by decide⟩ : Fin 3) := Fin.ext hv
      rw [hu_eq, hv_eq, hs1, hs2]
      exact h_adj_12_at_20
    · have hu_eq : u = (⟨2, by decide⟩ : Fin 3) := Fin.ext hu
      have hv_eq : v = (⟨0, by decide⟩ : Fin 3) := Fin.ext hv
      rw [hu_eq, hv_eq, hs2, hs0,
        SimpleGraph.adj_comm (G := G_str.1), SimpleGraph.adj_comm (G := T_str.1)]
      exact h_adj_02_at_10
    · have hu_eq : u = (⟨2, by decide⟩ : Fin 3) := Fin.ext hu
      have hv_eq : v = (⟨1, by decide⟩ : Fin 3) := Fin.ext hv
      rw [hu_eq, hv_eq, hs2, hs1,
        SimpleGraph.adj_comm (G := G_str.1), SimpleGraph.adj_comm (G := T_str.1)]
      exact h_adj_12_at_20
    · have hu_eq : u = (⟨2, by decide⟩ : Fin 3) := Fin.ext hu
      have hv_eq : v = (⟨2, by decide⟩ : Fin 3) := Fin.ext hv
      rw [hu_eq, hv_eq, hs2]
      constructor <;> intro hadj <;> exact absurd hadj (SimpleGraph.irrefl _)
  · -- h_col
    intro v
    have h01 : ((⟨0, by decide⟩ : Fin 3) : Fin 3) ≠ (⟨1, by decide⟩ : Fin 3) := by decide
    have h02 : ((⟨0, by decide⟩ : Fin 3) : Fin 3) ≠ (⟨2, by decide⟩ : Fin 3) := by decide
    have h12 : ((⟨1, by decide⟩ : Fin 3) : Fin 3) ≠ (⟨2, by decide⟩ : Fin 3) := by decide
    have hs0 : φ (⟨0, by decide⟩ : Fin 3) = (⟨1, by decide⟩ : Fin 3) := by
      change (Equiv.swap (⟨0, by decide⟩ : Fin 3) ⟨2, by decide⟩)
        ((Equiv.swap (⟨0, by decide⟩ : Fin 3) ⟨1, by decide⟩) ⟨0, by decide⟩) = _
      rw [Equiv.swap_apply_left, Equiv.swap_apply_of_ne_of_ne h01.symm h12]
    have hs1 : φ (⟨1, by decide⟩ : Fin 3) = (⟨2, by decide⟩ : Fin 3) := by
      change (Equiv.swap (⟨0, by decide⟩ : Fin 3) ⟨2, by decide⟩)
        ((Equiv.swap (⟨0, by decide⟩ : Fin 3) ⟨1, by decide⟩) ⟨1, by decide⟩) = _
      rw [Equiv.swap_apply_right, Equiv.swap_apply_left]
    have hs2 : φ (⟨2, by decide⟩ : Fin 3) = (⟨0, by decide⟩ : Fin 3) := by
      change (Equiv.swap (⟨0, by decide⟩ : Fin 3) ⟨2, by decide⟩)
        ((Equiv.swap (⟨0, by decide⟩ : Fin 3) ⟨1, by decide⟩) ⟨2, by decide⟩) = _
      rw [Equiv.swap_apply_of_ne_of_ne h02.symm h12.symm, Equiv.swap_apply_right]
    rcases fin3_val_cases v with hv | hv | hv
    · have hv_eq : v = (⟨0, by decide⟩ : Fin 3) := Fin.ext hv
      rw [hv_eq, hs0]; exact h_col_0_at_1
    · have hv_eq : v = (⟨1, by decide⟩ : Fin 3) := Fin.ext hv
      rw [hv_eq, hs1]; exact h_col_1_at_2
    · have hv_eq : v = (⟨2, by decide⟩ : Fin 3) := Fin.ext hv
      rw [hv_eq, hs2]
      have hG := size3_sigma_col_eq_one G_str G_emb G_isInd
      have hT := size3_sigma_col_eq_one T_str T_emb T_isInd
      have hG_emb_eq : G_emb (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) =
          (⟨2, by decide⟩ : Fin 3) := Fin.ext h_emb_G
      have hT_emb_eq : T_emb (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) =
          (⟨0, by decide⟩ : Fin 3) := Fin.ext h_emb_T
      rw [hG_emb_eq] at hG; rw [hT_emb_eq] at hT
      rw [hG, hT]

/-! ### Master classification: `any_size3_extAdjBoth_iso`

Any size-3 σ-flag at vertexBlackType where the σ-vertex is adjacent to both
non-σ vertices is iso to one of `vbExt2_RR_indep`, `vbExt2_RR_edge`,
`vbExt2_RB_indep`, `vbExt2_RB_edge`, `vbExt2_BB_indep`, `vbExt2_BB_edge`. -/

/-- Helper: map `Fin 2` colour to `0 ∨ 1`. -/
private theorem fin2_col_cases (c : Fin 2) : c = (0 : Fin 2) ∨ c = (1 : Fin 2) := by
  rcases fin2_eq_zero_or_one c with h | h
  · left; exact Fin.ext h
  · right; exact Fin.ext h

/-- Master classification theorem: any size-3 σ-flag at vertexBlackType where
    the σ-vertex is adjacent to both non-σ vertices is iso to one of the 6
    `vbExt2_*` flags. -/
theorem any_size3_extAdjBoth_iso (G : GenFlag CG2 vertexBlackType) (hsize : G.size = 3)
    (hadj_both : ∀ v : Fin G.size, v ≠ G.embedding ⟨0, Nat.zero_lt_one⟩ →
                 G.str.1.Adj (G.embedding ⟨0, Nat.zero_lt_one⟩) v) :
    GenFlagIso vertexBlackType G vbExt2_RR_indep ∨
    GenFlagIso vertexBlackType G vbExt2_RR_edge ∨
    GenFlagIso vertexBlackType G vbExt2_RB_indep ∨
    GenFlagIso vertexBlackType G vbExt2_RB_edge ∨
    GenFlagIso vertexBlackType G vbExt2_BB_indep ∨
    GenFlagIso vertexBlackType G vbExt2_BB_edge := by
  rcases G with ⟨size, G_str, G_emb, G_isInd, G_hsize⟩
  -- hsize : size = 3
  subst hsize
  -- All 6 targets share the property that their internal structure is
  -- ⟨3, *_str, *_emb, *_isInd, *_hsize⟩ with *_emb ⟨0,_⟩ = ⟨0,_⟩.
  -- We use the helpers based on σ-position.
  -- Cases on G_emb ⟨0,_⟩.val ∈ {0, 1, 2}.
  rcases fin3_val_cases (G_emb ⟨0, Nat.zero_lt_one⟩) with hp0 | hp1 | hp2
  · -- σ-position 0: leaves at 1 and 2.
    -- Get adjacency: σ adj 1 and σ adj 2.
    have h_emb_at_0 : G_emb (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) =
        (⟨0, by decide⟩ : Fin 3) := Fin.ext hp0
    have h_emb_neq_1 : G_emb (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) ≠
        (⟨1, by decide⟩ : Fin 3) := by rw [h_emb_at_0]; decide
    have h_emb_neq_2 : G_emb (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) ≠
        (⟨2, by decide⟩ : Fin 3) := by rw [h_emb_at_0]; decide
    have h_adj_at_1 : G_str.1.Adj (G_emb ⟨0, Nat.zero_lt_one⟩) (⟨1, by decide⟩ : Fin 3) :=
      hadj_both (⟨1, by decide⟩ : Fin 3) h_emb_neq_1.symm
    have h_adj_at_2 : G_str.1.Adj (G_emb ⟨0, Nat.zero_lt_one⟩) (⟨2, by decide⟩ : Fin 3) :=
      hadj_both (⟨2, by decide⟩ : Fin 3) h_emb_neq_2.symm
    rw [h_emb_at_0] at h_adj_at_1 h_adj_at_2
    -- Case-split on colours at positions 1 and 2.
    rcases fin2_col_cases (G_str.2 ⟨1, by decide⟩) with hc1 | hc1 <;>
      rcases fin2_col_cases (G_str.2 ⟨2, by decide⟩) with hc2 | hc2 <;>
      by_cases h_e : G_str.1.Adj (⟨1, by decide⟩ : Fin 3) (⟨2, by decide⟩ : Fin 3)
    -- Case (c1=0, c2=0, edge): RR_edge via id
    · refine Or.inr (Or.inl ?_)
      apply size3_sigma0_id_iso G_str vbExt2_RR_edge.str G_emb vbExt2_RR_edge.embedding
        G_isInd vbExt2_RR_edge.isInduced G_hsize vbExt2_RR_edge.hsize hp0 (by rfl)
      · -- adj 0-1
        constructor
        · intro _; rw [vbExt2_RR_edge_adj_iff]; left; exact ⟨rfl, rfl⟩
        · intro _; exact h_adj_at_1
      · constructor
        · intro _; rw [vbExt2_RR_edge_adj_iff]; right; right; left; exact ⟨rfl, rfl⟩
        · intro _; exact h_adj_at_2
      · constructor
        · intro _; rw [vbExt2_RR_edge_adj_iff]; right; right; right; right; left; exact ⟨rfl, rfl⟩
        · intro _; exact h_e
      · -- col at 1
        rw [hc1]; rfl
      · rw [hc2]; rfl
    -- Case (c1=0, c2=0, no edge): RR_indep via id
    · refine Or.inl ?_
      apply size3_sigma0_id_iso G_str vbExt2_RR_indep.str G_emb vbExt2_RR_indep.embedding
        G_isInd vbExt2_RR_indep.isInduced G_hsize vbExt2_RR_indep.hsize hp0 (by rfl)
      · constructor
        · intro _; rw [vbExt2_RR_indep_adj_iff]; left; exact ⟨rfl, rfl⟩
        · intro _; exact h_adj_at_1
      · constructor
        · intro _; rw [vbExt2_RR_indep_adj_iff]; right; right; left; exact ⟨rfl, rfl⟩
        · intro _; exact h_adj_at_2
      · constructor
        · intro hadj; exact absurd hadj h_e
        · intro hadj; rw [vbExt2_RR_indep_adj_iff] at hadj
          rcases hadj with ⟨h1, h2⟩ | ⟨h1, h2⟩ | ⟨h1, h2⟩ | ⟨h1, h2⟩ <;>
            (first | (exact absurd h1 (by decide)) | (exact absurd h2 (by decide)))
      · rw [hc1]; rfl
      · rw [hc2]; rfl
    -- Case (c1=0, c2=1, edge): RB_edge via id
    · refine Or.inr (Or.inr (Or.inr (Or.inl ?_)))
      apply size3_sigma0_id_iso G_str vbExt2_RB_edge.str G_emb vbExt2_RB_edge.embedding
        G_isInd vbExt2_RB_edge.isInduced G_hsize vbExt2_RB_edge.hsize hp0 (by rfl)
      · constructor
        · intro _; rw [vbExt2_RB_edge_adj_iff]; left; exact ⟨rfl, rfl⟩
        · intro _; exact h_adj_at_1
      · constructor
        · intro _; rw [vbExt2_RB_edge_adj_iff]; right; right; left; exact ⟨rfl, rfl⟩
        · intro _; exact h_adj_at_2
      · constructor
        · intro _; rw [vbExt2_RB_edge_adj_iff]; right; right; right; right; left; exact ⟨rfl, rfl⟩
        · intro _; exact h_e
      · rw [hc1]; rfl
      · rw [hc2]; rfl
    -- Case (c1=0, c2=1, no edge): RB_indep via id
    · refine Or.inr (Or.inr (Or.inl ?_))
      apply size3_sigma0_id_iso G_str vbExt2_RB_indep.str G_emb vbExt2_RB_indep.embedding
        G_isInd vbExt2_RB_indep.isInduced G_hsize vbExt2_RB_indep.hsize hp0 (by rfl)
      · constructor
        · intro _; rw [vbExt2_RB_indep_adj_iff]; left; exact ⟨rfl, rfl⟩
        · intro _; exact h_adj_at_1
      · constructor
        · intro _; rw [vbExt2_RB_indep_adj_iff]; right; right; left; exact ⟨rfl, rfl⟩
        · intro _; exact h_adj_at_2
      · constructor
        · intro hadj; exact absurd hadj h_e
        · intro hadj; rw [vbExt2_RB_indep_adj_iff] at hadj
          rcases hadj with ⟨h1, h2⟩ | ⟨h1, h2⟩ | ⟨h1, h2⟩ | ⟨h1, h2⟩ <;>
            (first | (exact absurd h1 (by decide)) | (exact absurd h2 (by decide)))
      · rw [hc1]; rfl
      · rw [hc2]; rfl
    -- Case (c1=1, c2=0, edge): RB_edge via swap(1,2)
    · refine Or.inr (Or.inr (Or.inr (Or.inl ?_)))
      apply size3_sigma0_swap12_iso G_str vbExt2_RB_edge.str G_emb vbExt2_RB_edge.embedding
        G_isInd vbExt2_RB_edge.isInduced G_hsize vbExt2_RB_edge.hsize hp0 (by rfl)
      · -- G(0,1) ↔ T(0,2) (red leaf at T pos 1, but G has it at pos 2 since c1=1=black at 1)
        -- Wait this is wrong direction. Let me reconsider.
        -- G has σ at 0, leaf 1 black (c1=1), leaf 2 red (c2=0). T (RB_edge) has σ at 0,
        -- leaf 1 red, leaf 2 black. So we map G-pos 1 (black) to T-pos 2, G-pos 2 (red)
        -- to T-pos 1. That's swap(1,2).
        -- After φ = swap(1,2): φ(0)=0, φ(1)=2, φ(2)=1.
        -- Goal: G.Adj 0 1 ↔ T.Adj φ(0) φ(1) = T.Adj 0 2. Hmm so h_adj_01_at_02.
        constructor
        · intro _; rw [vbExt2_RB_edge_adj_iff]; right; right; left; exact ⟨rfl, rfl⟩
        · intro _; exact h_adj_at_1
      · constructor
        · intro _; rw [vbExt2_RB_edge_adj_iff]; left; exact ⟨rfl, rfl⟩
        · intro _; exact h_adj_at_2
      · constructor
        · intro _; rw [vbExt2_RB_edge_adj_iff]; right; right; right; right; left; exact ⟨rfl, rfl⟩
        · intro _; exact h_e
      · -- col G(1) = T(2): G(1) = 1 (hc1), T(2) = 1.
        rw [hc1]; rfl
      · rw [hc2]; rfl
    -- Case (c1=1, c2=0, no edge): RB_indep via swap(1,2)
    · refine Or.inr (Or.inr (Or.inl ?_))
      apply size3_sigma0_swap12_iso G_str vbExt2_RB_indep.str G_emb vbExt2_RB_indep.embedding
        G_isInd vbExt2_RB_indep.isInduced G_hsize vbExt2_RB_indep.hsize hp0 (by rfl)
      · constructor
        · intro _; rw [vbExt2_RB_indep_adj_iff]; right; right; left; exact ⟨rfl, rfl⟩
        · intro _; exact h_adj_at_1
      · constructor
        · intro _; rw [vbExt2_RB_indep_adj_iff]; left; exact ⟨rfl, rfl⟩
        · intro _; exact h_adj_at_2
      · constructor
        · intro hadj; exact absurd hadj h_e
        · intro hadj; rw [vbExt2_RB_indep_adj_iff] at hadj
          rcases hadj with ⟨h1, h2⟩ | ⟨h1, h2⟩ | ⟨h1, h2⟩ | ⟨h1, h2⟩ <;>
            (first | (exact absurd h1 (by decide)) | (exact absurd h2 (by decide)))
      · rw [hc1]; rfl
      · rw [hc2]; rfl
    -- Case (c1=1, c2=1, edge): BB_edge via id
    · refine Or.inr (Or.inr (Or.inr (Or.inr (Or.inr ?_))))
      apply size3_sigma0_id_iso G_str vbExt2_BB_edge.str G_emb vbExt2_BB_edge.embedding
        G_isInd vbExt2_BB_edge.isInduced G_hsize vbExt2_BB_edge.hsize hp0 (by rfl)
      · constructor
        · intro _; rw [vbExt2_BB_edge_adj_iff]; left; exact ⟨rfl, rfl⟩
        · intro _; exact h_adj_at_1
      · constructor
        · intro _; rw [vbExt2_BB_edge_adj_iff]; right; right; left; exact ⟨rfl, rfl⟩
        · intro _; exact h_adj_at_2
      · constructor
        · intro _; rw [vbExt2_BB_edge_adj_iff]; right; right; right; right; left; exact ⟨rfl, rfl⟩
        · intro _; exact h_e
      · rw [hc1]; rfl
      · rw [hc2]; rfl
    -- Case (c1=1, c2=1, no edge): BB_indep via id
    · refine Or.inr (Or.inr (Or.inr (Or.inr (Or.inl ?_))))
      apply size3_sigma0_id_iso G_str vbExt2_BB_indep.str G_emb vbExt2_BB_indep.embedding
        G_isInd vbExt2_BB_indep.isInduced G_hsize vbExt2_BB_indep.hsize hp0 (by rfl)
      · constructor
        · intro _; rw [vbExt2_BB_indep_adj_iff]; left; exact ⟨rfl, rfl⟩
        · intro _; exact h_adj_at_1
      · constructor
        · intro _; rw [vbExt2_BB_indep_adj_iff]; right; right; left; exact ⟨rfl, rfl⟩
        · intro _; exact h_adj_at_2
      · constructor
        · intro hadj; exact absurd hadj h_e
        · intro hadj; rw [vbExt2_BB_indep_adj_iff] at hadj
          rcases hadj with ⟨h1, h2⟩ | ⟨h1, h2⟩ | ⟨h1, h2⟩ | ⟨h1, h2⟩ <;>
            (first | (exact absurd h1 (by decide)) | (exact absurd h2 (by decide)))
      · rw [hc1]; rfl
      · rw [hc2]; rfl
  · -- σ-position 1: leaves at 0 and 2.
    have h_emb_at_1 : G_emb (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) =
        (⟨1, by decide⟩ : Fin 3) := Fin.ext hp1
    have h_emb_neq_0 : G_emb (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) ≠
        (⟨0, by decide⟩ : Fin 3) := by rw [h_emb_at_1]; decide
    have h_emb_neq_2 : G_emb (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) ≠
        (⟨2, by decide⟩ : Fin 3) := by rw [h_emb_at_1]; decide
    have h_adj_at_0 : G_str.1.Adj (G_emb ⟨0, Nat.zero_lt_one⟩) (⟨0, by decide⟩ : Fin 3) :=
      hadj_both (⟨0, by decide⟩ : Fin 3) h_emb_neq_0.symm
    have h_adj_at_2 : G_str.1.Adj (G_emb ⟨0, Nat.zero_lt_one⟩) (⟨2, by decide⟩ : Fin 3) :=
      hadj_both (⟨2, by decide⟩ : Fin 3) h_emb_neq_2.symm
    rw [h_emb_at_1] at h_adj_at_0 h_adj_at_2
    -- Adjacency rephrased: σ at 1, so G(0,1) adj (use sym), G(1,2) adj.
    have h_adj_01 : G_str.1.Adj (⟨0, by decide⟩ : Fin 3) (⟨1, by decide⟩ : Fin 3) := by
      rw [SimpleGraph.adj_comm]; exact h_adj_at_0
    have h_adj_12 : G_str.1.Adj (⟨1, by decide⟩ : Fin 3) (⟨2, by decide⟩ : Fin 3) :=
      h_adj_at_2
    rcases fin2_col_cases (G_str.2 ⟨0, by decide⟩) with hc0 | hc0 <;>
      rcases fin2_col_cases (G_str.2 ⟨2, by decide⟩) with hc2 | hc2 <;>
      by_cases h_e : G_str.1.Adj (⟨0, by decide⟩ : Fin 3) (⟨2, by decide⟩ : Fin 3)
    -- (c0=0, c2=0, edge): RR_edge via swap(0,1).
    -- φ : 0↔1, 2 fixed. G-pos 1 → T-pos 0 (σ); G-pos 0 → T-pos 1; G-pos 2 → T-pos 2.
    · refine Or.inr (Or.inl ?_)
      apply size3_sigma1_swap01_iso G_str vbExt2_RR_edge.str G_emb vbExt2_RR_edge.embedding
        G_isInd vbExt2_RR_edge.isInduced G_hsize vbExt2_RR_edge.hsize hp1 (by rfl)
      · -- G(0,1) ↔ T(1,0): use sym on T side, T(0,1) = T-edge ⟨0,1⟩
        constructor
        · intro _; rw [vbExt2_RR_edge_adj_iff]; right; left; exact ⟨rfl, rfl⟩
        · intro _; exact h_adj_01
      · -- G(0,2) ↔ T(1,2)
        constructor
        · intro _; rw [vbExt2_RR_edge_adj_iff]; right; right; right; right; left; exact ⟨rfl, rfl⟩
        · intro _; exact h_e
      · -- G(1,2) ↔ T(0,2)
        constructor
        · intro _; rw [vbExt2_RR_edge_adj_iff]; right; right; left; exact ⟨rfl, rfl⟩
        · intro _; exact h_adj_12
      · -- col G(0) = T(1)
        rw [hc0]; rfl
      · -- col G(2) = T(2)
        rw [hc2]; rfl
    -- (c0=0, c2=0, no edge): RR_indep via swap(0,1).
    · refine Or.inl ?_
      apply size3_sigma1_swap01_iso G_str vbExt2_RR_indep.str G_emb vbExt2_RR_indep.embedding
        G_isInd vbExt2_RR_indep.isInduced G_hsize vbExt2_RR_indep.hsize hp1 (by rfl)
      · constructor
        · intro _; rw [vbExt2_RR_indep_adj_iff]; right; left; exact ⟨rfl, rfl⟩
        · intro _; exact h_adj_01
      · constructor
        · intro hadj; exact absurd hadj h_e
        · intro hadj; rw [vbExt2_RR_indep_adj_iff] at hadj
          rcases hadj with ⟨h1, h2⟩ | ⟨h1, h2⟩ | ⟨h1, h2⟩ | ⟨h1, h2⟩ <;>
            (first | (exact absurd h1 (by decide)) | (exact absurd h2 (by decide)))
      · constructor
        · intro _; rw [vbExt2_RR_indep_adj_iff]; right; right; left; exact ⟨rfl, rfl⟩
        · intro _; exact h_adj_12
      · rw [hc0]; rfl
      · rw [hc2]; rfl
    -- (c0=0, c2=1, edge): RB_edge via swap(0,1).
    -- T(RB) leaves: 1 red, 2 black. We map G-0 (red) to T-1; G-2 (black) to T-2. ✓
    · refine Or.inr (Or.inr (Or.inr (Or.inl ?_)))
      apply size3_sigma1_swap01_iso G_str vbExt2_RB_edge.str G_emb vbExt2_RB_edge.embedding
        G_isInd vbExt2_RB_edge.isInduced G_hsize vbExt2_RB_edge.hsize hp1 (by rfl)
      · constructor
        · intro _; rw [vbExt2_RB_edge_adj_iff]; right; left; exact ⟨rfl, rfl⟩
