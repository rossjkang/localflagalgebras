set_option maxHeartbeats 32000000 in
-- Recursion-prone: hoist destructuring of generic cls into clean context.
set_option maxRecDepth 4000 in
set_option linter.constructorNameAsVariable false in
/-- Outside-witnessSet contribution lemma for v2-side. Given a witnessSet
    containing the 3 v2-witness classes, every cls in the v2-extAdj filter
    that is NOT in witnessSet has zero contribution to the extSum eval, because
    the dichotomy forces cls into one of the 3 witnesses (contradiction) or
