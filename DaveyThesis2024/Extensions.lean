  · have : c = (⟨0, by decide⟩ : Fin 4) := Fin.ext hc0
    rw [this, fin4_skip0_zero]
    simp [vbExt4_RRRR_e0, SimpleGraph.fromRel_adj]
  · have : c = (⟨1, by decide⟩ : Fin 4) := Fin.ext hc1
    rw [this, fin4_skip0_one]
    simp [vbExt4_RRRR_e0, SimpleGraph.fromRel_adj]
  · have : c = (⟨2, by decide⟩ : Fin 4) := Fin.ext hc2
    rw [this, fin4_skip0_two]
    simp [vbExt4_RRRR_e0, SimpleGraph.fromRel_adj]
  · have : c = (⟨3, by decide⟩ : Fin 4) := Fin.ext hc3
    rw [this, fin4_skip0_three]
    simp [vbExt4_RRRR_e0, SimpleGraph.fromRel_adj]

/-- vbExt4_RRRR_e0 has NO leaf-leaf edges between two distinct skip0 values. -/
private theorem vbExt4_RRRR_e0_not_adj_skip_skip (a b : Fin 4) :
    ¬ vbExt4_RRRR_e0.str.1.Adj (fin4_skip0 a) (fin4_skip0 b) := by
  intro h
  have h_adj : (SimpleGraph.fromRel _).Adj (fin4_skip0 a) (fin4_skip0 b) := h
  rw [SimpleGraph.fromRel_adj] at h_adj
  obtain ⟨_, hrel⟩ := h_adj
  have ha_pos : 1 ≤ (fin4_skip0 a).val := by change 1 ≤ a.val + 1; omega
  have hb_pos : 1 ≤ (fin4_skip0 b).val := by change 1 ≤ b.val + 1; omega
  rcases hrel with hl | hr
  · rcases hl with ⟨hl1, _⟩ | ⟨hl1, _⟩ | ⟨hl1, _⟩ | ⟨hl1, _⟩ | ⟨hl1, _⟩ |
      ⟨hl1, _⟩ | ⟨hl1, _⟩ | ⟨hl1, _⟩ <;> omega
  · rcases hr with ⟨hr1, _⟩ | ⟨hr1, _⟩ | ⟨hr1, _⟩ | ⟨hr1, _⟩ | ⟨hr1, _⟩ |
      ⟨hr1, _⟩ | ⟨hr1, _⟩ | ⟨hr1, _⟩ <;> omega

/-- vbExt4_RRRR_e0 colour at fin4_skip0 c is 0 (red) for any c : Fin 4. -/
private theorem vbExt4_RRRR_e0_col_skip (c : Fin 4) :
    vbExt4_RRRR_e0.str.2 (fin4_skip0 c) = 0 := by
  change (if (c.val + 1) = 0 then (1 : Fin 2) else 0) = 0
  have : c.val + 1 ≠ 0 := by omega
  simp [this]

/-- The induced-graph + colour structure pulls back correctly for `red_leaf_to_5 c`. -/
private theorem red_leaf_to_5_str_eq (c : Fin 4) :
    CG2.comap (red_leaf_to_5 c) vbExt4_RRRR_e0.str = vbExtRed.str := by
  apply Prod.ext
  · -- Graph equality.
    ext u v
    change vbExt4_RRRR_e0.str.1.Adj (red_leaf_to_5 c u) (red_leaf_to_5 c v) ↔
      vbExtRed.str.1.Adj u v
    rcases fin2_eq_zero_or_one u with hu | hu <;>
      rcases fin2_eq_zero_or_one v with hv | hv
    · have hu' : u = (⟨0, by decide⟩ : Fin 2) := Fin.ext hu
      have hv' : v = (⟨0, by decide⟩ : Fin 2) := Fin.ext hv
      rw [hu', hv', red_leaf_to_5_zero]
      simp [vbExt4_RRRR_e0, vbExtRed]
    · have hu' : u = (⟨0, by decide⟩ : Fin 2) := Fin.ext hu
      have hv' : v = (⟨1, by decide⟩ : Fin 2) := Fin.ext hv
      rw [hu', hv', red_leaf_to_5_zero, red_leaf_to_5_one]
      have h_red : vbExtRed.str.1.Adj (⟨0, by decide⟩ : Fin 2) ⟨1, by decide⟩ := by
        simp [vbExtRed, SimpleGraph.fromRel_adj]
      constructor
      · intro _; exact h_red
      · intro _; exact vbExt4_RRRR_e0_adj_0_skip c
    · have hu' : u = (⟨1, by decide⟩ : Fin 2) := Fin.ext hu
      have hv' : v = (⟨0, by decide⟩ : Fin 2) := Fin.ext hv
      rw [hu', hv', red_leaf_to_5_zero, red_leaf_to_5_one]
      have h_red : vbExtRed.str.1.Adj (⟨1, by decide⟩ : Fin 2) ⟨0, by decide⟩ := by
        simp [vbExtRed, SimpleGraph.fromRel_adj]
      constructor
      · intro _; exact h_red
      · intro _; exact (vbExt4_RRRR_e0_adj_0_skip c).symm
    · have hu' : u = (⟨1, by decide⟩ : Fin 2) := Fin.ext hu
      have hv' : v = (⟨1, by decide⟩ : Fin 2) := Fin.ext hv
      rw [hu', hv', red_leaf_to_5_one]
      simp [vbExt4_RRRR_e0, vbExtRed]
  · -- Colour equality.
    funext v
    rcases fin2_eq_zero_or_one v with hv | hv
    · have hv' : v = (⟨0, by decide⟩ : Fin 2) := Fin.ext hv
      rw [hv']
      change vbExt4_RRRR_e0.str.2 (red_leaf_to_5 c (⟨0, by decide⟩ : Fin 2)) =
