             SimpleGraph.adj_comm (G := T_str.1)]; exact h_adj_13)
      | (have hu_eq : u = (⟨2, by decide⟩ : Fin 4) := Fin.ext hu
         have hv_eq : v = (⟨3, by decide⟩ : Fin 4) := Fin.ext hv
