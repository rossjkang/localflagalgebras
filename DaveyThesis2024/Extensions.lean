      have h_f2 : f (⟨2, by omega⟩ : Fin 3) = (⟨2, by omega⟩ : Fin 3) := by
        rcases fin3_val_cases (f (⟨2, by decide⟩ : Fin 3)) with k0 | k1 | k2
        · exfalso
          have h_eq : f (⟨2, by omega⟩ : Fin 3) = (⟨0, by omega⟩ : Fin 3) := Fin.ext k0
          have h_inj : (⟨2, by omega⟩ : Fin 3) = (⟨0, by omega⟩ : Fin 3) :=
