theorem t5_v2_extSum_outside_witnessSet_zero
    (phi : GenLimitFunctional CG2 (GenFlagType.empty CG2)
      brrbGenGraphClass brrbGenDelta)
    (witnessSet : Finset (GenFlagClass CG2 thesisType5))
    (h_a : GenFlagClass.mk t5_v2_a ∈ witnessSet)
    (h_b : GenFlagClass.mk t5_v2_b ∈ witnessSet)
    (h_c : GenFlagClass.mk t5_v2_c ∈ witnessSet) :
    ∀ cls ∈ ((genClassesOfSize CG2 thesisType5
        (thesisType5.size + 1) (Nat.le_succ _)).filter
        (fun cls => extAdjacencyClass thesisType5 cls ⟨2, by decide⟩)),
        cls ∉ witnessSet →
