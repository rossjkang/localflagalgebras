-- ne lemmas for indep vs edge within same colour pair: distinguish via Adj 1 2.
private lemma vbExt2_RR_indep_ne_RR_edge :
    GenFlagClass.mk vbExt2_RR_indep ≠ GenFlagClass.mk vbExt2_RR_edge := by
  intro h
  obtain ⟨φ, hstr, hcompat⟩ : GenFlagIso vertexBlackType vbExt2_RR_indep vbExt2_RR_edge :=
    (GenFlagClass.mk_eq _ _).mp h
  -- σ-compat: φ ⟨0⟩ = ⟨0⟩
  have h0 : φ (⟨0, by decide⟩ : Fin 3) = (⟨0, by decide⟩ : Fin 3) := hcompat ⟨0, Nat.zero_lt_one⟩
  -- The other 2 vertices: φ permutes {1, 2}. RR_edge has Adj 1 2; RR_indep does not.
  -- RR_indep adj 1 2 = false (no leaf-leaf edge)
  have h_RR_indep_not_adj : ¬ vbExt2_RR_indep.str.1.Adj
      (⟨1, by decide⟩ : Fin 3) (⟨2, by decide⟩ : Fin 3) := by
    rw [vbExt2_RR_indep_adj_iff]
    rintro (⟨h1, h2⟩ | ⟨h1, h2⟩ | ⟨h1, h2⟩ | ⟨h1, h2⟩) <;>
      first | exact absurd h1 (by decide) | exact absurd h2 (by decide)
  -- pull back via comap: vbExt2_RR_edge.Adj (φ 1) (φ 2) ↔ vbExt2_RR_indep.Adj 1 2
  have h_iff : vbExt2_RR_edge.str.1.Adj (φ ⟨1, by decide⟩) (φ ⟨2, by decide⟩) ↔
      vbExt2_RR_indep.str.1.Adj (⟨1, by decide⟩ : Fin 3) (⟨2, by decide⟩ : Fin 3) := by
    rw [show vbExt2_RR_indep.str = CG2.comap φ vbExt2_RR_edge.str from hstr.symm]
    rfl
  -- φ permutes {1, 2}: φ ⟨1⟩ ≠ ⟨0⟩, φ ⟨2⟩ ≠ ⟨0⟩, φ ⟨1⟩ ≠ φ ⟨2⟩
  have hφ1_ne_0 : φ (⟨1, by decide⟩ : Fin 3) ≠ (⟨0, by decide⟩ : Fin 3) := by
    intro h_eq
    have : φ (⟨1, by decide⟩ : Fin 3) = φ (⟨0, by decide⟩ : Fin 3) := h_eq.trans h0.symm
    have hh : (⟨1, by decide⟩ : Fin 3) = (⟨0, by decide⟩ : Fin 3) := φ.injective this
    have : (1 : ℕ) = 0 := congr_arg Fin.val hh; omega
  have hφ2_ne_0 : φ (⟨2, by decide⟩ : Fin 3) ≠ (⟨0, by decide⟩ : Fin 3) := by
    intro h_eq
    have : φ (⟨2, by decide⟩ : Fin 3) = φ (⟨0, by decide⟩ : Fin 3) := h_eq.trans h0.symm
    have hh : (⟨2, by decide⟩ : Fin 3) = (⟨0, by decide⟩ : Fin 3) := φ.injective this
    have : (2 : ℕ) = 0 := congr_arg Fin.val hh; omega
  -- vbExt2_RR_edge has Adj 1-2 (and Adj for 2-1)
  have h_RR_edge_adj_12 : vbExt2_RR_edge.str.1.Adj
      (⟨1, by decide⟩ : Fin 3) (⟨2, by decide⟩ : Fin 3) := by
    rw [vbExt2_RR_edge_adj_iff]; right; right; right; right; left; exact ⟨rfl, rfl⟩
  have h_RR_edge_adj_21 : vbExt2_RR_edge.str.1.Adj
      (⟨2, by decide⟩ : Fin 3) (⟨1, by decide⟩ : Fin 3) :=
    h_RR_edge_adj_12.symm
  -- Case split: φ ⟨1⟩ ∈ {1, 2}
  rcases fin3_val_cases (φ (⟨1, by decide⟩ : Fin 3)) with hp0 | hp1 | hp2
  · exact hφ1_ne_0 (Fin.ext hp0)
  · -- φ ⟨1⟩ = 1, so φ ⟨2⟩ = 2 (by injectivity)
    have hp1_eq : φ (⟨1, by decide⟩ : Fin 3) = (⟨1, by decide⟩ : Fin 3) := Fin.ext hp1
    rcases fin3_val_cases (φ (⟨2, by decide⟩ : Fin 3)) with hq0 | hq1 | hq2
    · exact hφ2_ne_0 (Fin.ext hq0)
    · -- φ ⟨2⟩ = 1, but φ ⟨1⟩ = 1, contradiction
      have hq1_eq : φ (⟨2, by decide⟩ : Fin 3) = (⟨1, by decide⟩ : Fin 3) := Fin.ext hq1
      have : φ (⟨1, by decide⟩ : Fin 3) = φ (⟨2, by decide⟩ : Fin 3) :=
        hp1_eq.trans hq1_eq.symm
      have hh : (⟨1, by decide⟩ : Fin 3) = (⟨2, by decide⟩ : Fin 3) := φ.injective this
      have : (1 : ℕ) = 2 := congr_arg Fin.val hh; omega
    · -- φ ⟨2⟩ = 2, h_iff says edge.adj 1 2 ↔ indep.adj 1 2
      have hq2_eq : φ (⟨2, by decide⟩ : Fin 3) = (⟨2, by decide⟩ : Fin 3) := Fin.ext hq2
      rw [hp1_eq, hq2_eq] at h_iff
      exact h_RR_indep_not_adj (h_iff.mp h_RR_edge_adj_12)
  · -- φ ⟨1⟩ = 2, so φ ⟨2⟩ = 1
    have hp2_eq : φ (⟨1, by decide⟩ : Fin 3) = (⟨2, by decide⟩ : Fin 3) := Fin.ext hp2
    rcases fin3_val_cases (φ (⟨2, by decide⟩ : Fin 3)) with hq0 | hq1 | hq2
    · exact hφ2_ne_0 (Fin.ext hq0)
    · -- φ ⟨2⟩ = 1, h_iff says edge.adj 2 1 ↔ indep.adj 1 2
      have hq1_eq : φ (⟨2, by decide⟩ : Fin 3) = (⟨1, by decide⟩ : Fin 3) := Fin.ext hq1
      rw [hp2_eq, hq1_eq] at h_iff
      exact h_RR_indep_not_adj (h_iff.mp h_RR_edge_adj_21)
    · -- φ ⟨1⟩ = 2, φ ⟨2⟩ = 2, contradiction
      have hq2_eq : φ (⟨2, by decide⟩ : Fin 3) = (⟨2, by decide⟩ : Fin 3) := Fin.ext hq2
      have : φ (⟨1, by decide⟩ : Fin 3) = φ (⟨2, by decide⟩ : Fin 3) :=
        hp2_eq.trans hq2_eq.symm
      have hh : (⟨1, by decide⟩ : Fin 3) = (⟨2, by decide⟩ : Fin 3) := φ.injective this
      have : (1 : ℕ) = 2 := congr_arg Fin.val hh; omega

-- Analogous for RB and BB.
private lemma vbExt2_RB_indep_ne_RB_edge :
    GenFlagClass.mk vbExt2_RB_indep ≠ GenFlagClass.mk vbExt2_RB_edge := by
  intro h
  obtain ⟨φ, hstr, hcompat⟩ : GenFlagIso vertexBlackType vbExt2_RB_indep vbExt2_RB_edge :=
    (GenFlagClass.mk_eq _ _).mp h
  -- σ-compat: φ ⟨0⟩ = ⟨0⟩
  have h0 : φ (⟨0, by decide⟩ : Fin 3) = (⟨0, by decide⟩ : Fin 3) := hcompat ⟨0, Nat.zero_lt_one⟩
  -- Colour preservation: vbExt2_RB has different colours at vertex 1 vs 2.
  -- RB_indep: col 1 = 0 (red), col 2 = 1 (black). Same for RB_edge.
  -- φ must preserve colour, so φ 1 = 1 and φ 2 = 2 (no swap possible).
  have h_col_match : ∀ v : Fin 3,
      vbExt2_RB_indep.str.2 v = vbExt2_RB_edge.str.2 (φ v) := by
    intro v
    have : (CG2.comap φ vbExt2_RB_edge.str).2 v = vbExt2_RB_indep.str.2 v := by
      rw [hstr]
    exact this.symm
  have h_col_1 : vbExt2_RB_indep.str.2 (⟨1, by decide⟩ : Fin 3) = 0 := by
    change (if (1 : ℕ) = 0 then (1 : Fin 2) else if (1 : ℕ) = 1 then 0 else 1) = 0; decide
  have h_col_2 : vbExt2_RB_indep.str.2 (⟨2, by decide⟩ : Fin 3) = 1 := by
    change (if (2 : ℕ) = 0 then (1 : Fin 2) else if (2 : ℕ) = 1 then 0 else 1) = 1; decide
  -- vbExt2_RB_edge col function
  have h_RB_edge_col : ∀ v : Fin 3, vbExt2_RB_edge.str.2 v =
      (if v.val = 0 then (1 : Fin 2) else if v.val = 1 then 0 else 1) := fun _ => rfl
  -- φ ⟨1⟩ can only be ⟨1⟩ (since col there must be 0), and φ ⟨2⟩ can only be ⟨2⟩.
  have hφ1 : φ (⟨1, by decide⟩ : Fin 3) = (⟨1, by decide⟩ : Fin 3) := by
    have hc := (h_col_match (⟨1, by decide⟩ : Fin 3))
    rw [h_col_1] at hc
    rcases fin3_val_cases (φ (⟨1, by decide⟩ : Fin 3)) with hp0 | hp1 | hp2
    · -- φ ⟨1⟩ = ⟨0⟩: but injectivity says φ ⟨0⟩ = ⟨0⟩, so φ ⟨1⟩ = φ ⟨0⟩ → ⟨1⟩ = ⟨0⟩
      have hp0_eq : φ (⟨1, by decide⟩ : Fin 3) = (⟨0, by decide⟩ : Fin 3) := Fin.ext hp0
      have : φ (⟨1, by decide⟩ : Fin 3) = φ (⟨0, by decide⟩ : Fin 3) :=
        hp0_eq.trans h0.symm
      have hh : (⟨1, by decide⟩ : Fin 3) = (⟨0, by decide⟩ : Fin 3) := φ.injective this
      have : (1 : ℕ) = 0 := congr_arg Fin.val hh; omega
    · exact Fin.ext hp1
    · -- φ ⟨1⟩ = ⟨2⟩: col at ⟨2⟩ in RB_edge = 1, but should be 0
      have hp2_eq : φ (⟨1, by decide⟩ : Fin 3) = (⟨2, by decide⟩ : Fin 3) := Fin.ext hp2
      rw [hp2_eq] at hc
      rw [h_RB_edge_col] at hc
      simp at hc
  -- Now we have φ ⟨0⟩ = ⟨0⟩, φ ⟨1⟩ = ⟨1⟩, so φ ⟨2⟩ = ⟨2⟩
  have hφ2 : φ (⟨2, by decide⟩ : Fin 3) = (⟨2, by decide⟩ : Fin 3) := by
    rcases fin3_val_cases (φ (⟨2, by decide⟩ : Fin 3)) with hp0 | hp1 | hp2
    · have hp0_eq : φ (⟨2, by decide⟩ : Fin 3) = (⟨0, by decide⟩ : Fin 3) := Fin.ext hp0
      have : φ (⟨2, by decide⟩ : Fin 3) = φ (⟨0, by decide⟩ : Fin 3) :=
        hp0_eq.trans h0.symm
      have hh : (⟨2, by decide⟩ : Fin 3) = (⟨0, by decide⟩ : Fin 3) := φ.injective this
      have : (2 : ℕ) = 0 := congr_arg Fin.val hh; omega
    · have hp1_eq : φ (⟨2, by decide⟩ : Fin 3) = (⟨1, by decide⟩ : Fin 3) := Fin.ext hp1
      have : φ (⟨2, by decide⟩ : Fin 3) = φ (⟨1, by decide⟩ : Fin 3) :=
        hp1_eq.trans hφ1.symm
      have hh : (⟨2, by decide⟩ : Fin 3) = (⟨1, by decide⟩ : Fin 3) := φ.injective this
      have : (2 : ℕ) = 1 := congr_arg Fin.val hh; omega
    · exact Fin.ext hp2
  -- Now show contradiction via Adj 1 2: edge has it, indep doesn't
  have h_RB_indep_not_adj : ¬ vbExt2_RB_indep.str.1.Adj
      (⟨1, by decide⟩ : Fin 3) (⟨2, by decide⟩ : Fin 3) := by
    rw [vbExt2_RB_indep_adj_iff]
    rintro (⟨h1, h2⟩ | ⟨h1, h2⟩ | ⟨h1, h2⟩ | ⟨h1, h2⟩) <;>
      first | exact absurd h1 (by decide) | exact absurd h2 (by decide)
  have h_RB_edge_adj_12 : vbExt2_RB_edge.str.1.Adj
      (⟨1, by decide⟩ : Fin 3) (⟨2, by decide⟩ : Fin 3) := by
    rw [vbExt2_RB_edge_adj_iff]; right; right; right; right; left; exact ⟨rfl, rfl⟩
  have h_iff : vbExt2_RB_indep.str.1.Adj (⟨1, by decide⟩ : Fin 3) (⟨2, by decide⟩ : Fin 3) ↔
      vbExt2_RB_edge.str.1.Adj (φ (⟨1, by decide⟩ : Fin 3)) (φ (⟨2, by decide⟩ : Fin 3)) := by
    rw [show vbExt2_RB_indep.str = CG2.comap φ vbExt2_RB_edge.str from hstr.symm]
    rfl
  rw [hφ1, hφ2] at h_iff
  exact h_RB_indep_not_adj (h_iff.mpr h_RB_edge_adj_12)

private lemma vbExt2_BB_indep_ne_BB_edge :
    GenFlagClass.mk vbExt2_BB_indep ≠ GenFlagClass.mk vbExt2_BB_edge := by
  intro h
  obtain ⟨φ, hstr, hcompat⟩ : GenFlagIso vertexBlackType vbExt2_BB_indep vbExt2_BB_edge :=
    (GenFlagClass.mk_eq _ _).mp h
  have h0 : φ (⟨0, by decide⟩ : Fin 3) = (⟨0, by decide⟩ : Fin 3) := hcompat ⟨0, Nat.zero_lt_one⟩
  -- BB_indep adj 1 2 = false; BB_edge adj 1 2 = true. φ permutes {1,2}.
  have h_BB_indep_not_adj : ¬ vbExt2_BB_indep.str.1.Adj
      (⟨1, by decide⟩ : Fin 3) (⟨2, by decide⟩ : Fin 3) := by
    rw [vbExt2_BB_indep_adj_iff]
    rintro (⟨h1, h2⟩ | ⟨h1, h2⟩ | ⟨h1, h2⟩ | ⟨h1, h2⟩) <;>
      first | exact absurd h1 (by decide) | exact absurd h2 (by decide)
  have h_BB_edge_adj_12 : vbExt2_BB_edge.str.1.Adj
      (⟨1, by decide⟩ : Fin 3) (⟨2, by decide⟩ : Fin 3) := by
    rw [vbExt2_BB_edge_adj_iff]; right; right; right; right; left; exact ⟨rfl, rfl⟩
  have h_BB_edge_adj_21 : vbExt2_BB_edge.str.1.Adj
      (⟨2, by decide⟩ : Fin 3) (⟨1, by decide⟩ : Fin 3) :=
    h_BB_edge_adj_12.symm
  have h_iff : vbExt2_BB_edge.str.1.Adj (φ (⟨1, by decide⟩ : Fin 3))
      (φ (⟨2, by decide⟩ : Fin 3)) ↔
      vbExt2_BB_indep.str.1.Adj (⟨1, by decide⟩ : Fin 3) (⟨2, by decide⟩ : Fin 3) := by
    rw [show vbExt2_BB_indep.str = CG2.comap φ vbExt2_BB_edge.str from hstr.symm]
    rfl
  have hφ1_ne_0 : φ (⟨1, by decide⟩ : Fin 3) ≠ (⟨0, by decide⟩ : Fin 3) := by
    intro h_eq
    have : φ (⟨1, by decide⟩ : Fin 3) = φ (⟨0, by decide⟩ : Fin 3) := h_eq.trans h0.symm
    have hh : (⟨1, by decide⟩ : Fin 3) = (⟨0, by decide⟩ : Fin 3) := φ.injective this
    have : (1 : ℕ) = 0 := congr_arg Fin.val hh; omega
  have hφ2_ne_0 : φ (⟨2, by decide⟩ : Fin 3) ≠ (⟨0, by decide⟩ : Fin 3) := by
    intro h_eq
    have : φ (⟨2, by decide⟩ : Fin 3) = φ (⟨0, by decide⟩ : Fin 3) := h_eq.trans h0.symm
    have hh : (⟨2, by decide⟩ : Fin 3) = (⟨0, by decide⟩ : Fin 3) := φ.injective this
    have : (2 : ℕ) = 0 := congr_arg Fin.val hh; omega
  rcases fin3_val_cases (φ (⟨1, by decide⟩ : Fin 3)) with hp0 | hp1 | hp2
  · exact hφ1_ne_0 (Fin.ext hp0)
  · have hp1_eq : φ (⟨1, by decide⟩ : Fin 3) = (⟨1, by decide⟩ : Fin 3) := Fin.ext hp1
    rcases fin3_val_cases (φ (⟨2, by decide⟩ : Fin 3)) with hq0 | hq1 | hq2
    · exact hφ2_ne_0 (Fin.ext hq0)
    · have hq1_eq : φ (⟨2, by decide⟩ : Fin 3) = (⟨1, by decide⟩ : Fin 3) := Fin.ext hq1
      have : φ (⟨1, by decide⟩ : Fin 3) = φ (⟨2, by decide⟩ : Fin 3) :=
        hp1_eq.trans hq1_eq.symm
      have hh : (⟨1, by decide⟩ : Fin 3) = (⟨2, by decide⟩ : Fin 3) := φ.injective this
      have : (1 : ℕ) = 2 := congr_arg Fin.val hh; omega
    · have hq2_eq : φ (⟨2, by decide⟩ : Fin 3) = (⟨2, by decide⟩ : Fin 3) := Fin.ext hq2
      rw [hp1_eq, hq2_eq] at h_iff
      exact h_BB_indep_not_adj (h_iff.mp h_BB_edge_adj_12)
  · have hp2_eq : φ (⟨1, by decide⟩ : Fin 3) = (⟨2, by decide⟩ : Fin 3) := Fin.ext hp2
    rcases fin3_val_cases (φ (⟨2, by decide⟩ : Fin 3)) with hq0 | hq1 | hq2
    · exact hφ2_ne_0 (Fin.ext hq0)
    · have hq1_eq : φ (⟨2, by decide⟩ : Fin 3) = (⟨1, by decide⟩ : Fin 3) := Fin.ext hq1
      rw [hp2_eq, hq1_eq] at h_iff
      exact h_BB_indep_not_adj (h_iff.mp h_BB_edge_adj_21)
    · have hq2_eq : φ (⟨2, by decide⟩ : Fin 3) = (⟨2, by decide⟩ : Fin 3) := Fin.ext hq2
      have : φ (⟨1, by decide⟩ : Fin 3) = φ (⟨2, by decide⟩ : Fin 3) :=
        hp2_eq.trans hq2_eq.symm
      have hh : (⟨1, by decide⟩ : Fin 3) = (⟨2, by decide⟩ : Fin 3) := φ.injective this
      have : (1 : ℕ) = 2 := congr_arg Fin.val hh; omega

/-! ### Per-pair `genLocalFlagProduct` evaluations -/

/-- The size hypothesis for vbExt × vbExt at vertexBlackType. -/
private lemma vbExt_size_le : vertexBlackType.size ≤ 2 + 2 - vertexBlackType.size := by
  change (1 : ℕ) ≤ 2 + 2 - 1; decide

/-- `genClassesOfSize CG2 vertexBlackType (vbExt.size + vbExt'.size - 1)` simplifies. -/
private lemma vbExt_classes_size_eq :
    (2 : ℕ) + 2 - vertexBlackType.size = 3 := by change 2 + 2 - 1 = 3; decide

/-- The 6 named vbExt2 classes are members of `genClassesOfSize CG2 vertexBlackType 3`.
    Helper that goes through F.size and substitutes hF : F.size = 3.

    Strategy: we don't substitute; instead we transport along the equality of
    Finsets `genClassesOfSize σ F.size hsize = genClassesOfSize σ 3 h3`. -/
private lemma vbExt2_named_mem
    (F : GenFlag CG2 vertexBlackType) (hF : F.size = 3)
    (h3 : vertexBlackType.size ≤ 3) :
    GenFlagClass.mk F ∈ genClassesOfSize CG2 vertexBlackType 3 h3 := by
  -- Express the membership via mk_F_mem_genClassesOfSize, then transport.
  have hsize_le : vertexBlackType.size ≤ F.size := F.hsize
  have hmem := mk_F_mem_genClassesOfSize (σ := vertexBlackType) F hsize_le
  -- The Finset depends on F.size; rewrite using hF to get to 3.
  -- Use the heq pattern: cls ∈ S₁ → cls ∈ S₂ when S₁ = S₂.
  have hSet_eq : genClassesOfSize CG2 vertexBlackType F.size hsize_le =
                 genClassesOfSize CG2 vertexBlackType 3 h3 := by
    congr 1
  exact hSet_eq ▸ hmem

