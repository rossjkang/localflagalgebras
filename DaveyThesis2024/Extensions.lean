        · intro h; simp [t1_v1_d] at h
        · intro h; exact (G.str.1.irrefl h).elim
      -- (v3, w): edge (case 4: w adj v3)
      · rw [hφv3, hφw]; constructor
        · intro _; exact G_wv3.symm
        · intro _; simp [t1_v1_d, SimpleGraph.fromRel_adj]
      -- (w, v0): non-edge
      · rw [hφw, hφv0]; constructor
        · intro h; simp [t1_v1_d] at h
        · intro h; exact (h_no_v0 h).elim
      -- (w, v1): edge
      · rw [hφw, hφv1]; constructor
        · intro _; exact G_wv1
        · intro _; simp [t1_v1_d, SimpleGraph.fromRel_adj]
      -- (w, v2): edge (case 4: w adj v2)
      · rw [hφw, hφv2]; constructor
        · intro _; exact G_wv2
        · intro _; simp [t1_v1_d, SimpleGraph.fromRel_adj]
      -- (w, v3): edge (case 4: w adj v3)
      · rw [hφw, hφv3]; constructor
        · intro _; exact G_wv3
        · intro _; simp [t1_v1_d, SimpleGraph.fromRel_adj]
      -- (w, w): self-loop
      · rw [hφw]; constructor
        · intro h; simp [t1_v1_d] at h
        · intro h; exact (G.str.1.irrefl h).elim
    · -- Colour component
      funext x
      change t1_v1_d.str.2 (φ x) = G.str.2 x
      rcases x_cases x with hx | hx | hx | hx | hx <;> rw [hx]
      · rw [hφv0, hcol_v0]; rfl
      · rw [hφv1, hcol_v1]; rfl
      · rw [hφv2, hcol_v2]; rfl
      · rw [hφv3, hcol_v3]; rfl
      · rw [hφw, h_w_R]; rfl
  · -- σ-compatibility: φ ∘ G.embedding = t1_v1_d.embedding
    intro i
    fin_cases i
    · change φ (G.embedding ⟨0, _⟩) = t1_v1_d.embedding ⟨0, _⟩
      rw [← hv0]; rw [hφv0]; rfl
    · change φ (G.embedding ⟨1, _⟩) = t1_v1_d.embedding ⟨1, _⟩
      rw [← hv1]; rw [hφv1]; rfl
    · change φ (G.embedding ⟨2, _⟩) = t1_v1_d.embedding ⟨2, _⟩
      rw [← hv2]; rw [hφv2]; rfl
    · change φ (G.embedding ⟨3, _⟩) = t1_v1_d.embedding ⟨3, _⟩
      rw [← hv3]; rw [hφv3]; rfl

/-! ### σ₁-4-D BRRB constraints lemma

For ext-witnesses `t1_v0_R` and `t1_v0_B`, the ext vertex w is forced (by
extAdj-v0) adjacent to v0. Then triangle-freeness via the σ-edges v0-v1,
v0-v2, v0-v3 forces w not adjacent to v1, v2, v3. There is no colour
constraint on w because v0 is R, so neither w=R nor w=B creates a BB-edge
with a σ-vertex via the w-v0 edge.

These constraints are inputs to the 2-case classification in σ₁-4-D. -/

/-- BRRB + extAdj-v0 constraints: from triangle-free + ¬adjacent-blacks +
    extAdj-v0, the ext vertex w is forced to be non-adjacent to v1, v2, v3
    (each would form a triangle via the σ-edge v0-vᵢ).
    No colour constraint on w (since v0 is R, neither w=R nor w=B causes BB-edge). -/
theorem t1_extAdj_v0_BRRB_no_v1_v2_v3
    (G : GenFlag CG2 thesisType1) (h_size : G.size = 5)
    (h_ext : extAdjacency thesisType1 G ⟨0, by decide⟩)
    (_h_no_BB : ¬∃ u v : Fin G.size,
      G.str.2 u = 1 ∧ G.str.2 v = 1 ∧ G.str.1.Adj u v)
    (h_no_tri : ¬∃ u v w : Fin G.size,
      G.str.1.Adj u v ∧ G.str.1.Adj v w ∧ G.str.1.Adj u w) :
    ¬G.str.1.Adj (extVertex G h_size) (G.embedding ⟨1, by decide⟩) ∧
    ¬G.str.1.Adj (extVertex G h_size) (G.embedding ⟨2, by decide⟩) ∧
    ¬G.str.1.Adj (extVertex G h_size) (G.embedding ⟨3, by decide⟩) := by
  -- Extract w := extVertex G and its adjacency to v0.
  set w := extVertex G h_size with hw_def
  obtain ⟨v, hv_notin, hv_adj_v0⟩ := h_ext
  have hv_eq : v = w := extVertex_unique G h_size v hv_notin
  subst hv_eq
  -- σ-image vertices.
  set v0 := G.embedding ⟨0, by decide⟩ with hv0
  set v1 := G.embedding ⟨1, by decide⟩ with hv1
  set v2 := G.embedding ⟨2, by decide⟩ with hv2
  set v3 := G.embedding ⟨3, by decide⟩ with hv3
  -- σ-edges v0-v1, v0-v2, v0-v3 from G.isInduced
  have hcomap : (CG2.comap G.embedding G.str).1 = thesisType1.str.1 :=
    congr_arg Prod.fst G.isInduced
  have hv0_adj_v1 : G.str.1.Adj v0 v1 := by
    have h_sigma : thesisType1.str.1.Adj ⟨0, by decide⟩ ⟨1, by decide⟩ := by
      simp [thesisType1, SimpleGraph.fromRel_adj]
    rw [← hcomap] at h_sigma; exact h_sigma
  have hv0_adj_v2 : G.str.1.Adj v0 v2 := by
    have h_sigma : thesisType1.str.1.Adj ⟨0, by decide⟩ ⟨2, by decide⟩ := by
      simp [thesisType1, SimpleGraph.fromRel_adj]
    rw [← hcomap] at h_sigma; exact h_sigma
  have hv0_adj_v3 : G.str.1.Adj v0 v3 := by
    have h_sigma : thesisType1.str.1.Adj ⟨0, by decide⟩ ⟨3, by decide⟩ := by
      simp [thesisType1, SimpleGraph.fromRel_adj]
    rw [← hcomap] at h_sigma; exact h_sigma
  have hv_adj_v0' : G.str.1.Adj w v0 := by rw [hv0]; exact hv_adj_v0
  refine ⟨?_, ?_, ?_⟩
  · intro h_w_v1
    apply h_no_tri
    -- triangle v0-v1-w: edges v0-v1, v1-w, v0-w
    refine ⟨v0, v1, w, hv0_adj_v1, h_w_v1.symm, hv_adj_v0'.symm⟩
  · intro h_w_v2
    apply h_no_tri
    refine ⟨v0, v2, w, hv0_adj_v2, h_w_v2.symm, hv_adj_v0'.symm⟩
  · intro h_w_v3
    apply h_no_tri
    refine ⟨v0, v3, w, hv0_adj_v3, h_w_v3.symm, hv_adj_v0'.symm⟩

/-! ### σ₁-4-D case 5: classification for w=R, w adj only v0

Given the BRRB constraints from `t1_extAdj_v0_BRRB_no_v1_v2_v3` plus the
case 5 hypothesis (w coloured R), the σ-flag G is forced to be σ-iso to
`t1_v0_R` (K_{1,3} on v0 with extra v0-w edge, w coloured R). -/

set_option maxHeartbeats 1600000 in
-- Increased heartbeats: 25-case graph dispatch with simp [t1_v0_R] in each branch.
/-- Case 5 of σ₁-4-D: any size-5 thesisType1-flag G with extAdj-v0, w coloured
    R, and w not adjacent to v1, v2, v3 is σ-iso to the canonical witness
    `t1_v0_R` (the only adjacency of w is to v0, which is forced by extAdj-v0). -/
theorem t1_v0_R_classification (G : GenFlag CG2 thesisType1)
    (h_size : G.size = 5)
    (h_ext : extAdjacency thesisType1 G ⟨0, by decide⟩)
    (h_w_R : G.str.2 (extVertex G h_size) = 0)
    (h_no_v1 : ¬G.str.1.Adj (extVertex G h_size) (G.embedding ⟨1, by decide⟩))
    (h_no_v2 : ¬G.str.1.Adj (extVertex G h_size) (G.embedding ⟨2, by decide⟩))
    (h_no_v3 : ¬G.str.1.Adj (extVertex G h_size) (G.embedding ⟨3, by decide⟩)) :
    GenFlagIso thesisType1 G t1_v0_R := by
  classical
  set v0 := G.embedding ⟨0, by decide⟩ with hv0
  set v1 := G.embedding ⟨1, by decide⟩ with hv1
  set v2 := G.embedding ⟨2, by decide⟩ with hv2
  set v3 := G.embedding ⟨3, by decide⟩ with hv3
  set w := extVertex G h_size with hw
  have hv01 : v0 ≠ v1 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv02 : v0 ≠ v2 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv03 : v0 ≠ v3 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv12 : v1 ≠ v2 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv13 : v1 ≠ v3 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv23 : v2 ≠ v3 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hw_notin : w ∉ Set.range G.embedding := extVertex_notin_range G h_size
  have hwv0 : w ≠ v0 := fun h => hw_notin ⟨⟨0, by decide⟩, h.symm⟩
  have hwv1 : w ≠ v1 := fun h => hw_notin ⟨⟨1, by decide⟩, h.symm⟩
  have hwv2 : w ≠ v2 := fun h => hw_notin ⟨⟨2, by decide⟩, h.symm⟩
  have hwv3 : w ≠ v3 := fun h => hw_notin ⟨⟨3, by decide⟩, h.symm⟩
  have h_str_eq : (CG2.comap G.embedding G.str).1 = thesisType1.str.1 :=
    congr_arg Prod.fst G.isInduced
  have h_col_eq : ∀ j : Fin thesisType1.size,
      G.str.2 (G.embedding j) = thesisType1.str.2 j := fun j =>
    congr_fun (congr_arg Prod.snd G.isInduced) j
  have G_v0v1 : G.str.1.Adj v0 v1 := by
    have h_sigma : thesisType1.str.1.Adj ⟨0, by decide⟩ ⟨1, by decide⟩ := by
      simp [thesisType1, SimpleGraph.fromRel_adj]
    rw [← h_str_eq] at h_sigma; exact h_sigma
  have G_v0v2 : G.str.1.Adj v0 v2 := by
    have h_sigma : thesisType1.str.1.Adj ⟨0, by decide⟩ ⟨2, by decide⟩ := by
      simp [thesisType1, SimpleGraph.fromRel_adj]
    rw [← h_str_eq] at h_sigma; exact h_sigma
  have G_v0v3 : G.str.1.Adj v0 v3 := by
    have h_sigma : thesisType1.str.1.Adj ⟨0, by decide⟩ ⟨3, by decide⟩ := by
      simp [thesisType1, SimpleGraph.fromRel_adj]
    rw [← h_str_eq] at h_sigma; exact h_sigma
  have G_v1v2_no : ¬G.str.1.Adj v1 v2 := by
    intro h
    have h' : (CG2.comap G.embedding G.str).1.Adj ⟨1, by decide⟩ ⟨2, by decide⟩ := h
    rw [h_str_eq] at h'
    simp [thesisType1, SimpleGraph.fromRel_adj] at h'
  have G_v1v3_no : ¬G.str.1.Adj v1 v3 := by
    intro h
    have h' : (CG2.comap G.embedding G.str).1.Adj ⟨1, by decide⟩ ⟨3, by decide⟩ := h
    rw [h_str_eq] at h'
    simp [thesisType1, SimpleGraph.fromRel_adj] at h'
  have G_v2v3_no : ¬G.str.1.Adj v2 v3 := by
    intro h
    have h' : (CG2.comap G.embedding G.str).1.Adj ⟨2, by decide⟩ ⟨3, by decide⟩ := h
    rw [h_str_eq] at h'
    simp [thesisType1, SimpleGraph.fromRel_adj] at h'
  obtain ⟨v_ext, hv_ext_notin, hv_ext_adj⟩ := h_ext
  have hv_ext_eq : v_ext = w := extVertex_unique G h_size v_ext hv_ext_notin
  subst hv_ext_eq
  have G_wv0 : G.str.1.Adj w v0 := by rw [hv0]; exact hv_ext_adj
  have hcol_v0 : G.str.2 v0 = 0 := by rw [hv0, h_col_eq]; simp [thesisType1]
  have hcol_v1 : G.str.2 v1 = 1 := by rw [hv1, h_col_eq]; simp [thesisType1]
  have hcol_v2 : G.str.2 v2 = 0 := by rw [hv2, h_col_eq]; simp [thesisType1]
  have hcol_v3 : G.str.2 v3 = 0 := by rw [hv3, h_col_eq]; simp [thesisType1]
  -- Define φ : Fin G.size ≃ Fin 5 mapping vᵢ ↦ ⟨i,_⟩, w ↦ ⟨4,_⟩
  let φ_fn : Fin G.size → Fin 5 := fun x =>
    if x = v0 then ⟨0, by decide⟩
    else if x = v1 then ⟨1, by decide⟩
    else if x = v2 then ⟨2, by decide⟩
    else if x = v3 then ⟨3, by decide⟩
    else ⟨4, by decide⟩
  have φv0 : φ_fn v0 = ⟨0, by decide⟩ := by simp [φ_fn]
  have φv1 : φ_fn v1 = ⟨1, by decide⟩ := by
    simp only [φ_fn]; rw [if_neg hv01.symm]; simp
  have φv2 : φ_fn v2 = ⟨2, by decide⟩ := by
    simp only [φ_fn]; rw [if_neg hv02.symm, if_neg hv12.symm]; simp
  have φv3 : φ_fn v3 = ⟨3, by decide⟩ := by
    simp only [φ_fn]
    rw [if_neg hv03.symm, if_neg hv13.symm, if_neg hv23.symm]; simp
  have φw : φ_fn w = ⟨4, by decide⟩ := by
    simp only [φ_fn]
    rw [if_neg hwv0, if_neg hwv1, if_neg hwv2, if_neg hwv3]
  have x_cases : ∀ x : Fin G.size, x = v0 ∨ x = v1 ∨ x = v2 ∨ x = v3 ∨ x = w := by
    intro x
    by_cases h0 : x = v0
    · exact Or.inl h0
    by_cases h1 : x = v1
    · exact Or.inr (Or.inl h1)
    by_cases h2 : x = v2
    · exact Or.inr (Or.inr (Or.inl h2))
    by_cases h3 : x = v3
    · exact Or.inr (Or.inr (Or.inr (Or.inl h3)))
    right; right; right; right
    apply extVertex_unique G h_size
    rintro ⟨⟨j, hj⟩, hj_eq⟩
    have hjlt : j < 4 := hj
    have hsize : thesisType1.size = 4 := rfl
    interval_cases j
    · exact h0 hj_eq.symm
    · exact h1 hj_eq.symm
    · exact h2 hj_eq.symm
    · exact h3 hj_eq.symm
  have φ_inj : Function.Injective φ_fn := by
    intro x y hxy
    rcases x_cases x with hx | hx | hx | hx | hx <;>
    rcases x_cases y with hy | hy | hy | hy | hy <;>
      subst hx <;> subst hy <;>
      first
      | rfl
      | (exfalso
         try rw [φv0] at hxy
         try rw [φv1] at hxy
         try rw [φv2] at hxy
         try rw [φv3] at hxy
         try rw [φw] at hxy
         exact absurd hxy (by decide))
  have hcard : Fintype.card (Fin G.size) = Fintype.card (Fin 5) := by
    rw [Fintype.card_fin, Fintype.card_fin, h_size]
  have φ_bij : Function.Bijective φ_fn :=
    (Fintype.bijective_iff_injective_and_card φ_fn).mpr ⟨φ_inj, hcard⟩
  let φ : Fin G.size ≃ Fin t1_v0_R.size := Equiv.ofBijective φ_fn φ_bij
  have hφv0 : φ v0 = ⟨0, by decide⟩ := φv0
  have hφv1 : φ v1 = ⟨1, by decide⟩ := φv1
  have hφv2 : φ v2 = ⟨2, by decide⟩ := φv2
  have hφv3 : φ v3 = ⟨3, by decide⟩ := φv3
  have hφw : φ w = ⟨4, by decide⟩ := φw
  refine ⟨φ, ?_, ?_⟩
  · -- Structure equality: CG2.comap φ t1_v0_R.str = G.str
    apply Prod.ext
    · -- Graph component
      ext u v
      change (t1_v0_R.str.1.comap (φ : Fin G.size → Fin 5)).Adj u v ↔ G.str.1.Adj u v
      simp only [SimpleGraph.comap_adj]
      rcases x_cases u with hu | hu | hu | hu | hu <;>
      rcases x_cases v with hv | hv | hv | hv | hv <;>
        rw [hu, hv]
      -- 25 goals, dispatched by edge type:
      -- (v0, v0): self-loop
      · rw [hφv0]; constructor
        · intro h; simp [t1_v0_R] at h
        · intro h; exact (G.str.1.irrefl h).elim
      -- (v0, v1): edge
      · rw [hφv0, hφv1]; constructor
        · intro _; exact G_v0v1
        · intro _; simp [t1_v0_R, SimpleGraph.fromRel_adj]
      -- (v0, v2): edge
      · rw [hφv0, hφv2]; constructor
        · intro _; exact G_v0v2
        · intro _; simp [t1_v0_R, SimpleGraph.fromRel_adj]
      -- (v0, v3): edge
      · rw [hφv0, hφv3]; constructor
        · intro _; exact G_v0v3
        · intro _; simp [t1_v0_R, SimpleGraph.fromRel_adj]
      -- (v0, w): edge (G_wv0.symm)
      · rw [hφv0, hφw]; constructor
        · intro _; exact G_wv0.symm
        · intro _; simp [t1_v0_R, SimpleGraph.fromRel_adj]
      -- (v1, v0): edge
      · rw [hφv1, hφv0]; constructor
        · intro _; exact G_v0v1.symm
        · intro _; simp [t1_v0_R, SimpleGraph.fromRel_adj]
      -- (v1, v1): self-loop
      · rw [hφv1]; constructor
        · intro h; simp [t1_v0_R] at h
        · intro h; exact (G.str.1.irrefl h).elim
      -- (v1, v2): non-edge
      · rw [hφv1, hφv2]; constructor
        · intro h; simp [t1_v0_R] at h
        · intro h; exact (G_v1v2_no h).elim
      -- (v1, v3): non-edge
      · rw [hφv1, hφv3]; constructor
        · intro h; simp [t1_v0_R] at h
        · intro h; exact (G_v1v3_no h).elim
      -- (v1, w): non-edge (h_no_v1.symm)
      · rw [hφv1, hφw]; constructor
        · intro h; simp [t1_v0_R] at h
        · intro h; exact (h_no_v1 h.symm).elim
      -- (v2, v0): edge
      · rw [hφv2, hφv0]; constructor
        · intro _; exact G_v0v2.symm
        · intro _; simp [t1_v0_R, SimpleGraph.fromRel_adj]
      -- (v2, v1): non-edge
      · rw [hφv2, hφv1]; constructor
        · intro h; simp [t1_v0_R] at h
        · intro h; exact (G_v1v2_no h.symm).elim
      -- (v2, v2): self-loop
      · rw [hφv2]; constructor
        · intro h; simp [t1_v0_R] at h
        · intro h; exact (G.str.1.irrefl h).elim
      -- (v2, v3): non-edge
      · rw [hφv2, hφv3]; constructor
        · intro h; simp [t1_v0_R] at h
        · intro h; exact (G_v2v3_no h).elim
      -- (v2, w): non-edge (h_no_v2.symm)
      · rw [hφv2, hφw]; constructor
        · intro h; simp [t1_v0_R] at h
        · intro h; exact (h_no_v2 h.symm).elim
      -- (v3, v0): edge
      · rw [hφv3, hφv0]; constructor
        · intro _; exact G_v0v3.symm
        · intro _; simp [t1_v0_R, SimpleGraph.fromRel_adj]
      -- (v3, v1): non-edge
      · rw [hφv3, hφv1]; constructor
        · intro h; simp [t1_v0_R] at h
        · intro h; exact (G_v1v3_no h.symm).elim
      -- (v3, v2): non-edge
      · rw [hφv3, hφv2]; constructor
        · intro h; simp [t1_v0_R] at h
        · intro h; exact (G_v2v3_no h.symm).elim
      -- (v3, v3): self-loop
      · rw [hφv3]; constructor
        · intro h; simp [t1_v0_R] at h
        · intro h; exact (G.str.1.irrefl h).elim
      -- (v3, w): non-edge (h_no_v3.symm)
      · rw [hφv3, hφw]; constructor
        · intro h; simp [t1_v0_R] at h
        · intro h; exact (h_no_v3 h.symm).elim
      -- (w, v0): edge
      · rw [hφw, hφv0]; constructor
        · intro _; exact G_wv0
        · intro _; simp [t1_v0_R, SimpleGraph.fromRel_adj]
      -- (w, v1): non-edge
      · rw [hφw, hφv1]; constructor
        · intro h; simp [t1_v0_R] at h
        · intro h; exact (h_no_v1 h).elim
      -- (w, v2): non-edge
      · rw [hφw, hφv2]; constructor
        · intro h; simp [t1_v0_R] at h
        · intro h; exact (h_no_v2 h).elim
      -- (w, v3): non-edge
      · rw [hφw, hφv3]; constructor
        · intro h; simp [t1_v0_R] at h
        · intro h; exact (h_no_v3 h).elim
      -- (w, w): self-loop
      · rw [hφw]; constructor
        · intro h; simp [t1_v0_R] at h
        · intro h; exact (G.str.1.irrefl h).elim
    · -- Colour component
      funext x
      change t1_v0_R.str.2 (φ x) = G.str.2 x
      rcases x_cases x with hx | hx | hx | hx | hx <;> rw [hx]
      · rw [hφv0, hcol_v0]; rfl
      · rw [hφv1, hcol_v1]; rfl
      · rw [hφv2, hcol_v2]; rfl
      · rw [hφv3, hcol_v3]; rfl
      · rw [hφw, h_w_R]; rfl
  · -- σ-compatibility: φ ∘ G.embedding = t1_v0_R.embedding
    intro i
    fin_cases i
    · change φ (G.embedding ⟨0, _⟩) = t1_v0_R.embedding ⟨0, _⟩
      rw [← hv0]; rw [hφv0]; rfl
    · change φ (G.embedding ⟨1, _⟩) = t1_v0_R.embedding ⟨1, _⟩
      rw [← hv1]; rw [hφv1]; rfl
    · change φ (G.embedding ⟨2, _⟩) = t1_v0_R.embedding ⟨2, _⟩
      rw [← hv2]; rw [hφv2]; rfl
    · change φ (G.embedding ⟨3, _⟩) = t1_v0_R.embedding ⟨3, _⟩
      rw [← hv3]; rw [hφv3]; rfl

/-! ### σ₁-4-D case 6: classification for w=B, w adj only v0

Given the BRRB constraints from `t1_extAdj_v0_BRRB_no_v1_v2_v3` plus the
case 6 hypothesis (w coloured B), the σ-flag G is forced to be σ-iso to
`t1_v0_B` (K_{1,3} on v0 with extra v0-w edge, w coloured B). -/

set_option maxHeartbeats 1600000 in
-- Increased heartbeats: 25-case graph dispatch with simp [t1_v0_B] in each branch.
/-- Case 6 of σ₁-4-D: any size-5 thesisType1-flag G with extAdj-v0, w coloured
    B, and w not adjacent to v1, v2, v3 is σ-iso to the canonical witness
    `t1_v0_B` (the only adjacency of w is to v0, which is forced by extAdj-v0). -/
theorem t1_v0_B_classification (G : GenFlag CG2 thesisType1)
    (h_size : G.size = 5)
    (h_ext : extAdjacency thesisType1 G ⟨0, by decide⟩)
    (h_w_B : G.str.2 (extVertex G h_size) = 1)
    (h_no_v1 : ¬G.str.1.Adj (extVertex G h_size) (G.embedding ⟨1, by decide⟩))
    (h_no_v2 : ¬G.str.1.Adj (extVertex G h_size) (G.embedding ⟨2, by decide⟩))
    (h_no_v3 : ¬G.str.1.Adj (extVertex G h_size) (G.embedding ⟨3, by decide⟩)) :
    GenFlagIso thesisType1 G t1_v0_B := by
  classical
  set v0 := G.embedding ⟨0, by decide⟩ with hv0
  set v1 := G.embedding ⟨1, by decide⟩ with hv1
  set v2 := G.embedding ⟨2, by decide⟩ with hv2
  set v3 := G.embedding ⟨3, by decide⟩ with hv3
  set w := extVertex G h_size with hw
  have hv01 : v0 ≠ v1 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv02 : v0 ≠ v2 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv03 : v0 ≠ v3 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv12 : v1 ≠ v2 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv13 : v1 ≠ v3 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv23 : v2 ≠ v3 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hw_notin : w ∉ Set.range G.embedding := extVertex_notin_range G h_size
  have hwv0 : w ≠ v0 := fun h => hw_notin ⟨⟨0, by decide⟩, h.symm⟩
  have hwv1 : w ≠ v1 := fun h => hw_notin ⟨⟨1, by decide⟩, h.symm⟩
  have hwv2 : w ≠ v2 := fun h => hw_notin ⟨⟨2, by decide⟩, h.symm⟩
  have hwv3 : w ≠ v3 := fun h => hw_notin ⟨⟨3, by decide⟩, h.symm⟩
  have h_str_eq : (CG2.comap G.embedding G.str).1 = thesisType1.str.1 :=
    congr_arg Prod.fst G.isInduced
  have h_col_eq : ∀ j : Fin thesisType1.size,
      G.str.2 (G.embedding j) = thesisType1.str.2 j := fun j =>
    congr_fun (congr_arg Prod.snd G.isInduced) j
  have G_v0v1 : G.str.1.Adj v0 v1 := by
    have h_sigma : thesisType1.str.1.Adj ⟨0, by decide⟩ ⟨1, by decide⟩ := by
      simp [thesisType1, SimpleGraph.fromRel_adj]
    rw [← h_str_eq] at h_sigma; exact h_sigma
  have G_v0v2 : G.str.1.Adj v0 v2 := by
    have h_sigma : thesisType1.str.1.Adj ⟨0, by decide⟩ ⟨2, by decide⟩ := by
      simp [thesisType1, SimpleGraph.fromRel_adj]
    rw [← h_str_eq] at h_sigma; exact h_sigma
  have G_v0v3 : G.str.1.Adj v0 v3 := by
    have h_sigma : thesisType1.str.1.Adj ⟨0, by decide⟩ ⟨3, by decide⟩ := by
      simp [thesisType1, SimpleGraph.fromRel_adj]
    rw [← h_str_eq] at h_sigma; exact h_sigma
  have G_v1v2_no : ¬G.str.1.Adj v1 v2 := by
    intro h
    have h' : (CG2.comap G.embedding G.str).1.Adj ⟨1, by decide⟩ ⟨2, by decide⟩ := h
    rw [h_str_eq] at h'
    simp [thesisType1, SimpleGraph.fromRel_adj] at h'
  have G_v1v3_no : ¬G.str.1.Adj v1 v3 := by
    intro h
    have h' : (CG2.comap G.embedding G.str).1.Adj ⟨1, by decide⟩ ⟨3, by decide⟩ := h
    rw [h_str_eq] at h'
    simp [thesisType1, SimpleGraph.fromRel_adj] at h'
  have G_v2v3_no : ¬G.str.1.Adj v2 v3 := by
    intro h
    have h' : (CG2.comap G.embedding G.str).1.Adj ⟨2, by decide⟩ ⟨3, by decide⟩ := h
    rw [h_str_eq] at h'
    simp [thesisType1, SimpleGraph.fromRel_adj] at h'
  obtain ⟨v_ext, hv_ext_notin, hv_ext_adj⟩ := h_ext
  have hv_ext_eq : v_ext = w := extVertex_unique G h_size v_ext hv_ext_notin
  subst hv_ext_eq
  have G_wv0 : G.str.1.Adj w v0 := by rw [hv0]; exact hv_ext_adj
  have hcol_v0 : G.str.2 v0 = 0 := by rw [hv0, h_col_eq]; simp [thesisType1]
  have hcol_v1 : G.str.2 v1 = 1 := by rw [hv1, h_col_eq]; simp [thesisType1]
  have hcol_v2 : G.str.2 v2 = 0 := by rw [hv2, h_col_eq]; simp [thesisType1]
  have hcol_v3 : G.str.2 v3 = 0 := by rw [hv3, h_col_eq]; simp [thesisType1]
  -- Define φ : Fin G.size ≃ Fin 5 mapping vᵢ ↦ ⟨i,_⟩, w ↦ ⟨4,_⟩
  let φ_fn : Fin G.size → Fin 5 := fun x =>
    if x = v0 then ⟨0, by decide⟩
    else if x = v1 then ⟨1, by decide⟩
    else if x = v2 then ⟨2, by decide⟩
    else if x = v3 then ⟨3, by decide⟩
    else ⟨4, by decide⟩
  have φv0 : φ_fn v0 = ⟨0, by decide⟩ := by simp [φ_fn]
  have φv1 : φ_fn v1 = ⟨1, by decide⟩ := by
    simp only [φ_fn]; rw [if_neg hv01.symm]; simp
  have φv2 : φ_fn v2 = ⟨2, by decide⟩ := by
    simp only [φ_fn]; rw [if_neg hv02.symm, if_neg hv12.symm]; simp
  have φv3 : φ_fn v3 = ⟨3, by decide⟩ := by
    simp only [φ_fn]
    rw [if_neg hv03.symm, if_neg hv13.symm, if_neg hv23.symm]; simp
  have φw : φ_fn w = ⟨4, by decide⟩ := by
    simp only [φ_fn]
    rw [if_neg hwv0, if_neg hwv1, if_neg hwv2, if_neg hwv3]
  have x_cases : ∀ x : Fin G.size, x = v0 ∨ x = v1 ∨ x = v2 ∨ x = v3 ∨ x = w := by
    intro x
    by_cases h0 : x = v0
    · exact Or.inl h0
    by_cases h1 : x = v1
    · exact Or.inr (Or.inl h1)
    by_cases h2 : x = v2
    · exact Or.inr (Or.inr (Or.inl h2))
    by_cases h3 : x = v3
    · exact Or.inr (Or.inr (Or.inr (Or.inl h3)))
    right; right; right; right
    apply extVertex_unique G h_size
    rintro ⟨⟨j, hj⟩, hj_eq⟩
    have hjlt : j < 4 := hj
    have hsize : thesisType1.size = 4 := rfl
    interval_cases j
    · exact h0 hj_eq.symm
    · exact h1 hj_eq.symm
    · exact h2 hj_eq.symm
    · exact h3 hj_eq.symm
  have φ_inj : Function.Injective φ_fn := by
    intro x y hxy
    rcases x_cases x with hx | hx | hx | hx | hx <;>
    rcases x_cases y with hy | hy | hy | hy | hy <;>
      subst hx <;> subst hy <;>
      first
      | rfl
      | (exfalso
         try rw [φv0] at hxy
         try rw [φv1] at hxy
         try rw [φv2] at hxy
         try rw [φv3] at hxy
         try rw [φw] at hxy
         exact absurd hxy (by decide))
  have hcard : Fintype.card (Fin G.size) = Fintype.card (Fin 5) := by
    rw [Fintype.card_fin, Fintype.card_fin, h_size]
  have φ_bij : Function.Bijective φ_fn :=
    (Fintype.bijective_iff_injective_and_card φ_fn).mpr ⟨φ_inj, hcard⟩
  let φ : Fin G.size ≃ Fin t1_v0_B.size := Equiv.ofBijective φ_fn φ_bij
  have hφv0 : φ v0 = ⟨0, by decide⟩ := φv0
  have hφv1 : φ v1 = ⟨1, by decide⟩ := φv1
  have hφv2 : φ v2 = ⟨2, by decide⟩ := φv2
  have hφv3 : φ v3 = ⟨3, by decide⟩ := φv3
  have hφw : φ w = ⟨4, by decide⟩ := φw
  refine ⟨φ, ?_, ?_⟩
  · -- Structure equality: CG2.comap φ t1_v0_B.str = G.str
    apply Prod.ext
    · -- Graph component
      ext u v
      change (t1_v0_B.str.1.comap (φ : Fin G.size → Fin 5)).Adj u v ↔ G.str.1.Adj u v
      simp only [SimpleGraph.comap_adj]
      rcases x_cases u with hu | hu | hu | hu | hu <;>
      rcases x_cases v with hv | hv | hv | hv | hv <;>
        rw [hu, hv]
      -- 25 goals, dispatched by edge type:
      -- (v0, v0): self-loop
      · rw [hφv0]; constructor
        · intro h; simp [t1_v0_B] at h
        · intro h; exact (G.str.1.irrefl h).elim
