        = (⟨1, by decide⟩ : Fin 4)
    rw [Equiv.swap_apply_of_ne_of_ne
          (show (⟨2, by decide⟩ : Fin 4) ≠ ⟨0, by decide⟩ by decide)
          (show (⟨2, by decide⟩ : Fin 4) ≠ ⟨1, by decide⟩ by decide),
        Equiv.swap_apply_of_ne_of_ne
          (show (⟨2, by decide⟩ : Fin 4) ≠ ⟨1, by decide⟩ by decide)
          (show (⟨2, by decide⟩ : Fin 4) ≠ ⟨3, by decide⟩ by decide),
        Equiv.swap_apply_right]
  have hp3 : φ (⟨3, by decide⟩ : Fin 4) = (⟨2, by decide⟩ : Fin 4) := by
    change Equiv.swap (⟨1, by decide⟩ : Fin 4) ⟨2, by decide⟩
        (Equiv.swap (⟨1, by decide⟩ : Fin 4) ⟨3, by decide⟩
          (Equiv.swap (⟨0, by decide⟩ : Fin 4) ⟨1, by decide⟩ ⟨3, by decide⟩))
        = (⟨2, by decide⟩ : Fin 4)
    rw [Equiv.swap_apply_of_ne_of_ne
          (show (⟨3, by decide⟩ : Fin 4) ≠ ⟨0, by decide⟩ by decide)
          (show (⟨3, by decide⟩ : Fin 4) ≠ ⟨1, by decide⟩ by decide),
        Equiv.swap_apply_right,
        Equiv.swap_apply_left]
  apply size4_sigma1_iso_via_leafperm G_str T_str G_emb T_emb G_isInd T_isInd
    G_hsize T_hsize h_emb_G h_emb_T φ hp1
  · intro u v
    rcases fin4_val_cases u with hu | hu | hu | hu <;>
      rcases fin4_val_cases v with hv | hv | hv | hv <;>
      first
      | (have hu_eq : u = (⟨0, by decide⟩ : Fin 4) := Fin.ext hu
         have hv_eq : v = (⟨0, by decide⟩ : Fin 4) := Fin.ext hv
         rw [hu_eq, hv_eq, hp0]
         constructor <;> intro hadj <;> exact absurd hadj (SimpleGraph.irrefl _))
      | (have hu_eq : u = (⟨1, by decide⟩ : Fin 4) := Fin.ext hu
         have hv_eq : v = (⟨1, by decide⟩ : Fin 4) := Fin.ext hv
         rw [hu_eq, hv_eq, hp1]
         constructor <;> intro hadj <;> exact absurd hadj (SimpleGraph.irrefl _))
      | (have hu_eq : u = (⟨2, by decide⟩ : Fin 4) := Fin.ext hu
         have hv_eq : v = (⟨2, by decide⟩ : Fin 4) := Fin.ext hv
         rw [hu_eq, hv_eq, hp2]
         constructor <;> intro hadj <;> exact absurd hadj (SimpleGraph.irrefl _))
      | (have hu_eq : u = (⟨3, by decide⟩ : Fin 4) := Fin.ext hu
         have hv_eq : v = (⟨3, by decide⟩ : Fin 4) := Fin.ext hv
         rw [hu_eq, hv_eq, hp3]
         constructor <;> intro hadj <;> exact absurd hadj (SimpleGraph.irrefl _))
      | (have hu_eq : u = (⟨0, by decide⟩ : Fin 4) := Fin.ext hu
         have hv_eq : v = (⟨1, by decide⟩ : Fin 4) := Fin.ext hv
         rw [hu_eq, hv_eq, hp0, hp1]; exact h_adj_01)
      | (have hu_eq : u = (⟨0, by decide⟩ : Fin 4) := Fin.ext hu
         have hv_eq : v = (⟨2, by decide⟩ : Fin 4) := Fin.ext hv
         rw [hu_eq, hv_eq, hp0, hp2]; exact h_adj_02)
      | (have hu_eq : u = (⟨0, by decide⟩ : Fin 4) := Fin.ext hu
         have hv_eq : v = (⟨3, by decide⟩ : Fin 4) := Fin.ext hv
         rw [hu_eq, hv_eq, hp0, hp3]; exact h_adj_03)
      | (have hu_eq : u = (⟨1, by decide⟩ : Fin 4) := Fin.ext hu
         have hv_eq : v = (⟨0, by decide⟩ : Fin 4) := Fin.ext hv
         rw [hu_eq, hv_eq, hp1, hp0,
             SimpleGraph.adj_comm (G := G_str.1),
