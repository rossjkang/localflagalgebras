    genInducedCount_vbExt3_RBB_e2_RBBB_vbExt4_RRRR_e0_eq_zero

/-- LFP(vbExt3_RBB_e2_RBRB, vbExtRed)(⟦RRRR_e0⟧) = 0. -/
theorem lfp_vbExt3_RBB_e2_RBRB_vbExtRed_at_RRRR_e0 :
    (genLocalFlagProduct CG2 vertexBlackType vbExt3_RBB_e2_RBRB vbExtRed)
      (GenFlagClass.mk vbExt4_RRRR_e0) = 0 :=
