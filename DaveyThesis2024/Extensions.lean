/-- σ-position-2 non-canonical iso via composite φ = swap(0,2) ∘ cycle(1,3,2). -/
private theorem size4_sigma2_swap02_cycle132_iso
    (G_str T_str : CG2.Str 4)
    (G_emb T_emb : Fin vertexBlackType.size ↪ Fin 4)
    (G_isInd : CG2.comap G_emb G_str = vertexBlackType.str)
    (T_isInd : CG2.comap T_emb T_str = vertexBlackType.str)
    (G_hsize T_hsize : vertexBlackType.size ≤ 4)
    (h_emb_G : (G_emb ⟨0, Nat.zero_lt_one⟩).val = 2)
    (h_emb_T : (T_emb ⟨0, Nat.zero_lt_one⟩).val = 0)
    -- φ : 0↦1, 1↦3, 2↦0, 3↦2.
    (h_adj_01 : G_str.1.Adj ⟨0, by decide⟩ ⟨1, by decide⟩ ↔
                T_str.1.Adj ⟨1, by decide⟩ ⟨3, by decide⟩)
    (h_adj_02 : G_str.1.Adj ⟨0, by decide⟩ ⟨2, by decide⟩ ↔
                T_str.1.Adj ⟨1, by decide⟩ ⟨0, by decide⟩)
    (h_adj_03 : G_str.1.Adj ⟨0, by decide⟩ ⟨3, by decide⟩ ↔
                T_str.1.Adj ⟨1, by decide⟩ ⟨2, by decide⟩)
    (h_adj_12 : G_str.1.Adj ⟨1, by decide⟩ ⟨2, by decide⟩ ↔
                T_str.1.Adj ⟨3, by decide⟩ ⟨0, by decide⟩)
    (h_adj_13 : G_str.1.Adj ⟨1, by decide⟩ ⟨3, by decide⟩ ↔
                T_str.1.Adj ⟨3, by decide⟩ ⟨2, by decide⟩)
    (h_adj_23 : G_str.1.Adj ⟨2, by decide⟩ ⟨3, by decide⟩ ↔
                T_str.1.Adj ⟨0, by decide⟩ ⟨2, by decide⟩)
    -- Colours: G(0) = T(1), G(1) = T(3), G(3) = T(2).
    (h_col_0 : G_str.2 ⟨0, by decide⟩ = T_str.2 ⟨1, by decide⟩)
    (h_col_1 : G_str.2 ⟨1, by decide⟩ = T_str.2 ⟨3, by decide⟩)
    (h_col_3 : G_str.2 ⟨3, by decide⟩ = T_str.2 ⟨2, by decide⟩) :
    GenFlagIso vertexBlackType
      (⟨4, G_str, G_emb, G_isInd, G_hsize⟩ : GenFlag CG2 vertexBlackType)
      (⟨4, T_str, T_emb, T_isInd, T_hsize⟩ : GenFlag CG2 vertexBlackType) := by
  classical
  -- φ values: 0↦1, 1↦3, 2↦0, 3↦2.
  -- Built as swap(0,2).trans(swap(1,2).trans(swap(2,3))).
  let φ : Fin 4 ≃ Fin 4 :=
    (Equiv.swap (⟨0, by decide⟩ : Fin 4) ⟨2, by decide⟩).trans
      ((Equiv.swap (⟨1, by decide⟩ : Fin 4) ⟨2, by decide⟩).trans
        (Equiv.swap (⟨2, by decide⟩ : Fin 4) ⟨3, by decide⟩))
  have hp0 : φ (⟨0, by decide⟩ : Fin 4) = (⟨1, by decide⟩ : Fin 4) := by
    change Equiv.swap (⟨2, by decide⟩ : Fin 4) ⟨3, by decide⟩
        (Equiv.swap (⟨1, by decide⟩ : Fin 4) ⟨2, by decide⟩
          (Equiv.swap (⟨0, by decide⟩ : Fin 4) ⟨2, by decide⟩ ⟨0, by decide⟩))
        = (⟨1, by decide⟩ : Fin 4)
    rw [Equiv.swap_apply_left,
        Equiv.swap_apply_right,
        Equiv.swap_apply_of_ne_of_ne
          (show (⟨1, by decide⟩ : Fin 4) ≠ ⟨2, by decide⟩ by decide)
          (show (⟨1, by decide⟩ : Fin 4) ≠ ⟨3, by decide⟩ by decide)]
  have hp1 : φ (⟨1, by decide⟩ : Fin 4) = (⟨3, by decide⟩ : Fin 4) := by
