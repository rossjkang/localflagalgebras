  · rintro ⟨⟨j, hj⟩, hjeq⟩
    have hjlt : j < 4 := hj
    have hval : (t4_v1_c.embedding ⟨j, hj⟩).val = 4 := congr_arg Fin.val hjeq
    have hcastle : (t4_v1_c.embedding ⟨j, hj⟩).val = j := rfl
    omega
