/-! ### Joint count zero-pattern for RB cases (overlap-violation)

For (Red, Red) at RB_*, both embeddings exist but are forced to map to the
same leaf vertex ⟨1⟩, violating the overlap constraint. Similarly for
(Black, Black) at RB_*: both forced to vertex ⟨2⟩.
-/

/-- Uniqueness: any e : vbExtRed → vbExt2_RB_indep has e ⟨1⟩ = ⟨1⟩. -/
private lemma vbExtRed_to_vbExt2_RB_indep_leaf_unique
    (e : GenInducedEmbedding CG2 vertexBlackType vbExtRed vbExt2_RB_indep) :
    e.toFun (⟨1, by decide⟩ : Fin 2) = (⟨1, by decide⟩ : Fin 3) := by
  obtain ⟨f, finj, find, fcompat⟩ := e
  have h_phi_0 : f (⟨0, by decide⟩ : Fin 2) = (⟨0, by decide⟩ : Fin 3) :=
    fcompat (⟨0, Nat.zero_lt_one⟩ : Fin 1)
  have h_col : vbExt2_RB_indep.str.2 (f (⟨1, by decide⟩ : Fin 2)) =
      vbExtRed.str.2 (⟨1, by decide⟩ : Fin 2) :=
    congr_arg (fun s : CG2.Str vbExtRed.size => s.2 (⟨1, by decide⟩ : Fin 2)) find
  have h_RHS : vbExtRed.str.2 (⟨1, by decide⟩ : Fin 2) = (0 : Fin 2) := by
    change (if (1 : ℕ) = 0 then (1 : Fin 2) else 0) = 0
    decide
  rw [h_RHS] at h_col
  change f (⟨1, by decide⟩ : Fin 2) = (⟨1, by decide⟩ : Fin 3)
  rcases fin3_val_cases (f (⟨1, by decide⟩ : Fin 2)) with h0 | h1 | h2
  · -- f ⟨1⟩ = ⟨0⟩ contradicts injectivity
    exfalso
    have h_eq : f (⟨1, by decide⟩ : Fin 2) = (⟨0, by decide⟩ : Fin 3) := Fin.ext h0
    have : (⟨1, by decide⟩ : Fin 2) = (⟨0, by decide⟩ : Fin 2) :=
      finj (h_eq.trans h_phi_0.symm)
    have : (1 : ℕ) = 0 := congr_arg Fin.val this
    omega
  · exact Fin.ext h1
  · -- f ⟨1⟩ = ⟨2⟩, but RB_indep colour at ⟨2⟩ is 1, not 0. Contradicts h_col.
    exfalso
    have h_eq : f (⟨1, by decide⟩ : Fin 2) = (⟨2, by decide⟩ : Fin 3) := Fin.ext h2
    rw [h_eq] at h_col
    have : vbExt2_RB_indep.str.2 (⟨2, by decide⟩ : Fin 3) = (1 : Fin 2) := by
      change (if (2 : ℕ) = 0 then (1 : Fin 2) else if (2 : ℕ) = 1 then 0 else 1) = 1
      decide
    rw [this] at h_col
    exact absurd h_col (by decide)

