adjacencies (positive/negative according to target), and 3 leaf colour facts. -/

/-! #### RRR family (3 red leaves; ψ = id) -/

/-- `vbExt3_RRR_e1`: σ + 3 red + leaf-leaf {1,2}. ψ = id case (one of 3 orbits;
    others by leaf permutation). -/
private theorem size4_sigma0_RRR_e1_iso
    (G_str : CG2.Str 4) (G_emb : Fin vertexBlackType.size ↪ Fin 4)
    (G_isInd : CG2.comap G_emb G_str = vertexBlackType.str)
    (G_hsize : vertexBlackType.size ≤ 4)
    (h_emb_G : (G_emb ⟨0, Nat.zero_lt_one⟩).val = 0)
    (h_adj_01 : G_str.1.Adj ⟨0, by decide⟩ ⟨1, by decide⟩)
    (h_adj_02 : G_str.1.Adj ⟨0, by decide⟩ ⟨2, by decide⟩)
    (h_adj_03 : G_str.1.Adj ⟨0, by decide⟩ ⟨3, by decide⟩)
    (h_adj_12 : G_str.1.Adj ⟨1, by decide⟩ ⟨2, by decide⟩)
    (h_nadj_13 : ¬ G_str.1.Adj ⟨1, by decide⟩ ⟨3, by decide⟩)
