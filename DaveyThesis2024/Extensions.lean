  have h_RHS : vbExtBlack.str.2 (⟨1, by decide⟩ : Fin 2) = (1 : Fin 2) := rfl
  rw [h_RHS] at h_col
  change f (⟨1, by decide⟩ : Fin 2) = (⟨2, by decide⟩ : Fin 3)
  rcases fin3_val_cases (f (⟨1, by decide⟩ : Fin 2)) with h0 | h1 | h2
  · exfalso
    have h_eq : f (⟨1, by decide⟩ : Fin 2) = (⟨0, by decide⟩ : Fin 3) := Fin.ext h0
    have : (⟨1, by decide⟩ : Fin 2) = (⟨0, by decide⟩ : Fin 2) :=
      finj (h_eq.trans h_phi_0.symm)
    have : (1 : ℕ) = 0 := congr_arg Fin.val this
    omega
  · exfalso
    have h_eq : f (⟨1, by decide⟩ : Fin 2) = (⟨1, by decide⟩ : Fin 3) := Fin.ext h1
    rw [h_eq] at h_col
    have : vbExt2_RB_edge.str.2 (⟨1, by decide⟩ : Fin 3) = (0 : Fin 2) := by
      change (if (1 : ℕ) = 0 then (1 : Fin 2) else if (1 : ℕ) = 1 then 0 else 1) = 0
      decide
    rw [this] at h_col
    exact absurd h_col (by decide)
  · exact Fin.ext h2

/-- jointCount(vbExtRed, vbExtRed, vbExt2_RB_indep) = 0: both embeddings forced
    to leaf ⟨1⟩, but then ⟨1⟩ is in both ranges yet not in σ-image, violating
    the overlap condition. -/
theorem genJointCount_vbExtRed_vbExtRed_vbExt2_RB_indep :
    genJointCount CG2 vertexBlackType vbExtRed vbExtRed vbExt2_RB_indep = 0 := by
  unfold genJointCount
  rw [Fintype.card_eq_zero_iff]
  refine ⟨fun ⟨⟨e₁, e₂⟩, hover, _⟩ => ?_⟩
  -- hover at i = ⟨1⟩: ⟨1⟩ ∈ range e₁ ∧ ⟨1⟩ ∈ range e₂ ↔ ⟨1⟩ ∈ range G.embedding
  have h_e1 : e₁.toFun (⟨1, by decide⟩ : Fin 2) = (⟨1, by decide⟩ : Fin 3) :=
    vbExtRed_to_vbExt2_RB_indep_leaf_unique e₁
  have h_e2 : e₂.toFun (⟨1, by decide⟩ : Fin 2) = (⟨1, by decide⟩ : Fin 3) :=
    vbExtRed_to_vbExt2_RB_indep_leaf_unique e₂
  have hover_1 := hover (⟨1, by decide⟩ : Fin 3)
  -- LHS: ⟨1⟩ ∈ range e₁ (yes via ⟨1⟩ : Fin 2 ↦ ⟨1⟩) ∧ ⟨1⟩ ∈ range e₂ (same)
  have h_in_e1 : (⟨1, by decide⟩ : Fin 3) ∈ Set.range e₁.toFun :=
    ⟨⟨1, by decide⟩, h_e1⟩
  have h_in_e2 : (⟨1, by decide⟩ : Fin 3) ∈ Set.range e₂.toFun :=
    ⟨⟨1, by decide⟩, h_e2⟩
  have h_LHS : (⟨1, by decide⟩ : Fin 3) ∈ Set.range e₁.toFun ∧
      (⟨1, by decide⟩ : Fin 3) ∈ Set.range e₂.toFun := ⟨h_in_e1, h_in_e2⟩
  -- RHS: ⟨1⟩ ∈ range G.embedding = {⟨0⟩}. False.
  have h_RHS : (⟨1, by decide⟩ : Fin 3) ∉ Set.range vbExt2_RB_indep.embedding := by
    rintro ⟨i, hi⟩
    have h_emb : vbExt2_RB_indep.embedding i = (⟨0, by decide⟩ : Fin 3) := by
      change (⟨0, by decide⟩ : Fin 3) = _
      rfl
    rw [h_emb] at hi
    have : (1 : ℕ) = 0 := congr_arg Fin.val hi.symm
    omega
  exact h_RHS (hover_1.mp h_LHS)

