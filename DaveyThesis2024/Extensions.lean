    GenFlagIso vertexBlackType
      (⟨4, G_str, G_emb, G_isInd, G_hsize⟩ : GenFlag CG2 vertexBlackType)
      vbExt3_RRR_e1 := by
  apply size4_sigma0_id_iso G_str vbExt3_RRR_e1.str G_emb vbExt3_RRR_e1.embedding
    G_isInd vbExt3_RRR_e1.isInduced G_hsize vbExt3_RRR_e1.hsize h_emb_G rfl
  · exact iff_of_true h_adj_01 (by rw [vbExt3_RRR_e1_adj_iff]; decide)
  · exact iff_of_true h_adj_02 (by rw [vbExt3_RRR_e1_adj_iff]; decide)
  · exact iff_of_true h_adj_03 (by rw [vbExt3_RRR_e1_adj_iff]; decide)
  · exact iff_of_true h_adj_12 (by rw [vbExt3_RRR_e1_adj_iff]; decide)
  · refine iff_of_false h_nadj_13 ?_; rw [vbExt3_RRR_e1_adj_iff]; decide
  · refine iff_of_false h_nadj_23 ?_; rw [vbExt3_RRR_e1_adj_iff]; decide
  · rw [h_col_1, vbExt3_RRR_e1_col]; rfl
  · rw [h_col_2, vbExt3_RRR_e1_col]; rfl
  · rw [h_col_3, vbExt3_RRR_e1_col]; rfl

