          rw [← hemb_eq]
          exact congr_arg (fun s : CG2.Str vertexBlackType.size =>
            s.2 ⟨0, Nat.zero_lt_one⟩) F_isInd
        rw [h_F_at_1]
  · intro i
    have hi : i = (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) := by
      obtain ⟨v, hv⟩ := i
      have h_size : vertexBlackType.size = 1 := rfl
      have hv' : v < 1 := h_size ▸ hv
      have : v = 0 := by omega
      ext; exact this
    rw [hi]
    change Equiv.swap (⟨0, Nat.zero_lt_two⟩ : Fin 2) ⟨1, Nat.one_lt_two⟩
      (F_emb ⟨0, Nat.zero_lt_one⟩) = vbExtBlack.embedding ⟨0, Nat.zero_lt_one⟩
    have hemb_eq : F_emb ⟨0, Nat.zero_lt_one⟩ = (⟨1, Nat.one_lt_two⟩ : Fin 2) :=
      Fin.ext hemb_val
    rw [hemb_eq]
    rw [Equiv.swap_apply_right]
    rfl

/-- Symmetric: black-leaf canonical case → iso to vbExtBlack. -/
theorem genFlag_size2_canonical_black_iso_vbExtBlack
    (F_str : CG2.Str 2)
    (F_emb : Fin vertexBlackType.size ↪ Fin 2)
    (F_isInd : CG2.comap F_emb F_str = vertexBlackType.str)
    (F_hsize : vertexBlackType.size ≤ 2)
    (hemb_val : (F_emb ⟨0, Nat.zero_lt_one⟩).val = 0)
    (hgraph : F_str.1 = vbExtBlack.str.1)
    (hcol1 : F_str.2 ⟨1, Nat.one_lt_two⟩ = 1) :
    GenFlagIso vertexBlackType
      (⟨2, F_str, F_emb, F_isInd, F_hsize⟩ : GenFlag CG2 vertexBlackType) vbExtBlack := by
  refine ⟨Equiv.refl (Fin 2), ?_, ?_⟩
  · change CG2.comap (Equiv.refl (Fin 2)) vbExtBlack.str = F_str
    rw [show (Equiv.refl (Fin 2) : Fin 2 → Fin 2) = id from rfl, CG2.comap_id]
    apply Prod.ext
    · change vbExtBlack.str.1 = F_str.1
      rw [hgraph]
    · change vbExtBlack.str.2 = F_str.2
      funext v
      have hv : v.val = 0 ∨ v.val = 1 := fin2_eq_zero_or_one v
      rcases hv with h0 | h1
      · have hv_eq : v = ⟨0, Nat.zero_lt_two⟩ := Fin.ext h0
        rw [hv_eq]
        have hemb_eq : F_emb ⟨0, Nat.zero_lt_one⟩ = ⟨0, Nat.zero_lt_two⟩ :=
          Fin.ext hemb_val
        have h_F_at_0 : F_str.2 ⟨0, Nat.zero_lt_two⟩ = 1 := by
          rw [← hemb_eq]
          have := congr_arg (fun s : CG2.Str vertexBlackType.size =>
            s.2 ⟨0, Nat.zero_lt_one⟩) F_isInd
          exact this
        rw [h_F_at_0]; rfl
      · have hv_eq : v = ⟨1, Nat.one_lt_two⟩ := Fin.ext h1
        rw [hv_eq, hcol1]
        rfl
  · intro i
    have hi : i = (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) := by
      obtain ⟨v, hv⟩ := i
      have h_size : vertexBlackType.size = 1 := rfl
      have hv' : v < 1 := h_size ▸ hv
      have : v = 0 := by omega
      ext; exact this
    rw [hi]
    change (Equiv.refl (Fin 2)) (F_emb ⟨0, Nat.zero_lt_one⟩) =
      vbExtBlack.embedding ⟨0, Nat.zero_lt_one⟩
    rw [show (Equiv.refl (Fin 2) : Fin 2 → Fin 2) = id from rfl]
    change F_emb ⟨0, Nat.zero_lt_one⟩ = ⟨0, Nat.zero_lt_two⟩
    exact Fin.ext hemb_val

