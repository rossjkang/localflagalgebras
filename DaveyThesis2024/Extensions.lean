/-! ### Universal σ-position-{1,2,3} helpers via arbitrary leaf permutations

The next three theorems extend the σ-pos-0 generic helper
(`size4_sigma0_iso_via_leafperm`) to σ-positions 1, 2, and 3.

Each takes an arbitrary equiv `ψ : Fin 4 ≃ Fin 4` together with a
constraint `ψ ⟨N, _⟩ = ⟨0, _⟩` (so that ψ sends G's σ-vertex at position N
to T's σ-vertex at position 0), pointwise adjacency biconditionals over
ψ, and pointwise leaf-colour equalities. They serve as the substrate for
non-canonical configurations where, after the σ-swap (0 ↔ N), an
additional leaf-permutation is required to align G's leaves with T's. -/

/-- Generic σ-position-1 iso for size-4 σ-flags using an arbitrary
    permutation `ψ : Fin 4 ≃ Fin 4` that maps position 1 to 0 (i.e., sends
    G's σ-vertex at G-pos-1 to T's σ-vertex at T-pos-0). -/
private theorem size4_sigma1_iso_via_leafperm
    (G_str T_str : CG2.Str 4)
    (G_emb T_emb : Fin vertexBlackType.size ↪ Fin 4)
    (G_isInd : CG2.comap G_emb G_str = vertexBlackType.str)
    (T_isInd : CG2.comap T_emb T_str = vertexBlackType.str)
    (G_hsize T_hsize : vertexBlackType.size ≤ 4)
    (h_emb_G : (G_emb ⟨0, Nat.zero_lt_one⟩).val = 1)
    (h_emb_T : (T_emb ⟨0, Nat.zero_lt_one⟩).val = 0)
    (ψ : Fin 4 ≃ Fin 4)
    (h_psi_1 : ψ (⟨1, by decide⟩ : Fin 4) = (⟨0, by decide⟩ : Fin 4))
    (h_adj : ∀ u v : Fin 4,
      G_str.1.Adj u v ↔ T_str.1.Adj (ψ u) (ψ v))
    (h_col : ∀ v : Fin 4, G_str.2 v = T_str.2 (ψ v)) :
    GenFlagIso vertexBlackType
      (⟨4, G_str, G_emb, G_isInd, G_hsize⟩ : GenFlag CG2 vertexBlackType)
      (⟨4, T_str, T_emb, T_isInd, T_hsize⟩ : GenFlag CG2 vertexBlackType) := by
  have hT_emb_zero : T_emb (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) =
      (⟨0, (by decide : (0:ℕ) < 4)⟩ : Fin 4) := Fin.ext h_emb_T
  apply size4_iso_via_perm G_str T_str G_emb T_emb G_isInd T_isInd G_hsize T_hsize
    hT_emb_zero ψ
  · have hG_emb_eq : G_emb (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) =
        (⟨1, by decide⟩ : Fin 4) := Fin.ext h_emb_G
    rw [hG_emb_eq, h_psi_1]
  · exact h_adj
  · exact h_col

