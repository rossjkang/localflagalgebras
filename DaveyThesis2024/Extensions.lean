      · rw [hφv2, hφv3]; constructor
        · intro _; exact G_v2v3
        · intro _; simp [t4_v1_d, SimpleGraph.fromRel_adj]
      · rw [hφv2, hφw]; constructor
        · intro _; exact G_wv2.symm
        · intro _; simp [t4_v1_d, SimpleGraph.fromRel_adj]
      · rw [hφv3, hφv0]; constructor
        · intro h; simp [t4_v1_d] at h
        · intro h; exact (G_v0v3_no h.symm).elim
      · rw [hφv3, hφv1]; constructor
        · intro _; exact G_v1v3.symm
        · intro _; simp [t4_v1_d, SimpleGraph.fromRel_adj]
      · rw [hφv3, hφv2]; constructor
        · intro _; exact G_v2v3.symm
        · intro _; simp [t4_v1_d, SimpleGraph.fromRel_adj]
      · rw [hφv3]; constructor
        · intro h; simp [t4_v1_d] at h
        · intro h; exact (G.str.1.irrefl h).elim
      · rw [hφv3, hφw]; constructor
        · intro h; simp [t4_v1_d] at h
        · intro h; exact (h_no_v3 h.symm).elim
      · rw [hφw, hφv0]; constructor
        · intro h; simp [t4_v1_d] at h
        · intro h; exact (h_no_v0 h).elim
      · rw [hφw, hφv1]; constructor
        · intro _; exact G_wv1
        · intro _; simp [t4_v1_d, SimpleGraph.fromRel_adj]
      · rw [hφw, hφv2]; constructor
        · intro _; exact G_wv2
        · intro _; simp [t4_v1_d, SimpleGraph.fromRel_adj]
      · rw [hφw, hφv3]; constructor
        · intro h; simp [t4_v1_d] at h
        · intro h; exact (h_no_v3 h).elim
      · rw [hφw]; constructor
        · intro h; simp [t4_v1_d] at h
        · intro h; exact (G.str.1.irrefl h).elim
    · funext x
      change t4_v1_d.str.2 (φ x) = G.str.2 x
      rcases x_cases x with hx | hx | hx | hx | hx <;> rw [hx]
      · rw [hφv0, hcol_v0]; rfl
      · rw [hφv1, hcol_v1]; rfl
      · rw [hφv2, hcol_v2]; rfl
      · rw [hφv3, hcol_v3]; rfl
      · rw [hφw, h_w_B]; rfl
  · intro i
    fin_cases i
    · simp [t4_v1_d, Fin.castLE]; exact hφv0
    · simp [t4_v1_d, Fin.castLE]; exact hφv1
    · simp [t4_v1_d, Fin.castLE]; exact hφv2
    · simp [t4_v1_d, Fin.castLE]; exact hφv3

/-! ### σ₄-3.3: extAdj-v0 dichotomy (thesisType4)

Same template as σ₃-3.3: 2-way split on `w-v3` (R color forced). -/
theorem t4_extAdj_v0_dichotomy
    (cls : GenFlagClass CG2 thesisType4)
    (h_size : cls.out.size = 5)
    (h_extAdj : extAdjacencyClass thesisType4 cls ⟨0, by decide⟩)
    (phi : GenLimitFunctional CG2 (GenFlagType.empty CG2)
      brrbGenGraphClass brrbGenDelta) :
    cls = GenFlagClass.mk t4_v0_a ∨
    cls = GenFlagClass.mk t4_v0_b ∨
    phi.eval cls.out.forget = 0 := by
  classical
  have h_ext : extAdjacency thesisType4 cls.out ⟨0, by decide⟩ := h_extAdj
  by_cases h_BB : ∃ u v : Fin cls.out.size,
      cls.out.str.2 u = 1 ∧ cls.out.str.2 v = 1 ∧ cls.out.str.1.Adj u v
  · right; right
    exact eval_zero_of_adj_black phi cls.out.forget h_BB
  by_cases h_tri : ∃ u v w : Fin cls.out.size,
      cls.out.str.1.Adj u v ∧ cls.out.str.1.Adj v w ∧ cls.out.str.1.Adj u w
  · right; right
    exact eval_zero_of_triangle phi cls.out.forget h_tri
  obtain ⟨h_w_R, h_no_v1, h_no_v2⟩ :=
    t4_extAdj_v0_BRRB_constraints cls.out h_size h_ext h_BB h_tri
  set w := extVertex cls.out h_size with hw_def
  set v3 := cls.out.embedding ⟨3, by decide⟩ with hv3_def
  by_cases h_v3 : cls.out.str.1.Adj w v3
  · right; left
    have hiso := t4_v0_b_classification cls.out h_size h_ext h_w_R h_no_v1 h_no_v2 h_v3
    have hmk : GenFlagClass.mk cls.out = GenFlagClass.mk t4_v0_b :=
      Quotient.sound hiso
    rw [← Quotient.out_eq cls]; exact hmk
  · left
    have hiso := t4_v0_a_classification cls.out h_size h_ext h_w_R h_no_v1 h_no_v2 h_v3
    have hmk : GenFlagClass.mk cls.out = GenFlagClass.mk t4_v0_a :=
      Quotient.sound hiso
    rw [← Quotient.out_eq cls]; exact hmk

/-! ### σ₄-3.3: extAdj-v1 dichotomy (thesisType4)

Same template as σ₃-3.3 v1: 4-way split on color × adj v2. -/
set_option maxHeartbeats 800000 in
theorem t4_extAdj_v1_dichotomy
    (cls : GenFlagClass CG2 thesisType4)
    (h_size : cls.out.size = 5)
    (h_extAdj : extAdjacencyClass thesisType4 cls ⟨1, by decide⟩)
    (phi : GenLimitFunctional CG2 (GenFlagType.empty CG2)
      brrbGenGraphClass brrbGenDelta) :
    cls = GenFlagClass.mk t4_v1_a ∨
    cls = GenFlagClass.mk t4_v1_b ∨
    cls = GenFlagClass.mk t4_v1_c ∨
    cls = GenFlagClass.mk t4_v1_d ∨
    phi.eval cls.out.forget = 0 := by
  classical
  have h_ext : extAdjacency thesisType4 cls.out ⟨1, by decide⟩ := h_extAdj
  by_cases h_BB : ∃ u v : Fin cls.out.size,
      cls.out.str.2 u = 1 ∧ cls.out.str.2 v = 1 ∧ cls.out.str.1.Adj u v
  · right; right; right; right
    exact eval_zero_of_adj_black phi cls.out.forget h_BB
  by_cases h_tri : ∃ u v w : Fin cls.out.size,
      cls.out.str.1.Adj u v ∧ cls.out.str.1.Adj v w ∧ cls.out.str.1.Adj u w
  · right; right; right; right
    exact eval_zero_of_triangle phi cls.out.forget h_tri
  obtain ⟨h_no_v0, h_no_v3⟩ :=
    t4_extAdj_v1_BRRB_constraints cls.out h_size h_ext h_BB h_tri
  set w := extVertex cls.out h_size with hw_def
  set v2 := cls.out.embedding ⟨2, by decide⟩ with hv2_def
  have hcol_lt : (cls.out.str.2 w).val < 2 := (cls.out.str.2 w).isLt
  interval_cases h_w_col : (cls.out.str.2 w).val
  · have h_w_R : cls.out.str.2 w = 0 := Fin.ext h_w_col
    by_cases h_v2 : cls.out.str.1.Adj w v2
    · right; left
      have hiso := t4_v1_b_classification cls.out h_size h_ext h_w_R h_no_v0 h_v2 h_no_v3
      have hmk : GenFlagClass.mk cls.out = GenFlagClass.mk t4_v1_b :=
        Quotient.sound hiso
      rw [← Quotient.out_eq cls]; exact hmk
    · left
      have hiso := t4_v1_a_classification cls.out h_size h_ext h_w_R h_no_v0 h_v2 h_no_v3
      have hmk : GenFlagClass.mk cls.out = GenFlagClass.mk t4_v1_a :=
        Quotient.sound hiso
      rw [← Quotient.out_eq cls]; exact hmk
  · have h_w_B : cls.out.str.2 w = 1 := Fin.ext h_w_col
    by_cases h_v2 : cls.out.str.1.Adj w v2
    · right; right; right; left
      have hiso := t4_v1_d_classification cls.out h_size h_ext h_w_B h_no_v0 h_v2 h_no_v3
      have hmk : GenFlagClass.mk cls.out = GenFlagClass.mk t4_v1_d :=
        Quotient.sound hiso
      rw [← Quotient.out_eq cls]; exact hmk
    · right; right; left
      have hiso := t4_v1_c_classification cls.out h_size h_ext h_w_B h_no_v0 h_v2 h_no_v3
      have hmk : GenFlagClass.mk cls.out = GenFlagClass.mk t4_v1_c :=
        Quotient.sound hiso
      rw [← Quotient.out_eq cls]; exact hmk

