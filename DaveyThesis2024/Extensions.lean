    · ext u v
      change vbExt2_RB_edge.str.1.Adj (fin2to3_skip u) (fin2to3_skip v) ↔
        vbExtBlack.str.1.Adj u v
      rcases fin2_eq_zero_or_one u with hu | hu <;>
        rcases fin2_eq_zero_or_one v with hv | hv
