/-- **ExtAdjAll lifts through joint-density positivity**: if `F` and `F'` both
    satisfy `ExtAdjAll`, then any `H` with positive `genJointInducedDensity F F' H`
    also satisfies `ExtAdjAll`.

    Proof: from positivity, get embeddings `e₁ : F → H`, `e₂ : F' → H` overlapping
    exactly on σ-image and covering `H`. For any non-σ vertex `v` of `H`, by
    `gen_vertex_in_exactly_one_side`, `v` is in exactly one of `range e₁`, `range
    e₂`. WLOG `v = e₁ v_F` for some `v_F`. Then `v_F ∉ range F.embedding` (else
    overlap), so by `ExtAdjAll F`, `F.str.Adj (F.emb 0) v_F`, which lifts via
    `e₁` to `H.str.Adj (H.emb 0) v` (using compat at 0). -/
theorem ExtAdjAll_of_joint_pos {σ : GenFlagType CG2} {F F' H : GenFlag CG2 σ}
    (i : Fin σ.size)
    (hF : ExtAdjAll F i) (hF' : ExtAdjAll F' i)
    (hp : genJointInducedDensity CG2 σ F F' H > 0) :
    ExtAdjAll H i := by
  obtain ⟨e₁, e₂, hoverlap, hcovering⟩ := gen_joint_pos_witness hp
  intro v hv_notin
  rcases gen_vertex_in_exactly_one_side e₁ e₂ hoverlap hcovering v hv_notin with
    ⟨⟨v₁, hv₁⟩, _⟩ | ⟨_, ⟨v₂, hv₂⟩⟩
  · -- v = e₁ v₁; v₁ ∉ range F.embedding
    have h_v₁_notin : v₁ ∉ Set.range F.embedding := by
      intro ⟨j, hj⟩
      apply hv_notin
      refine ⟨j, ?_⟩
      have hcompat : e₁.toFun (F.embedding j) = H.embedding j := e₁.compat j
      rw [← hcompat, hj]; exact hv₁
    have h_F_adj : F.str.1.Adj (F.embedding i) v₁ := hF v₁ h_v₁_notin
    -- Lift via e₁: F.str = comap e₁ H.str (componentwise on graph).
    have hind : F.str.1 = (CG2.comap e₁.toFun H.str).1 := by rw [e₁.isInduced]
    have h_adj_iff : ∀ u w : Fin F.size,
        F.str.1.Adj u w ↔ H.str.1.Adj (e₁.toFun u) (e₁.toFun w) := by
      intro u w; rw [hind]; rfl
    have h_H_adj := (h_adj_iff (F.embedding i) v₁).mp h_F_adj
    rw [e₁.compat i] at h_H_adj
    rw [hv₁] at h_H_adj
    exact h_H_adj
  · -- Symmetric: v = e₂ v₂
    have h_v₂_notin : v₂ ∉ Set.range F'.embedding := by
      intro ⟨j, hj⟩
      apply hv_notin
      refine ⟨j, ?_⟩
      have hcompat : e₂.toFun (F'.embedding j) = H.embedding j := e₂.compat j
      rw [← hcompat, hj]; exact hv₂
    have h_F'_adj : F'.str.1.Adj (F'.embedding i) v₂ := hF' v₂ h_v₂_notin
    have hind : F'.str.1 = (CG2.comap e₂.toFun H.str).1 := by rw [e₂.isInduced]
    have h_adj_iff : ∀ u w : Fin F'.size,
        F'.str.1.Adj u w ↔ H.str.1.Adj (e₂.toFun u) (e₂.toFun w) := by
      intro u w; rw [hind]; rfl
    have h_H_adj := (h_adj_iff (F'.embedding i) v₂).mp h_F'_adj
    rw [e₂.compat i] at h_H_adj
    rw [hv₂] at h_H_adj
    exact h_H_adj

/-- **`ExtAdjAll` propagates through `genLocalFlagProduct.support`**: every class
    in `(genLocalFlagProduct F F').support` has `ExtAdjAll` on its representative
    when both `F` and `F'` do. -/
theorem ExtAdjAllClass_of_lfp_support {σ : GenFlagType CG2} {F F' : GenFlag CG2 σ}
    (i : Fin σ.size)
    (hF : ExtAdjAll F i) (hF' : ExtAdjAll F' i)
    (cls : GenFlagClass CG2 σ)
    (hcls : cls ∈ (genLocalFlagProduct CG2 σ F F').support) :
    ExtAdjAllClass cls i := by
  -- Mirror the proof of `genLocalFlagProduct_local_support`, but use
  -- `ExtAdjAll_of_joint_pos` instead of `genProduct_closure`.
  unfold ExtAdjAllClass
  simp only [genLocalFlagProduct] at hcls
  by_cases hn : σ.size ≤ F.size + F'.size - σ.size
  · rw [dif_pos hn] at hcls
    simp only [Finsupp.mem_support_iff] at hcls
    rw [Finsupp.smul_apply] at hcls
    have hscalar_ne : ((↑(genFlagAutCount CG2 σ F) * ↑(genFlagAutCount CG2 σ F'))⁻¹ : ℝ) ≠ 0 :=
      inv_ne_zero (mul_ne_zero
        (Nat.cast_ne_zero.mpr (Nat.pos_iff_ne_zero.mp (genFlagAutCount_pos σ F)))
        (Nat.cast_ne_zero.mpr (Nat.pos_iff_ne_zero.mp (genFlagAutCount_pos σ F'))))
    have hsum_ne := right_ne_zero_of_mul (by rwa [smul_eq_mul] at hcls)
    rw [Finsupp.finset_sum_apply] at hsum_ne
    by_contra h_not_extAdjAll
    apply hsum_ne
    apply Finset.sum_eq_zero
    intro cls' _
    simp only [Finsupp.single_apply]
    split_ifs with heq
    · subst heq
      by_contra h_jid_ne
      have h_jid_nn : 0 ≤ genJointInducedDensity CG2 σ F F' cls'.out := by
        unfold genJointInducedDensity
        exact div_nonneg (Nat.cast_nonneg _)
          (mul_nonneg (Nat.cast_nonneg _) (Nat.cast_nonneg _))
      exact h_not_extAdjAll (ExtAdjAll_of_joint_pos i hF hF'
        (lt_of_le_of_ne h_jid_nn (Ne.symm h_jid_ne)))
    · rfl
  · rw [dif_neg hn] at hcls
    exact absurd hcls (by simp [Finsupp.support_zero])

/-- Size containment for `genLocalFlagProduct.support`: every class in the
    support has size `F.size + F'.size - σ.size`. -/
theorem genLocalFlagProduct_support_size {σ : GenFlagType CG2} {F F' : GenFlag CG2 σ}
    (cls : GenFlagClass CG2 σ)
    (hcls : cls ∈ (genLocalFlagProduct CG2 σ F F').support) :
    cls.out.size = F.size + F'.size - σ.size := by
  simp only [genLocalFlagProduct] at hcls
  by_cases hn : σ.size ≤ F.size + F'.size - σ.size
  · rw [dif_pos hn] at hcls
    simp only [Finsupp.mem_support_iff] at hcls
    rw [Finsupp.smul_apply] at hcls
    have hscalar_ne : ((↑(genFlagAutCount CG2 σ F) * ↑(genFlagAutCount CG2 σ F'))⁻¹ : ℝ) ≠ 0 :=
      inv_ne_zero (mul_ne_zero
        (Nat.cast_ne_zero.mpr (Nat.pos_iff_ne_zero.mp (genFlagAutCount_pos σ F)))
        (Nat.cast_ne_zero.mpr (Nat.pos_iff_ne_zero.mp (genFlagAutCount_pos σ F'))))
    have hsum_ne := right_ne_zero_of_mul (by rwa [smul_eq_mul] at hcls)
    rw [Finsupp.finset_sum_apply] at hsum_ne
    -- Some cls' in genClassesOfSize gives nonzero summand at cls.
    by_contra h_size_ne
    apply hsum_ne
    apply Finset.sum_eq_zero
    intro cls' hcls'
    simp only [Finsupp.single_apply]
    split_ifs with heq
    · -- cls' = cls; but cls' has size F.size + F'.size - σ.size ≠ cls.out.size — contradiction.
      exfalso
      apply h_size_ne
      have := genClassesOfSize_out_size hcls'
      rw [heq] at this
      exact this
    · rfl
  · rw [dif_neg hn] at hcls
    exact absurd hcls (by simp [Finsupp.support_zero])

/-! ### Support properties of `extPow vbType ⟨0,_⟩ 3`

Combine `extPow_three_eq_twelve_lfp` with the LFP support lemmas above to get
both size and `ExtAdjAll` for every class in the support. -/

/-- Helper: peel `support_add` once. Takes explicit arguments to avoid
    deep unification recursion when called repeatedly. -/
private theorem peel_support_add
    (a b : GenFlagAlg CG2 vertexBlackType)
    (cls : GenFlagClass CG2 vertexBlackType)
    (h : cls ∈ (a + b).support) :
    cls ∈ a.support ∨ cls ∈ b.support :=
  Finset.mem_union.mp (Finsupp.support_add h)

/-- Generic helper: at any LFP support of size-3 × size-2, the class has size 4. -/
private theorem cls_size_four_of_lfp_support
    {cls : GenFlagClass CG2 vertexBlackType}
    {F F' : GenFlag CG2 vertexBlackType}
    (hF : F.size = 3) (hF' : F'.size = 2)
    (h : cls ∈ (genLocalFlagProduct CG2 vertexBlackType F F').support) :
    cls.out.size = 4 := by
  have hsize_eq := genLocalFlagProduct_support_size cls h
  rw [hsize_eq, hF, hF']; rfl

set_option maxRecDepth 2048 in
/-- Generic helper: from "cls in support of nonzero summand A + B" extract
    where cls came from. -/
private theorem support_add_or
    (a b : GenFlagAlg CG2 vertexBlackType)
    (cls : GenFlagClass CG2 vertexBlackType)
    (h : cls ∈ (a + b).support) :
    cls ∈ a.support ∨ cls ∈ b.support := by
  have h1 : cls ∈ a.support ∪ b.support := Finsupp.support_add h
  exact Finset.mem_union.mp h1

set_option maxHeartbeats 8000000 in
/-- Every class in `(extPow vbType ⟨0,_⟩ 3).support` has `cls.out.size = 4`.

    Strategy: prove the contrapositive — if `cls.out.size ≠ 4`, then `cls`
    is not in the support of any of the 12 LFP terms, hence the value at `cls`
    in the 12-fold sum is 0, contradicting `hcls`. -/
theorem extPow_three_support_size_eq_four
    (cls : GenFlagClass CG2 vertexBlackType)
    (hcls : cls ∈ (extPow vertexBlackType
      (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) 3).support) :
    cls.out.size = 4 := by
  by_contra h_not_four
  rw [extPow_three_eq_twelve_lfp] at hcls
  -- Strategy: each LFP has cls coefficient = 0 (since cls.out.size ≠ 4).
  -- The 12-fold sum's value at cls is 0, contradicting hcls.
  have at_each : ∀ (F F' : GenFlag CG2 vertexBlackType),
      F.size = 3 → F'.size = 2 →
      (genLocalFlagProduct CG2 vertexBlackType F F') cls = 0 := by
    intro F F' hF hF'
    apply Finsupp.notMem_support_iff.mp
    intro hsupp
    have := genLocalFlagProduct_support_size cls hsupp
    apply h_not_four
    rw [this, hF, hF']; rfl
  rw [Finsupp.mem_support_iff] at hcls
  apply hcls
  simp only [Finsupp.add_apply,
    at_each vbExt2_RR_indep vbExtRed rfl rfl,
    at_each vbExt2_RR_indep vbExtBlack rfl rfl,
    at_each vbExt2_RR_edge vbExtRed rfl rfl,
    at_each vbExt2_RR_edge vbExtBlack rfl rfl,
    at_each vbExt2_RB_indep vbExtRed rfl rfl,
    at_each vbExt2_RB_indep vbExtBlack rfl rfl,
    at_each vbExt2_RB_edge vbExtRed rfl rfl,
    at_each vbExt2_RB_edge vbExtBlack rfl rfl,
    at_each vbExt2_BB_indep vbExtRed rfl rfl,
    at_each vbExt2_BB_indep vbExtBlack rfl rfl,
    at_each vbExt2_BB_edge vbExtRed rfl rfl,
    at_each vbExt2_BB_edge vbExtBlack rfl rfl, add_zero]

set_option maxHeartbeats 8000000 in
/-- Every class in `(extPow vbType ⟨0,_⟩ 3).support` has `ExtAdjAllClass`.

    Strategy: prove the contrapositive — if `¬ ExtAdjAllClass cls`, then `cls`
    is not in the support of any LFP term, so the 12-fold sum has 0 at `cls`,
    contradicting `hcls`. -/
theorem extPow_three_support_extAdjAllClass
    (cls : GenFlagClass CG2 vertexBlackType)
    (hcls : cls ∈ (extPow vertexBlackType
      (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) 3).support) :
    ExtAdjAllClass cls (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) := by
  by_contra h_not_extAdjAll
  rw [extPow_three_eq_twelve_lfp] at hcls
  have at_each : ∀ (F F' : GenFlag CG2 vertexBlackType),
      ExtAdjAll F (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) →
      ExtAdjAll F' (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) →
      (genLocalFlagProduct CG2 vertexBlackType F F') cls = 0 := by
    intro F F' hF hF'
    apply Finsupp.notMem_support_iff.mp
    intro hsupp
    apply h_not_extAdjAll
    exact ExtAdjAllClass_of_lfp_support _ hF hF' cls hsupp
  rw [Finsupp.mem_support_iff] at hcls
  apply hcls
  simp only [Finsupp.add_apply,
    at_each _ _ vbExt2_RR_indep_extAdjAll vbExtRed_extAdjAll,
    at_each _ _ vbExt2_RR_indep_extAdjAll vbExtBlack_extAdjAll,
    at_each _ _ vbExt2_RR_edge_extAdjAll vbExtRed_extAdjAll,
    at_each _ _ vbExt2_RR_edge_extAdjAll vbExtBlack_extAdjAll,
    at_each _ _ vbExt2_RB_indep_extAdjAll vbExtRed_extAdjAll,
    at_each _ _ vbExt2_RB_indep_extAdjAll vbExtBlack_extAdjAll,
    at_each _ _ vbExt2_RB_edge_extAdjAll vbExtRed_extAdjAll,
    at_each _ _ vbExt2_RB_edge_extAdjAll vbExtBlack_extAdjAll,
    at_each _ _ vbExt2_BB_indep_extAdjAll vbExtRed_extAdjAll,
    at_each _ _ vbExt2_BB_indep_extAdjAll vbExtBlack_extAdjAll,
    at_each _ _ vbExt2_BB_edge_extAdjAll vbExtRed_extAdjAll,
    at_each _ _ vbExt2_BB_edge_extAdjAll vbExtBlack_extAdjAll, add_zero]

/-! ### Master theorem: unconditional eval-level discharge

Combine the support property lemmas with the sharper dichotomy and
`extPow_three_apply_RRR_e0` to compute `psi.evalAlg(extPow ... 3)` directly,
without requiring the algebra-level decomposition hypothesis. -/

set_option maxHeartbeats 4000000 in
/-- **Unconditional v5 size-4 identity** (master theorem):
    For any BRRB sigma-functional `psi` satisfying the standard regularity
    bundle, `psi.evalAlg(single vbExt3_RRR_e0) = 1`.

    Proof:
    1. By `evalAlg_extPow`, `psi.evalAlg(extPow ... 3) = 1`.
    2. By the Finsupp.sum unfold, `psi.evalAlg(extPow ... 3)` equals
       `Σ_{cls ∈ support} (extPow ... 3)(cls) * psi.eval(cls.out)`.
    3. For each `cls ∈ support`: by `extPow_three_support_size_eq_four` and
       `extPow_three_support_extAdjAllClass`, `cls.out` is size-4 and `extAdjAll`.
    4. Apply `evalAlg_single_size4_extAdjAll_dichotomy_sharp`:
       - If `cls = ⟦vbExt3_RRR_e0⟧`: by `Quotient.out_eq` and `eval_iso`,
         `psi.eval cls.out = psi.eval vbExt3_RRR_e0`.
       - Else: `psi.eval cls.out = 0`.
    5. Hence the sum equals `(extPow ... 3)(⟦vbExt3_RRR_e0⟧) * psi.eval vbExt3_RRR_e0`,
       which by `extPow_three_apply_RRR_e0` is `1 * psi.eval vbExt3_RRR_e0`.
    6. Combining with step 1: `1 = psi.eval vbExt3_RRR_e0`. -/
theorem evalAlg_single_vbExt3_RRR_e0_eq_one
    (psi : GenLimitFunctional CG2 vertexBlackType brrbGenGraphClass brrbGenDelta)
    (h_ext_local : ∀ cls ∈ ((genClassesOfSize CG2 vertexBlackType
      (vertexBlackType.size + 1) (Nat.le_succ _)).filter
      (fun cls => extAdjacencyClass vertexBlackType cls
        (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size))),
      GenIsLocalFlag vertexBlackType cls.out brrbGenGraphClass brrbGenDelta)
    (h_reg : ∀ k, ∀ v : Fin (psi.seq.seq k).size,
      (Finset.univ.filter ((psi.seq.seq k).str.1.Adj v)).card =
        brrbGenDelta (psi.seq.seq k).forget)
    (h_Δ_to_inf : Filter.Tendsto
      (fun k => brrbGenDelta (psi.seq.seq (psi.sub k)).forget)
      Filter.atTop Filter.atTop)
    (hσ_toFlag : GenIsLocalFlag vertexBlackType vertexBlackType.toFlag
      brrbGenGraphClass brrbGenDelta) :
    psi.evalAlg (GenFlagAlg.single vbExt3_RRR_e0) = 1 := by
  -- Step 1: psi.evalAlg(extPow ... 3) = 1.
  have h_pow_eval : psi.evalAlg (extPow vertexBlackType
      (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) 3) = 1 :=
    evalAlg_extPow vertexBlackType psi
      (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) hσ_toFlag h_ext_local
      h_reg h_Δ_to_inf 3
  -- Step 2: expand via Finsupp.sum.
  have h_pow_sum : psi.evalAlg (extPow vertexBlackType
      (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) 3) =
      (extPow vertexBlackType (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) 3).sum
        (fun cls c => c * psi.eval cls.out) := by
    change genEvalAlgOf psi.eval _ = _
    unfold genEvalAlgOf
    rfl
  rw [h_pow_sum] at h_pow_eval
  -- Step 3: split off the ⟦RRR_e0⟧ term.
  -- The support is finite. Each cls in support is size 4 + extAdjAll.
  -- For the ⟦RRR_e0⟧ class, contribution = 1 * psi.eval vbExt3_RRR_e0.
  -- For each other cls, contribution = c * 0 = 0.
  -- Hence sum = psi.eval vbExt3_RRR_e0.
  set v := extPow vertexBlackType
    (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) 3 with hv_def
  -- Per-support-class evaluation rewrite.
  have h_eval_rewrite : ∀ cls ∈ v.support,
      v cls * psi.eval cls.out =
      if cls = GenFlagClass.mk vbExt3_RRR_e0
      then v cls * psi.eval vbExt3_RRR_e0
      else 0 := by
    intro cls hcls
    have hsize := extPow_three_support_size_eq_four cls hcls
    have hadjC := extPow_three_support_extAdjAllClass cls hcls
    -- Translate ExtAdjAllClass to the form needed by the dichotomy.
    have hadj_form : ∀ v' : Fin cls.out.size,
        v' ≠ cls.out.embedding ⟨0, Nat.zero_lt_one⟩ →
        cls.out.str.1.Adj (cls.out.embedding ⟨0, Nat.zero_lt_one⟩) v' := by
      intro v' hne
      -- ExtAdjAllClass uses "v ∉ Set.range emb" form. Equivalent to v ≠ emb 0
      -- since σ.size = 1 (vertexBlackType has size 1).
      apply hadjC
      intro ⟨j, hj⟩
      apply hne
      -- j : Fin vertexBlackType.size = Fin 1, so j = ⟨0, _⟩.
      have hj_val : j.val = 0 := by
        have hjlt : j.val < 1 := j.isLt
        omega
      have hj_zero : j = (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) :=
        Fin.ext hj_val
      rw [hj_zero] at hj
      exact hj.symm
    rcases evalAlg_single_size4_extAdjAll_dichotomy_sharp cls hsize hadj_form psi with
      h_eq_RRR | h_eval_zero
    · -- cls = ⟦RRR_e0⟧
      rw [if_pos h_eq_RRR]
      have h_iso_out : GenFlagIso vertexBlackType cls.out vbExt3_RRR_e0 := by
        have hmk_out : GenFlagClass.mk cls.out = cls := Quotient.out_eq cls
        have hmk : GenFlagClass.mk cls.out = GenFlagClass.mk vbExt3_RRR_e0 := by
          rw [hmk_out]; exact h_eq_RRR
        exact (GenFlagClass.mk_eq _ _).mp hmk
      rw [psi.eval_iso _ _ h_iso_out]
    · -- psi.evalAlg (single cls.out) = 0, so psi.eval cls.out = 0.
      rw [GenLimitFunctional.evalAlg_single] at h_eval_zero
      rw [h_eval_zero, mul_zero]
      split_ifs with hcls_eq
      · -- cls = ⟦RRR_e0⟧ but psi.eval cls.out = 0. The conclusion is
        --   v cls * psi.eval RRR_e0 = 0. Substitute h_eq_zero: psi.eval cls.out = 0;
        --   But the cls = ⟦RRR_e0⟧ case shows cls.out is iso to RRR_e0, so
        --   psi.eval cls.out = psi.eval RRR_e0 (= 0 here), so RHS is also 0.
        have h_iso_out : GenFlagIso vertexBlackType cls.out vbExt3_RRR_e0 := by
          have hmk_out : GenFlagClass.mk cls.out = cls := Quotient.out_eq cls
          have hmk : GenFlagClass.mk cls.out = GenFlagClass.mk vbExt3_RRR_e0 := by
            rw [hmk_out]; exact hcls_eq
          exact (GenFlagClass.mk_eq _ _).mp hmk
        have h_RRR_zero : psi.eval vbExt3_RRR_e0 = 0 := by
          rw [← psi.eval_iso _ _ h_iso_out]; exact h_eval_zero
        rw [h_RRR_zero, mul_zero]
      · rfl
  -- Step 4: substitute and reduce the Finsupp.sum.
  have h_sum_rewrite : v.sum (fun cls c => c * psi.eval cls.out) =
      v.sum (fun cls c =>
        if cls = GenFlagClass.mk vbExt3_RRR_e0
        then c * psi.eval vbExt3_RRR_e0 else 0) := by
    apply Finsupp.sum_congr
    intro cls hcls
    have hcls_supp : cls ∈ v.support := hcls
    have heq := h_eval_rewrite cls hcls_supp
    -- heq : v cls * psi.eval cls.out = if ... then v cls * psi.eval RRR_e0 else 0
    -- want: v cls * psi.eval cls.out = if ... then v cls * psi.eval RRR_e0 else 0
    -- The Finsupp.sum applies the function with c = v cls.
    change v cls * psi.eval cls.out =
      if cls = GenFlagClass.mk vbExt3_RRR_e0 then v cls * psi.eval vbExt3_RRR_e0 else 0
    exact heq
  rw [h_sum_rewrite] at h_pow_eval
  -- Step 5: collapse the sum to the single ⟦RRR_e0⟧ term.
  have h_collapse : v.sum (fun cls c =>
        if cls = GenFlagClass.mk vbExt3_RRR_e0
        then c * psi.eval vbExt3_RRR_e0 else 0) =
      v (GenFlagClass.mk vbExt3_RRR_e0) * psi.eval vbExt3_RRR_e0 := by
    -- Unfold Finsupp.sum, then use Finset.sum_ite_eq' on v.support.
    rw [Finsupp.sum]
    by_cases hmem : GenFlagClass.mk vbExt3_RRR_e0 ∈ v.support
    · rw [Finset.sum_eq_single (GenFlagClass.mk vbExt3_RRR_e0)
          (fun cls _ hne => by simp [hne]) (fun h => absurd hmem h)]
      simp
    · have h_zero : v (GenFlagClass.mk vbExt3_RRR_e0) = 0 :=
        Finsupp.notMem_support_iff.mp hmem
      rw [h_zero, zero_mul]
      apply Finset.sum_eq_zero
      intro cls hcls
      by_cases hcls_eq : cls = GenFlagClass.mk vbExt3_RRR_e0
      · -- if cls = ⟦RRR_e0⟧ then cls ∉ support contradicts hcls
        rw [hcls_eq] at hcls; exact absurd hcls hmem
      · simp [hcls_eq]
  rw [h_collapse] at h_pow_eval
  -- Step 6: the coefficient at ⟦RRR_e0⟧ is 1.
  rw [extPow_three_apply_RRR_e0] at h_pow_eval
  -- h_pow_eval : 1 * psi.eval vbExt3_RRR_e0 = 1
  rw [one_mul] at h_pow_eval
  rw [GenLimitFunctional.evalAlg_single]
  exact h_pow_eval

/-! ## V5 phase, size 5: `vbExt4_RRRR_e0` and forbidden-meta theorem

This section starts the size-5 v5 work. Architecturally we mirror size 4:
* a single BRRB-local σ-flag class, `vbExt4_RRRR_e0` = K_{1,4} all-red leaves,
  σ-adj to all 4 leaves, no leaf-leaf edges.
* a meta-forbidden theorem: any size-5 σ-flag with σ-adj-all and either a black
  leaf or a leaf-leaf edge is forbidden in BRRB (zero induced count).

The Aut count (= 24 = |S₄|) and the size-5 master classification / extPow⁴
identity are deferred to subsequent iterations. -/

/-! #### `Fin 5` helper -/

/-- Helper: any element of `Fin 5` has val ∈ {0, 1, 2, 3, 4}. -/
private theorem fin5_val_cases (x : Fin 5) :
    x.val = 0 ∨ x.val = 1 ∨ x.val = 2 ∨ x.val = 3 ∨ x.val = 4 := by
  have hlt : x.val < 5 := x.isLt
  omega

/-! #### Definition: `vbExt4_RRRR_e0` (the BRRB-local size-5 σ-flag)

σ + 4 red leaves, all σ-adj-all, no leaf-leaf edges. This is the K_{1,4}-with-
black-σ graph; it is the only BRRB-local size-5 σ-flag with σ-adj-all. -/

/-- σ + 4 red leaves, no leaf-leaf edges (star K_{1,4}). σ at vertex 0 (black);
    leaves at 1, 2, 3, 4 (all red). -/
noncomputable def vbExt4_RRRR_e0 : GenFlag CG2 vertexBlackType where
  size := 5
  str := (SimpleGraph.fromRel
    (fun u v : Fin 5 =>
      (u.val = 0 ∧ v.val = 1) ∨ (u.val = 1 ∧ v.val = 0) ∨
      (u.val = 0 ∧ v.val = 2) ∨ (u.val = 2 ∧ v.val = 0) ∨
      (u.val = 0 ∧ v.val = 3) ∨ (u.val = 3 ∧ v.val = 0) ∨
      (u.val = 0 ∧ v.val = 4) ∨ (u.val = 4 ∧ v.val = 0)),
    fun v : Fin 5 => if v.val = 0 then 1 else 0)
  embedding := ⟨fun _ => (⟨0, by omega⟩ : Fin 5),
    fun a b _ => by
      have : a.val < 1 := a.isLt
      have : b.val < 1 := b.isLt
      ext; omega⟩
  isInduced := by
    have h_eq : ((SimpleGraph.fromRel
        (fun u v : Fin 5 =>
          (u.val = 0 ∧ v.val = 1) ∨ (u.val = 1 ∧ v.val = 0) ∨
          (u.val = 0 ∧ v.val = 2) ∨ (u.val = 2 ∧ v.val = 0) ∨
          (u.val = 0 ∧ v.val = 3) ∨ (u.val = 3 ∧ v.val = 0) ∨
          (u.val = 0 ∧ v.val = 4) ∨ (u.val = 4 ∧ v.val = 0))).comap
        (fun (_ : Fin 1) => (⟨0, by omega⟩ : Fin 5)),
        (fun v : Fin 5 => if v.val = 0 then (1 : Fin 2) else 0) ∘
          (fun (_ : Fin 1) => (⟨0, by omega⟩ : Fin 5)))
        = ((⊥ : SimpleGraph (Fin 1)), fun _ : Fin 1 => (1 : Fin 2)) := by
      ext
      · simp [SimpleGraph.comap, SimpleGraph.fromRel]
      · rfl
    exact h_eq
  hsize := by change 1 ≤ 5; omega

@[simp] theorem vbExt4_RRRR_e0_size : vbExt4_RRRR_e0.size = 5 := rfl

/-- `⟦vbExt4_RRRR_e0⟧` is a class of size 5. Analog of
    `vbExt3_RRR_e0_isClassOfSize`. -/
theorem vbExt4_RRRR_e0_isClassOfSize :
    IsClassOfSize 5 (GenFlagClass.mk vbExt4_RRRR_e0) := by
  unfold IsClassOfSize
  have hiso : GenFlagIso vertexBlackType
      (Quotient.out (GenFlagClass.mk vbExt4_RRRR_e0)) vbExt4_RRRR_e0 :=
    Quotient.exact (Quotient.out_eq (GenFlagClass.mk vbExt4_RRRR_e0))
  rw [genFlagIso_size_eq hiso]
  exact vbExt4_RRRR_e0_size

/-! #### Colour helpers for `vbExt4_RRRR_e0` -/

/-- Colour at `i` is `1` iff `i = 0` (σ vertex is black, all 4 leaves red). -/
private theorem vbExt4_RRRR_e0_col0 :
    vbExt4_RRRR_e0.str.2 (⟨0, by omega⟩ : Fin 5) = 1 := rfl

private theorem vbExt4_RRRR_e0_col1 :
    vbExt4_RRRR_e0.str.2 (⟨1, by omega⟩ : Fin 5) = 0 := rfl

private theorem vbExt4_RRRR_e0_col2 :
    vbExt4_RRRR_e0.str.2 (⟨2, by omega⟩ : Fin 5) = 0 := rfl

private theorem vbExt4_RRRR_e0_col3 :
    vbExt4_RRRR_e0.str.2 (⟨3, by omega⟩ : Fin 5) = 0 := rfl

private theorem vbExt4_RRRR_e0_col4 :
    vbExt4_RRRR_e0.str.2 (⟨4, by omega⟩ : Fin 5) = 0 := rfl

/-! ### Meta-forbidden theorem for size-5 σ-flags in BRRB

Any size-5 σ-flag `F` is forbidden in BRRB if either:

* (A) some leaf `i ≠ 0` is black AND σ-adj to vertex 0 (gives a black-black
  edge under any embedding into a BRRB graph), OR
* (B) some pair of leaves `i, j ∈ {1,2,3,4}` with `i ≠ j` are adjacent AND
  both σ-adj to vertex 0 (gives a triangle under any embedding).

These cover the σ-adj-all + (black-leaf or leaf-leaf-edge) forbidden scenarios.
The BRRB-local case `vbExt4_RRRR_e0` is the only size-5 σ-flag with σ-adj-all
and neither black leaf nor leaf-leaf edge — all other σ-adj-all size-5 σ-flags
fall into (A) or (B). -/

/-- **Meta-forbidden (A)**: any size-5 σ-flag with a σ-adj black-leaf is BRRB-
    forbidden. Pulls back the σ-leaf edge with both colours = 1 to a black-black
    edge in any BRRB graph. -/
theorem isForbidden_brrb_of_black_sigma_leaf
    (F : GenFlag CG2 vertexBlackType) (hF : F.size = 5)
    (i : Fin 5) (hi_ne : i.val ≠ 0)
    (h_F_col0 : F.str.2 (hF ▸ (⟨0, by omega⟩ : Fin 5)) = 1)
    (h_F_coli : F.str.2 (hF ▸ i) = 1)
    (h_F_adj : F.str.1.Adj (hF ▸ (⟨0, by omega⟩ : Fin 5)) (hF ▸ i)) :
    IsForbidden vertexBlackType F brrbGenGraphClass := by
  intro G hG
  unfold genInducedCount
  rw [Fintype.card_eq_zero_iff]
  refine ⟨fun ⟨f, _, find, _⟩ => ?_⟩
  have h_G_adj := cg2_find_adj f find h_F_adj
  have h_G_col0 := cg2_find_col f find (hF ▸ (⟨0, by omega⟩ : Fin 5))
  have h_G_coli := cg2_find_col f find (hF ▸ i)
  rw [h_F_col0] at h_G_col0
  rw [h_F_coli] at h_G_coli
  -- Avoid unused variable warning
  have _ := hi_ne
  exact brrbGenGraphClass_blackIndep G.forget hG _ _ h_G_col0 h_G_coli h_G_adj

/-- **Meta-forbidden (B)**: any size-5 σ-flag with σ-adj to leaves `i, j` AND
    a leaf-leaf edge `i-j` is BRRB-forbidden via triangle (0, i, j). -/
theorem isForbidden_brrb_of_leaf_leaf_edge
    (F : GenFlag CG2 vertexBlackType) (hF : F.size = 5)
    (i j : Fin 5) (hi_ne : i.val ≠ 0) (hj_ne : j.val ≠ 0) (hij : i ≠ j)
    (h_F_0i : F.str.1.Adj (hF ▸ (⟨0, by omega⟩ : Fin 5)) (hF ▸ i))
    (h_F_ij : F.str.1.Adj (hF ▸ i) (hF ▸ j))
    (h_F_0j : F.str.1.Adj (hF ▸ (⟨0, by omega⟩ : Fin 5)) (hF ▸ j)) :
    IsForbidden vertexBlackType F brrbGenGraphClass := by
  intro G hG
  unfold genInducedCount
  rw [Fintype.card_eq_zero_iff]
  refine ⟨fun ⟨f, _, find, _⟩ => ?_⟩
  have h_G_0i := cg2_find_adj f find h_F_0i
  have h_G_ij := cg2_find_adj f find h_F_ij
  have h_G_0j := cg2_find_adj f find h_F_0j
  -- Avoid unused variable warnings
  have _ := hi_ne
  have _ := hj_ne
  have _ := hij
  exact brrbGenGraphClass_triangleFree G.forget hG _ _ _ h_G_0i h_G_ij h_G_0j

/-! ### Adjacency characterization for `vbExt4_RRRR_e0`

Pointwise iff describing the 4 σ-leaf edges (0–1, 0–2, 0–3, 0–4). Used by the
size-5 iso construction below. -/

/-- Helper: build `u ≠ v` from `u.val ≠ v.val` for `Fin 5`. -/
private theorem fin5_ne_of_val_ne {u v : Fin 5} (h : u.val ≠ v.val) : u ≠ v := by
  intro heq; exact h (congr_arg Fin.val heq)

/-- Adjacency in `vbExt4_RRRR_e0` is exactly the σ-leaf edges 0-1, 0-2, 0-3, 0-4
    (as the K_{1,4} star with σ at position 0). -/
private theorem vbExt4_RRRR_e0_adj_iff (u v : Fin 5) :
    vbExt4_RRRR_e0.str.1.Adj u v ↔
      ((u.val = 0 ∧ v.val = 1) ∨ (u.val = 1 ∧ v.val = 0) ∨
        (u.val = 0 ∧ v.val = 2) ∨ (u.val = 2 ∧ v.val = 0) ∨
        (u.val = 0 ∧ v.val = 3) ∨ (u.val = 3 ∧ v.val = 0) ∨
        (u.val = 0 ∧ v.val = 4) ∨ (u.val = 4 ∧ v.val = 0)) := by
  change (SimpleGraph.fromRel _).Adj u v ↔ _
  simp only [SimpleGraph.fromRel_adj]
  constructor
  · rintro ⟨_, h | h⟩
    · rcases h with ⟨h1, h2⟩ | ⟨h1, h2⟩ | ⟨h1, h2⟩ | ⟨h1, h2⟩ | ⟨h1, h2⟩
                  | ⟨h1, h2⟩ | ⟨h1, h2⟩ | ⟨h1, h2⟩ <;>
        (rw [h1, h2]; decide)
    · rcases h with ⟨h1, h2⟩ | ⟨h1, h2⟩ | ⟨h1, h2⟩ | ⟨h1, h2⟩ | ⟨h1, h2⟩
                  | ⟨h1, h2⟩ | ⟨h1, h2⟩ | ⟨h1, h2⟩ <;>
        (rw [h1, h2]; decide)
  · intro h
    refine ⟨?_, Or.inl h⟩
    rcases h with ⟨h1, h2⟩ | ⟨h1, h2⟩ | ⟨h1, h2⟩ | ⟨h1, h2⟩ | ⟨h1, h2⟩
                | ⟨h1, h2⟩ | ⟨h1, h2⟩ | ⟨h1, h2⟩ <;>
      exact fin5_ne_of_val_ne (by rw [h1, h2]; decide)

/-! ### Size-5 generic iso-via-permutation helper

Mirrors `size4_iso_via_perm` for size 5. Both source and target are size-5
σ-flags presented in "exposed" form; we exhibit a permutation `φ : Fin 5 ≃ Fin 5`
mapping σ-vertex of G to σ-vertex of T (both required at position 0 in T) and
matching the structures pointwise. -/

private theorem size5_iso_via_perm
    (G_str T_str : CG2.Str 5)
    (G_emb T_emb : Fin vertexBlackType.size ↪ Fin 5)
    (G_isInd : CG2.comap G_emb G_str = vertexBlackType.str)
    (T_isInd : CG2.comap T_emb T_str = vertexBlackType.str)
    (G_hsize T_hsize : vertexBlackType.size ≤ 5)
    (h_T_emb : T_emb (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) =
      (⟨0, (by decide : (0 : ℕ) < 5)⟩ : Fin 5))
    (φ : Fin 5 ≃ Fin 5)
    (h_emb : φ (G_emb ⟨0, Nat.zero_lt_one⟩) =
      (⟨0, (by decide : (0 : ℕ) < 5)⟩ : Fin 5))
    (h_adj : ∀ u v : Fin 5,
      G_str.1.Adj u v ↔ T_str.1.Adj (φ u) (φ v))
    (h_col : ∀ v : Fin 5, G_str.2 v = T_str.2 (φ v)) :
    GenFlagIso vertexBlackType
      (⟨5, G_str, G_emb, G_isInd, G_hsize⟩ : GenFlag CG2 vertexBlackType)
      (⟨5, T_str, T_emb, T_isInd, T_hsize⟩ : GenFlag CG2 vertexBlackType) := by
  refine ⟨φ, ?_, ?_⟩
  · apply Prod.ext
    · ext u v
      change T_str.1.Adj (φ u) (φ v) ↔ G_str.1.Adj u v
      rw [h_adj u v]
    · funext v
      change T_str.2 (φ v) = G_str.2 v
      exact (h_col v).symm
  · intro i
    have hi : i = (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) := by
      obtain ⟨v, hv⟩ := i
      have h_size : vertexBlackType.size = 1 := rfl
      have hv' : v < 1 := h_size ▸ hv
      have : v = 0 := by omega
      ext; exact this
    rw [hi, h_T_emb, h_emb]

/-! ### Size-5 σ-adj-all + all-red + no-leaf-edges iso to `vbExt4_RRRR_e0`

Given a size-5 σ-flag with:
* σ-vertex at position `p : Fin 5`,
* all non-σ vertices coloured red (0),
* σ adjacent to every non-σ vertex,
* no edges among non-σ vertices,

we construct an explicit isomorphism to `vbExt4_RRRR_e0` via the permutation
`Equiv.swap p ⟨0,_⟩` (which is the identity when `p = 0`).

This is the "classification-lite" step: the only size-5 σ-flag (up to iso) with
σ-adj-all and no σ-leaf-edge-with-black or leaf-leaf-edge is `vbExt4_RRRR_e0`. -/

/-- Helper: for `φ = Equiv.swap p (⟨0,_⟩ : Fin 5)`, we have `φ x = ⟨0,_⟩ ↔ x = p`. -/
private theorem swap_p_zero_eq_zero_iff (p x : Fin 5) :
    Equiv.swap p (⟨0, by decide⟩ : Fin 5) x = (⟨0, by decide⟩ : Fin 5) ↔ x = p := by
  by_cases hp : p = (⟨0, by decide⟩ : Fin 5)
  · -- p = 0: swap is identity
    rw [hp]; simp
  · constructor
    · intro h
      by_cases hx_p : x = p
      · exact hx_p
      · by_cases hx_0 : x = (⟨0, by decide⟩ : Fin 5)
        · rw [hx_0] at h; rw [Equiv.swap_apply_right] at h
          exact absurd h hp
        · rw [Equiv.swap_apply_of_ne_of_ne hx_p hx_0] at h
          exact absurd h hx_0
    · intro h
      rw [h, Equiv.swap_apply_left]

/-- Helper: for `φ = Equiv.swap p ⟨0,_⟩`, we have `φ x ≠ ⟨0,_⟩ ↔ x ≠ p`. -/
private theorem swap_p_zero_ne_zero_iff (p x : Fin 5) :
    Equiv.swap p (⟨0, by decide⟩ : Fin 5) x ≠ (⟨0, by decide⟩ : Fin 5) ↔ x ≠ p := by
  rw [Ne, Ne, swap_p_zero_eq_zero_iff]

/-- Adjacency in K_{1,4} centered at vertex 0 in `Fin 5`: `Adj a b` iff exactly
    one of `{a, b}` is `⟨0,_⟩`. -/
private theorem vbExt4_RRRR_e0_adj_iff_zero (a b : Fin 5) :
    vbExt4_RRRR_e0.str.1.Adj a b ↔
      (a = (⟨0, by decide⟩ : Fin 5) ∧ b ≠ (⟨0, by decide⟩ : Fin 5)) ∨
      (b = (⟨0, by decide⟩ : Fin 5) ∧ a ≠ (⟨0, by decide⟩ : Fin 5)) := by
  rw [vbExt4_RRRR_e0_adj_iff a b]
  constructor
  · intro h
    rcases h with ⟨h1, h2⟩ | ⟨h1, h2⟩ | ⟨h1, h2⟩ | ⟨h1, h2⟩ | ⟨h1, h2⟩
                | ⟨h1, h2⟩ | ⟨h1, h2⟩ | ⟨h1, h2⟩
    · left; refine ⟨Fin.ext h1, ?_⟩; intro heq; rw [heq] at h2; exact absurd h2 (by decide)
    · right; refine ⟨Fin.ext h2, ?_⟩; intro heq; rw [heq] at h1; exact absurd h1 (by decide)
    · left; refine ⟨Fin.ext h1, ?_⟩; intro heq; rw [heq] at h2; exact absurd h2 (by decide)
    · right; refine ⟨Fin.ext h2, ?_⟩; intro heq; rw [heq] at h1; exact absurd h1 (by decide)
    · left; refine ⟨Fin.ext h1, ?_⟩; intro heq; rw [heq] at h2; exact absurd h2 (by decide)
    · right; refine ⟨Fin.ext h2, ?_⟩; intro heq; rw [heq] at h1; exact absurd h1 (by decide)
    · left; refine ⟨Fin.ext h1, ?_⟩; intro heq; rw [heq] at h2; exact absurd h2 (by decide)
    · right; refine ⟨Fin.ext h2, ?_⟩; intro heq; rw [heq] at h1; exact absurd h1 (by decide)
  · intro h
    rcases h with ⟨ha, hb⟩ | ⟨hb, ha⟩
    · -- a.val = 0; b.val ∈ {1, 2, 3, 4}
      have ha_val : a.val = 0 := by rw [ha]
      rcases fin5_val_cases b with hb0 | hb1 | hb2 | hb3 | hb4
      · exact absurd (Fin.ext hb0) hb
      · exact Or.inl ⟨ha_val, hb1⟩
      · exact Or.inr (Or.inr (Or.inl ⟨ha_val, hb2⟩))
      · exact Or.inr (Or.inr (Or.inr (Or.inr (Or.inl ⟨ha_val, hb3⟩))))
      · exact Or.inr (Or.inr (Or.inr (Or.inr (Or.inr (Or.inr (Or.inl ⟨ha_val, hb4⟩))))))
    · -- b.val = 0; a.val ∈ {1, 2, 3, 4}
      have hb_val : b.val = 0 := by rw [hb]
      rcases fin5_val_cases a with ha0 | ha1 | ha2 | ha3 | ha4
      · exact absurd (Fin.ext ha0) ha
      · exact Or.inr (Or.inl ⟨ha1, hb_val⟩)
      · exact Or.inr (Or.inr (Or.inr (Or.inl ⟨ha2, hb_val⟩)))
      · exact Or.inr (Or.inr (Or.inr (Or.inr (Or.inr (Or.inl ⟨ha3, hb_val⟩)))))
      · exact Or.inr (Or.inr (Or.inr (Or.inr (Or.inr (Or.inr (Or.inr ⟨ha4, hb_val⟩))))))

/-- Colour at any vertex of `vbExt4_RRRR_e0`: 1 at position 0, 0 elsewhere. -/
private theorem vbExt4_RRRR_e0_col_eq (v : Fin 5) :
    vbExt4_RRRR_e0.str.2 v = if v.val = 0 then 1 else 0 := rfl

/-- Generic σ-vertex colour at position 0 for size-5 σ-flag (analog of
    `size4_sigma_col_eq_one`). -/
private theorem size5_sigma_col_eq_one
    (G_str : CG2.Str 5) (G_emb : Fin vertexBlackType.size ↪ Fin 5)
    (G_isInd : CG2.comap G_emb G_str = vertexBlackType.str) :
    G_str.2 (G_emb ⟨0, Nat.zero_lt_one⟩) = 1 := by
  have h_col := congr_arg (fun s : CG2.Str vertexBlackType.size =>
    s.2 ⟨0, Nat.zero_lt_one⟩) G_isInd
  exact h_col

/-- The classification-lite step: given a size-5 σ-flag `G` whose σ-vertex is
    at position `p`, with all leaves red, σ-adj-all, and no leaf-leaf edges,
    `G` is iso to `vbExt4_RRRR_e0`. The iso uses `Equiv.swap p ⟨0,_⟩`. -/
private theorem size5_extAdjAll_red_no_edges_iso
    (G_str : CG2.Str 5)
    (G_emb : Fin vertexBlackType.size ↪ Fin 5)
    (G_isInd : CG2.comap G_emb G_str = vertexBlackType.str)
    (G_hsize : vertexBlackType.size ≤ 5)
    (p : Fin 5)
    (h_emb_p : G_emb (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) = p)
    (h_col_leaves : ∀ q : Fin 5, q ≠ p → G_str.2 q = 0)
    (h_adj_all : ∀ q : Fin 5, q ≠ p → G_str.1.Adj p q)
    (h_no_leaf_leaf : ∀ q r : Fin 5, q ≠ p → r ≠ p → q ≠ r →
                        ¬ G_str.1.Adj q r) :
    GenFlagIso vertexBlackType
      (⟨5, G_str, G_emb, G_isInd, G_hsize⟩ : GenFlag CG2 vertexBlackType)
      vbExt4_RRRR_e0 := by
  set φ : Fin 5 ≃ Fin 5 := Equiv.swap p (⟨0, by decide⟩ : Fin 5) with hφ_def
  have h_T_emb : vbExt4_RRRR_e0.embedding (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) =
      (⟨0, by decide⟩ : Fin 5) := rfl
  -- Note: vbExt4_RRRR_e0 has size 5 by `vbExt4_RRRR_e0_size`, but we need to
  -- present it in exposed form to use size5_iso_via_perm.
  -- Use the underlying record fields.
  have hT_size : vbExt4_RRRR_e0.size = 5 := vbExt4_RRRR_e0_size
  -- Build the iso directly, since vbExt4_RRRR_e0 is already in record form.
  refine ⟨φ, ?_, ?_⟩
  · -- comap φ vbExt4_RRRR_e0.str = G_str
    apply Prod.ext
    · -- Adjacency
      ext u v
      change vbExt4_RRRR_e0.str.1.Adj (φ u) (φ v) ↔ G_str.1.Adj u v
      rw [vbExt4_RRRR_e0_adj_iff_zero (φ u) (φ v)]
      -- φ x = ⟨0,_⟩ ↔ x = p; φ x ≠ ⟨0,_⟩ ↔ x ≠ p
      rw [show φ = Equiv.swap p (⟨0, by decide⟩ : Fin 5) from rfl]
      rw [swap_p_zero_eq_zero_iff p u, swap_p_zero_eq_zero_iff p v,
          swap_p_zero_ne_zero_iff p u, swap_p_zero_ne_zero_iff p v]
      -- Goal: ((u = p ∧ v ≠ p) ∨ (v = p ∧ u ≠ p)) ↔ G_str.1.Adj u v
      constructor
      · rintro (⟨hu, hv⟩ | ⟨hv, hu⟩)
        · rw [hu]; exact h_adj_all v hv
        · rw [hv, SimpleGraph.adj_comm]; exact h_adj_all u hu
      · intro hadj
        by_cases hu_p : u = p
        · -- u = p, so adj implies v ≠ p (else self-loop) and edge exists
          left
          refine ⟨hu_p, ?_⟩
          intro hv_p
          rw [hu_p, hv_p] at hadj
          exact absurd hadj (SimpleGraph.irrefl _)
        · by_cases hv_p : v = p
          · right; exact ⟨hv_p, hu_p⟩
          · -- both u, v ≠ p
            by_cases huv : u = v
            · rw [huv] at hadj; exact absurd hadj (SimpleGraph.irrefl _)
            · exact absurd hadj (h_no_leaf_leaf u v hu_p hv_p huv)
    · -- Colour
      funext v
      change vbExt4_RRRR_e0.str.2 (φ v) = G_str.2 v
      rw [vbExt4_RRRR_e0_col_eq (φ v)]
      rw [show φ = Equiv.swap p (⟨0, by decide⟩ : Fin 5) from rfl]
      by_cases hv_p : v = p
      · -- v = p: G col = 1; φ v = ⟨0,_⟩ so target col = 1
        rw [hv_p]
        rw [Equiv.swap_apply_left]
        -- LHS: if (⟨0,_⟩).val = 0 then 1 else 0 = 1
        have h_lhs : (if ((⟨0, by decide⟩ : Fin 5)).val = 0 then (1 : Fin 2) else 0) = 1 := by
          decide
        rw [h_lhs]
        -- RHS: G_str.2 p = 1 (from h_emb_p and σ-induced)
        have h_sigma_col := size5_sigma_col_eq_one G_str G_emb G_isInd
        rw [h_emb_p] at h_sigma_col
        exact h_sigma_col.symm
      · -- v ≠ p: φ v ≠ ⟨0,_⟩, so target col = 0
        have h_phi_ne : Equiv.swap p (⟨0, by decide⟩ : Fin 5) v ≠ (⟨0, by decide⟩ : Fin 5) := by
          rw [swap_p_zero_ne_zero_iff]; exact hv_p
        have h_lhs : (if (Equiv.swap p (⟨0, by decide⟩ : Fin 5) v).val = 0 then (1 : Fin 2)
                       else 0) = 0 := by
          have : (Equiv.swap p (⟨0, by decide⟩ : Fin 5) v).val ≠ 0 := by
            intro hval
            apply h_phi_ne
            ext; exact hval
          rw [if_neg this]
        rw [h_lhs]
        rw [h_col_leaves v hv_p]
  · -- σ-compat: φ (G_emb ⟨0,_⟩) = vbExt4_RRRR_e0.embedding ⟨0,_⟩
    intro i
    have hi : i = (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) := by
      obtain ⟨v, hv⟩ := i
      have h_size : vertexBlackType.size = 1 := rfl
      have hv' : v < 1 := h_size ▸ hv
      have : v = 0 := by omega
      ext; exact this
    rw [hi, h_emb_p, h_T_emb]
    change φ p = (⟨0, by decide⟩ : Fin 5)
    simp [hφ_def, Equiv.swap_apply_left]

/-! ### Size-5 dichotomy: either iso to `vbExt4_RRRR_e0`, or eval = 0

For any size-5 σ-flag with σ adjacent to all 4 leaves, we case-split on whether
there is a black σ-leaf or leaf-leaf edge. If either, the flag is BRRB-forbidden
(meta-forbidden A or B). Otherwise — all leaves red, no leaf-leaf edges — the
flag is iso to `vbExt4_RRRR_e0` via the swap permutation. -/

/-- Flag-level dichotomy: any size-5 σ-flag with σ-adj-all is either iso to
    `vbExt4_RRRR_e0`, or BRRB-forbidden. -/
private theorem any_size5_extAdjAll_iso_or_forbidden
    (G : GenFlag CG2 vertexBlackType) (hsize : G.size = 5)
    (hadj_all : ∀ v : Fin G.size, v ≠ G.embedding ⟨0, Nat.zero_lt_one⟩ →
                 G.str.1.Adj (G.embedding ⟨0, Nat.zero_lt_one⟩) v) :
    GenFlagIso vertexBlackType G vbExt4_RRRR_e0 ∨
    IsForbidden vertexBlackType G brrbGenGraphClass := by
  rcases G with ⟨size, G_str, G_emb, G_isInd, G_hsize⟩
  -- hsize : size = 5
  subst hsize
  -- Set p := σ-position.
  set p : Fin 5 := G_emb ⟨0, Nat.zero_lt_one⟩ with hp_def
  -- σ has colour 1.
  have h_col_p : G_str.2 p = 1 := size5_sigma_col_eq_one G_str G_emb G_isInd
  -- After `set`, hadj_all already speaks about p directly.
  have hadj_p : ∀ q : Fin 5, q ≠ p → G_str.1.Adj p q := hadj_all
  -- Decide: is there a black leaf?
  by_cases h_black_leaf : ∃ q : Fin 5, q ≠ p ∧ G_str.2 q = 1
  · -- Right disjunct: meta-forbidden A.
    right
    obtain ⟨q, hq_ne_p, hq_col⟩ := h_black_leaf
    -- σ-adj to q (since q ≠ p) and both σ and q have colour 1.
    have hq_adj : G_str.1.Adj p q := hadj_p q hq_ne_p
    -- Apply isForbidden_brrb_of_black_sigma_leaf. The σ-vertex is `p`, but the
    -- meta theorem uses the canonical position 0. We need to express σ at p as
    -- an embedding into Fin 5 — the meta theorem takes F.str etc. Simpler: use
    -- the meta theorem at the constructor level.
    -- The flag here is ⟨5, G_str, G_emb, G_isInd, G_hsize⟩.
    -- Need: F.str.2 (hF ▸ ⟨0,_⟩) = 1 and F.str.2 (hF ▸ i) = 1 and
    --       F.str.1.Adj (hF ▸ ⟨0,_⟩) (hF ▸ i).
    -- But our σ is at position p, not 0. We use the explicit forbidden meta
    -- with i pointing to a black leaf in F's coords.
    -- Let's apply meta directly: the flag is ⟨5, G_str, G_emb, G_isInd, G_hsize⟩.
    -- "F.str.2 (hF ▸ ⟨0,_⟩) = 1" with hF = rfl (since size = 5 already) means
    -- "G_str.2 ⟨0,_⟩ = 1". This requires the σ-vertex to be at position 0.
    -- But our σ is at p. So if p ≠ 0, we can't use the meta directly.
    -- Workaround: build the IsForbidden directly without the meta theorem.
    intro G_target hG_target
    unfold genInducedCount
    rw [Fintype.card_eq_zero_iff]
    refine ⟨fun ⟨f, _, find, _⟩ => ?_⟩
    have h_G_adj := cg2_find_adj f find hq_adj
    have h_G_col_p := cg2_find_col f find p
    have h_G_col_q := cg2_find_col f find q
    rw [h_col_p] at h_G_col_p
    rw [hq_col] at h_G_col_q
    exact brrbGenGraphClass_blackIndep G_target.forget hG_target _ _ h_G_col_p h_G_col_q h_G_adj
  · push_neg at h_black_leaf
    -- All non-σ vertices are non-black, i.e., red (colour 0).
    have h_col_leaves : ∀ q : Fin 5, q ≠ p → G_str.2 q = 0 := by
      intro q hq_ne_p
      have h := h_black_leaf q hq_ne_p
      -- G_str.2 q : Fin 2; ¬ = 1 means = 0
      rcases fin2_col_cases (G_str.2 q) with hc | hc
      · exact hc
      · exact absurd hc h
    -- Decide: is there a leaf-leaf edge?
    by_cases h_leaf_edge : ∃ q r : Fin 5, q ≠ p ∧ r ≠ p ∧ q ≠ r ∧ G_str.1.Adj q r
    · -- Right disjunct: meta-forbidden B (triangle p-q-r).
      right
      obtain ⟨q, r, hq_ne_p, hr_ne_p, hqr, hqr_adj⟩ := h_leaf_edge
      have hpq_adj : G_str.1.Adj p q := hadj_p q hq_ne_p
      have hpr_adj : G_str.1.Adj p r := hadj_p r hr_ne_p
      intro G_target hG_target
      unfold genInducedCount
      rw [Fintype.card_eq_zero_iff]
      refine ⟨fun ⟨f, _, find, _⟩ => ?_⟩
      have h_G_pq := cg2_find_adj f find hpq_adj
      have h_G_qr := cg2_find_adj f find hqr_adj
      have h_G_pr := cg2_find_adj f find hpr_adj
      exact brrbGenGraphClass_triangleFree G_target.forget hG_target _ _ _ h_G_pq h_G_qr h_G_pr
    · -- Left disjunct: build the iso.
      push_neg at h_leaf_edge
      have h_no_leaf_leaf : ∀ q r : Fin 5, q ≠ p → r ≠ p → q ≠ r →
                              ¬ G_str.1.Adj q r := by
        intros q r hq hr hqr h
        exact h_leaf_edge q r hq hr hqr h
      left
      exact size5_extAdjAll_red_no_edges_iso G_str G_emb G_isInd G_hsize p
        hp_def.symm h_col_leaves hadj_p h_no_leaf_leaf

/-- **Sharper class-level dichotomy at size 5**: for any class `cls` whose
    representative `cls.out` is size-5 with σ-vertex adjacent to all 4 leaves,
    either `cls = ⟦vbExt4_RRRR_e0⟧`, or `psi.evalAlg(single cls.out) = 0`.

    This is the size-5 analog of `evalAlg_single_size4_extAdjAll_dichotomy_sharp`. -/
theorem evalAlg_single_size5_extAdjAll_dichotomy_sharp
    (cls : GenFlagClass CG2 vertexBlackType)
    (h_size : IsClassOfSize 5 cls)
    (h_extAdjAll : ExtAdjAllClass cls (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size))
    (psi : GenLimitFunctional CG2 vertexBlackType brrbGenGraphClass brrbGenDelta) :
    cls = GenFlagClass.mk vbExt4_RRRR_e0 ∨
    psi.evalAlg (GenFlagAlg.single cls.out) = 0 := by
  -- Unfold IsClassOfSize and ExtAdjAllClass.
  have hsize : cls.out.size = 5 := h_size
  -- Translate ExtAdjAll to "∀ v, v ≠ emb ⟨0,_⟩ → adj"
  have hadj_all : ∀ v : Fin cls.out.size,
      v ≠ cls.out.embedding (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) →
      cls.out.str.1.Adj
        (cls.out.embedding (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size)) v := by
    intro v hv_ne
    -- ExtAdjAll uses "v ∉ Set.range emb"; vbType has 1 element so range = {emb 0}.
    have h_extAdjAll' : ExtAdjAll cls.out (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) :=
      h_extAdjAll
    apply h_extAdjAll'
    intro hv_in
    apply hv_ne
    obtain ⟨j, hj⟩ := hv_in
    have hj_eq : j = (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) := by
      obtain ⟨jv, jhv⟩ := j
      have h_size : vertexBlackType.size = 1 := rfl
      have hjv' : jv < 1 := h_size ▸ jhv
      have : jv = 0 := by omega
      ext; exact this
    rw [hj_eq] at hj
    exact hj.symm
  rcases any_size5_extAdjAll_iso_or_forbidden cls.out hsize hadj_all with h_iso | h_forbidden
  · -- iso to vbExt4_RRRR_e0: upgrade to class equality
    left
    have hmk : GenFlagClass.mk cls.out = GenFlagClass.mk vbExt4_RRRR_e0 :=
      (GenFlagClass.mk_eq _ _).mpr h_iso
    rw [← Quotient.out_eq cls]; exact hmk
  · right
    exact evalAlg_single_zero_of_forbidden h_forbidden psi

/-! ## Size-5 v5 closure: support infrastructure for `extPow vbType ⟨0,_⟩ 4`

We mirror the size-4 closure via the cleaner factorisation
`extPow vbType ⟨0,_⟩ 4 = (extPow vbType ⟨0,_⟩ 3).mul (extSum vbType ⟨0,_⟩)`.
Each class in the support is size 5 + `ExtAdjAll`, by lifting the size-4 + size-2
support properties of the factors through `genMul_local_support` analogs and
`ExtAdjAllClass_of_lfp_support`.

Combined with `evalAlg_single_size5_extAdjAll_dichotomy_sharp`, this lets us
collapse `psi.evalAlg(extPow ... 4)` into a sum of two terms: one at
`⟦vbExt4_RRRR_e0⟧`, and one at zero-eval forbidden classes.

The full closure `psi.evalAlg(single vbExt4_RRRR_e0) = 1` requires further the
explicit coefficient `(extPow ... 4)(⟦vbExt4_RRRR_e0⟧) = 1`. By the
joint-count formula:
* `LFP(vbExt3_RRR_e0, vbExtRed)(⟦vbExt4_RRRR_e0⟧) = (autF₁ · autF₂)⁻¹ · jointCount / 4 = 24 / 24 = 1`,
* `LFP(vbExt3_RRR_e0, vbExtBlack)(⟦vbExt4_RRRR_e0⟧) = 0` (no black leaves in `vbExt4_RRRR_e0`),
* All other LFP terms vanish at `⟦vbExt4_RRRR_e0⟧` (forbidden source class).

Computing `vbExt3_RRR_e0_aut = 6` (S₃ on the 3 red leaves) is below; the joint
count `= 24` (full S₄ symmetry on the 4 leaves) and the 19 induced-count zeros
remain follow-up work. -/

/-! ### `vbExt3_RRR_e0_aut = 6`

The σ-flag `vbExt3_RRR_e0` is the star `K_{1,3}` with σ at vertex 0 and red leaves
at vertices 1, 2, 3. Any σ-iso fixes vertex 0 (σ-compat) and permutes the three
leaves. Adjacency is automatic (each leaf adjacent only to σ), colour is automatic
(all leaves red). Hence `Aut = S₃ = 6`.

We build an explicit `Equiv` between σ-isos and `Equiv.Perm (Fin 3)` (cardinality 6
by `Fintype.card_perm`), using `fin3_skip0` and `fin3_skip0_inv` to translate
between {1, 2, 3} ⊆ Fin 4 and Fin 3. -/

/-- Helper: for any σ-iso `f` of `vbExt3_RRR_e0`, `f` fixes the σ-vertex `⟨0⟩`. -/
private theorem vbExt3_RRR_e0_aut_fix0
    (e : GenInducedEmbedding CG2 vertexBlackType vbExt3_RRR_e0 vbExt3_RRR_e0) :
    e.toFun (⟨0, by omega⟩ : Fin 4) = (⟨0, by omega⟩ : Fin 4) := by
  have h_emb : vbExt3_RRR_e0.embedding (⟨0, Nat.zero_lt_one⟩ : Fin 1) =
      (⟨0, by omega⟩ : Fin 4) := rfl
  have := e.compat (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size)
  rw [h_emb] at this
  exact this

/-- Helper: for any σ-iso `e`, the val of `e.toFun ⟨k⟩` for `k ∈ {1,2,3}` is ≠ 0
    (since `e` is injective and `e ⟨0⟩ = ⟨0⟩`). -/
private theorem vbExt3_RRR_e0_aut_image_ne_zero
    (e : GenInducedEmbedding CG2 vertexBlackType vbExt3_RRR_e0 vbExt3_RRR_e0)
    (c : Fin 3) :
    (e.toFun (fin3_skip0 c)).val ≠ 0 := by
  intro hval
  have h_eq : e.toFun (fin3_skip0 c) = (⟨0, by omega⟩ : Fin 4) := Fin.ext hval
  have h0 := vbExt3_RRR_e0_aut_fix0 e
  have h_inj : fin3_skip0 c = (⟨0, by omega⟩ : Fin 4) :=
    e.injective (h_eq.trans h0.symm)
  exact fin3_skip0_ne_zero c h_inj

/-- Forward map: σ-iso ↦ `Fin 3 → Fin 3` permutation of leaves. -/
private noncomputable def vbExt3_RRR_e0_to_perm_fn
    (e : GenInducedEmbedding CG2 vertexBlackType vbExt3_RRR_e0 vbExt3_RRR_e0) :
    Fin 3 → Fin 3 :=
  fun c => fin3_skip0_inv (e.toFun (fin3_skip0 c))
    (vbExt3_RRR_e0_aut_image_ne_zero e c)

/-- The forward map is injective. -/
private theorem vbExt3_RRR_e0_to_perm_fn_inj
    (e : GenInducedEmbedding CG2 vertexBlackType vbExt3_RRR_e0 vbExt3_RRR_e0) :
    Function.Injective (vbExt3_RRR_e0_to_perm_fn e) := by
  intro a b h
  unfold vbExt3_RRR_e0_to_perm_fn at h
  -- h : fin3_skip0_inv (e.toFun (fin3_skip0 a)) _ = fin3_skip0_inv (e.toFun (fin3_skip0 b)) _
  have h1 := congr_arg fin3_skip0 h
  rw [fin3_skip0_apply_inv, fin3_skip0_apply_inv] at h1
  -- h1 : e.toFun (fin3_skip0 a) = e.toFun (fin3_skip0 b)
  have h2 : fin3_skip0 a = fin3_skip0 b := e.injective h1
  exact fin3_skip0_inj h2

/-- Forward map: σ-iso ↦ `Equiv.Perm (Fin 3)`. -/
private noncomputable def vbExt3_RRR_e0_to_perm
    (e : GenInducedEmbedding CG2 vertexBlackType vbExt3_RRR_e0 vbExt3_RRR_e0) :
    Equiv.Perm (Fin 3) :=
  Equiv.ofBijective (vbExt3_RRR_e0_to_perm_fn e)
    ⟨vbExt3_RRR_e0_to_perm_fn_inj e,
     Finite.injective_iff_surjective.mp (vbExt3_RRR_e0_to_perm_fn_inj e)⟩

/-- The underlying function of `vbExt3_RRR_e0_to_perm e` is `to_perm_fn`. -/
private theorem vbExt3_RRR_e0_to_perm_apply
    (e : GenInducedEmbedding CG2 vertexBlackType vbExt3_RRR_e0 vbExt3_RRR_e0)
    (c : Fin 3) :
    vbExt3_RRR_e0_to_perm e c = vbExt3_RRR_e0_to_perm_fn e c := rfl

/-- Backward map: `Perm (Fin 3)` ↦ a function `Fin 4 → Fin 4` fixing `⟨0⟩` and
    permuting the leaves via `π`. -/
private def vbExt3_RRR_e0_of_perm_fn (π : Equiv.Perm (Fin 3)) : Fin 4 → Fin 4 :=
  fun x => if h : x.val = 0 then (⟨0, by omega⟩ : Fin 4)
    else fin3_skip0 (π (fin3_skip0_inv x h))

@[simp] private theorem vbExt3_RRR_e0_of_perm_fn_zero (π : Equiv.Perm (Fin 3)) :
    vbExt3_RRR_e0_of_perm_fn π (⟨0, by omega⟩ : Fin 4) = (⟨0, by omega⟩ : Fin 4) := by
  unfold vbExt3_RRR_e0_of_perm_fn; simp

private theorem vbExt3_RRR_e0_of_perm_fn_skip
    (π : Equiv.Perm (Fin 3)) (c : Fin 3) :
    vbExt3_RRR_e0_of_perm_fn π (fin3_skip0 c) = fin3_skip0 (π c) := by
  unfold vbExt3_RRR_e0_of_perm_fn
  have hne : (fin3_skip0 c).val ≠ 0 := by
    change (c.val + 1) ≠ 0; omega
  rw [dif_neg hne, fin3_skip0_inv_apply]

/-- The backward map produces an injective function. -/
private theorem vbExt3_RRR_e0_of_perm_fn_inj (π : Equiv.Perm (Fin 3)) :
    Function.Injective (vbExt3_RRR_e0_of_perm_fn π) := by
  intro a b h
  unfold vbExt3_RRR_e0_of_perm_fn at h
  by_cases ha : a.val = 0
  · by_cases hb : b.val = 0
    · exact Fin.ext (ha.trans hb.symm)
    · -- a.val = 0, b.val ≠ 0: LHS = ⟨0⟩, RHS = fin3_skip0 (π (...)) ≠ ⟨0⟩
      exfalso
      rw [dif_pos ha, dif_neg hb] at h
      exact fin3_skip0_ne_zero _ h.symm
  · by_cases hb : b.val = 0
    · exfalso
      rw [dif_neg ha, dif_pos hb] at h
      exact fin3_skip0_ne_zero _ h
    · rw [dif_neg ha, dif_neg hb] at h
      have h1 : π (fin3_skip0_inv a ha) = π (fin3_skip0_inv b hb) := fin3_skip0_inj h
      have h2 : fin3_skip0_inv a ha = fin3_skip0_inv b hb := π.injective h1
      have h3 := congr_arg fin3_skip0 h2
      rw [fin3_skip0_apply_inv, fin3_skip0_apply_inv] at h3
      exact h3

/-- Helper: in `vbExt3_RRR_e0`, vertex 0 is adjacent to `fin3_skip0 c` (any leaf). -/
private theorem vbExt3_RRR_e0_zero_adj_skip (c : Fin 3) :
    vbExt3_RRR_e0.str.1.Adj (⟨0, by omega⟩ : Fin 4) (fin3_skip0 c) := by
  rcases fin3_val_cases c with h0 | h1 | h2
  · have : c = (⟨0, by decide⟩ : Fin 3) := Fin.ext h0
    rw [this]
    change (SimpleGraph.fromRel _).Adj _ _
    rw [SimpleGraph.fromRel_adj]
    exact ⟨by decide, Or.inl (Or.inl ⟨rfl, rfl⟩)⟩
  · have : c = (⟨1, by decide⟩ : Fin 3) := Fin.ext h1
    rw [this]
    change (SimpleGraph.fromRel _).Adj _ _
    rw [SimpleGraph.fromRel_adj]
    exact ⟨by decide, Or.inl (Or.inr (Or.inr (Or.inl ⟨rfl, rfl⟩)))⟩
  · have : c = (⟨2, by decide⟩ : Fin 3) := Fin.ext h2
    rw [this]
    change (SimpleGraph.fromRel _).Adj _ _
    rw [SimpleGraph.fromRel_adj]
    exact ⟨by decide, Or.inl (Or.inr (Or.inr (Or.inr (Or.inr (Or.inl ⟨rfl, rfl⟩)))))⟩

/-- Helper: in `vbExt3_RRR_e0`, `fin3_skip0 c` is adjacent to vertex 0 (symmetric). -/
private theorem vbExt3_RRR_e0_skip_adj_zero (c : Fin 3) :
    vbExt3_RRR_e0.str.1.Adj (fin3_skip0 c) (⟨0, by omega⟩ : Fin 4) :=
  (vbExt3_RRR_e0_zero_adj_skip c).symm

/-- Helper: in `vbExt3_RRR_e0`, two leaves `fin3_skip0 c` and `fin3_skip0 d` are
    NOT adjacent (no leaf-leaf edges). -/
private theorem vbExt3_RRR_e0_skip_not_adj_skip (c d : Fin 3) :
    ¬ vbExt3_RRR_e0.str.1.Adj (fin3_skip0 c) (fin3_skip0 d) := by
  intro h
  -- Adj in fromRel R: u ≠ v ∧ (R u v ∨ R v u). All branches of R need one arg
  -- to have val 0, but fin3_skip0 c.val = c.val + 1 ≥ 1.
  have h_adj : (SimpleGraph.fromRel _).Adj (fin3_skip0 c) (fin3_skip0 d) := h
  rw [SimpleGraph.fromRel_adj] at h_adj
  obtain ⟨_, hrel⟩ := h_adj
  have hc_pos : 1 ≤ (fin3_skip0 c).val := by change 1 ≤ c.val + 1; omega
  have hd_pos : 1 ≤ (fin3_skip0 d).val := by change 1 ≤ d.val + 1; omega
  rcases hrel with hl | hr
  · rcases hl with ⟨hl1, _⟩ | ⟨hl1, _⟩ | ⟨hl1, _⟩ | ⟨hl1, _⟩ | ⟨hl1, _⟩ | ⟨hl1, _⟩ <;>
      omega
  · rcases hr with ⟨hr1, _⟩ | ⟨hr1, _⟩ | ⟨hr1, _⟩ | ⟨hr1, _⟩ | ⟨hr1, _⟩ | ⟨hr1, _⟩ <;>
      omega

/-- The backward map preserves the structure (graph + colour) of `vbExt3_RRR_e0`. -/
private theorem vbExt3_RRR_e0_of_perm_fn_isInduced (π : Equiv.Perm (Fin 3)) :
    CG2.comap (vbExt3_RRR_e0_of_perm_fn π) vbExt3_RRR_e0.str = vbExt3_RRR_e0.str := by
  apply Prod.ext
  · -- Graph: adjacency preserved.
    ext u v
    change vbExt3_RRR_e0.str.1.Adj
      (vbExt3_RRR_e0_of_perm_fn π u) (vbExt3_RRR_e0_of_perm_fn π v)
      ↔ vbExt3_RRR_e0.str.1.Adj u v
    by_cases hu : u.val = 0
    · by_cases hv : v.val = 0
      · -- both u, v = 0: both sides false (loop)
        have hu' : u = (⟨0, by omega⟩ : Fin 4) := Fin.ext hu
        have hv' : v = (⟨0, by omega⟩ : Fin 4) := Fin.ext hv
        rw [hu', hv']
        simp
      · -- u = 0, v ≠ 0: 0 adj v means 0 adj fin3_skip0 c (any leaf), true on both sides.
        have hu' : u = (⟨0, by omega⟩ : Fin 4) := Fin.ext hu
        rw [hu', vbExt3_RRR_e0_of_perm_fn_zero]
        set c := fin3_skip0_inv v hv with hc_def
        have hv_eq : v = fin3_skip0 c := (fin3_skip0_apply_inv v hv).symm
        rw [hv_eq, vbExt3_RRR_e0_of_perm_fn_skip]
        constructor
        · intro _; exact vbExt3_RRR_e0_zero_adj_skip c
        · intro _; exact vbExt3_RRR_e0_zero_adj_skip (π c)
    · by_cases hv : v.val = 0
      · -- u ≠ 0, v = 0: symmetric.
        have hv' : v = (⟨0, by omega⟩ : Fin 4) := Fin.ext hv
        rw [hv', vbExt3_RRR_e0_of_perm_fn_zero]
        set c := fin3_skip0_inv u hu with hc_def
        have hu_eq : u = fin3_skip0 c := (fin3_skip0_apply_inv u hu).symm
        rw [hu_eq, vbExt3_RRR_e0_of_perm_fn_skip]
        constructor
        · intro _; exact vbExt3_RRR_e0_skip_adj_zero c
        · intro _; exact vbExt3_RRR_e0_skip_adj_zero (π c)
      · -- both u, v ≠ 0: both sides false (no leaf-leaf edges).
        set c := fin3_skip0_inv u hu with hc_def
        set d := fin3_skip0_inv v hv with hd_def
        have hu_eq : u = fin3_skip0 c := (fin3_skip0_apply_inv u hu).symm
        have hv_eq : v = fin3_skip0 d := (fin3_skip0_apply_inv v hv).symm
        rw [hu_eq, hv_eq, vbExt3_RRR_e0_of_perm_fn_skip,
            vbExt3_RRR_e0_of_perm_fn_skip]
        constructor
        · intro h; exact absurd h (vbExt3_RRR_e0_skip_not_adj_skip _ _)
        · intro h; exact absurd h (vbExt3_RRR_e0_skip_not_adj_skip _ _)
  · -- Colour: π preserves "is σ-vertex" predicate, and all non-σ vertices have colour 0.
    funext v
    change vbExt3_RRR_e0.str.2 (vbExt3_RRR_e0_of_perm_fn π v) = vbExt3_RRR_e0.str.2 v
    by_cases hv : v.val = 0
    · have hv' : v = (⟨0, by omega⟩ : Fin 4) := Fin.ext hv
      rw [hv', vbExt3_RRR_e0_of_perm_fn_zero]
    · set c := fin3_skip0_inv v hv with hc_def
      have hv_eq : v = fin3_skip0 c := (fin3_skip0_apply_inv v hv).symm
      rw [hv_eq, vbExt3_RRR_e0_of_perm_fn_skip]
      -- Both sides: colour at fin3_skip0 (...) = 0 (red), since fin3_skip0 always
      -- yields val ≥ 1 ≠ 0.
      have h_col_skip : ∀ x : Fin 3, vbExt3_RRR_e0.str.2 (fin3_skip0 x) = (0 : Fin 2) := by
        intro x
        change (if (x.val + 1) = 0 then (1 : Fin 2) else 0) = 0
        have : x.val + 1 ≠ 0 := by omega
        simp [this]
      rw [h_col_skip (π c), h_col_skip c]

/-- Backward map: `Perm (Fin 3)` ↦ σ-iso of `vbExt3_RRR_e0`. -/
private noncomputable def vbExt3_RRR_e0_of_perm (π : Equiv.Perm (Fin 3)) :
    GenInducedEmbedding CG2 vertexBlackType vbExt3_RRR_e0 vbExt3_RRR_e0 where
  toFun := vbExt3_RRR_e0_of_perm_fn π
  injective := vbExt3_RRR_e0_of_perm_fn_inj π
  isInduced := vbExt3_RRR_e0_of_perm_fn_isInduced π
  compat := by
    intro i
    have hi : i = (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) := by
      obtain ⟨v, hv⟩ := i
      have h_size : vertexBlackType.size = 1 := rfl
      have hv' : v < 1 := h_size ▸ hv
      have : v = 0 := by omega
      ext; exact this
    rw [hi]
    have h_emb : vbExt3_RRR_e0.embedding (⟨0, Nat.zero_lt_one⟩ : Fin 1) =
        (⟨0, by omega⟩ : Fin 4) := rfl
    rw [h_emb, vbExt3_RRR_e0_of_perm_fn_zero]

/-- The Equiv between σ-isos of `vbExt3_RRR_e0` and `Equiv.Perm (Fin 3)`. -/
private noncomputable def vbExt3_RRR_e0_aut_equiv :
    GenInducedEmbedding CG2 vertexBlackType vbExt3_RRR_e0 vbExt3_RRR_e0 ≃
      Equiv.Perm (Fin 3) where
  toFun := vbExt3_RRR_e0_to_perm
  invFun := vbExt3_RRR_e0_of_perm
  left_inv := by
    intro e
    -- Show: of_perm (to_perm e) = e. Reduce to toFun equality via mk.injEq.
    have h_funext : ∀ x : Fin 4,
        (vbExt3_RRR_e0_of_perm (vbExt3_RRR_e0_to_perm e)).toFun x = e.toFun x := by
      intro x
      change vbExt3_RRR_e0_of_perm_fn (vbExt3_RRR_e0_to_perm e) x = e.toFun x
      by_cases hx : x.val = 0
      · have hx' : x = (⟨0, by omega⟩ : Fin 4) := Fin.ext hx
        rw [hx', vbExt3_RRR_e0_of_perm_fn_zero, vbExt3_RRR_e0_aut_fix0 e]
      · -- x ≠ 0; show LHS = e.toFun x at value level.
        apply Fin.ext
        change (vbExt3_RRR_e0_of_perm_fn (vbExt3_RRR_e0_to_perm e) x).val = (e.toFun x).val
        unfold vbExt3_RRR_e0_of_perm_fn
        rw [dif_neg hx]
        -- Goal: (fin3_skip0 ((to_perm e) (fin3_skip0_inv x hx))).val = (e.toFun x).val
        change (fin3_skip0 (vbExt3_RRR_e0_to_perm_fn e (fin3_skip0_inv x hx))).val =
          (e.toFun x).val
        -- Both sides are nats. LHS = (to_perm_fn e (fin3_skip0_inv x hx)).val + 1
        --                          = (fin3_skip0_inv (e.toFun (fin3_skip0 (fin3_skip0_inv x hx))) _).val + 1
        --                          = (e.toFun (fin3_skip0 (fin3_skip0_inv x hx))).val - 1 + 1
        -- And fin3_skip0 (fin3_skip0_inv x hx) = x, so the inner expression = e.toFun x,
        -- and the val is positive (by the image-ne-zero lemma applied to the result).
        -- We argue at the val level using the rewrite hidden inside `Fin.ext`.
        have h_inv_skip : fin3_skip0 (fin3_skip0_inv x hx) = x := fin3_skip0_apply_inv x hx
        -- Rather than rewriting through the dep proof, we derive the equation we need:
        have h_e_eq : e.toFun (fin3_skip0 (fin3_skip0_inv x hx)) = e.toFun x := by
          rw [h_inv_skip]
        -- Now strip the outer fin3_skip0 by working at val level.
        unfold vbExt3_RRR_e0_to_perm_fn
        -- Goal: (fin3_skip0 (fin3_skip0_inv (e.toFun (fin3_skip0 (fin3_skip0_inv x hx))) _)).val
        --     = (e.toFun x).val
        -- Use Fin.val of fin3_skip0 ∘ fin3_skip0_inv: lhs.val = (e.toFun (...)).val
        -- (since fin3_skip0 (fin3_skip0_inv y h) = y by fin3_skip0_apply_inv).
        -- We can't rewrite directly because the proof is dependent, so we manually
        -- unfold and use Fin.val arithmetic.
        change ((e.toFun (fin3_skip0 (fin3_skip0_inv x hx))).val - 1) + 1 =
          (e.toFun x).val
        have h_val : (e.toFun (fin3_skip0 (fin3_skip0_inv x hx))).val = (e.toFun x).val :=
          congr_arg Fin.val h_e_eq
        rw [h_val]
        have h_pos : 1 ≤ (e.toFun x).val := by
          by_contra h
          push_neg at h
          have h_zero : (e.toFun x).val = 0 := by omega
          have h_eq : e.toFun x = (⟨0, by omega⟩ : Fin 4) := Fin.ext h_zero
          have h_inj : x = (⟨0, by omega⟩ : Fin 4) :=
            e.injective (h_eq.trans (vbExt3_RRR_e0_aut_fix0 e).symm)
          have : x.val = 0 := congr_arg Fin.val h_inj
          exact hx this
        omega
    -- Lift function equality to embedding equality (toFun is the only data field).
    -- The other fields (injective, isInduced, compat) are propositions, so
    -- equality of structures reduces to equality of toFun.
    have h_toFun : (vbExt3_RRR_e0_of_perm (vbExt3_RRR_e0_to_perm e)).toFun = e.toFun :=
      funext h_funext
    -- Use direct case analysis. The 3 propositional fields are equal via proof irrelevance.
    rcases e with ⟨f, finj, find, fcompat⟩
    -- h_toFun : (of_perm (to_perm ⟨f, ...⟩)).toFun = f
    -- Goal: of_perm (to_perm ⟨f, ...⟩) = ⟨f, ...⟩.
    -- Generalize the LHS via a fresh variable, then destruct.
    generalize h_lhs_def :
      vbExt3_RRR_e0_of_perm (vbExt3_RRR_e0_to_perm ⟨f, finj, find, fcompat⟩) = lhs
    rw [h_lhs_def] at h_toFun
    -- Now lhs : GenInducedEmbedding ..., h_toFun : lhs.toFun = f.
    rcases lhs with ⟨f', finj', find', fcompat'⟩
    -- h_toFun : f' = f. Substitute and conclude by proof irrelevance.
    cases h_toFun
    rfl
  right_inv := by
    intro π
    -- Show: to_perm (of_perm π) = π. Equate the underlying functions.
    apply Equiv.ext
    intro c
    change vbExt3_RRR_e0_to_perm_fn (vbExt3_RRR_e0_of_perm π) c = π c
    -- Apply Fin.ext with value-level reasoning. The point: the concrete value of
    -- `fin3_skip0_inv (e.toFun (fin3_skip0 c))` equals `π c` even with proof
    -- argument dependence — both reduce to same Nat val.
    apply Fin.ext
    change (fin3_skip0_inv ((vbExt3_RRR_e0_of_perm π).toFun (fin3_skip0 c))
          (vbExt3_RRR_e0_aut_image_ne_zero (vbExt3_RRR_e0_of_perm π) c)).val =
          (π c).val
    -- (vbExt3_RRR_e0_of_perm π).toFun = vbExt3_RRR_e0_of_perm_fn π by definition.
    -- of_perm_fn π (fin3_skip0 c) = fin3_skip0 (π c) by skip lemma.
    -- fin3_skip0_inv (fin3_skip0 (π c)) _ has val = (π c).val.
    have h_apply : (vbExt3_RRR_e0_of_perm π).toFun (fin3_skip0 c) = fin3_skip0 (π c) :=
      vbExt3_RRR_e0_of_perm_fn_skip π c
    -- Fin.val of fin3_skip0_inv x h = x.val - 1.
    change ((vbExt3_RRR_e0_of_perm π).toFun (fin3_skip0 c)).val - 1 = (π c).val
    rw [h_apply]
    change (fin3_skip0 (π c)).val - 1 = (π c).val
    change (π c).val + 1 - 1 = (π c).val
    omega

/-- **The S₃ automorphism count for `vbExt3_RRR_e0`.**
    The flag is the star K_{1,3} with σ at vertex 0 and 3 red leaves at {1, 2, 3}.
    Any σ-iso fixes vertex 0 and permutes the leaves; adjacency and colour are
    automatically preserved. Hence Aut = S₃ = 6. -/
theorem vbExt3_RRR_e0_aut :
    genFlagAutCount CG2 vertexBlackType vbExt3_RRR_e0 = 6 := by
  unfold genFlagAutCount genInducedCount
  rw [Fintype.card_congr vbExt3_RRR_e0_aut_equiv]
  -- Fintype.card (Equiv.Perm (Fin 3)) = (Fintype.card (Fin 3))! = 3! = 6.
  rw [Fintype.card_perm]
  decide

/-! ### `ExtAdjAll` for `vbExt3_RRR_e0` and `vbExt4_RRRR_e0` -/

private theorem vbExt3_RRR_e0_extAdjAll :
    ExtAdjAll vbExt3_RRR_e0 (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) := by
  intro v hv_notin
  have h_v_ne_zero : v.val ≠ 0 := by
    intro h_eq
    apply hv_notin
    exact ⟨⟨0, Nat.zero_lt_one⟩, by ext; exact h_eq.symm⟩
  have h_emb : vbExt3_RRR_e0.embedding (⟨0, Nat.zero_lt_one⟩ : Fin 1) =
      (⟨0, by omega⟩ : Fin 4) := rfl
  rw [h_emb]
  rcases fin4_val_cases v with hv0 | hv1 | hv2 | hv3
  · exact absurd hv0 h_v_ne_zero
  · have hv : v = (⟨1, by omega⟩ : Fin 4) := Fin.ext hv1
    rw [hv]; change (SimpleGraph.fromRel _).Adj _ _
    simp [SimpleGraph.fromRel_adj]
  · have hv : v = (⟨2, by omega⟩ : Fin 4) := Fin.ext hv2
    rw [hv]; change (SimpleGraph.fromRel _).Adj _ _
    simp [SimpleGraph.fromRel_adj]
  · have hv : v = (⟨3, by omega⟩ : Fin 4) := Fin.ext hv3
    rw [hv]; change (SimpleGraph.fromRel _).Adj _ _
    simp [SimpleGraph.fromRel_adj]

private theorem vbExt4_RRRR_e0_extAdjAll :
    ExtAdjAll vbExt4_RRRR_e0 (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) := by
  intro v hv_notin
  have h_v_ne_zero : v.val ≠ 0 := by
    intro h_eq
    apply hv_notin
    exact ⟨⟨0, Nat.zero_lt_one⟩, by ext; exact h_eq.symm⟩
  have h_emb : vbExt4_RRRR_e0.embedding (⟨0, Nat.zero_lt_one⟩ : Fin 1) =
      (⟨0, by omega⟩ : Fin 5) := rfl
  rw [h_emb]
  rcases fin5_val_cases v with hv0 | hv1 | hv2 | hv3 | hv4
  · exact absurd hv0 h_v_ne_zero
  · have hv : v = (⟨1, by omega⟩ : Fin 5) := Fin.ext hv1
    rw [hv]; change (SimpleGraph.fromRel _).Adj _ _
    simp [SimpleGraph.fromRel_adj]
  · have hv : v = (⟨2, by omega⟩ : Fin 5) := Fin.ext hv2
    rw [hv]; change (SimpleGraph.fromRel _).Adj _ _
    simp [SimpleGraph.fromRel_adj]
  · have hv : v = (⟨3, by omega⟩ : Fin 5) := Fin.ext hv3
    rw [hv]; change (SimpleGraph.fromRel _).Adj _ _
    simp [SimpleGraph.fromRel_adj]
  · have hv : v = (⟨4, by omega⟩ : Fin 5) := Fin.ext hv4
    rw [hv]; change (SimpleGraph.fromRel _).Adj _ _
    simp [SimpleGraph.fromRel_adj]

/-! ### `extPow ... 4` factorisation and support properties

`extPow vbType ⟨0,_⟩ 4 = (extPow vbType ⟨0,_⟩ 3).mul (extSum vbType ⟨0,_⟩)`
by definition of `extPow` (`extPow_succ`).

We then prove that every class in the support has size 5 + ExtAdjAll, by
combining:
* `extPow_three_support_size_eq_four` and `extPow_three_support_extAdjAllClass`
  for the size-3 (after one step) factor.
* `extSum_support_eq` for the right factor.
* `genLocalFlagProduct_support_size` and `ExtAdjAllClass_of_lfp_support`
  for each LFP term in the resulting Finsupp sum. -/

theorem extPow_four_eq_extPow_three_mul_extSum :
    extPow vertexBlackType (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) 4 =
      (extPow vertexBlackType
        (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) 3).mul
        (extSum vertexBlackType
          (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size)) := rfl

/-- For any class in the support of `v.mul w`, there exist `cls₁ ∈ v.support`
    and `cls₂ ∈ w.support` with `cls ∈ (genLocalFlagProduct_class cls₁ cls₂).support`.
    This is the "support of a Finsupp.mul is contained in the union of LFP supports"
    fact. -/
private theorem genMul_support_witness {σ : GenFlagType CG2}
    (v w : GenFlagAlg CG2 σ) (cls : GenFlagClass CG2 σ)
    (hcls : cls ∈ (v.mul w).support) :
    ∃ cls₁ ∈ v.support, ∃ cls₂ ∈ w.support,
      (genLocalFlagProduct_class CG2 σ cls₁ cls₂) cls ≠ 0 := by
  -- (v.mul w) cls = sum over (v.support × w.support) of v(cls₁) * w(cls₂) * LFP(cls₁, cls₂)(cls).
  -- If the sum is nonzero at cls, some summand is nonzero.
  have h_ne : (v.mul w) cls ≠ 0 := Finsupp.mem_support_iff.mp hcls
  -- Negate: assume all triples give 0.
  by_contra h_no_witness
  apply h_ne
  -- Convert h_no_witness to a uniform form.
  have h_all_zero : ∀ cls₁ ∈ v.support, ∀ cls₂ ∈ w.support,
      (genLocalFlagProduct_class CG2 σ cls₁ cls₂) cls = 0 := by
    intro cls₁ hcls₁ cls₂ hcls₂
    by_contra hne
    apply h_no_witness
    exact ⟨cls₁, hcls₁, cls₂, hcls₂, hne⟩
  -- Now compute (v.mul w) cls = 0 by summing zeros.
  simp only [GenFlagAlg.mul, Finsupp.sum]
  rw [Finsupp.finset_sum_apply]
  apply Finset.sum_eq_zero
  intro cls₁ hcls₁
  rw [Finsupp.finset_sum_apply]
  apply Finset.sum_eq_zero
  intro cls₂ hcls₂
  simp only [Finsupp.smul_apply, smul_eq_mul]
  rw [h_all_zero cls₁ hcls₁ cls₂ hcls₂, mul_zero]

/-- Every class in `(extPow vbType ⟨0,_⟩ 4).support` has `cls.out.size = 5`.

    Strategy: invoke `extPow_four_eq_extPow_three_mul_extSum` and use
    `genMul_support_witness` to find size-4 + size-2 source classes; their LFP
    has size `4 + 2 - 1 = 5`. -/
theorem extPow_four_support_size_eq_five
    (cls : GenFlagClass CG2 vertexBlackType)
    (hcls : cls ∈ (extPow vertexBlackType
      (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) 4).support) :
    cls.out.size = 5 := by
  rw [extPow_four_eq_extPow_three_mul_extSum] at hcls
  obtain ⟨cls₁, hcls₁, cls₂, hcls₂, h_lfp_ne⟩ :=
    genMul_support_witness _ _ cls hcls
  -- cls₁.out.size = 4 by extPow_three_support_size_eq_four.
  have hsize₁ : cls₁.out.size = 4 := extPow_three_support_size_eq_four cls₁ hcls₁
  -- cls₂.out.size = 2 by extSum support.
  rw [extSum_support_eq] at hcls₂
  have hsize₂ : cls₂.out.size = 2 := by
    rcases Finset.mem_filter.mp hcls₂ with ⟨hmem, _⟩
    have hsz := genClassesOfSize_out_size hmem
    change cls₂.out.size = 2
    have : vertexBlackType.size + 1 = 2 := rfl
    rw [this] at hsz; exact hsz
  -- LFP is at the level of classes; use Quotient.out_eq to get to the flag-level.
  rw [genLocalFlagProduct_class_out] at h_lfp_ne
  -- (genLocalFlagProduct cls₁.out cls₂.out) cls ≠ 0, so cls is in its support.
  have h_supp : cls ∈ (genLocalFlagProduct CG2 vertexBlackType cls₁.out cls₂.out).support :=
    Finsupp.mem_support_iff.mpr h_lfp_ne
  -- size in the LFP support is cls₁.out.size + cls₂.out.size - σ.size = 4 + 2 - 1 = 5.
  have hsz_eq := genLocalFlagProduct_support_size cls h_supp
  rw [hsize₁, hsize₂] at hsz_eq
  exact hsz_eq

/-- Every class in `(extPow vbType ⟨0,_⟩ 4).support` has `ExtAdjAllClass`.

    Strategy: similar to the size-4 version: use `genMul_support_witness` to find
    size-4 + size-2 source classes (each ExtAdjAll), then propagate via
    `ExtAdjAllClass_of_lfp_support`. -/
theorem extPow_four_support_extAdjAllClass
    (cls : GenFlagClass CG2 vertexBlackType)
    (hcls : cls ∈ (extPow vertexBlackType
      (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) 4).support) :
    ExtAdjAllClass cls (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) := by
  rw [extPow_four_eq_extPow_three_mul_extSum] at hcls
  obtain ⟨cls₁, hcls₁, cls₂, hcls₂, h_lfp_ne⟩ :=
    genMul_support_witness _ _ cls hcls
  -- cls₁ is ExtAdjAllClass by extPow_three_support_extAdjAllClass.
  have hadj₁ : ExtAdjAllClass cls₁ (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) :=
    extPow_three_support_extAdjAllClass cls₁ hcls₁
  -- cls₂ is in extSum.support, hence iso to vbExtRed or vbExtBlack, both ExtAdjAll.
  rw [extSum_support_eq] at hcls₂
  have hadj₂ : ExtAdjAllClass cls₂ (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) := by
    -- cls₂ ∈ extAdjacencyClass-filtered classes; reduce via genClassesOfSize_out_size.
    rcases Finset.mem_filter.mp hcls₂ with ⟨hmem, hadj_pred⟩
    -- cls₂.out has size σ.size + 1 = 2.
    have hsz := genClassesOfSize_out_size hmem
    -- The filter predicate gives us the σ-vertex is adjacent to a non-σ vertex
    -- in cls₂.out; for size-2 σ-flags this is exactly ExtAdjAll.
    change ExtAdjAll cls₂.out (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size)
    -- Unfold the predicate.
    intro v hv_notin
    -- cls₂.out has size 2; the σ-vertex is the unique element of Range emb.
    -- v ∉ Range emb means v ≠ emb 0. extAdjacencyClass states the unique non-σ vertex
    -- is σ-adjacent.
    unfold extAdjacencyClass at hadj_pred
    -- Decode: there exists a v' such that the σ-vertex is adjacent to v'.
    rcases hadj_pred with ⟨v', hv'_notin, hv'_adj⟩
    -- Now v and v' are both not in Range emb in a size-2 flag, so v = v'.
    have h_v_eq : v = v' := by
      -- The σ-vertex is unique (emb from Fin 1), so it equals emb ⟨0,_⟩.
      -- Both v, v' avoid the σ-vertex in a size-2 flag, so they must be the
      -- single non-σ vertex.
      have h_size : cls₂.out.size = 2 := by
        have h_eq : vertexBlackType.size + 1 = 2 := rfl
        rw [← h_eq]; exact hsz
      -- Argue both v and v' have the same val (the unique non-σ index).
      -- The σ-vertex's val is determined by emb ⟨0,_⟩.
      set emb0 := cls₂.out.embedding (⟨0, Nat.zero_lt_one⟩ : Fin 1) with hemb0_def
      have h_v_ne : v ≠ emb0 := by
        intro hv_eq
        apply hv_notin
        exact ⟨⟨0, Nat.zero_lt_one⟩, hv_eq.symm⟩
      have h_v'_ne : v' ≠ emb0 := by
        intro hv'_eq
        apply hv'_notin
        exact ⟨⟨0, Nat.zero_lt_one⟩, hv'_eq.symm⟩
      -- v, v', emb0 are all in Fin cls₂.out.size = Fin 2.
      -- Cast everything through h_size.
      have h_v_lt : v.val < 2 := h_size ▸ v.isLt
      have h_v'_lt : v'.val < 2 := h_size ▸ v'.isLt
      have h_emb0_lt : emb0.val < 2 := h_size ▸ emb0.isLt
      have h_v_val_ne : v.val ≠ emb0.val := fun heq => h_v_ne (Fin.ext heq)
      have h_v'_val_ne : v'.val ≠ emb0.val := fun heq => h_v'_ne (Fin.ext heq)
      have h_v_val_eq_v'_val : v.val = v'.val := by
        -- emb0.val ∈ {0, 1}; v.val ≠ emb0.val and v.val < 2 forces v.val = 1 - emb0.val.
        -- Same for v'.val.
        interval_cases v.val <;> interval_cases v'.val <;> interval_cases emb0.val <;>
          first | rfl | (exfalso; first | exact h_v_val_ne rfl | exact h_v'_val_ne rfl)
      exact Fin.ext h_v_val_eq_v'_val
    rw [h_v_eq]; exact hv'_adj.symm
  -- Push from class-level back to flag-level on cls.
  rw [genLocalFlagProduct_class_out] at h_lfp_ne
  have h_supp : cls ∈ (genLocalFlagProduct CG2 vertexBlackType cls₁.out cls₂.out).support :=
    Finsupp.mem_support_iff.mpr h_lfp_ne
  exact ExtAdjAllClass_of_lfp_support _ hadj₁ hadj₂ cls h_supp

/-! ### Master closure (conditional) for size-5 v5 phase

Mirroring the size-4 closure `evalAlg_single_vbExt3_RRR_e0_eq_one`, we collapse
`psi.evalAlg(extPow ... 4)` via the size-5 dichotomy and the support properties
above.

The result depends on the specific coefficient
`(extPow vbType ⟨0,_⟩ 4)(⟦vbExt4_RRRR_e0⟧) = 1`. By the joint-count formula:
* `LFP(vbExt3_RRR_e0, vbExtRed)(⟦vbExt4_RRRR_e0⟧) = 1` (joint count 24,
  divided by `aut(vbExt3_RRR_e0) · aut(vbExtRed) · C(4,3) · C(1,1) = 6 · 1 · 4 · 1 = 24`).
* `LFP(vbExt3_RRR_e0, vbExtBlack)(⟦vbExt4_RRRR_e0⟧) = 0`
  (no black leaves in vbExt4_RRRR_e0).
