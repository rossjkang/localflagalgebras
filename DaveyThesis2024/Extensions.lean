        vbExt3_RRR_e3 :=
      size4_sigma3_RRR_e3_iso G_str G_emb G_isInd G_hsize h_emb_G
        h01 h02 h_adj_03 h12 h_adj_13 h_adj_23 hc0 hc1 hc2
    tauto
  -- Case (RRR, h01=T, h02=T, h12=F): RRR_e2 via swap03_swap23.
  · have h_iso : GenFlagIso vertexBlackType
        (⟨4, G_str, G_emb, G_isInd, G_hsize⟩ : GenFlag CG2 vertexBlackType)
        vbExt3_RRR_e2 :=
        by
      apply size4_sigma3_swap03_swap23_iso G_str vbExt3_RRR_e2.str G_emb
        vbExt3_RRR_e2.embedding G_isInd vbExt3_RRR_e2.isInduced G_hsize
        vbExt3_RRR_e2.hsize h_emb_G rfl
      · exact iff_of_true h01 (by rw [vbExt3_RRR_e2_adj_iff]; decide)
      · exact iff_of_true h02 (by rw [vbExt3_RRR_e2_adj_iff]; decide)
      · exact iff_of_true h_adj_03 (by rw [vbExt3_RRR_e2_adj_iff]; decide)
      · refine iff_of_false h12 ?_; rw [vbExt3_RRR_e2_adj_iff]; decide
      · exact iff_of_true h_adj_13 (by rw [vbExt3_RRR_e2_adj_iff]; decide)
      · exact iff_of_true h_adj_23 (by rw [vbExt3_RRR_e2_adj_iff]; decide)
      · rw [hc0]; rfl
      · rw [hc1]; rfl
      · rw [hc2]; rfl
    tauto
  -- Case (RRR, h01=T, h02=F, h12=T): RRR_e2 via swap03_swap12.
  · have h_iso : GenFlagIso vertexBlackType
        (⟨4, G_str, G_emb, G_isInd, G_hsize⟩ : GenFlag CG2 vertexBlackType)
        vbExt3_RRR_e2 :=
        by
      apply size4_sigma3_swap03_swap12_iso G_str vbExt3_RRR_e2.str G_emb
        vbExt3_RRR_e2.embedding G_isInd vbExt3_RRR_e2.isInduced G_hsize
        vbExt3_RRR_e2.hsize h_emb_G rfl
      · exact iff_of_true h01 (by rw [vbExt3_RRR_e2_adj_iff]; decide)
      · refine iff_of_false h02 ?_; rw [vbExt3_RRR_e2_adj_iff]; decide
      · exact iff_of_true h_adj_03 (by rw [vbExt3_RRR_e2_adj_iff]; decide)
      · exact iff_of_true h12 (by rw [vbExt3_RRR_e2_adj_iff]; decide)
      · exact iff_of_true h_adj_13 (by rw [vbExt3_RRR_e2_adj_iff]; decide)
      · exact iff_of_true h_adj_23 (by rw [vbExt3_RRR_e2_adj_iff]; decide)
      · rw [hc0]; rfl
      · rw [hc1]; rfl
      · rw [hc2]; rfl
    tauto
  -- Case (RRR, h01=T, h02=F, h12=F): RRR_e1 via swap03_swap23.
  · have h_iso : GenFlagIso vertexBlackType
        (⟨4, G_str, G_emb, G_isInd, G_hsize⟩ : GenFlag CG2 vertexBlackType)
        vbExt3_RRR_e1 :=
        by
      apply size4_sigma3_swap03_swap23_iso G_str vbExt3_RRR_e1.str G_emb
        vbExt3_RRR_e1.embedding G_isInd vbExt3_RRR_e1.isInduced G_hsize
        vbExt3_RRR_e1.hsize h_emb_G rfl
      · exact iff_of_true h01 (by rw [vbExt3_RRR_e1_adj_iff]; decide)
