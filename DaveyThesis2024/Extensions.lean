        = (⟨3, by decide⟩ : Fin 4)
    rw [Equiv.swap_apply_of_ne_of_ne
          (show (⟨1, by decide⟩ : Fin 4) ≠ ⟨0, by decide⟩ by decide)
          (show (⟨1, by decide⟩ : Fin 4) ≠ ⟨2, by decide⟩ by decide),
