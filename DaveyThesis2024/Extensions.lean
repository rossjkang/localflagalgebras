          left
          refine ⟨(⟨2, by decide⟩ : Fin 3), ?_⟩
          change rr_indep_to a b (⟨2, by decide⟩ : Fin 3) = i
          rw [rr_indep_to_two]
          have hb' : b = (⟨2, by decide⟩ : Fin 3) := Fin.ext hb2
          rw [hb', fin3_skip0_two]
          exact (Fin.ext hi).symm
      · -- a = 2, fin3_skip0 a = ⟨3⟩.
        left
        refine ⟨(⟨1, by decide⟩ : Fin 3), ?_⟩
        change rr_indep_to a b (⟨1, by decide⟩ : Fin 3) = i
        rw [rr_indep_to_one]
        have ha' : a = (⟨2, by decide⟩ : Fin 3) := Fin.ext ha2
        rw [ha', fin3_skip0_two]
        exact (Fin.ext hi).symm

/-- The size-4 nonzero joint count: there are exactly 6 valid joint pairs,
    one per ordered pair `(a, b)` of distinct vertices in `Fin 3`. -/
theorem genJointCount_vbExt2_RR_indep_vbExtRed_vbExt3_RRR_e0 :
    genJointCount CG2 vertexBlackType vbExt2_RR_indep vbExtRed vbExt3_RRR_e0 = 6 := by
  classical
  unfold genJointCount
  -- Set up an Equiv to {(a, b) : Fin 3 × Fin 3 // a ≠ b}.
  have hcard : Fintype.card { ab : Fin 3 × Fin 3 // ab.1 ≠ ab.2 } = 6 := by decide
  rw [show (6 : ℕ) = Fintype.card { ab : Fin 3 × Fin 3 // ab.1 ≠ ab.2 } from hcard.symm]
  apply Fintype.card_congr
  refine {
    toFun := joint_to_pair_fwd
    invFun := fun ab => pair_witness ab.val.1 ab.val.2 ab.property
    left_inv := ?_
    right_inv := ?_ }
  · -- left_inv: (joint_to_pair_fwd ∘ pair_witness) p = p.
    intro p
    apply Subtype.ext
    obtain ⟨⟨e₁, e₂⟩, hover, hcover⟩ := p
    -- Extract a, b from joint_to_pair_fwd.
    set v1 := e₁.toFun (⟨1, by decide⟩ : Fin 3) with hv1_def
    set v2 := e₁.toFun (⟨2, by decide⟩ : Fin 3) with hv2_def
    have hv1ne : v1.val ≠ 0 := by
      rcases vbExt2_RR_indep_to_vbExt3_RRR_e0_leaf_cases e₁ (⟨1, by decide⟩ : Fin 3)
          (by decide) with h | h | h <;> rw [hv1_def, h] <;> decide
    have hv2ne : v2.val ≠ 0 := by
      rcases vbExt2_RR_indep_to_vbExt3_RRR_e0_leaf_cases e₁ (⟨2, by decide⟩ : Fin 3)
          (by decide) with h | h | h <;> rw [hv2_def, h] <;> decide
    set a := fin3_skip0_inv v1 hv1ne with ha_def
    set b := fin3_skip0_inv v2 hv2ne with hb_def
    have hab : a ≠ b := by
      intro h
      have h1 : fin3_skip0 a = v1 := fin3_skip0_apply_inv v1 hv1ne
      have h2 : fin3_skip0 b = v2 := fin3_skip0_apply_inv v2 hv2ne
      rw [h] at h1
      have : v1 = v2 := h1.symm.trans h2
      exact rr_joint_e1_distinct e₁ (hv1_def ▸ hv2_def ▸ this)
    -- Show pair_witness equals (e₁, e₂).
    -- Use vbExt2_RR_indep_to_vbExt3_RRR_e0_ext and vbExtRed_to_vbExt3_RRR_e0_ext.
    change (pair_witness a b hab).val = (e₁, e₂)
    -- Step 1: e₁ = canon a b hab via ext.
    have h_e1_leaf1 : e₁.toFun (⟨1, by decide⟩ : Fin 3) =
        (vbExt2_RR_indep_to_vbExt3_RRR_e0_canon a b hab).toFun (⟨1, by decide⟩ : Fin 3) := by
      change v1 = rr_indep_to a b (⟨1, by decide⟩ : Fin 3)
      rw [rr_indep_to_one]
      exact (fin3_skip0_apply_inv v1 hv1ne).symm
    have h_e1_leaf2 : e₁.toFun (⟨2, by decide⟩ : Fin 3) =
        (vbExt2_RR_indep_to_vbExt3_RRR_e0_canon a b hab).toFun (⟨2, by decide⟩ : Fin 3) := by
      change v2 = rr_indep_to a b (⟨2, by decide⟩ : Fin 3)
      rw [rr_indep_to_two]
      exact (fin3_skip0_apply_inv v2 hv2ne).symm
    have h_e1_eq : e₁ = vbExt2_RR_indep_to_vbExt3_RRR_e0_canon a b hab :=
      vbExt2_RR_indep_to_vbExt3_RRR_e0_ext e₁ _ h_e1_leaf1 h_e1_leaf2
    -- Step 2: e₂ = canon (third a b) via ext.
    -- Need to show e₂'s leaf = fin3_skip0 (fin3_third a b).
    have h_e2_leaf_third : e₂.toFun (⟨1, by decide⟩ : Fin 2) = fin3_skip0 (fin3_third a b) := by
      -- e₂'s leaf is some red vertex distinct from v1, v2 (by overlap).
      have ⟨h_ne_v1, h_ne_v2⟩ := rr_joint_e2_third
        ⟨(e₁, e₂), hover, hcover⟩
      -- e₂.toFun ⟨1⟩ ∈ {⟨1⟩, ⟨2⟩, ⟨3⟩}.
      have h_e2 := vbExtRed_to_vbExt3_RRR_e0_leaf_cases e₂
      -- Convert to Fin 3 via fin3_skip0_inv.
      have h_e2_ne_zero : (e₂.toFun (⟨1, by decide⟩ : Fin 2)).val ≠ 0 := by
        rcases h_e2 with h | h | h <;> rw [h] <;> decide
      set w := fin3_skip0_inv (e₂.toFun (⟨1, by decide⟩ : Fin 2)) h_e2_ne_zero with hw_def
      have hw_back : fin3_skip0 w = e₂.toFun (⟨1, by decide⟩ : Fin 2) :=
        fin3_skip0_apply_inv _ _
      have hw_ne_a : w ≠ a := by
        intro h
        have h1 : fin3_skip0 w = e₂.toFun (⟨1, by decide⟩ : Fin 2) := hw_back
        have h2 : fin3_skip0 a = v1 := fin3_skip0_apply_inv v1 hv1ne
        rw [h] at h1
        have : e₂.toFun (⟨1, by decide⟩ : Fin 2) = v1 := h1.symm.trans h2
        exact h_ne_v1 (this.trans hv1_def.symm)
      have hw_ne_b : w ≠ b := by
        intro h
        have h1 : fin3_skip0 w = e₂.toFun (⟨1, by decide⟩ : Fin 2) := hw_back
        have h2 : fin3_skip0 b = v2 := fin3_skip0_apply_inv v2 hv2ne
        rw [h] at h1
        have : e₂.toFun (⟨1, by decide⟩ : Fin 2) = v2 := h1.symm.trans h2
        exact h_ne_v2 (this.trans hv2_def.symm)
      have hw_eq : w = fin3_third a b := fin3_third_unique a b w hab hw_ne_a hw_ne_b
      rw [← hw_back, hw_eq]
    have h_e2_eq : e₂ = vbExtRed_to_vbExt3_RRR_e0_canon (fin3_third a b) := by
      apply vbExtRed_to_vbExt3_RRR_e0_ext
      show e₂.toFun (⟨1, by decide⟩ : Fin 2) =
        (vbExtRed_to_vbExt3_RRR_e0_canon (fin3_third a b)).toFun (⟨1, by decide⟩ : Fin 2)
      rw [h_e2_leaf_third]
      change fin3_skip0 (fin3_third a b) = red_leaf_to (fin3_third a b) (⟨1, by decide⟩ : Fin 2)
      rw [red_leaf_to_one]
    change ((vbExt2_RR_indep_to_vbExt3_RRR_e0_canon a b hab,
          vbExtRed_to_vbExt3_RRR_e0_canon (fin3_third a b)) :
            GenInducedEmbedding _ _ _ _ × GenInducedEmbedding _ _ _ _) = (e₁, e₂)
    rw [h_e1_eq, h_e2_eq]
  · -- right_inv: (pair_witness ∘ joint_to_pair_fwd) ab = ab.
    intro ab
    obtain ⟨⟨a, b⟩, hab⟩ := ab
    -- joint_to_pair_fwd of pair_witness reads off (a, b) directly.
    -- Use Subtype.ext to reduce to equality of the underlying pairs.
    apply Subtype.ext
    -- Compute fin3_skip0_inv ∘ rr_indep_to using helper lemma directly.
    -- The forward map applies fin3_skip0_inv to the rr_indep_to values.
    -- For canonical pair_witness, that gives (a, b).
    have key : ∀ (c : Fin 3) (h : (fin3_skip0 c).val ≠ 0),
        fin3_skip0_inv (fin3_skip0 c) h = c := fun c h => fin3_skip0_inv_apply c
    -- We just need to reduce the term and recognize the application.
    rfl

/-! ### Discharging the conditional v5 size-4 identity (partial)

This section provides infrastructure for discharging
`evalAlg_vbExt3_RRR_e0_eq_one_of_decomp`. We rewrite `extPow vbType ⟨0,_⟩ 3`
into the cube `(extSum * extSum) * extSum` (via the unit identity) and then
into a sum of 12 generic local flag products via `extSum_vertexBlackType_mul_self`.

We then establish:
* `extPow_three_apply_RRR_e0`: the coefficient of `⟦vbExt3_RRR_e0⟧` in
  `extPow vbType ⟨0,_⟩ 3` is `1` (computed via the 12 size-4 joint counts).
* `extPow_three_apply_forbidden_X`: the coefficient at each of the 19 forbidden
  classes (deferred — needs the same joint-count-style enumeration as RRR_e0).

The remaining gap (full algebra-level decomposition `extPow ... 3 =`
`single ⟦RRR_e0⟧ + Σ forbidden_19`) requires showing **support containment**:
every size-4 σ-class in `support(extPow ... 3)` is iso to one of the 20 named
classes. This is a size-4 σ-flag classification analog of
`any_size3_extAdjBoth_iso` and remains future work. -/

/-- The unit identity `(single σ.toFlag).mul v = v` follows from
`genProduct_unit` + commutativity, by expanding `mul` as a Finsupp `sum`. -/
theorem GenFlagAlg.single_toFlag_mul (σ : GenFlagType CG2) (v : GenFlagAlg CG2 σ) :
    (GenFlagAlg.single σ.toFlag).mul v = v := by
  -- Unfold mul and reduce. (single σ.toFlag) = Finsupp.single (mk σ.toFlag) 1.
  unfold GenFlagAlg.mul GenFlagAlg.single
  rw [Finsupp.sum_single_index (by simp)]
  -- Goal: v.sum (fun cls c => (1 * c) • genLocalFlagProduct_class CG2 σ (mk σ.toFlag) cls) = v
  -- Step: simplify the inner expression using LFP unit + commutativity.
  have h_lfp_unit : ∀ cls : GenFlagClass CG2 σ,
      genLocalFlagProduct_class CG2 σ (GenFlagClass.mk σ.toFlag) cls =
        (Finsupp.single cls 1 : GenFlagAlg CG2 σ) := by
    intro cls
    rw [genLocalFlagProduct_class_out]
    -- LFP σ.toFlag.out cls.out — but Quotient.out (mk σ.toFlag) ≈ σ.toFlag.
    -- Use commutativity to flip arguments: LFP A B = LFP B A.
    rw [genProduct_comm]
    -- Goal: LFP cls.out (Quotient.out (mk σ.toFlag)) = Finsupp.single cls 1
    -- Use iso between (Quotient.out (mk σ.toFlag)) and σ.toFlag to reduce.
    have hiso : GenFlagIso σ (Quotient.out (GenFlagClass.mk σ.toFlag)) σ.toFlag := by
      have := Quotient.exact (Quotient.out_eq (GenFlagClass.mk σ.toFlag) :
        GenFlagClass.mk (Quotient.out (GenFlagClass.mk σ.toFlag)) = GenFlagClass.mk σ.toFlag)
      exact this
    rw [genLocalFlagProduct_flagIso_right hiso]
    rw [genProduct_unit]
    change (Finsupp.single (GenFlagClass.mk cls.out) 1 : GenFlagAlg CG2 σ) =
      Finsupp.single cls 1
    congr 1
    exact Quotient.out_eq cls
  conv_lhs =>
    arg 2
    ext cls c
    rw [one_mul, h_lfp_unit cls, Finsupp.smul_single, smul_eq_mul, mul_one]
  exact Finsupp.sum_single v

/-- `extPow vbType ⟨0,_⟩ 1 = extSum vbType ⟨0,_⟩` (unit identity at k=1). -/
theorem extPow_one_eq_extSum :
    extPow vertexBlackType (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) 1 =
      extSum vertexBlackType (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) := by
  rw [extPow_one]
  exact GenFlagAlg.single_toFlag_mul _ _

/-- `extPow vbType ⟨0,_⟩ 2 = extSum.mul extSum`. -/
theorem extPow_two_eq_extSum_sq :
    extPow vertexBlackType (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) 2 =
      (extSum vertexBlackType (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size)).mul
        (extSum vertexBlackType (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size)) := by
  change (extPow vertexBlackType _ 1).mul _ = _
  rw [extPow_one_eq_extSum]

/-- `extPow vbType ⟨0,_⟩ 3 = (extSum.mul extSum).mul extSum`. -/
theorem extPow_three_eq_extSum_cubed :
    extPow vertexBlackType (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) 3 =
      ((extSum vertexBlackType (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size)).mul
        (extSum vertexBlackType (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size))).mul
        (extSum vertexBlackType (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size)) := by
  change (extPow vertexBlackType _ 2).mul _ = _
  rw [extPow_two_eq_extSum_sq]

set_option maxHeartbeats 8000000 in
set_option maxRecDepth 4000 in
/-- `extPow vbType ⟨0,_⟩ 3` expanded as a sum of 12 single×single products
    via `extSum_vertexBlackType_mul_self` and right-multiplication by `extSum`. -/
theorem extPow_three_eq_twelve_lfp :
    extPow vertexBlackType (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) 3 =
      genLocalFlagProduct CG2 vertexBlackType vbExt2_RR_indep vbExtRed +
      genLocalFlagProduct CG2 vertexBlackType vbExt2_RR_indep vbExtBlack +
      genLocalFlagProduct CG2 vertexBlackType vbExt2_RR_edge vbExtRed +
      genLocalFlagProduct CG2 vertexBlackType vbExt2_RR_edge vbExtBlack +
      genLocalFlagProduct CG2 vertexBlackType vbExt2_RB_indep vbExtRed +
      genLocalFlagProduct CG2 vertexBlackType vbExt2_RB_indep vbExtBlack +
      genLocalFlagProduct CG2 vertexBlackType vbExt2_RB_edge vbExtRed +
      genLocalFlagProduct CG2 vertexBlackType vbExt2_RB_edge vbExtBlack +
      genLocalFlagProduct CG2 vertexBlackType vbExt2_BB_indep vbExtRed +
      genLocalFlagProduct CG2 vertexBlackType vbExt2_BB_indep vbExtBlack +
      genLocalFlagProduct CG2 vertexBlackType vbExt2_BB_edge vbExtRed +
      genLocalFlagProduct CG2 vertexBlackType vbExt2_BB_edge vbExtBlack := by
  rw [extPow_three_eq_extSum_cubed]
  -- Step 1: rewrite the leftmost (extSum * extSum) using the size-3 expansion.
  rw [extSum_vertexBlackType_mul_self]
  -- Step 2: rewrite the rightmost extSum as `single vbExtRed + single vbExtBlack`.
  rw [extSum_vertexBlackType_eq_two_singles]
  -- Each `Finsupp.single ⟦F⟧ 1 = GenFlagAlg.single F` by defeq; the `.mul` on Finsupp
  -- resolves to `GenFlagAlg.mul`. Distribute via add_mul / mul_add and reduce
  -- single·single to genLocalFlagProduct.
  rw [show (Finsupp.single (GenFlagClass.mk vbExt2_RR_indep) (1:ℝ) :
        GenFlagAlg CG2 vertexBlackType) = GenFlagAlg.single vbExt2_RR_indep from rfl]
  rw [show (Finsupp.single (GenFlagClass.mk vbExt2_RR_edge) (1:ℝ) :
        GenFlagAlg CG2 vertexBlackType) = GenFlagAlg.single vbExt2_RR_edge from rfl]
  rw [show (Finsupp.single (GenFlagClass.mk vbExt2_RB_indep) (1:ℝ) :
        GenFlagAlg CG2 vertexBlackType) = GenFlagAlg.single vbExt2_RB_indep from rfl]
  rw [show (Finsupp.single (GenFlagClass.mk vbExt2_RB_edge) (1:ℝ) :
        GenFlagAlg CG2 vertexBlackType) = GenFlagAlg.single vbExt2_RB_edge from rfl]
  rw [show (Finsupp.single (GenFlagClass.mk vbExt2_BB_indep) (1:ℝ) :
        GenFlagAlg CG2 vertexBlackType) = GenFlagAlg.single vbExt2_BB_indep from rfl]
  rw [show (Finsupp.single (GenFlagClass.mk vbExt2_BB_edge) (1:ℝ) :
        GenFlagAlg CG2 vertexBlackType) = GenFlagAlg.single vbExt2_BB_edge from rfl]
  rw [show (Finsupp.single (GenFlagClass.mk vbExtRed) (1:ℝ) :
        GenFlagAlg CG2 vertexBlackType) = GenFlagAlg.single vbExtRed from rfl]
  rw [show (Finsupp.single (GenFlagClass.mk vbExtBlack) (1:ℝ) :
        GenFlagAlg CG2 vertexBlackType) = GenFlagAlg.single vbExtBlack from rfl]
  -- Distribute on the left: 5 add_mul applications (sum of 6 turned into binary tree).
  rw [GenFlagAlg.add_mul, GenFlagAlg.add_mul, GenFlagAlg.add_mul,
      GenFlagAlg.add_mul, GenFlagAlg.add_mul]
  -- Distribute on the right within each summand: 6 mul_add applications.
  rw [GenFlagAlg.mul_add, GenFlagAlg.mul_add, GenFlagAlg.mul_add,
      GenFlagAlg.mul_add, GenFlagAlg.mul_add, GenFlagAlg.mul_add]
  -- Replace each (single F).mul (single G) with genLocalFlagProduct F G.
  rw [GenFlagAlg.mul_single, GenFlagAlg.mul_single, GenFlagAlg.mul_single,
      GenFlagAlg.mul_single, GenFlagAlg.mul_single, GenFlagAlg.mul_single,
      GenFlagAlg.mul_single, GenFlagAlg.mul_single, GenFlagAlg.mul_single,
      GenFlagAlg.mul_single, GenFlagAlg.mul_single, GenFlagAlg.mul_single]
  -- LHS and RHS now have the same 12 LFP terms; reassociate via abel.
  abel

/-! #### Documentation: remaining gap to discharge the conditional

The conditional `evalAlg_vbExt3_RRR_e0_eq_one_of_decomp` requires the
algebra-level decomposition

  `extPow vbType ⟨0,_⟩ 3 = single vbExt3_RRR_e0 + Σ forbidden_19`.

The infrastructure built above (`extPow_three_eq_twelve_lfp`) reduces the LHS
to a sum of 12 generic local flag products. Each LFP, when evaluated as a
Finsupp at any specific size-4 class `cls`, equals
`(autF₁ * autF₂)⁻¹ * jointInducedDensity F₁ F₂ cls.out` (provided cls is a
size-4 class).

For the target class `⟦vbExt3_RRR_e0⟧`:
* Only `LFP(vbExt2_RR_indep, vbExtRed)` contributes a nonzero amount.
* It contributes `(2 * 1)⁻¹ * (6 / (C(3,2) * C(1,1))) = (1/2) * (6/3) = 1`.
* All 11 other LFPs vanish by zero joint counts (proved above).

Hence the coefficient of `⟦vbExt3_RRR_e0⟧` in `extPow ... 3` should equal `1`.

**Remaining gap**: showing **support containment** —
`(extPow ... 3).support ⊆ {⟦RRR_e0⟧} ∪ (forbidden_19 mapped through `mk`)`.
This requires a size-4 σ-flag classification analogous to
`any_size3_extAdjBoth_iso`.

Once support containment is in place, the algebra-level decomposition follows
by `Finsupp.ext` and the conditional `evalAlg_vbExt3_RRR_e0_eq_one_of_decomp`
discharges the v5 identity.

(Note: an attempt to compute `extPow ... 3 (⟦vbExt3_RRR_e0⟧) = 1` directly via
the Finsupp coefficient is blocked by Lean's `whnf` timeout when reducing
expressions involving `genClassesOfSize CG2 vertexBlackType 4`, which enumerates
all size-4 σ-flag structures (~thousands of cases, exceeding default
`maxHeartbeats`). A cleaner approach would express the per-class coefficient
without going through the universal `genClassesOfSize` enumeration.) -/

/-! ### Size-4 named-class membership helpers (size-3 pattern at size 4)

These avoid the `whnf` blow-up by transporting along a Finset equality
`genClassesOfSize σ F.size = genClassesOfSize σ 4` rather than reducing
the underlying enumeration. Mirrors `vbExt2_named_mem` at size 3. -/

-- Heartbeats raised to allow `congr 1` to reduce up to F.size.
set_option maxHeartbeats 16000000 in
set_option maxRecDepth 4000 in
/-- The 20 named vbExt3 classes are members of `genClassesOfSize CG2 vertexBlackType 4`.
    Helper that goes through F.size and substitutes hF : F.size = 4. -/
private lemma vbExt3_named_mem
    (F : GenFlag CG2 vertexBlackType) (hF : F.size = 4)
    (h4 : vertexBlackType.size ≤ 4) :
    GenFlagClass.mk F ∈ genClassesOfSize CG2 vertexBlackType 4 h4 := by
  have hsize_le : vertexBlackType.size ≤ F.size := F.hsize
  have hmem := mk_F_mem_genClassesOfSize (σ := vertexBlackType) F hsize_le
  have hSet_eq : genClassesOfSize CG2 vertexBlackType F.size hsize_le =
                 genClassesOfSize CG2 vertexBlackType 4 h4 := by
    congr 1
  exact hSet_eq ▸ hmem

/-- Generic Finset equality when the size index changes by a propositional Nat
    equation. Since both arguments are free variables, `subst` works cleanly
    without forcing any reduction of `genClassesOfSize`. -/
private theorem genClassesOfSize_size_irrel {R : RelUniverse} {σ : GenFlagType R}
    {n n' : ℕ} (h : n = n') (hn : σ.size ≤ n) (hn' : σ.size ≤ n') :
    genClassesOfSize R σ n hn = genClassesOfSize R σ n' hn' := by
  subst h; rfl

/-! ### V7: `IsClassOfSize` membership abstraction

The size-4 elaboration blocker (deep `Finset.image` equality test) is bypassed
by a bespoke abstraction `IsClassOfSize n cls := (Quotient.out cls).size = n`.
This avoids stating `cls ∈ genClassesOfSize ... 4 _` (which triggers the
`stack_space_exception`) and instead routes through the size of the quotient
representative, which is reducible.

The two membership directions are equivalent:
* From membership in `genClassesOfSize R σ n hn` to `IsClassOfSize n cls`:
  `genClassesOfSize_out_size`.
* From `IsClassOfSize n cls` to membership: route via
  `mk_F_mem_genClassesOfSize` applied to `cls.out` and transport.

The apply lemma `genLocalFlagProduct_apply_isClass` then computes the Finsupp
coefficient at any concrete `cls` *without* enumerating size-n flag classes.
-/

/-- `IsClassOfSize n cls` iff the quotient representative of `cls` has size `n`.
    Iso-invariant on `cls` because `(Quotient.out cls).size` is determined by
    `cls` (any two representatives of the same class have equal size). -/
def IsClassOfSize {R : RelUniverse} {σ : GenFlagType R} (n : ℕ)
    (cls : GenFlagClass R σ) : Prop :=
  (Quotient.out cls).size = n

/-- Membership in `genClassesOfSize R σ n hn` is equivalent to `IsClassOfSize n cls`.
    Forward: `genClassesOfSize_out_size`. Backward: every class is `mk` of its
    `out`, and `mk_F_mem_genClassesOfSize` provides membership at size `out.size`,
    which equals `n` by the `IsClassOfSize` hypothesis. -/
theorem mem_genClassesOfSize_iff_isClassOfSize
    {R : RelUniverse} {σ : GenFlagType R} {n : ℕ} (hn : σ.size ≤ n)
    {cls : GenFlagClass R σ} :
    cls ∈ genClassesOfSize R σ n hn ↔ IsClassOfSize n cls := by
  constructor
  · intro hmem
    exact genClassesOfSize_out_size hmem
  · intro hcls
    -- We have (Quotient.out cls).size = n. Use mk_F_mem_genClassesOfSize on cls.out
    -- to get membership at size cls.out.size, then transport to n via hcls.
    have hsize_le : σ.size ≤ (Quotient.out cls).size := (Quotient.out cls).hsize
    have hmem_out : GenFlagClass.mk (Quotient.out cls) ∈
        genClassesOfSize R σ (Quotient.out cls).size hsize_le :=
      mk_F_mem_genClassesOfSize (Quotient.out cls) hsize_le
    -- GenFlagClass.mk (Quotient.out cls) = cls.
    have hmk_out : GenFlagClass.mk (Quotient.out cls) = cls := Quotient.out_eq cls
    rw [hmk_out] at hmem_out
    -- Transport membership across the size equality hcls : (Quotient.out cls).size = n.
    have hSet_eq : genClassesOfSize R σ (Quotient.out cls).size hsize_le =
                   genClassesOfSize R σ n hn := by
      subst hcls; rfl
    exact hSet_eq ▸ hmem_out

/-- The apply lemma for `genLocalFlagProduct` at a generic size `n` class.
    Avoids the size-4 elaboration blocker by routing through `IsClassOfSize`
    instead of `cls ∈ genClassesOfSize ... 4`. -/
theorem genLocalFlagProduct_apply_isClass
    {R : RelUniverse} {σ : GenFlagType R} (F F' : GenFlag R σ)
    (hn : σ.size ≤ F.size + F'.size - σ.size)
    (cls : GenFlagClass R σ)
    (hcls : IsClassOfSize (F.size + F'.size - σ.size) cls) :
    (genLocalFlagProduct R σ F F') cls =
      ((genFlagAutCount R σ F : ℝ) * (genFlagAutCount R σ F' : ℝ))⁻¹ *
        genJointInducedDensity R σ F F' (Quotient.out cls) := by
  simp only [genLocalFlagProduct, dif_pos hn, Finsupp.smul_apply, smul_eq_mul,
    Finsupp.finset_sum_apply, Finsupp.single_apply]
  -- Goal: (autF * autF')⁻¹ * Σ_{c ∈ S} (if cls = c then density F F' c.out else 0)
  --     = (autF * autF')⁻¹ * density F F' (Quotient.out cls)
  congr 1
  -- Goal: Σ_{c ∈ S} (if cls = c then density F F' c.out else 0)
  --     = density F F' (Quotient.out cls)
  have hmem : cls ∈ genClassesOfSize R σ (F.size + F'.size - σ.size) hn :=
    (mem_genClassesOfSize_iff_isClassOfSize hn).mpr hcls
  rw [Finset.sum_ite_eq' (genClassesOfSize R σ (F.size + F'.size - σ.size) hn) cls
    (fun c => genJointInducedDensity R σ F F' c.out)]
  rw [if_pos hmem]

/-! ### Concrete v7: vbExt3_RRR_e0_isClassOfSize and per-pair LFP evaluations -/

/-- `⟦vbExt3_RRR_e0⟧` is a class of size 4. Avoids triggering size-4
    elaboration on the membership form. -/
theorem vbExt3_RRR_e0_isClassOfSize :
    IsClassOfSize 4 (GenFlagClass.mk vbExt3_RRR_e0) := by
  unfold IsClassOfSize
  -- Goal: (Quotient.out (GenFlagClass.mk vbExt3_RRR_e0)).size = 4
  have hiso : GenFlagIso vertexBlackType
      (Quotient.out (GenFlagClass.mk vbExt3_RRR_e0)) vbExt3_RRR_e0 :=
    Quotient.exact (Quotient.out_eq (GenFlagClass.mk vbExt3_RRR_e0))
  rw [genFlagIso_size_eq hiso]
  exact vbExt3_RRR_e0_size

/-! #### Per-pair `genLocalFlagProduct` evaluations at `⟦vbExt3_RRR_e0⟧`

For each of the 12 (vbExt2_X, vbExtY) pairs, we compute the Finsupp coefficient
of `⟦vbExt3_RRR_e0⟧` in `genLocalFlagProduct vbExt2_X vbExtY`. By
`genLocalFlagProduct_apply_isClass`, this equals
`(autX·autY)⁻¹ · jointDensity X Y (Quotient.out ⟦RRR_e0⟧)`, and we transport
the joint density to `vbExt3_RRR_e0` via `genJointInducedDensity_flagIso_target'`.
-/

private theorem hsz4 (A B : GenFlag CG2 vertexBlackType)
    (hA : A.size = 3) (hB : B.size = 2) :
    A.size + B.size - vertexBlackType.size = 4 := by
  rw [hA, hB]; rfl

private theorem h_le_4 : vertexBlackType.size ≤ 4 := by decide

/-- Helper: `(genLocalFlagProduct A B) ⟦vbExt3_RRR_e0⟧` computed via the
    `IsClassOfSize 4` apply lemma. For any size-3 σ-flag `A` and size-2 σ-flag
    `B`, the coefficient at `⟦vbExt3_RRR_e0⟧` is
    `(autA · autB)⁻¹ · jointDensity A B vbExt3_RRR_e0` (after transporting
    via `Quotient.out_eq`). -/
private theorem lfp_apply_at_RRR_e0
    (A B : GenFlag CG2 vertexBlackType)
    (hA : A.size = 3) (hB : B.size = 2) :
    (genLocalFlagProduct CG2 vertexBlackType A B) (GenFlagClass.mk vbExt3_RRR_e0) =
      ((genFlagAutCount CG2 vertexBlackType A : ℝ) *
        (genFlagAutCount CG2 vertexBlackType B : ℝ))⁻¹ *
        genJointInducedDensity CG2 vertexBlackType A B vbExt3_RRR_e0 := by
  have hsz : A.size + B.size - vertexBlackType.size = 4 := hsz4 A B hA hB
  have hn : vertexBlackType.size ≤ A.size + B.size - vertexBlackType.size := by
    rw [hsz]; decide
  have hcls : IsClassOfSize (A.size + B.size - vertexBlackType.size)
      (GenFlagClass.mk vbExt3_RRR_e0) := by
    rw [hsz]; exact vbExt3_RRR_e0_isClassOfSize
  rw [genLocalFlagProduct_apply_isClass A B hn (GenFlagClass.mk vbExt3_RRR_e0) hcls]
  -- Now transport the density along iso (Quotient.out (mk RRR_e0)) ≈ RRR_e0.
  have hiso : GenFlagIso vertexBlackType
      (Quotient.out (GenFlagClass.mk vbExt3_RRR_e0)) vbExt3_RRR_e0 :=
    Quotient.exact (Quotient.out_eq (GenFlagClass.mk vbExt3_RRR_e0))
  rw [genJointInducedDensity_flagIso_target' hiso]

/-- LFP(vbExt2_RR_indep, vbExtRed) at ⟦RRR_e0⟧ = 1. -/
theorem lfp_vbExt2_RR_indep_vbExtRed_at_RRR_e0 :
    (genLocalFlagProduct CG2 vertexBlackType vbExt2_RR_indep vbExtRed)
      (GenFlagClass.mk vbExt3_RRR_e0) = 1 := by
  rw [lfp_apply_at_RRR_e0 vbExt2_RR_indep vbExtRed rfl rfl]
  rw [vbExt2_RR_indep_aut, vbExtRed_aut]
  unfold genJointInducedDensity
  rw [genJointCount_vbExt2_RR_indep_vbExtRed_vbExt3_RRR_e0]
  -- vbExt3_RRR_e0.size = 4, vertexBlackType.size = 1, vbExt2_RR_indep.size = 3,
  -- vbExtRed.size = 2. The size differences are 3 - 2 = 1 and 1 - 1 = 0... wait.
  -- Actually: G.size - σ.size = 4 - 1 = 3. F₁.size - σ.size = 3 - 1 = 2.
  -- C(3, 2) = 3. G - F₁ = 3 - 2 = 1. F₂ - σ = 2 - 1 = 1. C(1, 1) = 1.
  -- So density = 6 / (3 * 1) = 2. Coefficient = (2*1)⁻¹ * 2 = 1.
  have h1 : (Nat.choose (vbExt3_RRR_e0.size - vertexBlackType.size)
              (vbExt2_RR_indep.size - vertexBlackType.size) : ℝ) = 3 := by
    change ((Nat.choose (4 - 1) (3 - 1) : ℕ) : ℝ) = 3
    norm_num
  have h2 : (Nat.choose (vbExt3_RRR_e0.size - vertexBlackType.size -
              (vbExt2_RR_indep.size - vertexBlackType.size))
              (vbExtRed.size - vertexBlackType.size) : ℝ) = 1 := by
    change ((Nat.choose (4 - 1 - (3 - 1)) (2 - 1) : ℕ) : ℝ) = 1
    norm_num
  rw [h1, h2]
  norm_num

/-- Helper: LFP(A, B) at ⟦RRR_e0⟧ = 0 whenever the joint count vanishes.
    Common shape for 11 zero-density `at_RRR_e0` lemmas. -/
private theorem lfp_at_RRR_e0_of_jc_zero
    (A B : GenFlag CG2 vertexBlackType) (hA : A.size = 3) (hB : B.size = 2)
    (hjc : genJointCount CG2 vertexBlackType A B vbExt3_RRR_e0 = 0) :
    (genLocalFlagProduct CG2 vertexBlackType A B) (GenFlagClass.mk vbExt3_RRR_e0) = 0 := by
  rw [lfp_apply_at_RRR_e0 A B hA hB]
  unfold genJointInducedDensity
  rw [hjc]
  push_cast; ring

/-- LFP(vbExt2_RR_indep, vbExtBlack) at ⟦RRR_e0⟧ = 0 (joint count is 0). -/
theorem lfp_vbExt2_RR_indep_vbExtBlack_at_RRR_e0 :
    (genLocalFlagProduct CG2 vertexBlackType vbExt2_RR_indep vbExtBlack)
      (GenFlagClass.mk vbExt3_RRR_e0) = 0 :=
  lfp_at_RRR_e0_of_jc_zero vbExt2_RR_indep vbExtBlack rfl rfl
    genJointCount_vbExt2_RR_indep_vbExtBlack_vbExt3_RRR_e0

