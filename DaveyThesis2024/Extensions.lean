          change f₂ (⟨0, by decide⟩ : Fin 2) = fin2to3_id (⟨0, by decide⟩ : Fin 2)
          rw [fin2to3_id_zero]; exact h_e2_zero
        · have hx' : x = (⟨1, by decide⟩ : Fin 2) := Fin.ext hx
          rw [hx']
          change f₂ (⟨1, by decide⟩ : Fin 2) = fin2to3_id (⟨1, by decide⟩ : Fin 2)
          rw [fin2to3_id_one]; exact h_e2_one
      apply Subtype.ext
      change (e₁, e₂) = _
      rw [h_e1_eq, h_e2_eq]

/-- **Explicit Finsupp form of extSum at vertexBlackType**:
    `extSum vertexBlackType ⟨0,_⟩ = single ⟦vbExtRed⟧ 1 + single ⟦vbExtBlack⟧ 1`.
    Provable by Finsupp.ext: agree on each class. -/
theorem extSum_vertexBlackType_eq_two_singles :
    extSum vertexBlackType (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) =
      Finsupp.single (GenFlagClass.mk vbExtRed) 1 +
      Finsupp.single (GenFlagClass.mk vbExtBlack) 1 := by
  ext cls
  by_cases h_red : cls = GenFlagClass.mk vbExtRed
  · rw [h_red, extSum_vertexBlackType_at_red, Finsupp.add_apply,
        Finsupp.single_apply, if_pos rfl, Finsupp.single_apply,
        if_neg (Ne.symm mk_vbExtRed_ne_mk_vbExtBlack)]
    norm_num
  · by_cases h_black : cls = GenFlagClass.mk vbExtBlack
    · rw [h_black, extSum_vertexBlackType_at_black, Finsupp.add_apply,
          Finsupp.single_apply, if_neg mk_vbExtRed_ne_mk_vbExtBlack,
          Finsupp.single_apply, if_pos rfl]
      norm_num
    · -- cls ∉ support
      have h_not_in : cls ∉ (extSum vertexBlackType
          (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size)).support := by
        rw [extSum_vertexBlackType_support]
        simp [h_red, h_black]
      rw [Finsupp.notMem_support_iff.mp h_not_in, Finsupp.add_apply,
          Finsupp.single_apply, if_neg (Ne.symm h_red),
          Finsupp.single_apply, if_neg (Ne.symm h_black)]
      norm_num

/-! ## Size-3 σ-flag classification: `any_size3_extAdjBoth_iso`

For the (extSum)·(extSum) expansion at vertexBlackType, every size-3 σ-flag
class with σ-vertex adjacent to both leaves is isomorphic to one of the 6
flags `vbExt2_RR_indep`, `vbExt2_RR_edge`, `vbExt2_RB_indep`, `vbExt2_RB_edge`,
`vbExt2_BB_indep`, `vbExt2_BB_edge`.

Proof structure:
1. Case-split on σ-vertex position p ∈ {0, 1, 2}.
2. For each p, the iso φ permutes Fin 3 to bring p to 0.
3. Case-split on leaf colours and leaf-leaf edge.
4. Each leaf case constructs the iso explicitly.
-/

/-- Generic helper: build a size-3 σ-flag iso to a target T_str/T_emb (size 3,
    with σ at position 0) from a permutation φ : Fin 3 ≃ Fin 3 and pointwise
    structural facts. Both source and target are size-3 σ-flags presented in
    "exposed" form.

    Hypotheses:
    * `h_T_emb`: T's embedding maps ⟨0,_⟩ to position 0.
    * `h_emb`: φ maps the σ-vertex of G to position 0 (= T's σ-vertex).
    * `h_adj`: pointwise adjacency match: G.str.1.Adj u v ↔ T.str.1.Adj (φ u) (φ v).
    * `h_col`: pointwise colour match: G.str.2 v = T.str.2 (φ v). -/
private theorem size3_iso_via_perm
    (G_str T_str : CG2.Str 3)
    (G_emb T_emb : Fin vertexBlackType.size ↪ Fin 3)
    (G_isInd : CG2.comap G_emb G_str = vertexBlackType.str)
    (T_isInd : CG2.comap T_emb T_str = vertexBlackType.str)
    (G_hsize T_hsize : vertexBlackType.size ≤ 3)
    (h_T_emb : T_emb (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) =
      (⟨0, (by decide : (0:ℕ) < 3)⟩ : Fin 3))
    (φ : Fin 3 ≃ Fin 3)
    (h_emb : φ (G_emb ⟨0, Nat.zero_lt_one⟩) =
      (⟨0, (by decide : (0:ℕ) < 3)⟩ : Fin 3))
    (h_adj : ∀ u v : Fin 3,
      G_str.1.Adj u v ↔ T_str.1.Adj (φ u) (φ v))
    (h_col : ∀ v : Fin 3, G_str.2 v = T_str.2 (φ v)) :
    GenFlagIso vertexBlackType
      (⟨3, G_str, G_emb, G_isInd, G_hsize⟩ : GenFlag CG2 vertexBlackType)
      (⟨3, T_str, T_emb, T_isInd, T_hsize⟩ : GenFlag CG2 vertexBlackType) := by
  refine ⟨φ, ?_, ?_⟩
  · -- comap φ T_str = G_str
    apply Prod.ext
    · -- Graph
      ext u v
      change T_str.1.Adj (φ u) (φ v) ↔ G_str.1.Adj u v
      rw [h_adj u v]
    · -- Colour
      funext v
      change T_str.2 (φ v) = G_str.2 v
      exact (h_col v).symm
  · -- σ-compat
    intro i
    have hi : i = (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) := by
      obtain ⟨v, hv⟩ := i
      have h_size : vertexBlackType.size = 1 := rfl
      have hv' : v < 1 := h_size ▸ hv
      have : v = 0 := by omega
      ext; exact this
    rw [hi, h_T_emb, h_emb]

/-! ### Adjacency facts for the 6 vbExt2_* targets

We provide pointwise `Adj` predicates as `simp`/`decide`-friendly facts. -/

/-- Helper: vbExt2_RR_indep adjacency on Fin 3 (no leaf-leaf edge). -/
private theorem vbExt2_RR_indep_adj_iff (u v : Fin 3) :
    vbExt2_RR_indep.str.1.Adj u v ↔
      ((u.val = 0 ∧ v.val = 1) ∨ (u.val = 1 ∧ v.val = 0) ∨
        (u.val = 0 ∧ v.val = 2) ∨ (u.val = 2 ∧ v.val = 0)) := by
  change (SimpleGraph.fromRel _).Adj u v ↔ _
  simp [SimpleGraph.fromRel_adj]
  constructor
  · rintro ⟨_, h | h⟩
    · exact h
    · rcases h with ⟨h1, h2⟩ | ⟨h1, h2⟩ | ⟨h1, h2⟩ | ⟨h1, h2⟩
      · exact Or.inr (Or.inl ⟨h2, h1⟩)
      · exact Or.inl ⟨h2, h1⟩
      · exact Or.inr (Or.inr (Or.inr ⟨h2, h1⟩))
      · exact Or.inr (Or.inr (Or.inl ⟨h2, h1⟩))
  · intro h
    refine ⟨?_, Or.inl h⟩
    rcases h with ⟨h1, h2⟩ | ⟨h1, h2⟩ | ⟨h1, h2⟩ | ⟨h1, h2⟩ <;>
      (intro heq; rw [heq] at h1; omega)

