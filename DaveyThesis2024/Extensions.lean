/-- **Clean `unlabel_extDiff_nonneg`**: discharges the diff-support locality
    hypothesis automatically. -/
theorem unlabel_extDiff_nonneg_clean (σ : GenFlagType CG2)
    {𝒢 : GenGraphClass CG2} {Δ : GenGraphParam CG2}
    (hσ : GenIsLocalType σ 𝒢 Δ)
    (h_reg : IsRegularClass 𝒢 Δ)
    (i j : Fin σ.size)
    (h_local_i : ∀ cls ∈ ((genClassesOfSize CG2 σ (σ.size + 1) (Nat.le_succ _)).filter
      (fun cls => extAdjacencyClass σ cls i)),
      GenIsLocalFlag σ cls.out 𝒢 Δ)
    (h_local_j : ∀ cls ∈ ((genClassesOfSize CG2 σ (σ.size + 1) (Nat.le_succ _)).filter
      (fun cls => extAdjacencyClass σ cls j)),
      GenIsLocalFlag σ cls.out 𝒢 Δ)
    (φ : GenLimitFunctional CG2 (GenFlagType.empty CG2) 𝒢 Δ) :
    0 ≤ φ.evalAlg (genAveragingAlg σ (extSum σ i - extSum σ j)) := by
  -- Locality of (extSum i - extSum j).support: extSum i and extSum j both
  -- have local support (by their respective filters), so their difference does too.
  have hi_supp : ∀ cls ∈ (extSum σ i).support, GenIsLocalFlag σ cls.out 𝒢 Δ := by
    intro cls hcls; rw [extSum_support_eq] at hcls; exact h_local_i cls hcls
  have hj_supp : ∀ cls ∈ (extSum σ j).support, GenIsLocalFlag σ cls.out 𝒢 Δ := by
    intro cls hcls; rw [extSum_support_eq] at hcls; exact h_local_j cls hcls
  exact unlabel_extDiff_nonneg σ hσ h_reg i j (fun _ => h_local_i)
    (fun _ => h_local_j) (support_sub_local _ _ hi_supp hj_supp) φ

/-- **Clean `unlabel_extDiff_eq_zero`**. -/
theorem unlabel_extDiff_eq_zero_clean (σ : GenFlagType CG2)
    {𝒢 : GenGraphClass CG2} {Δ : GenGraphParam CG2}
    (hσ : GenIsLocalType σ 𝒢 Δ)
    (h_reg : IsRegularClass 𝒢 Δ)
    (i j : Fin σ.size)
    (h_local_i : ∀ cls ∈ ((genClassesOfSize CG2 σ (σ.size + 1) (Nat.le_succ _)).filter
      (fun cls => extAdjacencyClass σ cls i)),
      GenIsLocalFlag σ cls.out 𝒢 Δ)
    (h_local_j : ∀ cls ∈ ((genClassesOfSize CG2 σ (σ.size + 1) (Nat.le_succ _)).filter
      (fun cls => extAdjacencyClass σ cls j)),
      GenIsLocalFlag σ cls.out 𝒢 Δ)
    (φ : GenLimitFunctional CG2 (GenFlagType.empty CG2) 𝒢 Δ) :
    φ.evalAlg (genAveragingAlg σ (extSum σ i - extSum σ j)) = 0 := by
  have h_ij := unlabel_extDiff_nonneg_clean σ hσ h_reg i j h_local_i h_local_j φ
  have h_ji := unlabel_extDiff_nonneg_clean σ hσ h_reg j i h_local_j h_local_i φ
  rw [show (extSum σ j - extSum σ i : GenFlagAlg CG2 σ) =
      (-1 : ℝ) • (extSum σ i - extSum σ j) by
    rw [neg_smul, one_smul]; abel] at h_ji
  rw [genAveragingAlg_smul, GenLimitFunctional.evalAlg_smul] at h_ji
  linarith

/-- **B₁ closer template**: from the (deferred) thesis identity
    `5 · φ(⟦(extSum vertexBlackType 0)^4⟧) = φ(certF6)` and the master chain
    `φ(⟦(extSum vertexBlackType 0)^4⟧) = φ(vertexBlackFlag.forget)`,
    derive `φ(certF6) = 5 · φ(vertexBlackFlag.forget)`.

    Combined with `φ(vertexBlackFlag.forget) ≤ 1` (BRRB class), gives `φ(certF6) ≤ 5`.

    The combinatorial identity (first hypothesis) remains as a future enumeration
    target; this theorem packages everything else. -/
theorem b1_closer_template
    {𝒢 : GenGraphClass CG2} {Δ : GenGraphParam CG2}
    (hσ : GenIsLocalType vertexBlackType 𝒢 Δ)
    (h_reg : IsRegularClass 𝒢 Δ)
    (hσ_toFlag : GenIsLocalFlag vertexBlackType vertexBlackType.toFlag 𝒢 Δ)
    (h_ext_local : ∀ cls ∈ ((genClassesOfSize CG2 vertexBlackType
      (vertexBlackType.size + 1) (Nat.le_succ _)).filter
      (fun cls => extAdjacencyClass vertexBlackType cls
        ⟨0, by change 0 < 1; omega⟩)),
      GenIsLocalFlag vertexBlackType cls.out 𝒢 Δ)
    (φ : GenLimitFunctional CG2 (GenFlagType.empty CG2) 𝒢 Δ)
    (combinatorial_identity :
      5 * φ.evalAlg (genAveragingAlg vertexBlackType
        (extPow vertexBlackType ⟨0, by change 0 < 1; omega⟩ 4)) = φ.eval certF6) :
    φ.eval certF6 = 5 * φ.eval vertexBlackFlag.forget := by
  rw [← combinatorial_identity]
  rw [vertexBlackType_master_chain_clean hσ h_reg hσ_toFlag h_ext_local φ 4]

/-- **B₁ bound**: `φ(certF6) ≤ 5` given the combinatorial identity and the
    bound `φ(vertexBlackFlag.forget) ≤ 1` (i.e., black-vertex density ≤ 1,
    which holds when |black| ≤ Δ in the BRRB class). -/
theorem b1_bound_template
    {𝒢 : GenGraphClass CG2} {Δ : GenGraphParam CG2}
    (hσ : GenIsLocalType vertexBlackType 𝒢 Δ)
    (h_reg : IsRegularClass 𝒢 Δ)
    (hσ_toFlag : GenIsLocalFlag vertexBlackType vertexBlackType.toFlag 𝒢 Δ)
    (h_ext_local : ∀ cls ∈ ((genClassesOfSize CG2 vertexBlackType
      (vertexBlackType.size + 1) (Nat.le_succ _)).filter
      (fun cls => extAdjacencyClass vertexBlackType cls
        ⟨0, by change 0 < 1; omega⟩)),
      GenIsLocalFlag vertexBlackType cls.out 𝒢 Δ)
    (φ : GenLimitFunctional CG2 (GenFlagType.empty CG2) 𝒢 Δ)
    (combinatorial_identity :
      5 * φ.evalAlg (genAveragingAlg vertexBlackType
        (extPow vertexBlackType ⟨0, by change 0 < 1; omega⟩ 4)) = φ.eval certF6)
    (h_black_density : φ.eval vertexBlackFlag.forget ≤ 1) :
    φ.eval certF6 ≤ 5 := by
  rw [b1_closer_template hσ h_reg hσ_toFlag h_ext_local φ combinatorial_identity]
  linarith

/-- **σᵢ closer template**: from the (deferred) thesis identity
    `120·⟦extSum σ a - extSum σ b⟧ = (named flag combination)` (taken as
    a hypothesis), `unlabel_extDiff_eq_zero` gives that the named flag
    combination evaluates to 0. -/
theorem sigma_closer_template (σ : GenFlagType CG2)
    {𝒢 : GenGraphClass CG2} {Δ : GenGraphParam CG2}
    (hσ : GenIsLocalType σ 𝒢 Δ)
    (h_reg : IsRegularClass 𝒢 Δ)
    (a b : Fin σ.size)
    (h_local_a : ∀ cls ∈ ((genClassesOfSize CG2 σ (σ.size + 1) (Nat.le_succ _)).filter
      (fun cls => extAdjacencyClass σ cls a)),
      GenIsLocalFlag σ cls.out 𝒢 Δ)
    (h_local_b : ∀ cls ∈ ((genClassesOfSize CG2 σ (σ.size + 1) (Nat.le_succ _)).filter
      (fun cls => extAdjacencyClass σ cls b)),
      GenIsLocalFlag σ cls.out 𝒢 Δ)
    (φ : GenLimitFunctional CG2 (GenFlagType.empty CG2) 𝒢 Δ)
    (named_flag_combo : ℝ)
    (combinatorial_identity :
      120 * φ.evalAlg (genAveragingAlg σ (extSum σ a - extSum σ b)) =
        named_flag_combo) :
    named_flag_combo = 0 := by
  rw [← combinatorial_identity]
  rw [unlabel_extDiff_eq_zero_clean σ hσ h_reg a b h_local_a h_local_b φ]
  ring

/-- Corollary: if the combinatorial identity holds, the named-flag combo is ≥ 0
    (trivially, since it equals 0). -/
theorem sigma_nonneg_template (σ : GenFlagType CG2)
    {𝒢 : GenGraphClass CG2} {Δ : GenGraphParam CG2}
    (hσ : GenIsLocalType σ 𝒢 Δ)
    (h_reg : IsRegularClass 𝒢 Δ)
    (a b : Fin σ.size)
    (h_local_a : ∀ cls ∈ ((genClassesOfSize CG2 σ (σ.size + 1) (Nat.le_succ _)).filter
      (fun cls => extAdjacencyClass σ cls a)),
      GenIsLocalFlag σ cls.out 𝒢 Δ)
    (h_local_b : ∀ cls ∈ ((genClassesOfSize CG2 σ (σ.size + 1) (Nat.le_succ _)).filter
      (fun cls => extAdjacencyClass σ cls b)),
      GenIsLocalFlag σ cls.out 𝒢 Δ)
    (φ : GenLimitFunctional CG2 (GenFlagType.empty CG2) 𝒢 Δ)
    (named_flag_combo : ℝ)
    (combinatorial_identity :
      120 * φ.evalAlg (genAveragingAlg σ (extSum σ a - extSum σ b)) =
        named_flag_combo) :
    0 ≤ named_flag_combo := by
  rw [sigma_closer_template σ hσ h_reg a b h_local_a h_local_b φ
    named_flag_combo combinatorial_identity]

/-- **BRRB graph class extraction**: |black| ≤ Δ from `brrbGenGraphClass`. -/
theorem brrbGenGraphClass_black_le_delta
    (G : GenFlag CG2 (GenFlagType.empty CG2))
    (hG : brrbGenGraphClass G) :
    (Finset.univ.filter (fun v : Fin G.size => G.str.2 v = 1)).card ≤
      brrbGenDelta G := hG.2.2

/-- **BRRB graph class extraction**: black-independence. -/
theorem brrbGenGraphClass_blackIndep
    (G : GenFlag CG2 (GenFlagType.empty CG2))
    (hG : brrbGenGraphClass G) :
    ∀ u v : Fin G.size,
      G.str.2 u = 1 → G.str.2 v = 1 → ¬G.str.1.Adj u v := hG.2.1

/-- **BRRB graph class extraction**: triangle-freeness. -/
theorem brrbGenGraphClass_triangleFree
    (G : GenFlag CG2 (GenFlagType.empty CG2))
    (hG : brrbGenGraphClass G) :
    ∀ u v w : Fin G.size,
      G.str.1.Adj u v → G.str.1.Adj v w → G.str.1.Adj u w → False := hG.1

/-- For BRRB class: every neighbor of a black vertex is red.

    Proof: black vertices are mutually non-adjacent (black-indep), so any neighbor
    of a black vertex must be red (since CG2 has 2 colours: 0 = red, 1 = black). -/
theorem brrb_black_neighbors_red
    (G : GenFlag CG2 (GenFlagType.empty CG2))
    (hG : brrbGenGraphClass G)
    (b : Fin G.size) (hb : G.str.2 b = 1)
    (v : Fin G.size) (hv_adj : G.str.1.Adj b v) :
    G.str.2 v = 0 := by
  have h_indep := brrbGenGraphClass_blackIndep G hG
  -- v's colour is in Fin 2 = {0, 1}. If 1 (black), contradicts black-indep.
  have hlt : (G.str.2 v).val < 2 := (G.str.2 v).isLt
  interval_cases h : (G.str.2 v).val
  · exact Fin.ext h
  · exfalso; exact h_indep b v hb (Fin.ext h) hv_adj

/-- The number of red vertices adjacent to a black vertex equals the degree
    of that vertex. -/
theorem brrb_black_redDeg_eq_deg
    (G : GenFlag CG2 (GenFlagType.empty CG2))
    (hG : brrbGenGraphClass G)
    (b : Fin G.size) (hb : G.str.2 b = 1) :
    (Finset.univ.filter (fun v : Fin G.size =>
      G.str.1.Adj b v ∧ G.str.2 v = 0)).card =
    (Finset.univ.filter (fun v : Fin G.size => G.str.1.Adj b v)).card := by
  congr 1
  ext v
  simp only [Finset.mem_filter, Finset.mem_univ, true_and]
  constructor
  · intro ⟨h_adj, _⟩; exact h_adj
  · intro h_adj
    refine ⟨h_adj, ?_⟩
    exact brrb_black_neighbors_red G hG b hb v h_adj

