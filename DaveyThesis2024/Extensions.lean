/-- Map `Fin 4 → Fin 5` sending ⟨0⟩ → ⟨0⟩ (σ), and the 3 leaf positions
    ⟨1⟩, ⟨2⟩, ⟨3⟩ to `fin4_skip0 a`, `fin4_skip0 b`, `fin4_skip0 c` respectively.
    Used as the underlying function of the canonical
    `vbExt3_RRR_e0 → vbExt4_RRRR_e0` embedding. -/
private def rrr_to_5 (a b c : Fin 4) : Fin 4 → Fin 5 :=
  fun x => if x.val = 0 then (⟨0, by decide⟩ : Fin 5)
           else if x.val = 1 then fin4_skip0 a
           else if x.val = 2 then fin4_skip0 b
           else fin4_skip0 c

private theorem rrr_to_5_zero (a b c : Fin 4) :
    rrr_to_5 a b c (⟨0, by decide⟩ : Fin 4) = (⟨0, by decide⟩ : Fin 5) := rfl

private theorem rrr_to_5_one (a b c : Fin 4) :
    rrr_to_5 a b c (⟨1, by decide⟩ : Fin 4) = fin4_skip0 a := rfl

private theorem rrr_to_5_two (a b c : Fin 4) :
    rrr_to_5 a b c (⟨2, by decide⟩ : Fin 4) = fin4_skip0 b := rfl

private theorem rrr_to_5_three (a b c : Fin 4) :
    rrr_to_5 a b c (⟨3, by decide⟩ : Fin 4) = fin4_skip0 c := rfl

private theorem rrr_to_5_inj (a b c : Fin 4)
    (hab : a ≠ b) (hac : a ≠ c) (hbc : b ≠ c) :
    Function.Injective (rrr_to_5 a b c) := by
  intro x y h
  rcases fin4_val_cases x with hx | hx | hx | hx <;>
    rcases fin4_val_cases y with hy | hy | hy | hy
  all_goals first
    | exact Fin.ext (hx.trans hy.symm)
    | (exfalso
       have hx' : x = (⟨0, by decide⟩ : Fin 4) := Fin.ext hx
       have hy' : y = (⟨1, by decide⟩ : Fin 4) := Fin.ext hy
       rw [hx', hy', rrr_to_5_zero, rrr_to_5_one] at h
       exact fin4_skip0_ne_zero a h.symm)
    | (exfalso
       have hx' : x = (⟨0, by decide⟩ : Fin 4) := Fin.ext hx
       have hy' : y = (⟨2, by decide⟩ : Fin 4) := Fin.ext hy
       rw [hx', hy', rrr_to_5_zero, rrr_to_5_two] at h
       exact fin4_skip0_ne_zero b h.symm)
    | (exfalso
       have hx' : x = (⟨0, by decide⟩ : Fin 4) := Fin.ext hx
       have hy' : y = (⟨3, by decide⟩ : Fin 4) := Fin.ext hy
       rw [hx', hy', rrr_to_5_zero, rrr_to_5_three] at h
       exact fin4_skip0_ne_zero c h.symm)
    | (exfalso
       have hx' : x = (⟨1, by decide⟩ : Fin 4) := Fin.ext hx
       have hy' : y = (⟨0, by decide⟩ : Fin 4) := Fin.ext hy
       rw [hx', hy', rrr_to_5_one, rrr_to_5_zero] at h
       exact fin4_skip0_ne_zero a h)
    | (exfalso
       have hx' : x = (⟨2, by decide⟩ : Fin 4) := Fin.ext hx
       have hy' : y = (⟨0, by decide⟩ : Fin 4) := Fin.ext hy
       rw [hx', hy', rrr_to_5_two, rrr_to_5_zero] at h
       exact fin4_skip0_ne_zero b h)
    | (exfalso
       have hx' : x = (⟨3, by decide⟩ : Fin 4) := Fin.ext hx
       have hy' : y = (⟨0, by decide⟩ : Fin 4) := Fin.ext hy
       rw [hx', hy', rrr_to_5_three, rrr_to_5_zero] at h
       exact fin4_skip0_ne_zero c h)
    | (exfalso
       have hx' : x = (⟨1, by decide⟩ : Fin 4) := Fin.ext hx
       have hy' : y = (⟨2, by decide⟩ : Fin 4) := Fin.ext hy
       rw [hx', hy', rrr_to_5_one, rrr_to_5_two] at h
       exact hab (fin4_skip0_inj h))
    | (exfalso
       have hx' : x = (⟨2, by decide⟩ : Fin 4) := Fin.ext hx
       have hy' : y = (⟨1, by decide⟩ : Fin 4) := Fin.ext hy
       rw [hx', hy', rrr_to_5_two, rrr_to_5_one] at h
       exact hab.symm (fin4_skip0_inj h))
    | (exfalso
       have hx' : x = (⟨1, by decide⟩ : Fin 4) := Fin.ext hx
       have hy' : y = (⟨3, by decide⟩ : Fin 4) := Fin.ext hy
       rw [hx', hy', rrr_to_5_one, rrr_to_5_three] at h
       exact hac (fin4_skip0_inj h))
    | (exfalso
       have hx' : x = (⟨3, by decide⟩ : Fin 4) := Fin.ext hx
       have hy' : y = (⟨1, by decide⟩ : Fin 4) := Fin.ext hy
       rw [hx', hy', rrr_to_5_three, rrr_to_5_one] at h
       exact hac.symm (fin4_skip0_inj h))
    | (exfalso
       have hx' : x = (⟨2, by decide⟩ : Fin 4) := Fin.ext hx
       have hy' : y = (⟨3, by decide⟩ : Fin 4) := Fin.ext hy
       rw [hx', hy', rrr_to_5_two, rrr_to_5_three] at h
       exact hbc (fin4_skip0_inj h))
    | (exfalso
       have hx' : x = (⟨3, by decide⟩ : Fin 4) := Fin.ext hx
       have hy' : y = (⟨2, by decide⟩ : Fin 4) := Fin.ext hy
       rw [hx', hy', rrr_to_5_three, rrr_to_5_two] at h
       exact hbc.symm (fin4_skip0_inj h))

/-- vbExt3_RRR_e0 has (0, fin3_skip0 c) edges for c ∈ Fin 3. -/
private theorem vbExt3_RRR_e0_adj_0_skip3 (c : Fin 3) :
    vbExt3_RRR_e0.str.1.Adj (⟨0, by decide⟩ : Fin 4) (fin3_skip0 c) :=
  vbExt3_RRR_e0_adj_0_skip c

/-- The induced-graph + colour structure pulls back correctly for `rrr_to_5 a b c`
    when `a, b, c` are distinct. Maps vbExt3_RRR_e0 (Fin 4) into vbExt4_RRRR_e0 (Fin 5). -/
private theorem rrr_to_5_str_eq (a b c : Fin 4)
    (_hab : a ≠ b) (_hac : a ≠ c) (_hbc : b ≠ c) :
    CG2.comap (rrr_to_5 a b c) vbExt4_RRRR_e0.str = vbExt3_RRR_e0.str := by
  apply Prod.ext
  · -- Graph: vbExt3_RRR_e0 has σ-leaf edges {0,1}, {0,2}, {0,3} and no leaf-leaf edges.
    ext u v
    change vbExt4_RRRR_e0.str.1.Adj (rrr_to_5 a b c u) (rrr_to_5 a b c v) ↔
      vbExt3_RRR_e0.str.1.Adj u v
    -- Helper: vbExt3_RRR_e0 σ-leaf edge is `Adj`.
    have h_e3_01 : vbExt3_RRR_e0.str.1.Adj (⟨0, by decide⟩ : Fin 4) ⟨1, by decide⟩ := by
      simp [vbExt3_RRR_e0, SimpleGraph.fromRel_adj]
    have h_e3_02 : vbExt3_RRR_e0.str.1.Adj (⟨0, by decide⟩ : Fin 4) ⟨2, by decide⟩ := by
      simp [vbExt3_RRR_e0, SimpleGraph.fromRel_adj]
    have h_e3_03 : vbExt3_RRR_e0.str.1.Adj (⟨0, by decide⟩ : Fin 4) ⟨3, by decide⟩ := by
      simp [vbExt3_RRR_e0, SimpleGraph.fromRel_adj]
    rcases fin4_val_cases u with hu | hu | hu | hu <;>
      rcases fin4_val_cases v with hv | hv | hv | hv
    all_goals (
      first
        | (have hu' : u = (⟨0, by decide⟩ : Fin 4) := Fin.ext hu
           have hv' : v = (⟨0, by decide⟩ : Fin 4) := Fin.ext hv
           rw [hu', hv', rrr_to_5_zero]
           simp [vbExt4_RRRR_e0, vbExt3_RRR_e0])
        | (have hu' : u = (⟨0, by decide⟩ : Fin 4) := Fin.ext hu
           have hv' : v = (⟨1, by decide⟩ : Fin 4) := Fin.ext hv
           rw [hu', hv', rrr_to_5_zero, rrr_to_5_one]
           refine ⟨fun _ => h_e3_01, fun _ => vbExt4_RRRR_e0_adj_0_skip a⟩)
        | (have hu' : u = (⟨0, by decide⟩ : Fin 4) := Fin.ext hu
           have hv' : v = (⟨2, by decide⟩ : Fin 4) := Fin.ext hv
           rw [hu', hv', rrr_to_5_zero, rrr_to_5_two]
           refine ⟨fun _ => h_e3_02, fun _ => vbExt4_RRRR_e0_adj_0_skip b⟩)
        | (have hu' : u = (⟨0, by decide⟩ : Fin 4) := Fin.ext hu
           have hv' : v = (⟨3, by decide⟩ : Fin 4) := Fin.ext hv
           rw [hu', hv', rrr_to_5_zero, rrr_to_5_three]
           refine ⟨fun _ => h_e3_03, fun _ => vbExt4_RRRR_e0_adj_0_skip c⟩)
        | (have hu' : u = (⟨1, by decide⟩ : Fin 4) := Fin.ext hu
           have hv' : v = (⟨0, by decide⟩ : Fin 4) := Fin.ext hv
           rw [hu', hv', rrr_to_5_zero, rrr_to_5_one]
           refine ⟨fun _ => h_e3_01.symm, fun _ => (vbExt4_RRRR_e0_adj_0_skip a).symm⟩)
        | (have hu' : u = (⟨2, by decide⟩ : Fin 4) := Fin.ext hu
           have hv' : v = (⟨0, by decide⟩ : Fin 4) := Fin.ext hv
           rw [hu', hv', rrr_to_5_zero, rrr_to_5_two]
           refine ⟨fun _ => h_e3_02.symm, fun _ => (vbExt4_RRRR_e0_adj_0_skip b).symm⟩)
        | (have hu' : u = (⟨3, by decide⟩ : Fin 4) := Fin.ext hu
           have hv' : v = (⟨0, by decide⟩ : Fin 4) := Fin.ext hv
           rw [hu', hv', rrr_to_5_zero, rrr_to_5_three]
           refine ⟨fun _ => h_e3_03.symm, fun _ => (vbExt4_RRRR_e0_adj_0_skip c).symm⟩)
        | (have hu' : u = (⟨1, by decide⟩ : Fin 4) := Fin.ext hu
           have hv' : v = (⟨1, by decide⟩ : Fin 4) := Fin.ext hv
           rw [hu', hv', rrr_to_5_one]
           simp [vbExt4_RRRR_e0, vbExt3_RRR_e0])
        | (have hu' : u = (⟨2, by decide⟩ : Fin 4) := Fin.ext hu
           have hv' : v = (⟨2, by decide⟩ : Fin 4) := Fin.ext hv
           rw [hu', hv', rrr_to_5_two]
           simp [vbExt4_RRRR_e0, vbExt3_RRR_e0])
        | (have hu' : u = (⟨3, by decide⟩ : Fin 4) := Fin.ext hu
           have hv' : v = (⟨3, by decide⟩ : Fin 4) := Fin.ext hv
           rw [hu', hv', rrr_to_5_three]
           simp [vbExt4_RRRR_e0, vbExt3_RRR_e0])
        | (have hu' : u = (⟨1, by decide⟩ : Fin 4) := Fin.ext hu
           have hv' : v = (⟨2, by decide⟩ : Fin 4) := Fin.ext hv
           rw [hu', hv', rrr_to_5_one, rrr_to_5_two]
           constructor
           · intro h; exact absurd h (vbExt4_RRRR_e0_not_adj_skip_skip a b)
           · intro h; exfalso; simp [vbExt3_RRR_e0, SimpleGraph.fromRel_adj] at h)
        | (have hu' : u = (⟨1, by decide⟩ : Fin 4) := Fin.ext hu
           have hv' : v = (⟨3, by decide⟩ : Fin 4) := Fin.ext hv
           rw [hu', hv', rrr_to_5_one, rrr_to_5_three]
           constructor
           · intro h; exact absurd h (vbExt4_RRRR_e0_not_adj_skip_skip a c)
           · intro h; exfalso; simp [vbExt3_RRR_e0, SimpleGraph.fromRel_adj] at h)
        | (have hu' : u = (⟨2, by decide⟩ : Fin 4) := Fin.ext hu
           have hv' : v = (⟨1, by decide⟩ : Fin 4) := Fin.ext hv
           rw [hu', hv', rrr_to_5_two, rrr_to_5_one]
           constructor
           · intro h; exact absurd h (vbExt4_RRRR_e0_not_adj_skip_skip b a)
           · intro h; exfalso; simp [vbExt3_RRR_e0, SimpleGraph.fromRel_adj] at h)
        | (have hu' : u = (⟨2, by decide⟩ : Fin 4) := Fin.ext hu
           have hv' : v = (⟨3, by decide⟩ : Fin 4) := Fin.ext hv
           rw [hu', hv', rrr_to_5_two, rrr_to_5_three]
           constructor
           · intro h; exact absurd h (vbExt4_RRRR_e0_not_adj_skip_skip b c)
           · intro h; exfalso; simp [vbExt3_RRR_e0, SimpleGraph.fromRel_adj] at h)
        | (have hu' : u = (⟨3, by decide⟩ : Fin 4) := Fin.ext hu
           have hv' : v = (⟨1, by decide⟩ : Fin 4) := Fin.ext hv
           rw [hu', hv', rrr_to_5_three, rrr_to_5_one]
           constructor
           · intro h; exact absurd h (vbExt4_RRRR_e0_not_adj_skip_skip c a)
           · intro h; exfalso; simp [vbExt3_RRR_e0, SimpleGraph.fromRel_adj] at h)
        | (have hu' : u = (⟨3, by decide⟩ : Fin 4) := Fin.ext hu
           have hv' : v = (⟨2, by decide⟩ : Fin 4) := Fin.ext hv
           rw [hu', hv', rrr_to_5_three, rrr_to_5_two]
           constructor
           · intro h; exact absurd h (vbExt4_RRRR_e0_not_adj_skip_skip c b)
           · intro h; exfalso; simp [vbExt3_RRR_e0, SimpleGraph.fromRel_adj] at h))
  · -- Colour.
    funext v
    rcases fin4_val_cases v with hv | hv | hv | hv
    · have hv' : v = (⟨0, by decide⟩ : Fin 4) := Fin.ext hv
      rw [hv']
      change vbExt4_RRRR_e0.str.2 (rrr_to_5 a b c (⟨0, by decide⟩ : Fin 4)) =
        vbExt3_RRR_e0.str.2 (⟨0, by decide⟩ : Fin 4)
      rw [rrr_to_5_zero]; decide
    · have hv' : v = (⟨1, by decide⟩ : Fin 4) := Fin.ext hv
      rw [hv']
      change vbExt4_RRRR_e0.str.2 (rrr_to_5 a b c (⟨1, by decide⟩ : Fin 4)) =
        vbExt3_RRR_e0.str.2 (⟨1, by decide⟩ : Fin 4)
      rw [rrr_to_5_one, vbExt4_RRRR_e0_col_skip]; rfl
    · have hv' : v = (⟨2, by decide⟩ : Fin 4) := Fin.ext hv
      rw [hv']
      change vbExt4_RRRR_e0.str.2 (rrr_to_5 a b c (⟨2, by decide⟩ : Fin 4)) =
        vbExt3_RRR_e0.str.2 (⟨2, by decide⟩ : Fin 4)
      rw [rrr_to_5_two, vbExt4_RRRR_e0_col_skip]; rfl
    · have hv' : v = (⟨3, by decide⟩ : Fin 4) := Fin.ext hv
      rw [hv']
      change vbExt4_RRRR_e0.str.2 (rrr_to_5 a b c (⟨3, by decide⟩ : Fin 4)) =
        vbExt3_RRR_e0.str.2 (⟨3, by decide⟩ : Fin 4)
      rw [rrr_to_5_three, vbExt4_RRRR_e0_col_skip]; rfl

/-- Canonical embedding `vbExt3_RRR_e0 → vbExt4_RRRR_e0` placing the 3 leaves
    at `fin4_skip0 a, fin4_skip0 b, fin4_skip0 c` for distinct `a, b, c : Fin 4`. -/
noncomputable def vbExt3_RRR_e0_to_vbExt4_RRRR_e0_canon
    (a b c : Fin 4) (hab : a ≠ b) (hac : a ≠ c) (hbc : b ≠ c) :
    GenInducedEmbedding CG2 vertexBlackType vbExt3_RRR_e0 vbExt4_RRRR_e0 where
  toFun := rrr_to_5 a b c
  injective := rrr_to_5_inj a b c hab hac hbc
  isInduced := rrr_to_5_str_eq a b c hab hac hbc
  compat := fun i => by
    have hi : i = (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) := by
      obtain ⟨v, hv⟩ := i
      have h_size : vertexBlackType.size = 1 := rfl
      have hv' : v < 1 := h_size ▸ hv
      have : v = 0 := by omega
      ext; exact this
    rw [hi]
    change rrr_to_5 a b c (⟨0, by decide⟩ : Fin 4) = (⟨0, by decide⟩ : Fin 5)
    rw [rrr_to_5_zero]

/-! #### Leaf-placement lemmas for embeddings into `vbExt4_RRRR_e0`. -/

/-- For any `e : vbExtRed → vbExt4_RRRR_e0`, the leaf goes to ⟨1⟩, ⟨2⟩, ⟨3⟩ or ⟨4⟩. -/
private lemma vbExtRed_to_vbExt4_RRRR_e0_leaf_cases
    (e : GenInducedEmbedding CG2 vertexBlackType vbExtRed vbExt4_RRRR_e0) :
    e.toFun (⟨1, by decide⟩ : Fin 2) = (⟨1, by decide⟩ : Fin 5) ∨
    e.toFun (⟨1, by decide⟩ : Fin 2) = (⟨2, by decide⟩ : Fin 5) ∨
    e.toFun (⟨1, by decide⟩ : Fin 2) = (⟨3, by decide⟩ : Fin 5) ∨
    e.toFun (⟨1, by decide⟩ : Fin 2) = (⟨4, by decide⟩ : Fin 5) := by
  obtain ⟨f, finj, find, fcompat⟩ := e
  have h_phi_0 : f (⟨0, by decide⟩ : Fin 2) = (⟨0, by decide⟩ : Fin 5) :=
    fcompat (⟨0, Nat.zero_lt_one⟩ : Fin 1)
  change f (⟨1, by decide⟩ : Fin 2) = (⟨1, by decide⟩ : Fin 5) ∨
       f (⟨1, by decide⟩ : Fin 2) = (⟨2, by decide⟩ : Fin 5) ∨
       f (⟨1, by decide⟩ : Fin 2) = (⟨3, by decide⟩ : Fin 5) ∨
       f (⟨1, by decide⟩ : Fin 2) = (⟨4, by decide⟩ : Fin 5)
  rcases fin5_val_cases (f (⟨1, by decide⟩ : Fin 2)) with h0 | h1 | h2 | h3 | h4
  · exfalso
    have h_eq : f (⟨1, by decide⟩ : Fin 2) = (⟨0, by decide⟩ : Fin 5) := Fin.ext h0
    have : (⟨1, by decide⟩ : Fin 2) = (⟨0, by decide⟩ : Fin 2) :=
      finj (h_eq.trans h_phi_0.symm)
    have : (1 : ℕ) = 0 := congr_arg Fin.val this
    omega
  · left; exact Fin.ext h1
  · right; left; exact Fin.ext h2
  · right; right; left; exact Fin.ext h3
  · right; right; right; exact Fin.ext h4

/-- For `e : vbExt3_RRR_e0 → vbExt4_RRRR_e0`, leaf at `i ∈ {1, 2, 3}` of vbExt3
    goes to one of `{⟨1⟩, ⟨2⟩, ⟨3⟩, ⟨4⟩}` in `Fin 5`. -/
private lemma vbExt3_RRR_e0_to_vbExt4_RRRR_e0_leaf_cases
    (e : GenInducedEmbedding CG2 vertexBlackType vbExt3_RRR_e0 vbExt4_RRRR_e0)
    (i : Fin 4) (hi : i.val ≠ 0) :
    e.toFun i = (⟨1, by decide⟩ : Fin 5) ∨
    e.toFun i = (⟨2, by decide⟩ : Fin 5) ∨
    e.toFun i = (⟨3, by decide⟩ : Fin 5) ∨
    e.toFun i = (⟨4, by decide⟩ : Fin 5) := by
  obtain ⟨f, finj, find, fcompat⟩ := e
  have h_phi_0 : f (⟨0, by decide⟩ : Fin 4) = (⟨0, by decide⟩ : Fin 5) :=
    fcompat (⟨0, Nat.zero_lt_one⟩ : Fin 1)
  change f i = (⟨1, by decide⟩ : Fin 5) ∨
       f i = (⟨2, by decide⟩ : Fin 5) ∨
       f i = (⟨3, by decide⟩ : Fin 5) ∨
       f i = (⟨4, by decide⟩ : Fin 5)
  rcases fin5_val_cases (f i) with h0 | h1 | h2 | h3 | h4
  · exfalso
    have h_eq : f i = (⟨0, by decide⟩ : Fin 5) := Fin.ext h0
    have : i = (⟨0, by decide⟩ : Fin 4) := finj (h_eq.trans h_phi_0.symm)
    have : i.val = 0 := congr_arg Fin.val this
    exact hi this
  · left; exact Fin.ext h1
  · right; left; exact Fin.ext h2
  · right; right; left; exact Fin.ext h3
  · right; right; right; exact Fin.ext h4

/-! #### Embedding-equality lemmas. -/

/-- Two `vbExtRed → vbExt4_RRRR_e0` embeddings agreeing on the leaf are equal. -/
private theorem vbExtRed_to_vbExt4_RRRR_e0_ext
    (e₁ e₂ : GenInducedEmbedding CG2 vertexBlackType vbExtRed vbExt4_RRRR_e0)
    (h_leaf : e₁.toFun (⟨1, by decide⟩ : Fin 2) = e₂.toFun (⟨1, by decide⟩ : Fin 2)) :
    e₁ = e₂ := by
  obtain ⟨f₁, finj₁, find₁, fcompat₁⟩ := e₁
  obtain ⟨f₂, finj₂, find₂, fcompat₂⟩ := e₂
  congr 1
  funext x
  rcases fin2_eq_zero_or_one x with hx | hx
  · have hx' : x = (⟨0, by decide⟩ : Fin 2) := Fin.ext hx
    rw [hx']
    have h1 : f₁ (⟨0, by decide⟩ : Fin 2) = (⟨0, by decide⟩ : Fin 5) :=
      fcompat₁ (⟨0, Nat.zero_lt_one⟩ : Fin 1)
    have h2 : f₂ (⟨0, by decide⟩ : Fin 2) = (⟨0, by decide⟩ : Fin 5) :=
      fcompat₂ (⟨0, Nat.zero_lt_one⟩ : Fin 1)
    rw [h1, h2]
  · have hx' : x = (⟨1, by decide⟩ : Fin 2) := Fin.ext hx
    rw [hx']
    exact h_leaf

/-- Two `vbExt3_RRR_e0 → vbExt4_RRRR_e0` embeddings agreeing on leaves
    ⟨1⟩, ⟨2⟩, ⟨3⟩ are equal. -/
private theorem vbExt3_RRR_e0_to_vbExt4_RRRR_e0_ext
    (e₁ e₂ : GenInducedEmbedding CG2 vertexBlackType vbExt3_RRR_e0 vbExt4_RRRR_e0)
    (h_leaf1 : e₁.toFun (⟨1, by decide⟩ : Fin 4) = e₂.toFun (⟨1, by decide⟩ : Fin 4))
    (h_leaf2 : e₁.toFun (⟨2, by decide⟩ : Fin 4) = e₂.toFun (⟨2, by decide⟩ : Fin 4))
    (h_leaf3 : e₁.toFun (⟨3, by decide⟩ : Fin 4) = e₂.toFun (⟨3, by decide⟩ : Fin 4)) :
    e₁ = e₂ := by
  obtain ⟨f₁, finj₁, find₁, fcompat₁⟩ := e₁
  obtain ⟨f₂, finj₂, find₂, fcompat₂⟩ := e₂
  congr 1
  funext x
  rcases fin4_val_cases x with hx | hx | hx | hx
  · have hx' : x = (⟨0, by decide⟩ : Fin 4) := Fin.ext hx
    rw [hx']
    have h1 : f₁ (⟨0, by decide⟩ : Fin 4) = (⟨0, by decide⟩ : Fin 5) :=
      fcompat₁ (⟨0, Nat.zero_lt_one⟩ : Fin 1)
    have h2 : f₂ (⟨0, by decide⟩ : Fin 4) = (⟨0, by decide⟩ : Fin 5) :=
      fcompat₂ (⟨0, Nat.zero_lt_one⟩ : Fin 1)
    rw [h1, h2]
  · have hx' : x = (⟨1, by decide⟩ : Fin 4) := Fin.ext hx
    rw [hx']; exact h_leaf1
  · have hx' : x = (⟨2, by decide⟩ : Fin 4) := Fin.ext hx
    rw [hx']; exact h_leaf2
  · have hx' : x = (⟨3, by decide⟩ : Fin 4) := Fin.ext hx
    rw [hx']; exact h_leaf3

/-! #### The forward map: joint pair → Perm (Fin 4). -/

/-- For a joint pair `(e₁, e₂)`, e₁'s 3 leaves go to 3 distinct red vertices. -/
private theorem rrrred_joint_e1_distinct
    (e₁ : GenInducedEmbedding CG2 vertexBlackType vbExt3_RRR_e0 vbExt4_RRRR_e0) :
    (∀ i j : Fin 4, i.val ≠ 0 → j.val ≠ 0 → i ≠ j → e₁.toFun i ≠ e₁.toFun j) := by
  intro i j _ _ hij heq
  exact hij (e₁.injective heq)

/-- The Subtype that genJointCount enumerates. -/
private abbrev RRRRedJointPair :=
  { p : GenInducedEmbedding CG2 vertexBlackType vbExt3_RRR_e0 vbExt4_RRRR_e0 ×
          GenInducedEmbedding CG2 vertexBlackType vbExtRed vbExt4_RRRR_e0 //
        (∀ i : Fin vbExt4_RRRR_e0.size,
          (i ∈ Set.range p.1.toFun ∧ i ∈ Set.range p.2.toFun) ↔
            i ∈ Set.range vbExt4_RRRR_e0.embedding) ∧
        (∀ i : Fin vbExt4_RRRR_e0.size,
          i ∈ Set.range p.1.toFun ∨ i ∈ Set.range p.2.toFun) }

/-- The four image values `e₁ ⟨1⟩`, `e₁ ⟨2⟩`, `e₁ ⟨3⟩`, `e₂ ⟨1⟩` are pairwise
    distinct (within a joint pair). -/
private theorem rrrred_four_distinct (p : RRRRedJointPair) :
    (∀ i j : Fin 4, i.val ≠ 0 → j.val ≠ 0 → i ≠ j →
      p.val.1.toFun i ≠ p.val.1.toFun j) ∧
    (∀ i : Fin 4, i.val ≠ 0 →
      p.val.2.toFun (⟨1, by decide⟩ : Fin 2) ≠ p.val.1.toFun i) := by
  obtain ⟨⟨e₁, e₂⟩, hover, _hcover⟩ := p
  refine ⟨rrrred_joint_e1_distinct e₁, ?_⟩
  intro i hi
  intro h
  -- e₂.toFun ⟨1⟩ = e₁.toFun i ⇒ in range e₁ ∩ range e₂ ⇒ ∈ Range vbExt4.embedding = {⟨0⟩}
  have hv1 : e₂.toFun (⟨1, by decide⟩ : Fin 2) ∈ Set.range e₁.toFun := ⟨i, h.symm⟩
  have hv2 : e₂.toFun (⟨1, by decide⟩ : Fin 2) ∈ Set.range e₂.toFun :=
    ⟨(⟨1, by decide⟩ : Fin 2), rfl⟩
  have hboth := (hover (e₂.toFun (⟨1, by decide⟩ : Fin 2))).mp ⟨hv1, hv2⟩
  obtain ⟨_, hj⟩ := hboth
  have h_eq : e₂.toFun (⟨1, by decide⟩ : Fin 2) = (⟨0, by decide⟩ : Fin 5) := by
    rw [← hj]; rfl
  -- But e₂.toFun ⟨1⟩ ≠ ⟨0⟩ (red, not σ).
  have h_e2_zero : e₂.toFun (⟨0, by decide⟩ : Fin 2) = (⟨0, by decide⟩ : Fin 5) := by
    rw [vbExtRed_emb_zero e₂]; rfl
  have h_inj : (⟨1, by decide⟩ : Fin 2) = (⟨0, by decide⟩ : Fin 2) :=
    e₂.injective (h_eq.trans h_e2_zero.symm)
  have : (1 : ℕ) = 0 := congr_arg Fin.val h_inj
  omega

/-- e₁'s leaf at i ≠ 0 in Fin 4 has nonzero val image. -/
private theorem rrrred_e1_image_ne_zero
    (e₁ : GenInducedEmbedding CG2 vertexBlackType vbExt3_RRR_e0 vbExt4_RRRR_e0)
    (i : Fin 4) (hi : i.val ≠ 0) :
    (e₁.toFun i).val ≠ 0 := by
  rcases vbExt3_RRR_e0_to_vbExt4_RRRR_e0_leaf_cases e₁ i hi with h | h | h | h <;>
    rw [h] <;> decide

/-- e₂'s leaf has nonzero val image. -/
private theorem rrrred_e2_image_ne_zero
    (e₂ : GenInducedEmbedding CG2 vertexBlackType vbExtRed vbExt4_RRRR_e0) :
    (e₂.toFun (⟨1, by decide⟩ : Fin 2)).val ≠ 0 := by
  rcases vbExtRed_to_vbExt4_RRRR_e0_leaf_cases e₂ with h | h | h | h <;>
    rw [h] <;> decide

/-- The forward map: a joint pair determines a `Perm (Fin 4)` whose values at
    `0, 1, 2` are e₁'s leaf images (via fin4_skip0_inv), and whose value at `3`
    is e₂'s leaf image. -/
private noncomputable def rrrred_joint_to_perm_fn
    (p : RRRRedJointPair) : Fin 4 → Fin 4 :=
  fun k =>
    if h : k.val = 3 then
      fin4_skip0_inv (p.val.2.toFun (⟨1, by decide⟩ : Fin 2))
        (rrrred_e2_image_ne_zero p.val.2)
    else by
      -- k.val ∈ {0, 1, 2}: read off e₁.toFun fin3_skip0(k_as_fin3).
      -- But k here is in Fin 4, with k.val ≠ 3. Use fin3_skip0 from Fin 3.
      have hk_lt : k.val < 3 := by have hlt := k.isLt; omega
      let k3 : Fin 3 := ⟨k.val, hk_lt⟩
      exact fin4_skip0_inv (p.val.1.toFun (fin3_skip0 k3))
        (rrrred_e1_image_ne_zero p.val.1 (fin3_skip0 k3) (by change k3.val + 1 ≠ 0; omega))

/-- The forward map's value at `k.val ≠ 3` is determined by e₁. -/
private theorem rrrred_joint_to_perm_fn_lt3
    (p : RRRRedJointPair) (k : Fin 4) (hk : k.val ≠ 3) :
    rrrred_joint_to_perm_fn p k =
      fin4_skip0_inv (p.val.1.toFun (fin3_skip0 ⟨k.val, by have := k.isLt; omega⟩))
        (rrrred_e1_image_ne_zero p.val.1 _
          (by change k.val + 1 ≠ 0; omega)) := by
  unfold rrrred_joint_to_perm_fn
  rw [dif_neg hk]

/-- The forward map's value at `3` is determined by e₂. -/
private theorem rrrred_joint_to_perm_fn_3
    (p : RRRRedJointPair) :
    rrrred_joint_to_perm_fn p (⟨3, by decide⟩ : Fin 4) =
      fin4_skip0_inv (p.val.2.toFun (⟨1, by decide⟩ : Fin 2))
        (rrrred_e2_image_ne_zero p.val.2) := by
  unfold rrrred_joint_to_perm_fn
  rw [dif_pos rfl]

/-- The forward map is injective. -/
private theorem rrrred_joint_to_perm_fn_inj (p : RRRRedJointPair) :
    Function.Injective (rrrred_joint_to_perm_fn p) := by
  intro k₁ k₂ heq
  -- Apply fin4_skip0 to both sides; both are fin4_skip0_inv of something.
  -- We get e₁.toFun ... = e₁.toFun ... or e₁ = e₂ or e₂ = e₂ depending on k₁, k₂ vs 3.
  have h_dist := rrrred_four_distinct p
  obtain ⟨h_e1_dist, h_e2_ne_e1⟩ := h_dist
  by_cases hk1 : k₁.val = 3
  · by_cases hk2 : k₂.val = 3
    · -- both = 3.
      have hk1' : k₁ = (⟨3, by decide⟩ : Fin 4) := Fin.ext hk1
      have hk2' : k₂ = (⟨3, by decide⟩ : Fin 4) := Fin.ext hk2
      rw [hk1', hk2']
    · -- k₁ = 3, k₂ ≠ 3: e₂'s leaf = e₁'s leaf at fin3_skip0 (k₂_as_fin3) ⇒ contradiction.
      exfalso
      rw [rrrred_joint_to_perm_fn_lt3 p k₂ hk2] at heq
      have hk1' : k₁ = (⟨3, by decide⟩ : Fin 4) := Fin.ext hk1
      rw [hk1', rrrred_joint_to_perm_fn_3] at heq
      have h_skip := congr_arg fin4_skip0 heq
      rw [fin4_skip0_apply_inv, fin4_skip0_apply_inv] at h_skip
      -- h_skip : e₂.toFun ⟨1⟩ = e₁.toFun (fin3_skip0 ...)
      have hk_lt : k₂.val < 3 := by have := k₂.isLt; omega
      have h_fin4_skip_ne : (fin3_skip0 (⟨k₂.val, hk_lt⟩ : Fin 3)).val ≠ 0 := by
        change k₂.val + 1 ≠ 0; omega
      exact h_e2_ne_e1 (fin3_skip0 ⟨k₂.val, hk_lt⟩) h_fin4_skip_ne h_skip
  · by_cases hk2 : k₂.val = 3
    · -- k₂ = 3, k₁ ≠ 3: symmetric.
      exfalso
      rw [rrrred_joint_to_perm_fn_lt3 p k₁ hk1] at heq
      have hk2' : k₂ = (⟨3, by decide⟩ : Fin 4) := Fin.ext hk2
      rw [hk2', rrrred_joint_to_perm_fn_3] at heq
      have h_skip := congr_arg fin4_skip0 heq
      rw [fin4_skip0_apply_inv, fin4_skip0_apply_inv] at h_skip
      have hk_lt : k₁.val < 3 := by have := k₁.isLt; omega
      have h_fin4_skip_ne : (fin3_skip0 (⟨k₁.val, hk_lt⟩ : Fin 3)).val ≠ 0 := by
        change k₁.val + 1 ≠ 0; omega
      exact h_e2_ne_e1 (fin3_skip0 ⟨k₁.val, hk_lt⟩) h_fin4_skip_ne h_skip.symm
    · -- both ≠ 3: e₁'s leaf at fin3_skip0(k₁_as_fin3) = e₁'s leaf at fin3_skip0(k₂_as_fin3).
      rw [rrrred_joint_to_perm_fn_lt3 p k₁ hk1, rrrred_joint_to_perm_fn_lt3 p k₂ hk2] at heq
      have h_skip := congr_arg fin4_skip0 heq
      rw [fin4_skip0_apply_inv, fin4_skip0_apply_inv] at h_skip
      -- h_skip : e₁.toFun (fin3_skip0 ...) = e₁.toFun (fin3_skip0 ...)
      have hk1_lt : k₁.val < 3 := by have := k₁.isLt; omega
      have hk2_lt : k₂.val < 3 := by have := k₂.isLt; omega
      have h_e1_inj : fin3_skip0 (⟨k₁.val, hk1_lt⟩ : Fin 3) =
          fin3_skip0 (⟨k₂.val, hk2_lt⟩ : Fin 3) := p.val.1.injective h_skip
      have h_inv : (⟨k₁.val, hk1_lt⟩ : Fin 3) = ⟨k₂.val, hk2_lt⟩ :=
        fin3_skip0_inj h_e1_inj
      have hv : k₁.val = k₂.val := by
        have := congr_arg (Fin.val : Fin 3 → ℕ) h_inv
        exact this
      exact Fin.ext hv

/-- The forward map: joint pair ↦ Perm (Fin 4). -/
private noncomputable def rrrred_joint_to_perm (p : RRRRedJointPair) :
    Equiv.Perm (Fin 4) :=
  Equiv.ofBijective (rrrred_joint_to_perm_fn p)
    ⟨rrrred_joint_to_perm_fn_inj p,
     Finite.injective_iff_surjective.mp (rrrred_joint_to_perm_fn_inj p)⟩

/-- The underlying function of `rrrred_joint_to_perm p` is `rrrred_joint_to_perm_fn p`. -/
private theorem rrrred_joint_to_perm_apply (p : RRRRedJointPair) (k : Fin 4) :
    rrrred_joint_to_perm p k = rrrred_joint_to_perm_fn p k := rfl

/-! #### The inverse map: Perm (Fin 4) → joint pair. -/

/-- Build the joint-pair witness from a permutation `π : Perm (Fin 4)`. -/
private noncomputable def rrrred_pair_witness (π : Equiv.Perm (Fin 4)) :
    RRRRedJointPair := by
  -- Distinctness from π's bijectivity.
  have hπ_dist : ∀ i j : Fin 4, i ≠ j → π i ≠ π j := fun i j hij heq =>
    hij (π.injective heq)
  have hab : π (⟨0, by decide⟩ : Fin 4) ≠ π (⟨1, by decide⟩ : Fin 4) :=
    hπ_dist _ _ (by decide)
  have hac : π (⟨0, by decide⟩ : Fin 4) ≠ π (⟨2, by decide⟩ : Fin 4) :=
    hπ_dist _ _ (by decide)
  have hbc : π (⟨1, by decide⟩ : Fin 4) ≠ π (⟨2, by decide⟩ : Fin 4) :=
    hπ_dist _ _ (by decide)
  refine ⟨⟨vbExt3_RRR_e0_to_vbExt4_RRRR_e0_canon
            (π (⟨0, by decide⟩ : Fin 4))
            (π (⟨1, by decide⟩ : Fin 4))
            (π (⟨2, by decide⟩ : Fin 4))
            hab hac hbc,
          vbExtRed_to_vbExt4_RRRR_e0_canon (π (⟨3, by decide⟩ : Fin 4))⟩, ?_, ?_⟩
  · -- Overlap.
    intro i
    -- σ-image of vbExt4_RRRR_e0 is {⟨0⟩}.
    have hsigma : ∀ v : Fin 5,
        v ∈ Set.range vbExt4_RRRR_e0.embedding ↔ v = (⟨0, by decide⟩ : Fin 5) := by
      intro v
      constructor
      · rintro ⟨_, hj⟩
        show v = (⟨0, by decide⟩ : Fin 5)
        rw [← hj]; rfl
      · intro hv
        exact ⟨⟨0, Nat.zero_lt_one⟩,
          by change (⟨0, by decide⟩ : Fin 5) = v; rw [hv]⟩
    rw [hsigma]
    constructor
    · rintro ⟨⟨j₁, hj₁⟩, ⟨j₂, hj₂⟩⟩
      change rrr_to_5 _ _ _ j₁ = i at hj₁
      change red_leaf_to_5 _ j₂ = i at hj₂
      rcases fin4_val_cases j₁ with h0 | h1 | h2 | h3
      · -- j₁ = 0: rrr_to_5 _ _ _ 0 = ⟨0⟩, so i = ⟨0⟩.
        have hj1' : j₁ = (⟨0, by decide⟩ : Fin 4) := Fin.ext h0
        rw [hj1', rrr_to_5_zero] at hj₁
        exact hj₁.symm
      · -- j₁ = 1: rrr_to_5 _ _ _ 1 = fin4_skip0 (π 0). j₂ ∈ {0, 1}.
        have hj1' : j₁ = (⟨1, by decide⟩ : Fin 4) := Fin.ext h1
        rw [hj1', rrr_to_5_one] at hj₁
        rcases fin2_eq_zero_or_one j₂ with hj₂0 | hj₂1
        · have hj2' : j₂ = (⟨0, by decide⟩ : Fin 2) := Fin.ext hj₂0
          rw [hj2', red_leaf_to_5_zero] at hj₂
          rw [← hj₁] at hj₂
          exact absurd hj₂.symm (fin4_skip0_ne_zero _)
        · have hj2' : j₂ = (⟨1, by decide⟩ : Fin 2) := Fin.ext hj₂1
          rw [hj2', red_leaf_to_5_one] at hj₂
          rw [← hj₁] at hj₂
          exfalso
          have heq : π (⟨0, by decide⟩ : Fin 4) = π (⟨3, by decide⟩ : Fin 4) :=
            fin4_skip0_inj hj₂.symm
          exact (hπ_dist _ _ (by decide)) heq
      · -- j₁ = 2.
        have hj1' : j₁ = (⟨2, by decide⟩ : Fin 4) := Fin.ext h2
        rw [hj1', rrr_to_5_two] at hj₁
        rcases fin2_eq_zero_or_one j₂ with hj₂0 | hj₂1
        · have hj2' : j₂ = (⟨0, by decide⟩ : Fin 2) := Fin.ext hj₂0
          rw [hj2', red_leaf_to_5_zero] at hj₂
          rw [← hj₁] at hj₂
          exact absurd hj₂.symm (fin4_skip0_ne_zero _)
        · have hj2' : j₂ = (⟨1, by decide⟩ : Fin 2) := Fin.ext hj₂1
          rw [hj2', red_leaf_to_5_one] at hj₂
          rw [← hj₁] at hj₂
          exfalso
          have heq : π (⟨1, by decide⟩ : Fin 4) = π (⟨3, by decide⟩ : Fin 4) :=
            fin4_skip0_inj hj₂.symm
          exact (hπ_dist _ _ (by decide)) heq
      · -- j₁ = 3.
        have hj1' : j₁ = (⟨3, by decide⟩ : Fin 4) := Fin.ext h3
        rw [hj1', rrr_to_5_three] at hj₁
        rcases fin2_eq_zero_or_one j₂ with hj₂0 | hj₂1
        · have hj2' : j₂ = (⟨0, by decide⟩ : Fin 2) := Fin.ext hj₂0
          rw [hj2', red_leaf_to_5_zero] at hj₂
          rw [← hj₁] at hj₂
          exact absurd hj₂.symm (fin4_skip0_ne_zero _)
        · have hj2' : j₂ = (⟨1, by decide⟩ : Fin 2) := Fin.ext hj₂1
          rw [hj2', red_leaf_to_5_one] at hj₂
          rw [← hj₁] at hj₂
          exfalso
          have heq : π (⟨2, by decide⟩ : Fin 4) = π (⟨3, by decide⟩ : Fin 4) :=
            fin4_skip0_inj hj₂.symm
          exact (hπ_dist _ _ (by decide)) heq
    · intro hi
      refine ⟨⟨(⟨0, by decide⟩ : Fin 4), ?_⟩, ⟨(⟨0, by decide⟩ : Fin 2), ?_⟩⟩
      · change rrr_to_5
          (π (⟨0, by decide⟩ : Fin 4))
          (π (⟨1, by decide⟩ : Fin 4))
          (π (⟨2, by decide⟩ : Fin 4))
          (⟨0, by decide⟩ : Fin 4) = i
        rw [rrr_to_5_zero]; exact hi.symm
      · change red_leaf_to_5
          (π (⟨3, by decide⟩ : Fin 4))
          (⟨0, by decide⟩ : Fin 2) = i
        rw [red_leaf_to_5_zero]; exact hi.symm
  · -- Cover.
    -- For each i : Fin 5, either i = ⟨0⟩ (in range e₁ at index 0), or i ≠ 0 means
    -- i = fin4_skip0 (fin4_skip0_inv i hi). Since π is bijective, fin4_skip0_inv i hi
    -- ∈ {π 0, π 1, π 2, π 3}. If it's π 0, π 1, or π 2, in range e₁; if π 3, in range e₂.
    intro i
    -- Helper: a π-leaf-position determines the appropriate range membership.
    -- For each j : Fin 4 (the unique value with π j = target), we case on j to
    -- find the appropriate index in vbExt3_RRR_e0/vbExtRed.
    -- The unifier needs a concrete fin4_skip0 form; we provide it via hi_eq.
    have h_find : ∀ (target : Fin 4),
        i = fin4_skip0 target →
        i ∈ Set.range (vbExt3_RRR_e0_to_vbExt4_RRRR_e0_canon
              (π (⟨0, by decide⟩ : Fin 4))
              (π (⟨1, by decide⟩ : Fin 4))
              (π (⟨2, by decide⟩ : Fin 4))
              hab hac hbc).toFun ∨
        i ∈ Set.range (vbExtRed_to_vbExt4_RRRR_e0_canon
              (π (⟨3, by decide⟩ : Fin 4))).toFun := by
      intro target hi_eq
      let j : Fin 4 := π.symm target
      have hπj : π j = target := π.apply_symm_apply _
      rcases fin4_val_cases j with hj | hj | hj | hj
      · left
        refine ⟨(⟨1, by decide⟩ : Fin 4), ?_⟩
        change rrr_to_5
          (π (⟨0, by decide⟩ : Fin 4))
          (π (⟨1, by decide⟩ : Fin 4))
          (π (⟨2, by decide⟩ : Fin 4))
          (⟨1, by decide⟩ : Fin 4) = i
        rw [rrr_to_5_one]
        have hj' : j = (⟨0, by decide⟩ : Fin 4) := Fin.ext hj
        rw [hj'] at hπj
        rw [← hπj] at hi_eq
        exact hi_eq.symm
      · left
        refine ⟨(⟨2, by decide⟩ : Fin 4), ?_⟩
        change rrr_to_5
          (π (⟨0, by decide⟩ : Fin 4))
          (π (⟨1, by decide⟩ : Fin 4))
          (π (⟨2, by decide⟩ : Fin 4))
          (⟨2, by decide⟩ : Fin 4) = i
        rw [rrr_to_5_two]
        have hj' : j = (⟨1, by decide⟩ : Fin 4) := Fin.ext hj
        rw [hj'] at hπj
        rw [← hπj] at hi_eq
        exact hi_eq.symm
      · left
        refine ⟨(⟨3, by decide⟩ : Fin 4), ?_⟩
        change rrr_to_5
          (π (⟨0, by decide⟩ : Fin 4))
          (π (⟨1, by decide⟩ : Fin 4))
          (π (⟨2, by decide⟩ : Fin 4))
          (⟨3, by decide⟩ : Fin 4) = i
        rw [rrr_to_5_three]
        have hj' : j = (⟨2, by decide⟩ : Fin 4) := Fin.ext hj
        rw [hj'] at hπj
        rw [← hπj] at hi_eq
        exact hi_eq.symm
      · right
        refine ⟨(⟨1, by decide⟩ : Fin 2), ?_⟩
        change red_leaf_to_5
          (π (⟨3, by decide⟩ : Fin 4))
          (⟨1, by decide⟩ : Fin 2) = i
        rw [red_leaf_to_5_one]
        have hj' : j = (⟨3, by decide⟩ : Fin 4) := Fin.ext hj
        rw [hj'] at hπj
        rw [← hπj] at hi_eq
        exact hi_eq.symm
    rcases fin5_val_cases i with hi0 | hi1 | hi2 | hi3 | hi4
    · left
      refine ⟨(⟨0, by decide⟩ : Fin 4), ?_⟩
      change rrr_to_5
        (π (⟨0, by decide⟩ : Fin 4))
        (π (⟨1, by decide⟩ : Fin 4))
        (π (⟨2, by decide⟩ : Fin 4))
        (⟨0, by decide⟩ : Fin 4) = i
      rw [rrr_to_5_zero]; exact (Fin.ext hi0).symm
    · exact h_find (⟨0, by decide⟩ : Fin 4) (by rw [fin4_skip0_zero]; exact Fin.ext hi1)
    · exact h_find (⟨1, by decide⟩ : Fin 4) (by rw [fin4_skip0_one]; exact Fin.ext hi2)
    · exact h_find (⟨2, by decide⟩ : Fin 4) (by rw [fin4_skip0_two]; exact Fin.ext hi3)
    · exact h_find (⟨3, by decide⟩ : Fin 4) (by rw [fin4_skip0_three]; exact Fin.ext hi4)

/-! #### The bijection and joint count theorem. -/

set_option maxHeartbeats 4000000 in
/-- **Joint count theorem**: there are exactly 24 joint pairs
    `(e₁ : vbExt3_RRR_e0 → vbExt4_RRRR_e0, e₂ : vbExtRed → vbExt4_RRRR_e0)`. -/
theorem genJointCount_vbExt3_RRR_e0_vbExtRed_vbExt4_RRRR_e0 :
    genJointCount CG2 vertexBlackType vbExt3_RRR_e0 vbExtRed vbExt4_RRRR_e0 = 24 := by
  classical
  unfold genJointCount
  -- Equiv to Equiv.Perm (Fin 4), which has cardinality 4! = 24.
  rw [show (24 : ℕ) = Fintype.card (Equiv.Perm (Fin 4)) by
    rw [Fintype.card_perm]; decide]
  apply Fintype.card_congr
  refine {
    toFun := rrrred_joint_to_perm
    invFun := rrrred_pair_witness
    left_inv := ?_
    right_inv := ?_ }
  · -- left_inv: rrrred_pair_witness (rrrred_joint_to_perm p) = p.
    intro p
    apply Subtype.ext
    obtain ⟨⟨e₁, e₂⟩, hover, hcover⟩ := p
    -- Derive π from p.
    set π := rrrred_joint_to_perm
      ⟨(e₁, e₂), hover, hcover⟩ with hπ_def
    -- Show e₁ = canon (π 0) (π 1) (π 2), e₂ = canon (π 3).
    -- For each i ∈ {1, 2, 3} of Fin 4, e₁.toFun i = fin4_skip0 (π (i-1)).
    have h_e1_leaf1 : e₁.toFun (⟨1, by decide⟩ : Fin 4) =
        fin4_skip0 (π (⟨0, by decide⟩ : Fin 4)) := by
      have hk : (⟨0, by decide⟩ : Fin 4).val ≠ 3 := by decide
      rw [show (π (⟨0, by decide⟩ : Fin 4)) =
        rrrred_joint_to_perm_fn ⟨(e₁, e₂), hover, hcover⟩ (⟨0, by decide⟩ : Fin 4) from rfl]
      rw [rrrred_joint_to_perm_fn_lt3 ⟨(e₁, e₂), hover, hcover⟩ (⟨0, by decide⟩ : Fin 4) hk]
      rw [fin4_skip0_apply_inv]
      rfl
    have h_e1_leaf2 : e₁.toFun (⟨2, by decide⟩ : Fin 4) =
        fin4_skip0 (π (⟨1, by decide⟩ : Fin 4)) := by
      have hk : (⟨1, by decide⟩ : Fin 4).val ≠ 3 := by decide
      rw [show (π (⟨1, by decide⟩ : Fin 4)) =
        rrrred_joint_to_perm_fn ⟨(e₁, e₂), hover, hcover⟩ (⟨1, by decide⟩ : Fin 4) from rfl]
      rw [rrrred_joint_to_perm_fn_lt3 ⟨(e₁, e₂), hover, hcover⟩ (⟨1, by decide⟩ : Fin 4) hk]
      rw [fin4_skip0_apply_inv]
      rfl
    have h_e1_leaf3 : e₁.toFun (⟨3, by decide⟩ : Fin 4) =
        fin4_skip0 (π (⟨2, by decide⟩ : Fin 4)) := by
      have hk : (⟨2, by decide⟩ : Fin 4).val ≠ 3 := by decide
      rw [show (π (⟨2, by decide⟩ : Fin 4)) =
        rrrred_joint_to_perm_fn ⟨(e₁, e₂), hover, hcover⟩ (⟨2, by decide⟩ : Fin 4) from rfl]
      rw [rrrred_joint_to_perm_fn_lt3 ⟨(e₁, e₂), hover, hcover⟩ (⟨2, by decide⟩ : Fin 4) hk]
      rw [fin4_skip0_apply_inv]
      rfl
    have h_e2_leaf : e₂.toFun (⟨1, by decide⟩ : Fin 2) =
        fin4_skip0 (π (⟨3, by decide⟩ : Fin 4)) := by
      rw [show (π (⟨3, by decide⟩ : Fin 4)) =
        rrrred_joint_to_perm_fn ⟨(e₁, e₂), hover, hcover⟩ (⟨3, by decide⟩ : Fin 4) from rfl]
      rw [rrrred_joint_to_perm_fn_3]
      rw [fin4_skip0_apply_inv]
    -- Distinctness from π's bijectivity, used for canon construction.
    have hπ_dist : ∀ i j : Fin 4, i ≠ j → π i ≠ π j := fun i j hij heq =>
      hij (π.injective heq)
    have hab : π (⟨0, by decide⟩ : Fin 4) ≠ π (⟨1, by decide⟩ : Fin 4) :=
      hπ_dist _ _ (by decide)
    have hac : π (⟨0, by decide⟩ : Fin 4) ≠ π (⟨2, by decide⟩ : Fin 4) :=
      hπ_dist _ _ (by decide)
    have hbc : π (⟨1, by decide⟩ : Fin 4) ≠ π (⟨2, by decide⟩ : Fin 4) :=
      hπ_dist _ _ (by decide)
    -- Now show e₁ = canon and e₂ = canon.
    have h_e1_eq : e₁ =
        vbExt3_RRR_e0_to_vbExt4_RRRR_e0_canon
          (π (⟨0, by decide⟩ : Fin 4))
          (π (⟨1, by decide⟩ : Fin 4))
          (π (⟨2, by decide⟩ : Fin 4))
          hab hac hbc := by
      apply vbExt3_RRR_e0_to_vbExt4_RRRR_e0_ext
      · change e₁.toFun (⟨1, by decide⟩ : Fin 4) =
          rrr_to_5
            (π (⟨0, by decide⟩ : Fin 4))
            (π (⟨1, by decide⟩ : Fin 4))
            (π (⟨2, by decide⟩ : Fin 4))
            (⟨1, by decide⟩ : Fin 4)
        rw [rrr_to_5_one]; exact h_e1_leaf1
      · change e₁.toFun (⟨2, by decide⟩ : Fin 4) =
          rrr_to_5
            (π (⟨0, by decide⟩ : Fin 4))
            (π (⟨1, by decide⟩ : Fin 4))
            (π (⟨2, by decide⟩ : Fin 4))
            (⟨2, by decide⟩ : Fin 4)
        rw [rrr_to_5_two]; exact h_e1_leaf2
      · change e₁.toFun (⟨3, by decide⟩ : Fin 4) =
          rrr_to_5
            (π (⟨0, by decide⟩ : Fin 4))
            (π (⟨1, by decide⟩ : Fin 4))
            (π (⟨2, by decide⟩ : Fin 4))
            (⟨3, by decide⟩ : Fin 4)
        rw [rrr_to_5_three]; exact h_e1_leaf3
    have h_e2_eq : e₂ = vbExtRed_to_vbExt4_RRRR_e0_canon
        (π (⟨3, by decide⟩ : Fin 4)) := by
      apply vbExtRed_to_vbExt4_RRRR_e0_ext
      change e₂.toFun (⟨1, by decide⟩ : Fin 2) =
        red_leaf_to_5
          (π (⟨3, by decide⟩ : Fin 4))
          (⟨1, by decide⟩ : Fin 2)
      rw [red_leaf_to_5_one]; exact h_e2_leaf
    -- Both components of `(rrrred_pair_witness π).val` are the canon
    -- embeddings, by defeq.
    change (rrrred_pair_witness π).val = (e₁, e₂)
    have h_def : (rrrred_pair_witness π).val =
        (vbExt3_RRR_e0_to_vbExt4_RRRR_e0_canon
            (π (⟨0, by decide⟩ : Fin 4))
            (π (⟨1, by decide⟩ : Fin 4))
            (π (⟨2, by decide⟩ : Fin 4))
            hab hac hbc,
         vbExtRed_to_vbExt4_RRRR_e0_canon
            (π (⟨3, by decide⟩ : Fin 4))) := rfl
    rw [h_def, ← h_e1_eq, ← h_e2_eq]
  · -- right_inv: rrrred_joint_to_perm (rrrred_pair_witness π) = π.
    intro π
    apply Equiv.ext
    intro k
    change rrrred_joint_to_perm_fn (rrrred_pair_witness π) k = π k
    by_cases hk : k.val = 3
    · have hk' : k = (⟨3, by decide⟩ : Fin 4) := Fin.ext hk
      rw [hk', rrrred_joint_to_perm_fn_3]
      apply Fin.ext
      change ((rrrred_pair_witness π).val.2.toFun (⟨1, by decide⟩ : Fin 2)).val - 1 =
        (π (⟨3, by decide⟩ : Fin 4)).val
      have h_e2_app : (rrrred_pair_witness π).val.2.toFun (⟨1, by decide⟩ : Fin 2) =
          fin4_skip0 (π (⟨3, by decide⟩ : Fin 4)) := by
        change red_leaf_to_5
          (π (⟨3, by decide⟩ : Fin 4))
          (⟨1, by decide⟩ : Fin 2) = _
        rw [red_leaf_to_5_one]
      rw [h_e2_app]
      change (π (⟨3, by decide⟩ : Fin 4)).val + 1 - 1 = (π (⟨3, by decide⟩ : Fin 4)).val
      omega
    · rw [rrrred_joint_to_perm_fn_lt3 (rrrred_pair_witness π) k hk]
      apply Fin.ext
      have hk_lt : k.val < 3 := by have := k.isLt; omega
      change ((rrrred_pair_witness π).val.1.toFun
            (fin3_skip0 ⟨k.val, hk_lt⟩)).val - 1 = (π k).val
      -- Compute (rrrred_pair_witness π).val.1.toFun (fin3_skip0 (k_as_fin3))
      -- = rrr_to_5 (π 0) (π 1) (π 2) (fin3_skip0 (k_as_fin3))
      rcases fin4_val_cases k with hk0 | hk1 | hk2 | hk3
      · -- k.val = 0: fin3_skip0 ⟨0⟩ = ⟨1⟩, rrr_to_5 _ _ _ ⟨1⟩ = fin4_skip0 (π ⟨0⟩).
        have hk' : k = (⟨0, by decide⟩ : Fin 4) := Fin.ext hk0
        have h3 : (⟨k.val, hk_lt⟩ : Fin 3) = (⟨0, by decide⟩ : Fin 3) := Fin.ext hk0
        rw [h3, fin3_skip0_zero]
        change (rrr_to_5
          (π (⟨0, by decide⟩ : Fin 4))
          (π (⟨1, by decide⟩ : Fin 4))
          (π (⟨2, by decide⟩ : Fin 4))
          (⟨1, by decide⟩ : Fin 4)).val - 1 = (π k).val
        rw [rrr_to_5_one, hk']
        change (π (⟨0, by decide⟩ : Fin 4)).val + 1 - 1 = (π (⟨0, by decide⟩ : Fin 4)).val
        omega
      · have hk' : k = (⟨1, by decide⟩ : Fin 4) := Fin.ext hk1
        have h3 : (⟨k.val, hk_lt⟩ : Fin 3) = (⟨1, by decide⟩ : Fin 3) := Fin.ext hk1
        rw [h3, fin3_skip0_one]
        change (rrr_to_5
          (π (⟨0, by decide⟩ : Fin 4))
          (π (⟨1, by decide⟩ : Fin 4))
          (π (⟨2, by decide⟩ : Fin 4))
          (⟨2, by decide⟩ : Fin 4)).val - 1 = (π k).val
        rw [rrr_to_5_two, hk']
        change (π (⟨1, by decide⟩ : Fin 4)).val + 1 - 1 = (π (⟨1, by decide⟩ : Fin 4)).val
        omega
      · have hk' : k = (⟨2, by decide⟩ : Fin 4) := Fin.ext hk2
        have h3 : (⟨k.val, hk_lt⟩ : Fin 3) = (⟨2, by decide⟩ : Fin 3) := Fin.ext hk2
        rw [h3, fin3_skip0_two]
        change (rrr_to_5
          (π (⟨0, by decide⟩ : Fin 4))
          (π (⟨1, by decide⟩ : Fin 4))
          (π (⟨2, by decide⟩ : Fin 4))
          (⟨3, by decide⟩ : Fin 4)).val - 1 = (π k).val
        rw [rrr_to_5_three, hk']
        change (π (⟨2, by decide⟩ : Fin 4)).val + 1 - 1 = (π (⟨2, by decide⟩ : Fin 4)).val
        omega
      · exact absurd hk3 hk

/-! ### Zero induced counts for size-4 → size-5 forbidden embeddings

For each of the 19 forbidden size-4 σ-flags `vbExt3_X` (i.e. all `vbExt3_*`
except `vbExt3_RRR_e0`), we show

```
genInducedCount CG2 vertexBlackType vbExt3_X vbExt4_RRRR_e0 = 0.
```

`vbExt4_RRRR_e0` is the K_{1,4} σ-flag: σ at position 0 (black), 4 red leaves
at positions 1, 2, 3, 4, with only σ-leaf edges. Hence:

* If `vbExt3_X` has a **black leaf** (BBB / RRB / RBB families, 16 cases),
  the induced count is 0 because any embedding pulls back the black leaf to a
  black vertex of `vbExt4_RRRR_e0`, but the only black vertex is σ at position
  0 which is already pinned by σ-compatibility.
* If `vbExt3_X` has a **leaf-leaf edge** (RRR_e1 / RRR_e2 / RRR_e3, 3 cases),
  the induced count is 0 because every edge in `vbExt4_RRRR_e0` has σ as an
  endpoint, but neither leaf can map to σ (injectivity vs σ-pinning).
-/

/-- Helper: in any adjacency of `vbExt4_RRRR_e0`, one endpoint has `val = 0`. -/
private theorem vbExt4_RRRR_e0_adj_zero_or_zero {u v : Fin 5}
    (h : vbExt4_RRRR_e0.str.1.Adj u v) : u.val = 0 ∨ v.val = 0 := by
  rw [vbExt4_RRRR_e0_adj_iff] at h
  rcases h with ⟨h0, _⟩ | ⟨_, h0⟩ | ⟨h0, _⟩ | ⟨_, h0⟩ |
                ⟨h0, _⟩ | ⟨_, h0⟩ | ⟨h0, _⟩ | ⟨_, h0⟩
  · exact Or.inl h0
  · exact Or.inr h0
  · exact Or.inl h0
  · exact Or.inr h0
  · exact Or.inl h0
  · exact Or.inr h0
  · exact Or.inl h0
  · exact Or.inr h0

/-- Helper: every non-zero index of `vbExt4_RRRR_e0` is red (col = 0). -/
private theorem vbExt4_RRRR_e0_col_ne_zero {v : Fin 5} (h : v.val ≠ 0) :
    vbExt4_RRRR_e0.str.2 v = 0 := by
  change (if v.val = 0 then (1 : Fin 2) else 0) = 0
  rw [if_neg h]

/-! #### RRR family: leaf-leaf-edge contradictions

For RRR_e1, RRR_e2, RRR_e3 we pick a leaf-leaf edge in F, pull back the
adjacency to G = vbExt4_RRRR_e0, and derive a contradiction since every edge
in vbExt4_RRRR_e0 has σ (= vertex 0) as an endpoint, but σ-pinning + injectivity
forbid both leaves from mapping to ⟨0⟩. -/

/-- Generic helper for size-4 σ-flags with `F.size = 4` definitionally: from a
    leaf-leaf edge `(i, j)` in `F` (with `i, j ≠ 0`, `i ≠ j`) and an induced
    embedding `f : F → vbExt4_RRRR_e0`, derive False. The flag `F` here has
    `F.size` reducing to 4 (no transport needed). -/
private theorem vbExt4_RRRR_e0_no_leaf_leaf_edge_aux
    (F : GenFlag CG2 vertexBlackType) (hF : F.size = 4)
    (h_F_emb : ∀ k : Fin 1, F.embedding k = (⟨0, by omega⟩ : Fin F.size))
    (i j : Fin 4) (hi_ne : i.val ≠ 0) (hj_ne : j.val ≠ 0)
    (h_F_adj : F.str.1.Adj (⟨i.val, by omega⟩ : Fin F.size)
                           (⟨j.val, by omega⟩ : Fin F.size))
    (f : Fin F.size → Fin vbExt4_RRRR_e0.size)
    (finj : Function.Injective f)
    (find : CG2.comap f vbExt4_RRRR_e0.str = F.str)
    (fcompat : ∀ k : Fin 1, f (F.embedding k) = vbExt4_RRRR_e0.embedding k) :
    False := by
  -- σ-pinning: f ⟨0⟩ = ⟨0⟩.
  have h_f0 : f (⟨0, by omega⟩ : Fin F.size) =
      (⟨0, by omega⟩ : Fin 5) := by
    have h := fcompat (⟨0, Nat.zero_lt_one⟩ : Fin 1)
    rw [h_F_emb] at h
    exact h
  -- Pull back leaf-leaf edge.
  have h_G_adj : vbExt4_RRRR_e0.str.1.Adj
      (f (⟨i.val, by omega⟩ : Fin F.size))
      (f (⟨j.val, by omega⟩ : Fin F.size)) :=
    cg2_find_adj f find h_F_adj
  rcases vbExt4_RRRR_e0_adj_zero_or_zero h_G_adj with h0 | h0
  · have h_eq : f (⟨i.val, by omega⟩ : Fin F.size) =
        f (⟨0, by omega⟩ : Fin F.size) := by
      rw [h_f0]; exact Fin.ext h0
    have h_inj := finj h_eq
    have h_val : i.val = 0 := congr_arg Fin.val h_inj
    exact hi_ne h_val
  · have h_eq : f (⟨j.val, by omega⟩ : Fin F.size) =
        f (⟨0, by omega⟩ : Fin F.size) := by
      rw [h_f0]; exact Fin.ext h0
    have h_inj := finj h_eq
    have h_val : j.val = 0 := congr_arg Fin.val h_inj
    exact hj_ne h_val

/-- Generic helper for black-leaf forbidden flags: from a black leaf at position
    `i ≠ 0` in `F` (with `F.size = 4`) and an induced embedding `f`, derive
    False. -/
private theorem vbExt4_RRRR_e0_no_black_leaf_aux
    (F : GenFlag CG2 vertexBlackType) (hF : F.size = 4)
    (h_F_emb : ∀ k : Fin 1, F.embedding k = (⟨0, by omega⟩ : Fin F.size))
    (i : Fin 4) (hi_ne : i.val ≠ 0)
    (h_F_coli : F.str.2 (⟨i.val, by omega⟩ : Fin F.size) = 1)
    (f : Fin F.size → Fin vbExt4_RRRR_e0.size)
    (finj : Function.Injective f)
    (find : CG2.comap f vbExt4_RRRR_e0.str = F.str)
    (fcompat : ∀ k : Fin 1, f (F.embedding k) = vbExt4_RRRR_e0.embedding k) :
    False := by
  have h_f0 : f (⟨0, by omega⟩ : Fin F.size) =
      (⟨0, by omega⟩ : Fin 5) := by
    have h := fcompat (⟨0, Nat.zero_lt_one⟩ : Fin 1)
    rw [h_F_emb] at h
    exact h
  have h_G_coli : vbExt4_RRRR_e0.str.2 (f (⟨i.val, by omega⟩ : Fin F.size)) = 1 := by
    rw [cg2_find_col f find]; exact h_F_coli
  have h_fi_zero : (f (⟨i.val, by omega⟩ : Fin F.size)).val = 0 := by
    by_contra hne
    rw [vbExt4_RRRR_e0_col_ne_zero hne] at h_G_coli
    exact absurd h_G_coli (by decide)
  have h_eq : f (⟨i.val, by omega⟩ : Fin F.size) =
      f (⟨0, by omega⟩ : Fin F.size) := by
    rw [h_f0]; exact Fin.ext h_fi_zero
  have h_inj := finj h_eq
  have h_val : i.val = 0 := congr_arg Fin.val h_inj
  exact hi_ne h_val

