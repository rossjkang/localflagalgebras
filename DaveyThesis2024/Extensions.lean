        rw [Equiv.swap_apply_right]
        rw [show vbExtBlack.str.2 (⟨0, Nat.zero_lt_two⟩ : Fin 2) = (1 : Fin 2) from rfl]
        -- F_str.2 ⟨1, _⟩ = 1 from F_isInd (σ-vertex is at position 1).
        have hemb_eq : F_emb ⟨0, Nat.zero_lt_one⟩ = ⟨1, Nat.one_lt_two⟩ :=
