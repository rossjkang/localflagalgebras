          left
          refine ⟨(⟨2, by decide⟩ : Fin 3), ?_⟩
          change rr_indep_to a b (⟨2, by decide⟩ : Fin 3) = i
          rw [rr_indep_to_two]
          have hb' : b = (⟨1, by decide⟩ : Fin 3) := Fin.ext hb1
          rw [hb', fin3_skip0_one]
          exact (Fin.ext hi).symm
        · exfalso
          have ha' : a = (⟨2, by decide⟩ : Fin 3) := Fin.ext ha2
          have hb' : b = (⟨2, by decide⟩ : Fin 3) := Fin.ext hb2
          exact hab (ha'.trans hb'.symm)
    · -- i = ⟨3⟩, similar.
      rcases fin3_val_cases a with ha0 | ha1 | ha2
      · rcases fin3_val_cases b with hb0 | hb1 | hb2
        · exfalso
          have ha' : a = (⟨0, by decide⟩ : Fin 3) := Fin.ext ha0
          have hb' : b = (⟨0, by decide⟩ : Fin 3) := Fin.ext hb0
          exact hab (ha'.trans hb'.symm)
        · -- a = 0, b = 1, c = 2.
          right
          refine ⟨(⟨1, by decide⟩ : Fin 2), ?_⟩
          change red_leaf_to c (⟨1, by decide⟩ : Fin 2) = i
          rw [red_leaf_to_one]
          have hc : c = (⟨2, by decide⟩ : Fin 3) := by
            change fin3_third a b = (⟨2, by decide⟩ : Fin 3)
            apply Fin.ext
            unfold fin3_third
            simp only
            rw [ha0, hb1]
            rfl
          rw [hc, fin3_skip0_two]
          exact (Fin.ext hi).symm
        · -- a = 0, b = 2, fin3_skip0 b = ⟨3⟩ ∈ range e₁.
          left
          refine ⟨(⟨2, by decide⟩ : Fin 3), ?_⟩
          change rr_indep_to a b (⟨2, by decide⟩ : Fin 3) = i
          rw [rr_indep_to_two]
          have hb' : b = (⟨2, by decide⟩ : Fin 3) := Fin.ext hb2
