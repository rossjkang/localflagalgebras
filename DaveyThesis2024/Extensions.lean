    · have hv_eq : v = (⟨1, by decide⟩ : Fin 4) := Fin.ext hv
      rw [hv_eq, hp1]
      have hG := size4_sigma_col_eq_one G_str G_emb G_isInd
      have hT := size4_sigma_col_eq_one T_str T_emb T_isInd
      have hG_emb_eq : G_emb (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) =
          (⟨1, by decide⟩ : Fin 4) := Fin.ext h_emb_G
      have hT_emb_eq : T_emb (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) =
          (⟨0, by decide⟩ : Fin 4) := Fin.ext h_emb_T
      rw [hG_emb_eq] at hG; rw [hT_emb_eq] at hT
