/-! ### Universal σ-position-0 helpers for size-4 cases

`size4_sigma0_id_iso` is the workhorse for any case where the leaf permutation
is the identity (G's leaves are already aligned with T's canonical layout).
Takes 6 unordered-pair adjacency biconditionals (3 σ-leaf, 3 leaf-leaf) and 3
leaf colour equalities. -/

/-- Universal σ-position-0 iso for size-4 σ-flags via identity leaf permutation.
    All u-v adjacencies and v colours specified pairwise. -/
private theorem size4_sigma0_id_iso
    (G_str T_str : CG2.Str 4)
    (G_emb T_emb : Fin vertexBlackType.size ↪ Fin 4)
    (G_isInd : CG2.comap G_emb G_str = vertexBlackType.str)
    (T_isInd : CG2.comap T_emb T_str = vertexBlackType.str)
    (G_hsize T_hsize : vertexBlackType.size ≤ 4)
    (h_emb_G : (G_emb ⟨0, Nat.zero_lt_one⟩).val = 0)
    (h_emb_T : (T_emb ⟨0, Nat.zero_lt_one⟩).val = 0)
    (h_adj_01 : G_str.1.Adj ⟨0, by decide⟩ ⟨1, by decide⟩ ↔
                T_str.1.Adj ⟨0, by decide⟩ ⟨1, by decide⟩)
    (h_adj_02 : G_str.1.Adj ⟨0, by decide⟩ ⟨2, by decide⟩ ↔
                T_str.1.Adj ⟨0, by decide⟩ ⟨2, by decide⟩)
    (h_adj_03 : G_str.1.Adj ⟨0, by decide⟩ ⟨3, by decide⟩ ↔
                T_str.1.Adj ⟨0, by decide⟩ ⟨3, by decide⟩)
    (h_adj_12 : G_str.1.Adj ⟨1, by decide⟩ ⟨2, by decide⟩ ↔
                T_str.1.Adj ⟨1, by decide⟩ ⟨2, by decide⟩)
    (h_adj_13 : G_str.1.Adj ⟨1, by decide⟩ ⟨3, by decide⟩ ↔
                T_str.1.Adj ⟨1, by decide⟩ ⟨3, by decide⟩)
    (h_adj_23 : G_str.1.Adj ⟨2, by decide⟩ ⟨3, by decide⟩ ↔
                T_str.1.Adj ⟨2, by decide⟩ ⟨3, by decide⟩)
    (h_col_1 : G_str.2 ⟨1, by decide⟩ = T_str.2 ⟨1, by decide⟩)
    (h_col_2 : G_str.2 ⟨2, by decide⟩ = T_str.2 ⟨2, by decide⟩)
    (h_col_3 : G_str.2 ⟨3, by decide⟩ = T_str.2 ⟨3, by decide⟩) :
    GenFlagIso vertexBlackType
      (⟨4, G_str, G_emb, G_isInd, G_hsize⟩ : GenFlag CG2 vertexBlackType)
      (⟨4, T_str, T_emb, T_isInd, T_hsize⟩ : GenFlag CG2 vertexBlackType) := by
  apply size4_sigma0_iso_via_leafperm G_str T_str G_emb T_emb G_isInd T_isInd
    G_hsize T_hsize h_emb_G h_emb_T (Equiv.refl (Fin 4)) rfl
  · intro u v
    change G_str.1.Adj u v ↔ T_str.1.Adj u v
    rcases fin4_val_cases u with hu | hu | hu | hu <;>
      rcases fin4_val_cases v with hv | hv | hv | hv <;>
      first
      | (have hu_eq : u = (⟨0, by decide⟩ : Fin 4) := Fin.ext hu
         have hv_eq : v = (⟨0, by decide⟩ : Fin 4) := Fin.ext hv
         rw [hu_eq, hv_eq]
         constructor <;> intro hadj <;> exact absurd hadj (SimpleGraph.irrefl _))
      | (have hu_eq : u = (⟨1, by decide⟩ : Fin 4) := Fin.ext hu
         have hv_eq : v = (⟨1, by decide⟩ : Fin 4) := Fin.ext hv
         rw [hu_eq, hv_eq]
         constructor <;> intro hadj <;> exact absurd hadj (SimpleGraph.irrefl _))
      | (have hu_eq : u = (⟨2, by decide⟩ : Fin 4) := Fin.ext hu
