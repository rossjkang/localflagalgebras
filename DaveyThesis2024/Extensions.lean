/-! ### Joint count zero-pattern lemmas

For the (extSum)·(extSum) expansion, joint embeddings are constrained by colour
preservation at the leaf vertex. Many joint counts vanish trivially when the
target G has no leaf vertex of the right colour. We prove these zero-counts
via `genInducedCount = 0`, which forces `genJointCount = 0` (no first
embedding exists, so no pair).
-/

/-- No GenInducedEmbedding from vbExtRed to vbExt2_BB_indep: vbExtRed has a
    red leaf at vertex 1 but BB_indep colours are all black. -/
theorem genInducedCount_vbExtRed_vbExt2_BB_indep_eq_zero :
    genInducedCount CG2 vertexBlackType vbExtRed vbExt2_BB_indep = 0 := by
  unfold genInducedCount
  rw [Fintype.card_eq_zero_iff]
  refine ⟨fun ⟨f, _, find, _⟩ => ?_⟩
  -- Colour preservation: (CG2.comap f vbExt2_BB_indep.str).2 ⟨1,_⟩ = vbExtRed.str.2 ⟨1,_⟩
  -- LHS reduces to vbExt2_BB_indep.str.2 (f ⟨1,_⟩) = 1; RHS = 0.
  have h_col : vbExt2_BB_indep.str.2 (f (⟨1, by decide⟩ : Fin 2)) =
      vbExtRed.str.2 (⟨1, by decide⟩ : Fin 2) :=
    congr_arg (fun s : CG2.Str vbExtRed.size => s.2 (⟨1, by decide⟩ : Fin 2)) find
  have h_LHS : vbExt2_BB_indep.str.2 (f (⟨1, by decide⟩ : Fin 2)) = (1 : Fin 2) := rfl
  have h_RHS : vbExtRed.str.2 (⟨1, by decide⟩ : Fin 2) = (0 : Fin 2) := by
    change (if (1 : ℕ) = 0 then (1 : Fin 2) else 0) = 0
    decide
  rw [h_LHS, h_RHS] at h_col
  exact absurd h_col (by decide)

/-- Analogous: no embedding from vbExtRed to vbExt2_BB_edge. -/
theorem genInducedCount_vbExtRed_vbExt2_BB_edge_eq_zero :
    genInducedCount CG2 vertexBlackType vbExtRed vbExt2_BB_edge = 0 := by
  unfold genInducedCount
  rw [Fintype.card_eq_zero_iff]
  refine ⟨fun ⟨f, _, find, _⟩ => ?_⟩
  have h_col : vbExt2_BB_edge.str.2 (f (⟨1, by decide⟩ : Fin 2)) =
      vbExtRed.str.2 (⟨1, by decide⟩ : Fin 2) :=
    congr_arg (fun s : CG2.Str vbExtRed.size => s.2 (⟨1, by decide⟩ : Fin 2)) find
  have h_LHS : vbExt2_BB_edge.str.2 (f (⟨1, by decide⟩ : Fin 2)) = (1 : Fin 2) := rfl
  have h_RHS : vbExtRed.str.2 (⟨1, by decide⟩ : Fin 2) = (0 : Fin 2) := by
    change (if (1 : ℕ) = 0 then (1 : Fin 2) else 0) = 0
    decide
  rw [h_LHS, h_RHS] at h_col
  exact absurd h_col (by decide)

/-- joinedCount factor: no embedding F₁ → G ⟹ no joint pairs. -/
theorem genJointCount_zero_of_genInducedCount_zero {R : RelUniverse} {σ : GenFlagType R}
    {F₁ F₂ G : GenFlag R σ} (h : genInducedCount R σ F₁ G = 0) :
    genJointCount R σ F₁ F₂ G = 0 := by
  unfold genJointCount
  rw [Fintype.card_eq_zero_iff]
  refine ⟨fun ⟨⟨e₁, _⟩, _⟩ => ?_⟩
  -- e₁ : GenInducedEmbedding R σ F₁ G but card = 0
  have h_pos : 0 < genInducedCount R σ F₁ G := by
    unfold genInducedCount
    exact Fintype.card_pos_iff.mpr ⟨e₁⟩
  omega

/-- Symmetric: no embedding F₂ → G ⟹ no joint pairs. -/
theorem genJointCount_zero_of_genInducedCount_zero_right {R : RelUniverse} {σ : GenFlagType R}
    {F₁ F₂ G : GenFlag R σ} (h : genInducedCount R σ F₂ G = 0) :
    genJointCount R σ F₁ F₂ G = 0 := by
  unfold genJointCount
  rw [Fintype.card_eq_zero_iff]
  refine ⟨fun ⟨⟨_, e₂⟩, _⟩ => ?_⟩
  have h_pos : 0 < genInducedCount R σ F₂ G := by
    unfold genInducedCount
    exact Fintype.card_pos_iff.mpr ⟨e₂⟩
  omega

/-- jointCount(vbExtRed, vbExtRed, vbExt2_BB_indep) = 0. -/
theorem genJointCount_vbExtRed_vbExtRed_vbExt2_BB_indep :
    genJointCount CG2 vertexBlackType vbExtRed vbExtRed vbExt2_BB_indep = 0 :=
  genJointCount_zero_of_genInducedCount_zero
    genInducedCount_vbExtRed_vbExt2_BB_indep_eq_zero

