/-- Generic σ-position-2 iso: 3-cycle (2 0 1) case. Maps G-pos 2 ↦ 0, 0 ↦ 1,
    1 ↦ 2. Used when G's σ-vertex is at position 2 with leaves swapped. -/
private theorem size3_sigma2_cycle201_iso
    (G_str T_str : CG2.Str 3)
    (G_emb T_emb : Fin vertexBlackType.size ↪ Fin 3)
    (G_isInd : CG2.comap G_emb G_str = vertexBlackType.str)
    (T_isInd : CG2.comap T_emb T_str = vertexBlackType.str)
    (G_hsize T_hsize : vertexBlackType.size ≤ 3)
    (h_emb_G : (G_emb ⟨0, Nat.zero_lt_one⟩).val = 2)
    (h_emb_T : (T_emb ⟨0, Nat.zero_lt_one⟩).val = 0)
    -- φ : 0 ↦ 1, 1 ↦ 2, 2 ↦ 0.
    (h_adj_01_at_12 : G_str.1.Adj ⟨0, by decide⟩ ⟨1, by decide⟩ ↔
                      T_str.1.Adj ⟨1, by decide⟩ ⟨2, by decide⟩)
    (h_adj_02_at_10 : G_str.1.Adj ⟨0, by decide⟩ ⟨2, by decide⟩ ↔
                      T_str.1.Adj ⟨1, by decide⟩ ⟨0, by decide⟩)
    (h_adj_12_at_20 : G_str.1.Adj ⟨1, by decide⟩ ⟨2, by decide⟩ ↔
                      T_str.1.Adj ⟨2, by decide⟩ ⟨0, by decide⟩)
    (h_col_0_at_1 : G_str.2 ⟨0, by decide⟩ = T_str.2 ⟨1, by decide⟩)
    (h_col_1_at_2 : G_str.2 ⟨1, by decide⟩ = T_str.2 ⟨2, by decide⟩) :
    GenFlagIso vertexBlackType
      (⟨3, G_str, G_emb, G_isInd, G_hsize⟩ : GenFlag CG2 vertexBlackType)
      (⟨3, T_str, T_emb, T_isInd, T_hsize⟩ : GenFlag CG2 vertexBlackType) := by
  classical
  have hT_emb_zero : T_emb (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) =
      (⟨0, (by decide : (0:ℕ) < 3)⟩ : Fin 3) := Fin.ext h_emb_T
  -- φ: 0 ↦ 1, 1 ↦ 2, 2 ↦ 0. Try swap(0, 2) ∘ swap(0, 1):
  -- v=0: swap(0,1) → 1; swap(0,2) → 1. Wait, we need 0↦1.
  -- Actually: swap(0,1) sends 0→1; then swap(0,2) sends 1→1. Result: 0↦1. ✓
  -- v=1: swap(0,1) → 0; swap(0,2) → 2. Result: 1↦2. ✓
  -- v=2: swap(0,1) → 2; swap(0,2) → 0. Result: 2↦0. ✓
  let φ : Fin 3 ≃ Fin 3 := (Equiv.swap (⟨0, by decide⟩ : Fin 3) ⟨1, by decide⟩).trans
                            (Equiv.swap (⟨0, by decide⟩ : Fin 3) ⟨2, by decide⟩)
  apply size3_iso_via_perm G_str T_str G_emb T_emb G_isInd T_isInd G_hsize T_hsize
    hT_emb_zero φ
  · have hG_emb_eq : G_emb (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) =
        (⟨2, by decide⟩ : Fin 3) := Fin.ext h_emb_G
    rw [hG_emb_eq]
    change (Equiv.swap (⟨0, by decide⟩ : Fin 3) ⟨2, by decide⟩)
      ((Equiv.swap (⟨0, by decide⟩ : Fin 3) ⟨1, by decide⟩) ⟨2, by decide⟩) = _
    have h02 : ((⟨0, by decide⟩ : Fin 3) : Fin 3) ≠ (⟨2, by decide⟩ : Fin 3) := by decide
    have h12 : ((⟨1, by decide⟩ : Fin 3) : Fin 3) ≠ (⟨2, by decide⟩ : Fin 3) := by decide
    rw [Equiv.swap_apply_of_ne_of_ne h02.symm h12.symm, Equiv.swap_apply_right]
  · -- h_adj
    intro u v
    have h01 : ((⟨0, by decide⟩ : Fin 3) : Fin 3) ≠ (⟨1, by decide⟩ : Fin 3) := by decide
    have h02 : ((⟨0, by decide⟩ : Fin 3) : Fin 3) ≠ (⟨2, by decide⟩ : Fin 3) := by decide
    have h12 : ((⟨1, by decide⟩ : Fin 3) : Fin 3) ≠ (⟨2, by decide⟩ : Fin 3) := by decide
    have hs0 : φ (⟨0, by decide⟩ : Fin 3) = (⟨1, by decide⟩ : Fin 3) := by
      change (Equiv.swap (⟨0, by decide⟩ : Fin 3) ⟨2, by decide⟩)
        ((Equiv.swap (⟨0, by decide⟩ : Fin 3) ⟨1, by decide⟩) ⟨0, by decide⟩) = _
      rw [Equiv.swap_apply_left, Equiv.swap_apply_of_ne_of_ne h01.symm h12]
    have hs1 : φ (⟨1, by decide⟩ : Fin 3) = (⟨2, by decide⟩ : Fin 3) := by
      change (Equiv.swap (⟨0, by decide⟩ : Fin 3) ⟨2, by decide⟩)
        ((Equiv.swap (⟨0, by decide⟩ : Fin 3) ⟨1, by decide⟩) ⟨1, by decide⟩) = _
      rw [Equiv.swap_apply_right, Equiv.swap_apply_left]
    have hs2 : φ (⟨2, by decide⟩ : Fin 3) = (⟨0, by decide⟩ : Fin 3) := by
      change (Equiv.swap (⟨0, by decide⟩ : Fin 3) ⟨2, by decide⟩)
        ((Equiv.swap (⟨0, by decide⟩ : Fin 3) ⟨1, by decide⟩) ⟨2, by decide⟩) = _
      rw [Equiv.swap_apply_of_ne_of_ne h02.symm h12.symm, Equiv.swap_apply_right]
    rcases fin3_val_cases u with hu | hu | hu <;>
      rcases fin3_val_cases v with hv | hv | hv
    · have hu_eq : u = (⟨0, by decide⟩ : Fin 3) := Fin.ext hu
      have hv_eq : v = (⟨0, by decide⟩ : Fin 3) := Fin.ext hv
      rw [hu_eq, hv_eq, hs0]
