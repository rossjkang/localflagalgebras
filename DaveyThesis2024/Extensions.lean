/-! #### Compute `extPow ... 3 ⟦vbExt3_RRR_e0⟧ = 1`

Apply `extPow_three_eq_twelve_lfp` then evaluate at `⟦vbExt3_RRR_e0⟧` using
the 12 per-pair LFP evaluations above. -/

set_option maxHeartbeats 4000000 in
-- Heartbeats raised because `extPow_three_eq_twelve_lfp` unfolding pulls in
-- 12 `genLocalFlagProduct` terms, each of which contains an unevaluated
-- `genClassesOfSize ... 4` Finset; even after our 12 per-pair `apply` lemmas
-- have rewritten away these enumerations, the residual elaborator work
-- (especially for `Finsupp.add_apply` chaining) crosses the default budget.
/-- The Finsupp coefficient of `⟦vbExt3_RRR_e0⟧` in `extPow ... 3` is exactly 1.
    This is the v7 deliverable: a direct per-class coefficient computation
    bypassing the size-4 elaboration blocker. -/
theorem extPow_three_apply_RRR_e0 :
    (extPow vertexBlackType (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) 3)
      (GenFlagClass.mk vbExt3_RRR_e0) = 1 := by
  rw [extPow_three_eq_twelve_lfp]
  simp only [Finsupp.add_apply]
  rw [lfp_vbExt2_RR_indep_vbExtRed_at_RRR_e0,
      lfp_vbExt2_RR_indep_vbExtBlack_at_RRR_e0,
      lfp_vbExt2_RR_edge_vbExtRed_at_RRR_e0,
      lfp_vbExt2_RR_edge_vbExtBlack_at_RRR_e0,
      lfp_vbExt2_RB_indep_vbExtRed_at_RRR_e0,
      lfp_vbExt2_RB_indep_vbExtBlack_at_RRR_e0,
      lfp_vbExt2_RB_edge_vbExtRed_at_RRR_e0,
      lfp_vbExt2_RB_edge_vbExtBlack_at_RRR_e0,
      lfp_vbExt2_BB_indep_vbExtRed_at_RRR_e0,
      lfp_vbExt2_BB_indep_vbExtBlack_at_RRR_e0,
      lfp_vbExt2_BB_edge_vbExtRed_at_RRR_e0,
      lfp_vbExt2_BB_edge_vbExtBlack_at_RRR_e0]
  ring

/-! ### Documentation: status of the v5 conditional discharge

The v7 abstraction landed:
* `IsClassOfSize` — bespoke membership notion bypassing `genClassesOfSize`
  elaboration at size 4.
* `mem_genClassesOfSize_iff_isClassOfSize` — the equivalence at generic n.
* `genLocalFlagProduct_apply_isClass` — apply lemma at generic n.
* `vbExt3_RRR_e0_isClassOfSize` — concrete instance at n = 4.
* 12 per-pair LFP evaluations at `⟦vbExt3_RRR_e0⟧`.
* `extPow_three_apply_RRR_e0` — the Finsupp coefficient of `⟦RRR_e0⟧` in
  `extPow ... 3` is exactly 1.

**Remaining gap to discharge `evalAlg_vbExt3_RRR_e0_eq_one_of_decomp`:**
The hypothesis `h_decomp` states an algebra-level Finsupp equality
`extPow ... 3 = single vbExt3_RRR_e0 + forbidden_singletons.sum`. To prove
this via `Finsupp.ext`, we need:
1. Coefficient at `⟦RRR_e0⟧`: ✓ (via `extPow_three_apply_RRR_e0`).
2. Coefficient at each forbidden class: each LFP evaluation analogous to
   the 12 above, giving 0 for all 19 forbidden flags. (~228 LOC of new
   per-pair zeros.)
3. **Coefficient at any OTHER class: must be 0** — this requires support
   classification at size 4, the original blocker. Without it, we cannot
   close `Finsupp.ext` because the universal "for all classes" quantifier
   includes size-4 classes outside our 20-flag enumeration.

Hence the v7 abstraction reduces but does not eliminate the support-classification
blocker. It cleanly delivers the per-class coefficient computation, but
the missing piece (size-4 support exhaustiveness) is independent of the
elaboration issue v7 solves. -/

/-! ## Size-4 σ-flag classification: infrastructure + σ-position-0 RRR cases

Mirrors the size-3 classification (`any_size3_extAdjBoth_iso`). For the
size-4 σ-flag at vertexBlackType where σ is adjacent to all 3 leaves, we
classify the structure into one of 20 named iso classes (`vbExt3_*`).

This file contains:
1. `size4_iso_via_perm` — generic iso-via-permutation helper.
2. `size4_sigma0_id_iso` — σ-position-0 iso with φ = id (canonical case).
3. `size4_sigma0_iso_via_leafperm` — σ-position-0 iso parameterized by an
   arbitrary leaf permutation φ (fixing position 0).
4. σ-position-0 RRR cases of `any_size4_extAdjAll_iso_sigma0_RRR` — proves
   that any σ-pos-0 σ-flag with all-red leaves is iso to one of
   `vbExt3_RRR_e{0,1,2,3}`, dispatching by edge count.

Future iterations will extend to BBB / RRB / RBB cases at σ-pos-0, and
σ-positions 1, 2, 3 (via vertex permutation). -/

/-- Size-4 generic iso-via-permutation helper. Mirrors `size3_iso_via_perm`
    for size 4. Both source and target are size-4 σ-flags presented in
    "exposed" form; we exhibit a permutation `φ : Fin 4 ≃ Fin 4` mapping
    σ-vertex of G to σ-vertex of T (both required at position 0 in T) and
    matching the structures pointwise. -/
private theorem size4_iso_via_perm
    (G_str T_str : CG2.Str 4)
    (G_emb T_emb : Fin vertexBlackType.size ↪ Fin 4)
    (G_isInd : CG2.comap G_emb G_str = vertexBlackType.str)
    (T_isInd : CG2.comap T_emb T_str = vertexBlackType.str)
    (G_hsize T_hsize : vertexBlackType.size ≤ 4)
    (h_T_emb : T_emb (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) =
      (⟨0, (by decide : (0:ℕ) < 4)⟩ : Fin 4))
    (φ : Fin 4 ≃ Fin 4)
    (h_emb : φ (G_emb ⟨0, Nat.zero_lt_one⟩) =
      (⟨0, (by decide : (0:ℕ) < 4)⟩ : Fin 4))
    (h_adj : ∀ u v : Fin 4,
      G_str.1.Adj u v ↔ T_str.1.Adj (φ u) (φ v))
    (h_col : ∀ v : Fin 4, G_str.2 v = T_str.2 (φ v)) :
    GenFlagIso vertexBlackType
      (⟨4, G_str, G_emb, G_isInd, G_hsize⟩ : GenFlag CG2 vertexBlackType)
      (⟨4, T_str, T_emb, T_isInd, T_hsize⟩ : GenFlag CG2 vertexBlackType) := by
  refine ⟨φ, ?_, ?_⟩
  · apply Prod.ext
    · ext u v
      change T_str.1.Adj (φ u) (φ v) ↔ G_str.1.Adj u v
      rw [h_adj u v]
    · funext v
      change T_str.2 (φ v) = G_str.2 v
      exact (h_col v).symm
  · intro i
    have hi : i = (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) := by
      obtain ⟨v, hv⟩ := i
      have h_size : vertexBlackType.size = 1 := rfl
      have hv' : v < 1 := h_size ▸ hv
      have : v = 0 := by omega
      ext; exact this
    rw [hi, h_T_emb, h_emb]

/-- σ-vertex colour at position 0 for size-4 σ-flag. -/
private theorem size4_sigma_col_eq_one
    (G_str : CG2.Str 4) (G_emb : Fin vertexBlackType.size ↪ Fin 4)
    (G_isInd : CG2.comap G_emb G_str = vertexBlackType.str) :
    G_str.2 (G_emb ⟨0, Nat.zero_lt_one⟩) = 1 := by
  have h_col := congr_arg (fun s : CG2.Str vertexBlackType.size =>
    s.2 ⟨0, Nat.zero_lt_one⟩) G_isInd
  exact h_col

/-- Generic σ-position-0 iso for size-4 σ-flags using an arbitrary leaf
    permutation `ψ : Fin 4 ≃ Fin 4` that fixes position 0 (`ψ ⟨0,_⟩ = ⟨0,_⟩`).
    Pointwise structural matches at all 4 × 4 (u, v) and all 4 colour
    positions are required.

    This is the workhorse for all σ-pos-0 case analyses. -/
private theorem size4_sigma0_iso_via_leafperm
    (G_str T_str : CG2.Str 4)
    (G_emb T_emb : Fin vertexBlackType.size ↪ Fin 4)
    (G_isInd : CG2.comap G_emb G_str = vertexBlackType.str)
    (T_isInd : CG2.comap T_emb T_str = vertexBlackType.str)
    (G_hsize T_hsize : vertexBlackType.size ≤ 4)
    (h_emb_G : (G_emb ⟨0, Nat.zero_lt_one⟩).val = 0)
    (h_emb_T : (T_emb ⟨0, Nat.zero_lt_one⟩).val = 0)
    (ψ : Fin 4 ≃ Fin 4)
    (h_psi_0 : ψ (⟨0, by decide⟩ : Fin 4) = (⟨0, by decide⟩ : Fin 4))
    (h_adj : ∀ u v : Fin 4,
      G_str.1.Adj u v ↔ T_str.1.Adj (ψ u) (ψ v))
    (h_col : ∀ v : Fin 4, G_str.2 v = T_str.2 (ψ v)) :
    GenFlagIso vertexBlackType
      (⟨4, G_str, G_emb, G_isInd, G_hsize⟩ : GenFlag CG2 vertexBlackType)
      (⟨4, T_str, T_emb, T_isInd, T_hsize⟩ : GenFlag CG2 vertexBlackType) := by
  have hT_emb_zero : T_emb (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) =
      (⟨0, (by decide : (0:ℕ) < 4)⟩ : Fin 4) := Fin.ext h_emb_T
  apply size4_iso_via_perm G_str T_str G_emb T_emb G_isInd T_isInd G_hsize T_hsize
    hT_emb_zero ψ
  · have hG_emb_eq : G_emb (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) =
        (⟨0, by decide⟩ : Fin 4) := Fin.ext h_emb_G
    rw [hG_emb_eq, h_psi_0]
  · exact h_adj
  · exact h_col

/-! ### Adjacency facts for the 4 RRR targets

Pointwise `Adj` predicates as `simp`/`decide`-friendly facts. -/

/-- Helper: build u≠v from u.val=a, v.val=b, with a≠b in ℕ. -/
private theorem fin4_ne_of_val_ne {u v : Fin 4} (h : u.val ≠ v.val) : u ≠ v := by
  intro heq; exact h (congr_arg Fin.val heq)

/-- `vbExt3_RRR_e0` adjacency: only σ–leaf edges (0–1, 0–2, 0–3). -/
private theorem vbExt3_RRR_e0_adj_iff (u v : Fin 4) :
    vbExt3_RRR_e0.str.1.Adj u v ↔
      ((u.val = 0 ∧ v.val = 1) ∨ (u.val = 1 ∧ v.val = 0) ∨
        (u.val = 0 ∧ v.val = 2) ∨ (u.val = 2 ∧ v.val = 0) ∨
        (u.val = 0 ∧ v.val = 3) ∨ (u.val = 3 ∧ v.val = 0)) := by
  change (SimpleGraph.fromRel _).Adj u v ↔ _
  simp only [SimpleGraph.fromRel_adj]
  constructor
  · rintro ⟨_, h | h⟩
    · rcases h with ⟨h1, h2⟩ | ⟨h1, h2⟩ | ⟨h1, h2⟩ | ⟨h1, h2⟩ | ⟨h1, h2⟩ | ⟨h1, h2⟩ <;>
        (rw [h1, h2]; decide)
    · rcases h with ⟨h1, h2⟩ | ⟨h1, h2⟩ | ⟨h1, h2⟩ | ⟨h1, h2⟩ | ⟨h1, h2⟩ | ⟨h1, h2⟩ <;>
        (rw [h1, h2]; decide)
  · intro h
    refine ⟨?_, Or.inl h⟩
    rcases h with ⟨h1, h2⟩ | ⟨h1, h2⟩ | ⟨h1, h2⟩ | ⟨h1, h2⟩ | ⟨h1, h2⟩ | ⟨h1, h2⟩ <;>
      exact fin4_ne_of_val_ne (by rw [h1, h2]; decide)

/-- `vbExt3_RRR_e1` adjacency: σ–leaf edges + leaf-leaf {1,2}. -/
private theorem vbExt3_RRR_e1_adj_iff (u v : Fin 4) :
    vbExt3_RRR_e1.str.1.Adj u v ↔
      ((u.val = 0 ∧ v.val = 1) ∨ (u.val = 1 ∧ v.val = 0) ∨
        (u.val = 0 ∧ v.val = 2) ∨ (u.val = 2 ∧ v.val = 0) ∨
        (u.val = 0 ∧ v.val = 3) ∨ (u.val = 3 ∧ v.val = 0) ∨
        (u.val = 1 ∧ v.val = 2) ∨ (u.val = 2 ∧ v.val = 1)) := by
  change (SimpleGraph.fromRel _).Adj u v ↔ _
