        rw [fin2to3_skip_one]; decide
  compat := fun i => by
    have hi : i = (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) := by
      obtain ⟨v, hv⟩ := i
      have h_size : vertexBlackType.size = 1 := rfl
      have hv' : v < 1 := h_size ▸ hv
      have : v = 0 := by omega
      ext; exact this
    rw [hi]
    have h1 : vbExtBlack.embedding (⟨0, Nat.zero_lt_one⟩ : Fin 1) =
