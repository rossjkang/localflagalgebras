/-- For vbExtRed → vbExt2_RR_indep, the leaf maps to ⟨1⟩ or ⟨2⟩ (both red). -/
private lemma vbExtRed_to_vbExt2_RR_indep_leaf_cases
    (e : GenInducedEmbedding CG2 vertexBlackType vbExtRed vbExt2_RR_indep) :
    e.toFun (⟨1, by decide⟩ : Fin 2) = (⟨1, by decide⟩ : Fin 3) ∨
    e.toFun (⟨1, by decide⟩ : Fin 2) = (⟨2, by decide⟩ : Fin 3) := by
  obtain ⟨f, finj, find, fcompat⟩ := e
  have h_phi_0 : f (⟨0, by decide⟩ : Fin 2) = (⟨0, by decide⟩ : Fin 3) :=
    fcompat (⟨0, Nat.zero_lt_one⟩ : Fin 1)
  have h_col : vbExt2_RR_indep.str.2 (f (⟨1, by decide⟩ : Fin 2)) =
      vbExtRed.str.2 (⟨1, by decide⟩ : Fin 2) :=
    congr_arg (fun s : CG2.Str vbExtRed.size => s.2 (⟨1, by decide⟩ : Fin 2)) find
  have h_RHS : vbExtRed.str.2 (⟨1, by decide⟩ : Fin 2) = (0 : Fin 2) := by
    change (if (1 : ℕ) = 0 then (1 : Fin 2) else 0) = 0
    decide
  rw [h_RHS] at h_col
  change f (⟨1, by decide⟩ : Fin 2) = (⟨1, by decide⟩ : Fin 3) ∨
       f (⟨1, by decide⟩ : Fin 2) = (⟨2, by decide⟩ : Fin 3)
  rcases fin3_val_cases (f (⟨1, by decide⟩ : Fin 2)) with h0 | h1 | h2
  · exfalso
    have h_eq : f (⟨1, by decide⟩ : Fin 2) = (⟨0, by decide⟩ : Fin 3) := Fin.ext h0
    have : (⟨1, by decide⟩ : Fin 2) = (⟨0, by decide⟩ : Fin 2) :=
      finj (h_eq.trans h_phi_0.symm)
    have : (1 : ℕ) = 0 := congr_arg Fin.val this
    omega
  · left; exact Fin.ext h1
  · right; exact Fin.ext h2

