theorem t2_v1_b_classification (G : GenFlag CG2 thesisType2)
    (h_size : G.size = 5)
    (h_ext : extAdjacency thesisType2 G ⟨1, by decide⟩)
    (h_w_R : G.str.2 (extVertex G h_size) = 0)
    (h_no_v0 : ¬G.str.1.Adj (extVertex G h_size) (G.embedding ⟨0, by decide⟩))
    (h_yes_v2 : G.str.1.Adj (extVertex G h_size) (G.embedding ⟨2, by decide⟩))
    (h_no_v3 : ¬G.str.1.Adj (extVertex G h_size) (G.embedding ⟨3, by decide⟩)) :
    GenFlagIso thesisType2 G t2_v1_b := by
  classical
  set v0 := G.embedding ⟨0, by decide⟩ with hv0
  set v1 := G.embedding ⟨1, by decide⟩ with hv1
  set v2 := G.embedding ⟨2, by decide⟩ with hv2
  set v3 := G.embedding ⟨3, by decide⟩ with hv3
  set w := extVertex G h_size with hw
  have hv01 : v0 ≠ v1 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv02 : v0 ≠ v2 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv03 : v0 ≠ v3 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv12 : v1 ≠ v2 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv13 : v1 ≠ v3 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv23 : v2 ≠ v3 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hw_notin : w ∉ Set.range G.embedding := extVertex_notin_range G h_size
  have hwv0 : w ≠ v0 := fun h => hw_notin ⟨⟨0, by decide⟩, h.symm⟩
  have hwv1 : w ≠ v1 := fun h => hw_notin ⟨⟨1, by decide⟩, h.symm⟩
  have hwv2 : w ≠ v2 := fun h => hw_notin ⟨⟨2, by decide⟩, h.symm⟩
  have hwv3 : w ≠ v3 := fun h => hw_notin ⟨⟨3, by decide⟩, h.symm⟩
  have h_str_eq : (CG2.comap G.embedding G.str).1 = thesisType2.str.1 :=
    congr_arg Prod.fst G.isInduced
  have h_col_eq : ∀ j : Fin thesisType2.size,
      G.str.2 (G.embedding j) = thesisType2.str.2 j := fun j =>
    congr_fun (congr_arg Prod.snd G.isInduced) j
  have G_v0v1 : G.str.1.Adj v0 v1 := by
    have h_sigma : thesisType2.str.1.Adj ⟨0, by decide⟩ ⟨1, by decide⟩ := by
      simp [thesisType2, SimpleGraph.fromRel_adj]
    rw [← h_str_eq] at h_sigma; exact h_sigma
  have G_v0v2 : G.str.1.Adj v0 v2 := by
    have h_sigma : thesisType2.str.1.Adj ⟨0, by decide⟩ ⟨2, by decide⟩ := by
      simp [thesisType2, SimpleGraph.fromRel_adj]
    rw [← h_str_eq] at h_sigma; exact h_sigma
  have G_v0v3 : G.str.1.Adj v0 v3 := by
    have h_sigma : thesisType2.str.1.Adj ⟨0, by decide⟩ ⟨3, by decide⟩ := by
      simp [thesisType2, SimpleGraph.fromRel_adj]
    rw [← h_str_eq] at h_sigma; exact h_sigma
  have G_v1v2_no : ¬G.str.1.Adj v1 v2 := by
    intro h
    have h' : (CG2.comap G.embedding G.str).1.Adj ⟨1, by decide⟩ ⟨2, by decide⟩ := h
    rw [h_str_eq] at h'
    simp [thesisType2, SimpleGraph.fromRel_adj] at h'
  have G_v1v3_no : ¬G.str.1.Adj v1 v3 := by
    intro h
    have h' : (CG2.comap G.embedding G.str).1.Adj ⟨1, by decide⟩ ⟨3, by decide⟩ := h
    rw [h_str_eq] at h'
    simp [thesisType2, SimpleGraph.fromRel_adj] at h'
  have G_v2v3_no : ¬G.str.1.Adj v2 v3 := by
    intro h
    have h' : (CG2.comap G.embedding G.str).1.Adj ⟨2, by decide⟩ ⟨3, by decide⟩ := h
    rw [h_str_eq] at h'
    simp [thesisType2, SimpleGraph.fromRel_adj] at h'
  obtain ⟨v_ext, hv_ext_notin, hv_ext_adj⟩ := h_ext
  have hv_ext_eq : v_ext = w := extVertex_unique G h_size v_ext hv_ext_notin
  subst hv_ext_eq
  have G_wv1 : G.str.1.Adj w v1 := by rw [hv1]; exact hv_ext_adj
  have hcol_v0 : G.str.2 v0 = 1 := by rw [hv0, h_col_eq]; simp [thesisType2]
  have hcol_v1 : G.str.2 v1 = 0 := by rw [hv1, h_col_eq]; simp [thesisType2]
  have hcol_v2 : G.str.2 v2 = 0 := by rw [hv2, h_col_eq]; simp [thesisType2]
  have hcol_v3 : G.str.2 v3 = 0 := by rw [hv3, h_col_eq]; simp [thesisType2]
  let φ_fn : Fin G.size → Fin 5 := fun x =>
    if x = v0 then ⟨0, by decide⟩
    else if x = v1 then ⟨1, by decide⟩
    else if x = v2 then ⟨2, by decide⟩
    else if x = v3 then ⟨3, by decide⟩
    else ⟨4, by decide⟩
  have φv0 : φ_fn v0 = ⟨0, by decide⟩ := by simp [φ_fn]
  have φv1 : φ_fn v1 = ⟨1, by decide⟩ := by
    simp only [φ_fn]; rw [if_neg hv01.symm]; simp
  have φv2 : φ_fn v2 = ⟨2, by decide⟩ := by
    simp only [φ_fn]; rw [if_neg hv02.symm, if_neg hv12.symm]; simp
  have φv3 : φ_fn v3 = ⟨3, by decide⟩ := by
    simp only [φ_fn]
    rw [if_neg hv03.symm, if_neg hv13.symm, if_neg hv23.symm]; simp
  have φw : φ_fn w = ⟨4, by decide⟩ := by
    simp only [φ_fn]
    rw [if_neg hwv0, if_neg hwv1, if_neg hwv2, if_neg hwv3]
  have x_cases : ∀ x : Fin G.size, x = v0 ∨ x = v1 ∨ x = v2 ∨ x = v3 ∨ x = w := by
    intro x
    by_cases h0 : x = v0
    · exact Or.inl h0
    by_cases h1 : x = v1
    · exact Or.inr (Or.inl h1)
    by_cases h2 : x = v2
    · exact Or.inr (Or.inr (Or.inl h2))
    by_cases h3 : x = v3
    · exact Or.inr (Or.inr (Or.inr (Or.inl h3)))
    right; right; right; right
    apply extVertex_unique G h_size
    rintro ⟨⟨j, hj⟩, hj_eq⟩
    have hjlt : j < 4 := hj
    have hsize : thesisType2.size = 4 := rfl
    interval_cases j
    · exact h0 hj_eq.symm
    · exact h1 hj_eq.symm
    · exact h2 hj_eq.symm
    · exact h3 hj_eq.symm
  have φ_inj : Function.Injective φ_fn := by
    intro x y hxy
    rcases x_cases x with hx | hx | hx | hx | hx <;>
    rcases x_cases y with hy | hy | hy | hy | hy <;>
      subst hx <;> subst hy <;>
      first
      | rfl
      | (exfalso
         try rw [φv0] at hxy
         try rw [φv1] at hxy
         try rw [φv2] at hxy
         try rw [φv3] at hxy
         try rw [φw] at hxy
         exact absurd hxy (by decide))
  have hcard : Fintype.card (Fin G.size) = Fintype.card (Fin 5) := by
    rw [Fintype.card_fin, Fintype.card_fin, h_size]
  have φ_bij : Function.Bijective φ_fn :=
    (Fintype.bijective_iff_injective_and_card φ_fn).mpr ⟨φ_inj, hcard⟩
  let φ : Fin G.size ≃ Fin t2_v1_b.size := Equiv.ofBijective φ_fn φ_bij
  have hφv0 : φ v0 = ⟨0, by decide⟩ := φv0
  have hφv1 : φ v1 = ⟨1, by decide⟩ := φv1
  have hφv2 : φ v2 = ⟨2, by decide⟩ := φv2
  have hφv3 : φ v3 = ⟨3, by decide⟩ := φv3
  have hφw : φ w = ⟨4, by decide⟩ := φw
  refine ⟨φ, ?_, ?_⟩
  · apply Prod.ext
    · ext u v
      change (t2_v1_b.str.1.comap (φ : Fin G.size → Fin 5)).Adj u v ↔ G.str.1.Adj u v
      simp only [SimpleGraph.comap_adj]
      rcases x_cases u with hu | hu | hu | hu | hu <;>
      rcases x_cases v with hv | hv | hv | hv | hv <;>
        rw [hu, hv]
      · rw [hφv0]; constructor
        · intro h; simp [t2_v1_b] at h
        · intro h; exact (G.str.1.irrefl h).elim
      · rw [hφv0, hφv1]; constructor
        · intro _; exact G_v0v1
        · intro _; simp [t2_v1_b, SimpleGraph.fromRel_adj]
      · rw [hφv0, hφv2]; constructor
        · intro _; exact G_v0v2
        · intro _; simp [t2_v1_b, SimpleGraph.fromRel_adj]
      · rw [hφv0, hφv3]; constructor
        · intro _; exact G_v0v3
        · intro _; simp [t2_v1_b, SimpleGraph.fromRel_adj]
      · rw [hφv0, hφw]; constructor
        · intro h; simp [t2_v1_b] at h
        · intro h; exact (h_no_v0 h.symm).elim
      · rw [hφv1, hφv0]; constructor
        · intro _; exact G_v0v1.symm
        · intro _; simp [t2_v1_b, SimpleGraph.fromRel_adj]
      · rw [hφv1]; constructor
        · intro h; simp [t2_v1_b] at h
        · intro h; exact (G.str.1.irrefl h).elim
      · rw [hφv1, hφv2]; constructor
        · intro h; simp [t2_v1_b] at h
        · intro h; exact (G_v1v2_no h).elim
      · rw [hφv1, hφv3]; constructor
        · intro h; simp [t2_v1_b] at h
        · intro h; exact (G_v1v3_no h).elim
      · rw [hφv1, hφw]; constructor
        · intro _; exact G_wv1.symm
        · intro _; simp [t2_v1_b, SimpleGraph.fromRel_adj]
      · rw [hφv2, hφv0]; constructor
        · intro _; exact G_v0v2.symm
        · intro _; simp [t2_v1_b, SimpleGraph.fromRel_adj]
      · rw [hφv2, hφv1]; constructor
        · intro h; simp [t2_v1_b] at h
        · intro h; exact (G_v1v2_no h.symm).elim
      · rw [hφv2]; constructor
        · intro h; simp [t2_v1_b] at h
        · intro h; exact (G.str.1.irrefl h).elim
      · rw [hφv2, hφv3]; constructor
        · intro h; simp [t2_v1_b] at h
        · intro h; exact (G_v2v3_no h).elim
      · rw [hφv2, hφw]; constructor
        · intro _; exact h_yes_v2.symm
        · intro _; simp [t2_v1_b, SimpleGraph.fromRel_adj]
      · rw [hφv3, hφv0]; constructor
        · intro _; exact G_v0v3.symm
        · intro _; simp [t2_v1_b, SimpleGraph.fromRel_adj]
      · rw [hφv3, hφv1]; constructor
        · intro h; simp [t2_v1_b] at h
        · intro h; exact (G_v1v3_no h.symm).elim
      · rw [hφv3, hφv2]; constructor
        · intro h; simp [t2_v1_b] at h
        · intro h; exact (G_v2v3_no h.symm).elim
      · rw [hφv3]; constructor
        · intro h; simp [t2_v1_b] at h
        · intro h; exact (G.str.1.irrefl h).elim
      · rw [hφv3, hφw]; constructor
        · intro h; simp [t2_v1_b] at h
        · intro h; exact (h_no_v3 h.symm).elim
      · rw [hφw, hφv0]; constructor
        · intro h; simp [t2_v1_b] at h
        · intro h; exact (h_no_v0 h).elim
      · rw [hφw, hφv1]; constructor
        · intro _; exact G_wv1
        · intro _; simp [t2_v1_b, SimpleGraph.fromRel_adj]
      · rw [hφw, hφv2]; constructor
        · intro _; exact h_yes_v2
        · intro _; simp [t2_v1_b, SimpleGraph.fromRel_adj]
      · rw [hφw, hφv3]; constructor
        · intro h; simp [t2_v1_b] at h
        · intro h; exact (h_no_v3 h).elim
      · rw [hφw]; constructor
        · intro h; simp [t2_v1_b] at h
        · intro h; exact (G.str.1.irrefl h).elim
    · funext x
      change t2_v1_b.str.2 (φ x) = G.str.2 x
      rcases x_cases x with hx | hx | hx | hx | hx <;> rw [hx]
      · rw [hφv0, hcol_v0]; rfl
      · rw [hφv1, hcol_v1]; rfl
      · rw [hφv2, hcol_v2]; rfl
      · rw [hφv3, hcol_v3]; rfl
      · rw [hφw, h_w_R]; rfl
  · intro i
    fin_cases i
    · simp [t2_v1_b, Fin.castLE]; exact hφv0
    · simp [t2_v1_b, Fin.castLE]; exact hφv1
    · simp [t2_v1_b, Fin.castLE]; exact hφv2
    · simp [t2_v1_b, Fin.castLE]; exact hφv3

/-! ### σ₂-3.2 case c: v1-side R, leaf-set {v2,v3} → t2_v1_c (K_{3,2}) -/

set_option maxHeartbeats 1600000 in
theorem t2_v1_c_classification (G : GenFlag CG2 thesisType2)
    (h_size : G.size = 5)
    (h_ext : extAdjacency thesisType2 G ⟨1, by decide⟩)
    (h_w_R : G.str.2 (extVertex G h_size) = 0)
    (h_no_v0 : ¬G.str.1.Adj (extVertex G h_size) (G.embedding ⟨0, by decide⟩))
    (h_yes_v2 : G.str.1.Adj (extVertex G h_size) (G.embedding ⟨2, by decide⟩))
    (h_yes_v3 : G.str.1.Adj (extVertex G h_size) (G.embedding ⟨3, by decide⟩)) :
    GenFlagIso thesisType2 G t2_v1_c := by
  classical
  set v0 := G.embedding ⟨0, by decide⟩ with hv0
  set v1 := G.embedding ⟨1, by decide⟩ with hv1
  set v2 := G.embedding ⟨2, by decide⟩ with hv2
  set v3 := G.embedding ⟨3, by decide⟩ with hv3
  set w := extVertex G h_size with hw
  have hv01 : v0 ≠ v1 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv02 : v0 ≠ v2 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv03 : v0 ≠ v3 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv12 : v1 ≠ v2 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv13 : v1 ≠ v3 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv23 : v2 ≠ v3 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hw_notin : w ∉ Set.range G.embedding := extVertex_notin_range G h_size
  have hwv0 : w ≠ v0 := fun h => hw_notin ⟨⟨0, by decide⟩, h.symm⟩
  have hwv1 : w ≠ v1 := fun h => hw_notin ⟨⟨1, by decide⟩, h.symm⟩
  have hwv2 : w ≠ v2 := fun h => hw_notin ⟨⟨2, by decide⟩, h.symm⟩
  have hwv3 : w ≠ v3 := fun h => hw_notin ⟨⟨3, by decide⟩, h.symm⟩
  have h_str_eq : (CG2.comap G.embedding G.str).1 = thesisType2.str.1 :=
    congr_arg Prod.fst G.isInduced
  have h_col_eq : ∀ j : Fin thesisType2.size,
      G.str.2 (G.embedding j) = thesisType2.str.2 j := fun j =>
    congr_fun (congr_arg Prod.snd G.isInduced) j
  have G_v0v1 : G.str.1.Adj v0 v1 := by
    have h_sigma : thesisType2.str.1.Adj ⟨0, by decide⟩ ⟨1, by decide⟩ := by
      simp [thesisType2, SimpleGraph.fromRel_adj]
    rw [← h_str_eq] at h_sigma; exact h_sigma
  have G_v0v2 : G.str.1.Adj v0 v2 := by
    have h_sigma : thesisType2.str.1.Adj ⟨0, by decide⟩ ⟨2, by decide⟩ := by
      simp [thesisType2, SimpleGraph.fromRel_adj]
    rw [← h_str_eq] at h_sigma; exact h_sigma
  have G_v0v3 : G.str.1.Adj v0 v3 := by
    have h_sigma : thesisType2.str.1.Adj ⟨0, by decide⟩ ⟨3, by decide⟩ := by
      simp [thesisType2, SimpleGraph.fromRel_adj]
    rw [← h_str_eq] at h_sigma; exact h_sigma
  have G_v1v2_no : ¬G.str.1.Adj v1 v2 := by
    intro h
    have h' : (CG2.comap G.embedding G.str).1.Adj ⟨1, by decide⟩ ⟨2, by decide⟩ := h
    rw [h_str_eq] at h'
    simp [thesisType2, SimpleGraph.fromRel_adj] at h'
  have G_v1v3_no : ¬G.str.1.Adj v1 v3 := by
    intro h
    have h' : (CG2.comap G.embedding G.str).1.Adj ⟨1, by decide⟩ ⟨3, by decide⟩ := h
    rw [h_str_eq] at h'
    simp [thesisType2, SimpleGraph.fromRel_adj] at h'
  have G_v2v3_no : ¬G.str.1.Adj v2 v3 := by
    intro h
    have h' : (CG2.comap G.embedding G.str).1.Adj ⟨2, by decide⟩ ⟨3, by decide⟩ := h
    rw [h_str_eq] at h'
    simp [thesisType2, SimpleGraph.fromRel_adj] at h'
  obtain ⟨v_ext, hv_ext_notin, hv_ext_adj⟩ := h_ext
  have hv_ext_eq : v_ext = w := extVertex_unique G h_size v_ext hv_ext_notin
  subst hv_ext_eq
  have G_wv1 : G.str.1.Adj w v1 := by rw [hv1]; exact hv_ext_adj
  have hcol_v0 : G.str.2 v0 = 1 := by rw [hv0, h_col_eq]; simp [thesisType2]
  have hcol_v1 : G.str.2 v1 = 0 := by rw [hv1, h_col_eq]; simp [thesisType2]
  have hcol_v2 : G.str.2 v2 = 0 := by rw [hv2, h_col_eq]; simp [thesisType2]
  have hcol_v3 : G.str.2 v3 = 0 := by rw [hv3, h_col_eq]; simp [thesisType2]
  let φ_fn : Fin G.size → Fin 5 := fun x =>
    if x = v0 then ⟨0, by decide⟩
    else if x = v1 then ⟨1, by decide⟩
    else if x = v2 then ⟨2, by decide⟩
    else if x = v3 then ⟨3, by decide⟩
    else ⟨4, by decide⟩
  have φv0 : φ_fn v0 = ⟨0, by decide⟩ := by simp [φ_fn]
  have φv1 : φ_fn v1 = ⟨1, by decide⟩ := by
    simp only [φ_fn]; rw [if_neg hv01.symm]; simp
  have φv2 : φ_fn v2 = ⟨2, by decide⟩ := by
    simp only [φ_fn]; rw [if_neg hv02.symm, if_neg hv12.symm]; simp
  have φv3 : φ_fn v3 = ⟨3, by decide⟩ := by
    simp only [φ_fn]
    rw [if_neg hv03.symm, if_neg hv13.symm, if_neg hv23.symm]; simp
  have φw : φ_fn w = ⟨4, by decide⟩ := by
    simp only [φ_fn]
    rw [if_neg hwv0, if_neg hwv1, if_neg hwv2, if_neg hwv3]
  have x_cases : ∀ x : Fin G.size, x = v0 ∨ x = v1 ∨ x = v2 ∨ x = v3 ∨ x = w := by
    intro x
    by_cases h0 : x = v0
    · exact Or.inl h0
    by_cases h1 : x = v1
    · exact Or.inr (Or.inl h1)
    by_cases h2 : x = v2
    · exact Or.inr (Or.inr (Or.inl h2))
    by_cases h3 : x = v3
    · exact Or.inr (Or.inr (Or.inr (Or.inl h3)))
    right; right; right; right
    apply extVertex_unique G h_size
    rintro ⟨⟨j, hj⟩, hj_eq⟩
    have hjlt : j < 4 := hj
    have hsize : thesisType2.size = 4 := rfl
    interval_cases j
    · exact h0 hj_eq.symm
    · exact h1 hj_eq.symm
    · exact h2 hj_eq.symm
    · exact h3 hj_eq.symm
  have φ_inj : Function.Injective φ_fn := by
    intro x y hxy
    rcases x_cases x with hx | hx | hx | hx | hx <;>
    rcases x_cases y with hy | hy | hy | hy | hy <;>
      subst hx <;> subst hy <;>
      first
      | rfl
      | (exfalso
         try rw [φv0] at hxy
         try rw [φv1] at hxy
         try rw [φv2] at hxy
         try rw [φv3] at hxy
         try rw [φw] at hxy
         exact absurd hxy (by decide))
  have hcard : Fintype.card (Fin G.size) = Fintype.card (Fin 5) := by
    rw [Fintype.card_fin, Fintype.card_fin, h_size]
  have φ_bij : Function.Bijective φ_fn :=
    (Fintype.bijective_iff_injective_and_card φ_fn).mpr ⟨φ_inj, hcard⟩
  let φ : Fin G.size ≃ Fin t2_v1_c.size := Equiv.ofBijective φ_fn φ_bij
  have hφv0 : φ v0 = ⟨0, by decide⟩ := φv0
  have hφv1 : φ v1 = ⟨1, by decide⟩ := φv1
  have hφv2 : φ v2 = ⟨2, by decide⟩ := φv2
  have hφv3 : φ v3 = ⟨3, by decide⟩ := φv3
  have hφw : φ w = ⟨4, by decide⟩ := φw
  refine ⟨φ, ?_, ?_⟩
  · apply Prod.ext
    · ext u v
      change (t2_v1_c.str.1.comap (φ : Fin G.size → Fin 5)).Adj u v ↔ G.str.1.Adj u v
      simp only [SimpleGraph.comap_adj]
      rcases x_cases u with hu | hu | hu | hu | hu <;>
      rcases x_cases v with hv | hv | hv | hv | hv <;>
        rw [hu, hv]
      · rw [hφv0]; constructor
        · intro h; simp [t2_v1_c] at h
        · intro h; exact (G.str.1.irrefl h).elim
      · rw [hφv0, hφv1]; constructor
        · intro _; exact G_v0v1
        · intro _; simp [t2_v1_c, SimpleGraph.fromRel_adj]
      · rw [hφv0, hφv2]; constructor
        · intro _; exact G_v0v2
        · intro _; simp [t2_v1_c, SimpleGraph.fromRel_adj]
      · rw [hφv0, hφv3]; constructor
        · intro _; exact G_v0v3
        · intro _; simp [t2_v1_c, SimpleGraph.fromRel_adj]
      · rw [hφv0, hφw]; constructor
        · intro h; simp [t2_v1_c] at h
        · intro h; exact (h_no_v0 h.symm).elim
      · rw [hφv1, hφv0]; constructor
        · intro _; exact G_v0v1.symm
        · intro _; simp [t2_v1_c, SimpleGraph.fromRel_adj]
      · rw [hφv1]; constructor
        · intro h; simp [t2_v1_c] at h
        · intro h; exact (G.str.1.irrefl h).elim
      · rw [hφv1, hφv2]; constructor
        · intro h; simp [t2_v1_c] at h
        · intro h; exact (G_v1v2_no h).elim
      · rw [hφv1, hφv3]; constructor
        · intro h; simp [t2_v1_c] at h
        · intro h; exact (G_v1v3_no h).elim
      · rw [hφv1, hφw]; constructor
        · intro _; exact G_wv1.symm
        · intro _; simp [t2_v1_c, SimpleGraph.fromRel_adj]
      · rw [hφv2, hφv0]; constructor
        · intro _; exact G_v0v2.symm
        · intro _; simp [t2_v1_c, SimpleGraph.fromRel_adj]
      · rw [hφv2, hφv1]; constructor
        · intro h; simp [t2_v1_c] at h
        · intro h; exact (G_v1v2_no h.symm).elim
      · rw [hφv2]; constructor
        · intro h; simp [t2_v1_c] at h
        · intro h; exact (G.str.1.irrefl h).elim
      · rw [hφv2, hφv3]; constructor
        · intro h; simp [t2_v1_c] at h
        · intro h; exact (G_v2v3_no h).elim
      · rw [hφv2, hφw]; constructor
        · intro _; exact h_yes_v2.symm
        · intro _; simp [t2_v1_c, SimpleGraph.fromRel_adj]
      · rw [hφv3, hφv0]; constructor
        · intro _; exact G_v0v3.symm
        · intro _; simp [t2_v1_c, SimpleGraph.fromRel_adj]
      · rw [hφv3, hφv1]; constructor
        · intro h; simp [t2_v1_c] at h
        · intro h; exact (G_v1v3_no h.symm).elim
      · rw [hφv3, hφv2]; constructor
        · intro h; simp [t2_v1_c] at h
        · intro h; exact (G_v2v3_no h.symm).elim
      · rw [hφv3]; constructor
        · intro h; simp [t2_v1_c] at h
        · intro h; exact (G.str.1.irrefl h).elim
      · rw [hφv3, hφw]; constructor
        · intro _; exact h_yes_v3.symm
        · intro _; simp [t2_v1_c, SimpleGraph.fromRel_adj]
      · rw [hφw, hφv0]; constructor
        · intro h; simp [t2_v1_c] at h
        · intro h; exact (h_no_v0 h).elim
      · rw [hφw, hφv1]; constructor
        · intro _; exact G_wv1
        · intro _; simp [t2_v1_c, SimpleGraph.fromRel_adj]
      · rw [hφw, hφv2]; constructor
        · intro _; exact h_yes_v2
        · intro _; simp [t2_v1_c, SimpleGraph.fromRel_adj]
      · rw [hφw, hφv3]; constructor
        · intro _; exact h_yes_v3
        · intro _; simp [t2_v1_c, SimpleGraph.fromRel_adj]
      · rw [hφw]; constructor
        · intro h; simp [t2_v1_c] at h
        · intro h; exact (G.str.1.irrefl h).elim
    · funext x
      change t2_v1_c.str.2 (φ x) = G.str.2 x
      rcases x_cases x with hx | hx | hx | hx | hx <;> rw [hx]
      · rw [hφv0, hcol_v0]; rfl
      · rw [hφv1, hcol_v1]; rfl
      · rw [hφv2, hcol_v2]; rfl
      · rw [hφv3, hcol_v3]; rfl
      · rw [hφw, h_w_R]; rfl
  · intro i
    fin_cases i
    · simp [t2_v1_c, Fin.castLE]; exact hφv0
    · simp [t2_v1_c, Fin.castLE]; exact hφv1
    · simp [t2_v1_c, Fin.castLE]; exact hφv2
    · simp [t2_v1_c, Fin.castLE]; exact hφv3

/-! ### σ₂-3.2 case g: v1-side R, leaf-set {v3} → t2_v1_g -/

set_option maxHeartbeats 1600000 in
theorem t2_v1_g_classification (G : GenFlag CG2 thesisType2)
    (h_size : G.size = 5)
    (h_ext : extAdjacency thesisType2 G ⟨1, by decide⟩)
    (h_w_R : G.str.2 (extVertex G h_size) = 0)
    (h_no_v0 : ¬G.str.1.Adj (extVertex G h_size) (G.embedding ⟨0, by decide⟩))
    (h_no_v2 : ¬G.str.1.Adj (extVertex G h_size) (G.embedding ⟨2, by decide⟩))
    (h_yes_v3 : G.str.1.Adj (extVertex G h_size) (G.embedding ⟨3, by decide⟩)) :
    GenFlagIso thesisType2 G t2_v1_g := by
  classical
  set v0 := G.embedding ⟨0, by decide⟩ with hv0
  set v1 := G.embedding ⟨1, by decide⟩ with hv1
  set v2 := G.embedding ⟨2, by decide⟩ with hv2
  set v3 := G.embedding ⟨3, by decide⟩ with hv3
  set w := extVertex G h_size with hw
  have hv01 : v0 ≠ v1 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv02 : v0 ≠ v2 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv03 : v0 ≠ v3 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv12 : v1 ≠ v2 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv13 : v1 ≠ v3 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv23 : v2 ≠ v3 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hw_notin : w ∉ Set.range G.embedding := extVertex_notin_range G h_size
  have hwv0 : w ≠ v0 := fun h => hw_notin ⟨⟨0, by decide⟩, h.symm⟩
  have hwv1 : w ≠ v1 := fun h => hw_notin ⟨⟨1, by decide⟩, h.symm⟩
  have hwv2 : w ≠ v2 := fun h => hw_notin ⟨⟨2, by decide⟩, h.symm⟩
  have hwv3 : w ≠ v3 := fun h => hw_notin ⟨⟨3, by decide⟩, h.symm⟩
  have h_str_eq : (CG2.comap G.embedding G.str).1 = thesisType2.str.1 :=
    congr_arg Prod.fst G.isInduced
  have h_col_eq : ∀ j : Fin thesisType2.size,
      G.str.2 (G.embedding j) = thesisType2.str.2 j := fun j =>
    congr_fun (congr_arg Prod.snd G.isInduced) j
  have G_v0v1 : G.str.1.Adj v0 v1 := by
    have h_sigma : thesisType2.str.1.Adj ⟨0, by decide⟩ ⟨1, by decide⟩ := by
      simp [thesisType2, SimpleGraph.fromRel_adj]
    rw [← h_str_eq] at h_sigma; exact h_sigma
  have G_v0v2 : G.str.1.Adj v0 v2 := by
    have h_sigma : thesisType2.str.1.Adj ⟨0, by decide⟩ ⟨2, by decide⟩ := by
      simp [thesisType2, SimpleGraph.fromRel_adj]
    rw [← h_str_eq] at h_sigma; exact h_sigma
  have G_v0v3 : G.str.1.Adj v0 v3 := by
    have h_sigma : thesisType2.str.1.Adj ⟨0, by decide⟩ ⟨3, by decide⟩ := by
      simp [thesisType2, SimpleGraph.fromRel_adj]
    rw [← h_str_eq] at h_sigma; exact h_sigma
  have G_v1v2_no : ¬G.str.1.Adj v1 v2 := by
    intro h
    have h' : (CG2.comap G.embedding G.str).1.Adj ⟨1, by decide⟩ ⟨2, by decide⟩ := h
    rw [h_str_eq] at h'
    simp [thesisType2, SimpleGraph.fromRel_adj] at h'
  have G_v1v3_no : ¬G.str.1.Adj v1 v3 := by
    intro h
    have h' : (CG2.comap G.embedding G.str).1.Adj ⟨1, by decide⟩ ⟨3, by decide⟩ := h
    rw [h_str_eq] at h'
    simp [thesisType2, SimpleGraph.fromRel_adj] at h'
  have G_v2v3_no : ¬G.str.1.Adj v2 v3 := by
    intro h
    have h' : (CG2.comap G.embedding G.str).1.Adj ⟨2, by decide⟩ ⟨3, by decide⟩ := h
    rw [h_str_eq] at h'
    simp [thesisType2, SimpleGraph.fromRel_adj] at h'
  obtain ⟨v_ext, hv_ext_notin, hv_ext_adj⟩ := h_ext
  have hv_ext_eq : v_ext = w := extVertex_unique G h_size v_ext hv_ext_notin
  subst hv_ext_eq
  have G_wv1 : G.str.1.Adj w v1 := by rw [hv1]; exact hv_ext_adj
  have hcol_v0 : G.str.2 v0 = 1 := by rw [hv0, h_col_eq]; simp [thesisType2]
  have hcol_v1 : G.str.2 v1 = 0 := by rw [hv1, h_col_eq]; simp [thesisType2]
  have hcol_v2 : G.str.2 v2 = 0 := by rw [hv2, h_col_eq]; simp [thesisType2]
  have hcol_v3 : G.str.2 v3 = 0 := by rw [hv3, h_col_eq]; simp [thesisType2]
  let φ_fn : Fin G.size → Fin 5 := fun x =>
    if x = v0 then ⟨0, by decide⟩
    else if x = v1 then ⟨1, by decide⟩
    else if x = v2 then ⟨2, by decide⟩
    else if x = v3 then ⟨3, by decide⟩
    else ⟨4, by decide⟩
  have φv0 : φ_fn v0 = ⟨0, by decide⟩ := by simp [φ_fn]
  have φv1 : φ_fn v1 = ⟨1, by decide⟩ := by
    simp only [φ_fn]; rw [if_neg hv01.symm]; simp
  have φv2 : φ_fn v2 = ⟨2, by decide⟩ := by
    simp only [φ_fn]; rw [if_neg hv02.symm, if_neg hv12.symm]; simp
  have φv3 : φ_fn v3 = ⟨3, by decide⟩ := by
    simp only [φ_fn]
    rw [if_neg hv03.symm, if_neg hv13.symm, if_neg hv23.symm]; simp
  have φw : φ_fn w = ⟨4, by decide⟩ := by
    simp only [φ_fn]
    rw [if_neg hwv0, if_neg hwv1, if_neg hwv2, if_neg hwv3]
  have x_cases : ∀ x : Fin G.size, x = v0 ∨ x = v1 ∨ x = v2 ∨ x = v3 ∨ x = w := by
    intro x
    by_cases h0 : x = v0
    · exact Or.inl h0
    by_cases h1 : x = v1
    · exact Or.inr (Or.inl h1)
    by_cases h2 : x = v2
    · exact Or.inr (Or.inr (Or.inl h2))
    by_cases h3 : x = v3
    · exact Or.inr (Or.inr (Or.inr (Or.inl h3)))
    right; right; right; right
    apply extVertex_unique G h_size
    rintro ⟨⟨j, hj⟩, hj_eq⟩
    have hjlt : j < 4 := hj
    have hsize : thesisType2.size = 4 := rfl
    interval_cases j
    · exact h0 hj_eq.symm
    · exact h1 hj_eq.symm
    · exact h2 hj_eq.symm
    · exact h3 hj_eq.symm
  have φ_inj : Function.Injective φ_fn := by
    intro x y hxy
    rcases x_cases x with hx | hx | hx | hx | hx <;>
    rcases x_cases y with hy | hy | hy | hy | hy <;>
      subst hx <;> subst hy <;>
      first
      | rfl
      | (exfalso
         try rw [φv0] at hxy
         try rw [φv1] at hxy
         try rw [φv2] at hxy
         try rw [φv3] at hxy
         try rw [φw] at hxy
         exact absurd hxy (by decide))
  have hcard : Fintype.card (Fin G.size) = Fintype.card (Fin 5) := by
    rw [Fintype.card_fin, Fintype.card_fin, h_size]
  have φ_bij : Function.Bijective φ_fn :=
    (Fintype.bijective_iff_injective_and_card φ_fn).mpr ⟨φ_inj, hcard⟩
  let φ : Fin G.size ≃ Fin t2_v1_g.size := Equiv.ofBijective φ_fn φ_bij
  have hφv0 : φ v0 = ⟨0, by decide⟩ := φv0
  have hφv1 : φ v1 = ⟨1, by decide⟩ := φv1
  have hφv2 : φ v2 = ⟨2, by decide⟩ := φv2
  have hφv3 : φ v3 = ⟨3, by decide⟩ := φv3
  have hφw : φ w = ⟨4, by decide⟩ := φw
  refine ⟨φ, ?_, ?_⟩
  · apply Prod.ext
    · ext u v
      change (t2_v1_g.str.1.comap (φ : Fin G.size → Fin 5)).Adj u v ↔ G.str.1.Adj u v
      simp only [SimpleGraph.comap_adj]
      rcases x_cases u with hu | hu | hu | hu | hu <;>
      rcases x_cases v with hv | hv | hv | hv | hv <;>
        rw [hu, hv]
      · rw [hφv0]; constructor
        · intro h; simp [t2_v1_g] at h
        · intro h; exact (G.str.1.irrefl h).elim
      · rw [hφv0, hφv1]; constructor
        · intro _; exact G_v0v1
        · intro _; simp [t2_v1_g, SimpleGraph.fromRel_adj]
      · rw [hφv0, hφv2]; constructor
        · intro _; exact G_v0v2
        · intro _; simp [t2_v1_g, SimpleGraph.fromRel_adj]
      · rw [hφv0, hφv3]; constructor
        · intro _; exact G_v0v3
        · intro _; simp [t2_v1_g, SimpleGraph.fromRel_adj]
      · rw [hφv0, hφw]; constructor
        · intro h; simp [t2_v1_g] at h
        · intro h; exact (h_no_v0 h.symm).elim
      · rw [hφv1, hφv0]; constructor
        · intro _; exact G_v0v1.symm
        · intro _; simp [t2_v1_g, SimpleGraph.fromRel_adj]
      · rw [hφv1]; constructor
        · intro h; simp [t2_v1_g] at h
        · intro h; exact (G.str.1.irrefl h).elim
      · rw [hφv1, hφv2]; constructor
        · intro h; simp [t2_v1_g] at h
        · intro h; exact (G_v1v2_no h).elim
      · rw [hφv1, hφv3]; constructor
        · intro h; simp [t2_v1_g] at h
        · intro h; exact (G_v1v3_no h).elim
      · rw [hφv1, hφw]; constructor
        · intro _; exact G_wv1.symm
        · intro _; simp [t2_v1_g, SimpleGraph.fromRel_adj]
      · rw [hφv2, hφv0]; constructor
        · intro _; exact G_v0v2.symm
        · intro _; simp [t2_v1_g, SimpleGraph.fromRel_adj]
      · rw [hφv2, hφv1]; constructor
        · intro h; simp [t2_v1_g] at h
        · intro h; exact (G_v1v2_no h.symm).elim
      · rw [hφv2]; constructor
        · intro h; simp [t2_v1_g] at h
        · intro h; exact (G.str.1.irrefl h).elim
      · rw [hφv2, hφv3]; constructor
        · intro h; simp [t2_v1_g] at h
        · intro h; exact (G_v2v3_no h).elim
      · rw [hφv2, hφw]; constructor
        · intro h; simp [t2_v1_g] at h
        · intro h; exact (h_no_v2 h.symm).elim
      · rw [hφv3, hφv0]; constructor
        · intro _; exact G_v0v3.symm
        · intro _; simp [t2_v1_g, SimpleGraph.fromRel_adj]
      · rw [hφv3, hφv1]; constructor
        · intro h; simp [t2_v1_g] at h
        · intro h; exact (G_v1v3_no h.symm).elim
      · rw [hφv3, hφv2]; constructor
        · intro h; simp [t2_v1_g] at h
        · intro h; exact (G_v2v3_no h.symm).elim
      · rw [hφv3]; constructor
        · intro h; simp [t2_v1_g] at h
        · intro h; exact (G.str.1.irrefl h).elim
      · rw [hφv3, hφw]; constructor
        · intro _; exact h_yes_v3.symm
        · intro _; simp [t2_v1_g, SimpleGraph.fromRel_adj]
      · rw [hφw, hφv0]; constructor
        · intro h; simp [t2_v1_g] at h
        · intro h; exact (h_no_v0 h).elim
      · rw [hφw, hφv1]; constructor
        · intro _; exact G_wv1
        · intro _; simp [t2_v1_g, SimpleGraph.fromRel_adj]
      · rw [hφw, hφv2]; constructor
        · intro h; simp [t2_v1_g] at h
        · intro h; exact (h_no_v2 h).elim
      · rw [hφw, hφv3]; constructor
        · intro _; exact h_yes_v3
        · intro _; simp [t2_v1_g, SimpleGraph.fromRel_adj]
      · rw [hφw]; constructor
        · intro h; simp [t2_v1_g] at h
        · intro h; exact (G.str.1.irrefl h).elim
    · funext x
      change t2_v1_g.str.2 (φ x) = G.str.2 x
      rcases x_cases x with hx | hx | hx | hx | hx <;> rw [hx]
      · rw [hφv0, hcol_v0]; rfl
      · rw [hφv1, hcol_v1]; rfl
      · rw [hφv2, hcol_v2]; rfl
      · rw [hφv3, hcol_v3]; rfl
      · rw [hφw, h_w_R]; rfl
  · intro i
    fin_cases i
    · simp [t2_v1_g, Fin.castLE]; exact hφv0
    · simp [t2_v1_g, Fin.castLE]; exact hφv1
    · simp [t2_v1_g, Fin.castLE]; exact hφv2
    · simp [t2_v1_g, Fin.castLE]; exact hφv3

/-! ### σ₂-3.2 case d: v1-side B, leaf-set ∅ → t2_v1_d -/

set_option maxHeartbeats 1600000 in
theorem t2_v1_d_classification (G : GenFlag CG2 thesisType2)
    (h_size : G.size = 5)
    (h_ext : extAdjacency thesisType2 G ⟨1, by decide⟩)
    (h_w_B : G.str.2 (extVertex G h_size) = 1)
    (h_no_v0 : ¬G.str.1.Adj (extVertex G h_size) (G.embedding ⟨0, by decide⟩))
    (h_no_v2 : ¬G.str.1.Adj (extVertex G h_size) (G.embedding ⟨2, by decide⟩))
    (h_no_v3 : ¬G.str.1.Adj (extVertex G h_size) (G.embedding ⟨3, by decide⟩)) :
    GenFlagIso thesisType2 G t2_v1_d := by
  classical
  set v0 := G.embedding ⟨0, by decide⟩ with hv0
  set v1 := G.embedding ⟨1, by decide⟩ with hv1
  set v2 := G.embedding ⟨2, by decide⟩ with hv2
  set v3 := G.embedding ⟨3, by decide⟩ with hv3
  set w := extVertex G h_size with hw
  have hv01 : v0 ≠ v1 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv02 : v0 ≠ v2 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv03 : v0 ≠ v3 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv12 : v1 ≠ v2 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv13 : v1 ≠ v3 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv23 : v2 ≠ v3 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hw_notin : w ∉ Set.range G.embedding := extVertex_notin_range G h_size
  have hwv0 : w ≠ v0 := fun h => hw_notin ⟨⟨0, by decide⟩, h.symm⟩
  have hwv1 : w ≠ v1 := fun h => hw_notin ⟨⟨1, by decide⟩, h.symm⟩
  have hwv2 : w ≠ v2 := fun h => hw_notin ⟨⟨2, by decide⟩, h.symm⟩
  have hwv3 : w ≠ v3 := fun h => hw_notin ⟨⟨3, by decide⟩, h.symm⟩
  have h_str_eq : (CG2.comap G.embedding G.str).1 = thesisType2.str.1 :=
    congr_arg Prod.fst G.isInduced
  have h_col_eq : ∀ j : Fin thesisType2.size,
      G.str.2 (G.embedding j) = thesisType2.str.2 j := fun j =>
    congr_fun (congr_arg Prod.snd G.isInduced) j
  have G_v0v1 : G.str.1.Adj v0 v1 := by
    have h_sigma : thesisType2.str.1.Adj ⟨0, by decide⟩ ⟨1, by decide⟩ := by
      simp [thesisType2, SimpleGraph.fromRel_adj]
    rw [← h_str_eq] at h_sigma; exact h_sigma
  have G_v0v2 : G.str.1.Adj v0 v2 := by
    have h_sigma : thesisType2.str.1.Adj ⟨0, by decide⟩ ⟨2, by decide⟩ := by
      simp [thesisType2, SimpleGraph.fromRel_adj]
    rw [← h_str_eq] at h_sigma; exact h_sigma
  have G_v0v3 : G.str.1.Adj v0 v3 := by
    have h_sigma : thesisType2.str.1.Adj ⟨0, by decide⟩ ⟨3, by decide⟩ := by
      simp [thesisType2, SimpleGraph.fromRel_adj]
    rw [← h_str_eq] at h_sigma; exact h_sigma
  have G_v1v2_no : ¬G.str.1.Adj v1 v2 := by
    intro h
    have h' : (CG2.comap G.embedding G.str).1.Adj ⟨1, by decide⟩ ⟨2, by decide⟩ := h
    rw [h_str_eq] at h'
    simp [thesisType2, SimpleGraph.fromRel_adj] at h'
  have G_v1v3_no : ¬G.str.1.Adj v1 v3 := by
    intro h
    have h' : (CG2.comap G.embedding G.str).1.Adj ⟨1, by decide⟩ ⟨3, by decide⟩ := h
    rw [h_str_eq] at h'
    simp [thesisType2, SimpleGraph.fromRel_adj] at h'
  have G_v2v3_no : ¬G.str.1.Adj v2 v3 := by
    intro h
    have h' : (CG2.comap G.embedding G.str).1.Adj ⟨2, by decide⟩ ⟨3, by decide⟩ := h
    rw [h_str_eq] at h'
    simp [thesisType2, SimpleGraph.fromRel_adj] at h'
  obtain ⟨v_ext, hv_ext_notin, hv_ext_adj⟩ := h_ext
  have hv_ext_eq : v_ext = w := extVertex_unique G h_size v_ext hv_ext_notin
  subst hv_ext_eq
  have G_wv1 : G.str.1.Adj w v1 := by rw [hv1]; exact hv_ext_adj
  have hcol_v0 : G.str.2 v0 = 1 := by rw [hv0, h_col_eq]; simp [thesisType2]
  have hcol_v1 : G.str.2 v1 = 0 := by rw [hv1, h_col_eq]; simp [thesisType2]
  have hcol_v2 : G.str.2 v2 = 0 := by rw [hv2, h_col_eq]; simp [thesisType2]
  have hcol_v3 : G.str.2 v3 = 0 := by rw [hv3, h_col_eq]; simp [thesisType2]
  let φ_fn : Fin G.size → Fin 5 := fun x =>
    if x = v0 then ⟨0, by decide⟩
    else if x = v1 then ⟨1, by decide⟩
    else if x = v2 then ⟨2, by decide⟩
    else if x = v3 then ⟨3, by decide⟩
    else ⟨4, by decide⟩
  have φv0 : φ_fn v0 = ⟨0, by decide⟩ := by simp [φ_fn]
  have φv1 : φ_fn v1 = ⟨1, by decide⟩ := by
    simp only [φ_fn]; rw [if_neg hv01.symm]; simp
  have φv2 : φ_fn v2 = ⟨2, by decide⟩ := by
    simp only [φ_fn]; rw [if_neg hv02.symm, if_neg hv12.symm]; simp
  have φv3 : φ_fn v3 = ⟨3, by decide⟩ := by
    simp only [φ_fn]
    rw [if_neg hv03.symm, if_neg hv13.symm, if_neg hv23.symm]; simp
  have φw : φ_fn w = ⟨4, by decide⟩ := by
    simp only [φ_fn]
    rw [if_neg hwv0, if_neg hwv1, if_neg hwv2, if_neg hwv3]
  have x_cases : ∀ x : Fin G.size, x = v0 ∨ x = v1 ∨ x = v2 ∨ x = v3 ∨ x = w := by
    intro x
    by_cases h0 : x = v0
    · exact Or.inl h0
    by_cases h1 : x = v1
    · exact Or.inr (Or.inl h1)
    by_cases h2 : x = v2
    · exact Or.inr (Or.inr (Or.inl h2))
    by_cases h3 : x = v3
    · exact Or.inr (Or.inr (Or.inr (Or.inl h3)))
    right; right; right; right
    apply extVertex_unique G h_size
    rintro ⟨⟨j, hj⟩, hj_eq⟩
    have hjlt : j < 4 := hj
    have hsize : thesisType2.size = 4 := rfl
    interval_cases j
    · exact h0 hj_eq.symm
    · exact h1 hj_eq.symm
    · exact h2 hj_eq.symm
    · exact h3 hj_eq.symm
  have φ_inj : Function.Injective φ_fn := by
    intro x y hxy
    rcases x_cases x with hx | hx | hx | hx | hx <;>
    rcases x_cases y with hy | hy | hy | hy | hy <;>
      subst hx <;> subst hy <;>
      first
      | rfl
      | (exfalso
         try rw [φv0] at hxy
         try rw [φv1] at hxy
         try rw [φv2] at hxy
         try rw [φv3] at hxy
         try rw [φw] at hxy
         exact absurd hxy (by decide))
  have hcard : Fintype.card (Fin G.size) = Fintype.card (Fin 5) := by
    rw [Fintype.card_fin, Fintype.card_fin, h_size]
  have φ_bij : Function.Bijective φ_fn :=
    (Fintype.bijective_iff_injective_and_card φ_fn).mpr ⟨φ_inj, hcard⟩
  let φ : Fin G.size ≃ Fin t2_v1_d.size := Equiv.ofBijective φ_fn φ_bij
  have hφv0 : φ v0 = ⟨0, by decide⟩ := φv0
  have hφv1 : φ v1 = ⟨1, by decide⟩ := φv1
  have hφv2 : φ v2 = ⟨2, by decide⟩ := φv2
  have hφv3 : φ v3 = ⟨3, by decide⟩ := φv3
  have hφw : φ w = ⟨4, by decide⟩ := φw
  refine ⟨φ, ?_, ?_⟩
  · apply Prod.ext
    · ext u v
      change (t2_v1_d.str.1.comap (φ : Fin G.size → Fin 5)).Adj u v ↔ G.str.1.Adj u v
      simp only [SimpleGraph.comap_adj]
      rcases x_cases u with hu | hu | hu | hu | hu <;>
      rcases x_cases v with hv | hv | hv | hv | hv <;>
        rw [hu, hv]
      · rw [hφv0]; constructor
        · intro h; simp [t2_v1_d] at h
        · intro h; exact (G.str.1.irrefl h).elim
      · rw [hφv0, hφv1]; constructor
        · intro _; exact G_v0v1
        · intro _; simp [t2_v1_d, SimpleGraph.fromRel_adj]
      · rw [hφv0, hφv2]; constructor
        · intro _; exact G_v0v2
        · intro _; simp [t2_v1_d, SimpleGraph.fromRel_adj]
      · rw [hφv0, hφv3]; constructor
        · intro _; exact G_v0v3
        · intro _; simp [t2_v1_d, SimpleGraph.fromRel_adj]
      · rw [hφv0, hφw]; constructor
        · intro h; simp [t2_v1_d] at h
        · intro h; exact (h_no_v0 h.symm).elim
      · rw [hφv1, hφv0]; constructor
        · intro _; exact G_v0v1.symm
        · intro _; simp [t2_v1_d, SimpleGraph.fromRel_adj]
      · rw [hφv1]; constructor
        · intro h; simp [t2_v1_d] at h
        · intro h; exact (G.str.1.irrefl h).elim
      · rw [hφv1, hφv2]; constructor
        · intro h; simp [t2_v1_d] at h
        · intro h; exact (G_v1v2_no h).elim
      · rw [hφv1, hφv3]; constructor
        · intro h; simp [t2_v1_d] at h
        · intro h; exact (G_v1v3_no h).elim
      · rw [hφv1, hφw]; constructor
        · intro _; exact G_wv1.symm
        · intro _; simp [t2_v1_d, SimpleGraph.fromRel_adj]
      · rw [hφv2, hφv0]; constructor
        · intro _; exact G_v0v2.symm
        · intro _; simp [t2_v1_d, SimpleGraph.fromRel_adj]
      · rw [hφv2, hφv1]; constructor
        · intro h; simp [t2_v1_d] at h
        · intro h; exact (G_v1v2_no h.symm).elim
      · rw [hφv2]; constructor
        · intro h; simp [t2_v1_d] at h
        · intro h; exact (G.str.1.irrefl h).elim
      · rw [hφv2, hφv3]; constructor
        · intro h; simp [t2_v1_d] at h
        · intro h; exact (G_v2v3_no h).elim
      · rw [hφv2, hφw]; constructor
        · intro h; simp [t2_v1_d] at h
        · intro h; exact (h_no_v2 h.symm).elim
      · rw [hφv3, hφv0]; constructor
        · intro _; exact G_v0v3.symm
        · intro _; simp [t2_v1_d, SimpleGraph.fromRel_adj]
      · rw [hφv3, hφv1]; constructor
        · intro h; simp [t2_v1_d] at h
        · intro h; exact (G_v1v3_no h.symm).elim
      · rw [hφv3, hφv2]; constructor
        · intro h; simp [t2_v1_d] at h
        · intro h; exact (G_v2v3_no h.symm).elim
      · rw [hφv3]; constructor
        · intro h; simp [t2_v1_d] at h
        · intro h; exact (G.str.1.irrefl h).elim
      · rw [hφv3, hφw]; constructor
        · intro h; simp [t2_v1_d] at h
        · intro h; exact (h_no_v3 h.symm).elim
      · rw [hφw, hφv0]; constructor
        · intro h; simp [t2_v1_d] at h
        · intro h; exact (h_no_v0 h).elim
      · rw [hφw, hφv1]; constructor
        · intro _; exact G_wv1
        · intro _; simp [t2_v1_d, SimpleGraph.fromRel_adj]
      · rw [hφw, hφv2]; constructor
        · intro h; simp [t2_v1_d] at h
        · intro h; exact (h_no_v2 h).elim
      · rw [hφw, hφv3]; constructor
        · intro h; simp [t2_v1_d] at h
        · intro h; exact (h_no_v3 h).elim
      · rw [hφw]; constructor
        · intro h; simp [t2_v1_d] at h
        · intro h; exact (G.str.1.irrefl h).elim
    · funext x
      change t2_v1_d.str.2 (φ x) = G.str.2 x
      rcases x_cases x with hx | hx | hx | hx | hx <;> rw [hx]
      · rw [hφv0, hcol_v0]; rfl
      · rw [hφv1, hcol_v1]; rfl
      · rw [hφv2, hcol_v2]; rfl
      · rw [hφv3, hcol_v3]; rfl
      · rw [hφw, h_w_B]; rfl
  · intro i
    fin_cases i
    · simp [t2_v1_d, Fin.castLE]; exact hφv0
    · simp [t2_v1_d, Fin.castLE]; exact hφv1
    · simp [t2_v1_d, Fin.castLE]; exact hφv2
    · simp [t2_v1_d, Fin.castLE]; exact hφv3

/-! ### σ₂-3.2 case e: v1-side B, leaf-set {v2} → t2_v1_e -/

set_option maxHeartbeats 1600000 in
theorem t2_v1_e_classification (G : GenFlag CG2 thesisType2)
    (h_size : G.size = 5)
    (h_ext : extAdjacency thesisType2 G ⟨1, by decide⟩)
    (h_w_B : G.str.2 (extVertex G h_size) = 1)
    (h_no_v0 : ¬G.str.1.Adj (extVertex G h_size) (G.embedding ⟨0, by decide⟩))
    (h_yes_v2 : G.str.1.Adj (extVertex G h_size) (G.embedding ⟨2, by decide⟩))
    (h_no_v3 : ¬G.str.1.Adj (extVertex G h_size) (G.embedding ⟨3, by decide⟩)) :
    GenFlagIso thesisType2 G t2_v1_e := by
  classical
  set v0 := G.embedding ⟨0, by decide⟩ with hv0
  set v1 := G.embedding ⟨1, by decide⟩ with hv1
  set v2 := G.embedding ⟨2, by decide⟩ with hv2
  set v3 := G.embedding ⟨3, by decide⟩ with hv3
  set w := extVertex G h_size with hw
  have hv01 : v0 ≠ v1 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv02 : v0 ≠ v2 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv03 : v0 ≠ v3 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv12 : v1 ≠ v2 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv13 : v1 ≠ v3 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv23 : v2 ≠ v3 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hw_notin : w ∉ Set.range G.embedding := extVertex_notin_range G h_size
  have hwv0 : w ≠ v0 := fun h => hw_notin ⟨⟨0, by decide⟩, h.symm⟩
  have hwv1 : w ≠ v1 := fun h => hw_notin ⟨⟨1, by decide⟩, h.symm⟩
  have hwv2 : w ≠ v2 := fun h => hw_notin ⟨⟨2, by decide⟩, h.symm⟩
  have hwv3 : w ≠ v3 := fun h => hw_notin ⟨⟨3, by decide⟩, h.symm⟩
  have h_str_eq : (CG2.comap G.embedding G.str).1 = thesisType2.str.1 :=
    congr_arg Prod.fst G.isInduced
  have h_col_eq : ∀ j : Fin thesisType2.size,
      G.str.2 (G.embedding j) = thesisType2.str.2 j := fun j =>
    congr_fun (congr_arg Prod.snd G.isInduced) j
  have G_v0v1 : G.str.1.Adj v0 v1 := by
    have h_sigma : thesisType2.str.1.Adj ⟨0, by decide⟩ ⟨1, by decide⟩ := by
      simp [thesisType2, SimpleGraph.fromRel_adj]
    rw [← h_str_eq] at h_sigma; exact h_sigma
  have G_v0v2 : G.str.1.Adj v0 v2 := by
    have h_sigma : thesisType2.str.1.Adj ⟨0, by decide⟩ ⟨2, by decide⟩ := by
      simp [thesisType2, SimpleGraph.fromRel_adj]
    rw [← h_str_eq] at h_sigma; exact h_sigma
  have G_v0v3 : G.str.1.Adj v0 v3 := by
    have h_sigma : thesisType2.str.1.Adj ⟨0, by decide⟩ ⟨3, by decide⟩ := by
      simp [thesisType2, SimpleGraph.fromRel_adj]
    rw [← h_str_eq] at h_sigma; exact h_sigma
  have G_v1v2_no : ¬G.str.1.Adj v1 v2 := by
    intro h
    have h' : (CG2.comap G.embedding G.str).1.Adj ⟨1, by decide⟩ ⟨2, by decide⟩ := h
    rw [h_str_eq] at h'
    simp [thesisType2, SimpleGraph.fromRel_adj] at h'
  have G_v1v3_no : ¬G.str.1.Adj v1 v3 := by
    intro h
    have h' : (CG2.comap G.embedding G.str).1.Adj ⟨1, by decide⟩ ⟨3, by decide⟩ := h
    rw [h_str_eq] at h'
    simp [thesisType2, SimpleGraph.fromRel_adj] at h'
  have G_v2v3_no : ¬G.str.1.Adj v2 v3 := by
    intro h
    have h' : (CG2.comap G.embedding G.str).1.Adj ⟨2, by decide⟩ ⟨3, by decide⟩ := h
    rw [h_str_eq] at h'
    simp [thesisType2, SimpleGraph.fromRel_adj] at h'
  obtain ⟨v_ext, hv_ext_notin, hv_ext_adj⟩ := h_ext
  have hv_ext_eq : v_ext = w := extVertex_unique G h_size v_ext hv_ext_notin
  subst hv_ext_eq
  have G_wv1 : G.str.1.Adj w v1 := by rw [hv1]; exact hv_ext_adj
  have hcol_v0 : G.str.2 v0 = 1 := by rw [hv0, h_col_eq]; simp [thesisType2]
  have hcol_v1 : G.str.2 v1 = 0 := by rw [hv1, h_col_eq]; simp [thesisType2]
  have hcol_v2 : G.str.2 v2 = 0 := by rw [hv2, h_col_eq]; simp [thesisType2]
  have hcol_v3 : G.str.2 v3 = 0 := by rw [hv3, h_col_eq]; simp [thesisType2]
  let φ_fn : Fin G.size → Fin 5 := fun x =>
    if x = v0 then ⟨0, by decide⟩
    else if x = v1 then ⟨1, by decide⟩
    else if x = v2 then ⟨2, by decide⟩
    else if x = v3 then ⟨3, by decide⟩
    else ⟨4, by decide⟩
  have φv0 : φ_fn v0 = ⟨0, by decide⟩ := by simp [φ_fn]
  have φv1 : φ_fn v1 = ⟨1, by decide⟩ := by
    simp only [φ_fn]; rw [if_neg hv01.symm]; simp
  have φv2 : φ_fn v2 = ⟨2, by decide⟩ := by
    simp only [φ_fn]; rw [if_neg hv02.symm, if_neg hv12.symm]; simp
  have φv3 : φ_fn v3 = ⟨3, by decide⟩ := by
    simp only [φ_fn]
    rw [if_neg hv03.symm, if_neg hv13.symm, if_neg hv23.symm]; simp
  have φw : φ_fn w = ⟨4, by decide⟩ := by
    simp only [φ_fn]
    rw [if_neg hwv0, if_neg hwv1, if_neg hwv2, if_neg hwv3]
  have x_cases : ∀ x : Fin G.size, x = v0 ∨ x = v1 ∨ x = v2 ∨ x = v3 ∨ x = w := by
    intro x
    by_cases h0 : x = v0
    · exact Or.inl h0
    by_cases h1 : x = v1
    · exact Or.inr (Or.inl h1)
    by_cases h2 : x = v2
    · exact Or.inr (Or.inr (Or.inl h2))
    by_cases h3 : x = v3
    · exact Or.inr (Or.inr (Or.inr (Or.inl h3)))
    right; right; right; right
    apply extVertex_unique G h_size
    rintro ⟨⟨j, hj⟩, hj_eq⟩
    have hjlt : j < 4 := hj
    have hsize : thesisType2.size = 4 := rfl
    interval_cases j
    · exact h0 hj_eq.symm
    · exact h1 hj_eq.symm
    · exact h2 hj_eq.symm
    · exact h3 hj_eq.symm
  have φ_inj : Function.Injective φ_fn := by
    intro x y hxy
    rcases x_cases x with hx | hx | hx | hx | hx <;>
    rcases x_cases y with hy | hy | hy | hy | hy <;>
      subst hx <;> subst hy <;>
      first
      | rfl
      | (exfalso
         try rw [φv0] at hxy
         try rw [φv1] at hxy
         try rw [φv2] at hxy
         try rw [φv3] at hxy
         try rw [φw] at hxy
         exact absurd hxy (by decide))
  have hcard : Fintype.card (Fin G.size) = Fintype.card (Fin 5) := by
    rw [Fintype.card_fin, Fintype.card_fin, h_size]
  have φ_bij : Function.Bijective φ_fn :=
    (Fintype.bijective_iff_injective_and_card φ_fn).mpr ⟨φ_inj, hcard⟩
  let φ : Fin G.size ≃ Fin t2_v1_e.size := Equiv.ofBijective φ_fn φ_bij
  have hφv0 : φ v0 = ⟨0, by decide⟩ := φv0
  have hφv1 : φ v1 = ⟨1, by decide⟩ := φv1
  have hφv2 : φ v2 = ⟨2, by decide⟩ := φv2
  have hφv3 : φ v3 = ⟨3, by decide⟩ := φv3
  have hφw : φ w = ⟨4, by decide⟩ := φw
  refine ⟨φ, ?_, ?_⟩
  · apply Prod.ext
    · ext u v
      change (t2_v1_e.str.1.comap (φ : Fin G.size → Fin 5)).Adj u v ↔ G.str.1.Adj u v
      simp only [SimpleGraph.comap_adj]
      rcases x_cases u with hu | hu | hu | hu | hu <;>
      rcases x_cases v with hv | hv | hv | hv | hv <;>
        rw [hu, hv]
      · rw [hφv0]; constructor
        · intro h; simp [t2_v1_e] at h
        · intro h; exact (G.str.1.irrefl h).elim
      · rw [hφv0, hφv1]; constructor
        · intro _; exact G_v0v1
        · intro _; simp [t2_v1_e, SimpleGraph.fromRel_adj]
      · rw [hφv0, hφv2]; constructor
        · intro _; exact G_v0v2
        · intro _; simp [t2_v1_e, SimpleGraph.fromRel_adj]
      · rw [hφv0, hφv3]; constructor
        · intro _; exact G_v0v3
        · intro _; simp [t2_v1_e, SimpleGraph.fromRel_adj]
      · rw [hφv0, hφw]; constructor
        · intro h; simp [t2_v1_e] at h
        · intro h; exact (h_no_v0 h.symm).elim
      · rw [hφv1, hφv0]; constructor
        · intro _; exact G_v0v1.symm
        · intro _; simp [t2_v1_e, SimpleGraph.fromRel_adj]
      · rw [hφv1]; constructor
        · intro h; simp [t2_v1_e] at h
        · intro h; exact (G.str.1.irrefl h).elim
      · rw [hφv1, hφv2]; constructor
        · intro h; simp [t2_v1_e] at h
        · intro h; exact (G_v1v2_no h).elim
      · rw [hφv1, hφv3]; constructor
        · intro h; simp [t2_v1_e] at h
        · intro h; exact (G_v1v3_no h).elim
      · rw [hφv1, hφw]; constructor
        · intro _; exact G_wv1.symm
        · intro _; simp [t2_v1_e, SimpleGraph.fromRel_adj]
      · rw [hφv2, hφv0]; constructor
        · intro _; exact G_v0v2.symm
        · intro _; simp [t2_v1_e, SimpleGraph.fromRel_adj]
      · rw [hφv2, hφv1]; constructor
        · intro h; simp [t2_v1_e] at h
        · intro h; exact (G_v1v2_no h.symm).elim
      · rw [hφv2]; constructor
        · intro h; simp [t2_v1_e] at h
        · intro h; exact (G.str.1.irrefl h).elim
      · rw [hφv2, hφv3]; constructor
        · intro h; simp [t2_v1_e] at h
        · intro h; exact (G_v2v3_no h).elim
      · rw [hφv2, hφw]; constructor
        · intro _; exact h_yes_v2.symm
        · intro _; simp [t2_v1_e, SimpleGraph.fromRel_adj]
      · rw [hφv3, hφv0]; constructor
        · intro _; exact G_v0v3.symm
        · intro _; simp [t2_v1_e, SimpleGraph.fromRel_adj]
      · rw [hφv3, hφv1]; constructor
        · intro h; simp [t2_v1_e] at h
        · intro h; exact (G_v1v3_no h.symm).elim
      · rw [hφv3, hφv2]; constructor
        · intro h; simp [t2_v1_e] at h
        · intro h; exact (G_v2v3_no h.symm).elim
      · rw [hφv3]; constructor
        · intro h; simp [t2_v1_e] at h
        · intro h; exact (G.str.1.irrefl h).elim
      · rw [hφv3, hφw]; constructor
        · intro h; simp [t2_v1_e] at h
        · intro h; exact (h_no_v3 h.symm).elim
      · rw [hφw, hφv0]; constructor
        · intro h; simp [t2_v1_e] at h
        · intro h; exact (h_no_v0 h).elim
      · rw [hφw, hφv1]; constructor
        · intro _; exact G_wv1
        · intro _; simp [t2_v1_e, SimpleGraph.fromRel_adj]
      · rw [hφw, hφv2]; constructor
        · intro _; exact h_yes_v2
        · intro _; simp [t2_v1_e, SimpleGraph.fromRel_adj]
      · rw [hφw, hφv3]; constructor
        · intro h; simp [t2_v1_e] at h
        · intro h; exact (h_no_v3 h).elim
      · rw [hφw]; constructor
        · intro h; simp [t2_v1_e] at h
        · intro h; exact (G.str.1.irrefl h).elim
    · funext x
      change t2_v1_e.str.2 (φ x) = G.str.2 x
      rcases x_cases x with hx | hx | hx | hx | hx <;> rw [hx]
      · rw [hφv0, hcol_v0]; rfl
      · rw [hφv1, hcol_v1]; rfl
      · rw [hφv2, hcol_v2]; rfl
      · rw [hφv3, hcol_v3]; rfl
      · rw [hφw, h_w_B]; rfl
  · intro i
    fin_cases i
    · simp [t2_v1_e, Fin.castLE]; exact hφv0
    · simp [t2_v1_e, Fin.castLE]; exact hφv1
    · simp [t2_v1_e, Fin.castLE]; exact hφv2
    · simp [t2_v1_e, Fin.castLE]; exact hφv3

/-! ### σ₂-3.2 case f: v1-side B, leaf-set {v2,v3} → t2_v1_f (K_{3,2}) -/

set_option maxHeartbeats 1600000 in
theorem t2_v1_f_classification (G : GenFlag CG2 thesisType2)
    (h_size : G.size = 5)
    (h_ext : extAdjacency thesisType2 G ⟨1, by decide⟩)
    (h_w_B : G.str.2 (extVertex G h_size) = 1)
    (h_no_v0 : ¬G.str.1.Adj (extVertex G h_size) (G.embedding ⟨0, by decide⟩))
    (h_yes_v2 : G.str.1.Adj (extVertex G h_size) (G.embedding ⟨2, by decide⟩))
    (h_yes_v3 : G.str.1.Adj (extVertex G h_size) (G.embedding ⟨3, by decide⟩)) :
    GenFlagIso thesisType2 G t2_v1_f := by
  classical
  set v0 := G.embedding ⟨0, by decide⟩ with hv0
  set v1 := G.embedding ⟨1, by decide⟩ with hv1
  set v2 := G.embedding ⟨2, by decide⟩ with hv2
  set v3 := G.embedding ⟨3, by decide⟩ with hv3
  set w := extVertex G h_size with hw
  have hv01 : v0 ≠ v1 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv02 : v0 ≠ v2 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv03 : v0 ≠ v3 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv12 : v1 ≠ v2 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv13 : v1 ≠ v3 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv23 : v2 ≠ v3 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hw_notin : w ∉ Set.range G.embedding := extVertex_notin_range G h_size
  have hwv0 : w ≠ v0 := fun h => hw_notin ⟨⟨0, by decide⟩, h.symm⟩
  have hwv1 : w ≠ v1 := fun h => hw_notin ⟨⟨1, by decide⟩, h.symm⟩
  have hwv2 : w ≠ v2 := fun h => hw_notin ⟨⟨2, by decide⟩, h.symm⟩
  have hwv3 : w ≠ v3 := fun h => hw_notin ⟨⟨3, by decide⟩, h.symm⟩
  have h_str_eq : (CG2.comap G.embedding G.str).1 = thesisType2.str.1 :=
    congr_arg Prod.fst G.isInduced
  have h_col_eq : ∀ j : Fin thesisType2.size,
      G.str.2 (G.embedding j) = thesisType2.str.2 j := fun j =>
    congr_fun (congr_arg Prod.snd G.isInduced) j
  have G_v0v1 : G.str.1.Adj v0 v1 := by
    have h_sigma : thesisType2.str.1.Adj ⟨0, by decide⟩ ⟨1, by decide⟩ := by
      simp [thesisType2, SimpleGraph.fromRel_adj]
    rw [← h_str_eq] at h_sigma; exact h_sigma
  have G_v0v2 : G.str.1.Adj v0 v2 := by
    have h_sigma : thesisType2.str.1.Adj ⟨0, by decide⟩ ⟨2, by decide⟩ := by
      simp [thesisType2, SimpleGraph.fromRel_adj]
    rw [← h_str_eq] at h_sigma; exact h_sigma
  have G_v0v3 : G.str.1.Adj v0 v3 := by
    have h_sigma : thesisType2.str.1.Adj ⟨0, by decide⟩ ⟨3, by decide⟩ := by
      simp [thesisType2, SimpleGraph.fromRel_adj]
    rw [← h_str_eq] at h_sigma; exact h_sigma
  have G_v1v2_no : ¬G.str.1.Adj v1 v2 := by
    intro h
    have h' : (CG2.comap G.embedding G.str).1.Adj ⟨1, by decide⟩ ⟨2, by decide⟩ := h
    rw [h_str_eq] at h'
    simp [thesisType2, SimpleGraph.fromRel_adj] at h'
  have G_v1v3_no : ¬G.str.1.Adj v1 v3 := by
    intro h
    have h' : (CG2.comap G.embedding G.str).1.Adj ⟨1, by decide⟩ ⟨3, by decide⟩ := h
    rw [h_str_eq] at h'
    simp [thesisType2, SimpleGraph.fromRel_adj] at h'
  have G_v2v3_no : ¬G.str.1.Adj v2 v3 := by
    intro h
    have h' : (CG2.comap G.embedding G.str).1.Adj ⟨2, by decide⟩ ⟨3, by decide⟩ := h
    rw [h_str_eq] at h'
    simp [thesisType2, SimpleGraph.fromRel_adj] at h'
  obtain ⟨v_ext, hv_ext_notin, hv_ext_adj⟩ := h_ext
  have hv_ext_eq : v_ext = w := extVertex_unique G h_size v_ext hv_ext_notin
  subst hv_ext_eq
  have G_wv1 : G.str.1.Adj w v1 := by rw [hv1]; exact hv_ext_adj
  have hcol_v0 : G.str.2 v0 = 1 := by rw [hv0, h_col_eq]; simp [thesisType2]
  have hcol_v1 : G.str.2 v1 = 0 := by rw [hv1, h_col_eq]; simp [thesisType2]
  have hcol_v2 : G.str.2 v2 = 0 := by rw [hv2, h_col_eq]; simp [thesisType2]
  have hcol_v3 : G.str.2 v3 = 0 := by rw [hv3, h_col_eq]; simp [thesisType2]
  let φ_fn : Fin G.size → Fin 5 := fun x =>
    if x = v0 then ⟨0, by decide⟩
    else if x = v1 then ⟨1, by decide⟩
    else if x = v2 then ⟨2, by decide⟩
    else if x = v3 then ⟨3, by decide⟩
    else ⟨4, by decide⟩
  have φv0 : φ_fn v0 = ⟨0, by decide⟩ := by simp [φ_fn]
  have φv1 : φ_fn v1 = ⟨1, by decide⟩ := by
    simp only [φ_fn]; rw [if_neg hv01.symm]; simp
  have φv2 : φ_fn v2 = ⟨2, by decide⟩ := by
    simp only [φ_fn]; rw [if_neg hv02.symm, if_neg hv12.symm]; simp
  have φv3 : φ_fn v3 = ⟨3, by decide⟩ := by
    simp only [φ_fn]
    rw [if_neg hv03.symm, if_neg hv13.symm, if_neg hv23.symm]; simp
  have φw : φ_fn w = ⟨4, by decide⟩ := by
    simp only [φ_fn]
    rw [if_neg hwv0, if_neg hwv1, if_neg hwv2, if_neg hwv3]
  have x_cases : ∀ x : Fin G.size, x = v0 ∨ x = v1 ∨ x = v2 ∨ x = v3 ∨ x = w := by
    intro x
    by_cases h0 : x = v0
    · exact Or.inl h0
    by_cases h1 : x = v1
    · exact Or.inr (Or.inl h1)
    by_cases h2 : x = v2
    · exact Or.inr (Or.inr (Or.inl h2))
    by_cases h3 : x = v3
    · exact Or.inr (Or.inr (Or.inr (Or.inl h3)))
    right; right; right; right
    apply extVertex_unique G h_size
    rintro ⟨⟨j, hj⟩, hj_eq⟩
    have hjlt : j < 4 := hj
    have hsize : thesisType2.size = 4 := rfl
    interval_cases j
    · exact h0 hj_eq.symm
    · exact h1 hj_eq.symm
    · exact h2 hj_eq.symm
    · exact h3 hj_eq.symm
  have φ_inj : Function.Injective φ_fn := by
    intro x y hxy
    rcases x_cases x with hx | hx | hx | hx | hx <;>
    rcases x_cases y with hy | hy | hy | hy | hy <;>
      subst hx <;> subst hy <;>
      first
      | rfl
      | (exfalso
         try rw [φv0] at hxy
         try rw [φv1] at hxy
         try rw [φv2] at hxy
         try rw [φv3] at hxy
         try rw [φw] at hxy
         exact absurd hxy (by decide))
  have hcard : Fintype.card (Fin G.size) = Fintype.card (Fin 5) := by
    rw [Fintype.card_fin, Fintype.card_fin, h_size]
  have φ_bij : Function.Bijective φ_fn :=
    (Fintype.bijective_iff_injective_and_card φ_fn).mpr ⟨φ_inj, hcard⟩
  let φ : Fin G.size ≃ Fin t2_v1_f.size := Equiv.ofBijective φ_fn φ_bij
  have hφv0 : φ v0 = ⟨0, by decide⟩ := φv0
  have hφv1 : φ v1 = ⟨1, by decide⟩ := φv1
  have hφv2 : φ v2 = ⟨2, by decide⟩ := φv2
  have hφv3 : φ v3 = ⟨3, by decide⟩ := φv3
  have hφw : φ w = ⟨4, by decide⟩ := φw
  refine ⟨φ, ?_, ?_⟩
  · apply Prod.ext
    · ext u v
      change (t2_v1_f.str.1.comap (φ : Fin G.size → Fin 5)).Adj u v ↔ G.str.1.Adj u v
      simp only [SimpleGraph.comap_adj]
      rcases x_cases u with hu | hu | hu | hu | hu <;>
      rcases x_cases v with hv | hv | hv | hv | hv <;>
        rw [hu, hv]
      · rw [hφv0]; constructor
        · intro h; simp [t2_v1_f] at h
        · intro h; exact (G.str.1.irrefl h).elim
      · rw [hφv0, hφv1]; constructor
        · intro _; exact G_v0v1
        · intro _; simp [t2_v1_f, SimpleGraph.fromRel_adj]
      · rw [hφv0, hφv2]; constructor
        · intro _; exact G_v0v2
        · intro _; simp [t2_v1_f, SimpleGraph.fromRel_adj]
      · rw [hφv0, hφv3]; constructor
        · intro _; exact G_v0v3
        · intro _; simp [t2_v1_f, SimpleGraph.fromRel_adj]
      · rw [hφv0, hφw]; constructor
        · intro h; simp [t2_v1_f] at h
        · intro h; exact (h_no_v0 h.symm).elim
      · rw [hφv1, hφv0]; constructor
        · intro _; exact G_v0v1.symm
        · intro _; simp [t2_v1_f, SimpleGraph.fromRel_adj]
      · rw [hφv1]; constructor
        · intro h; simp [t2_v1_f] at h
        · intro h; exact (G.str.1.irrefl h).elim
      · rw [hφv1, hφv2]; constructor
        · intro h; simp [t2_v1_f] at h
        · intro h; exact (G_v1v2_no h).elim
      · rw [hφv1, hφv3]; constructor
        · intro h; simp [t2_v1_f] at h
        · intro h; exact (G_v1v3_no h).elim
      · rw [hφv1, hφw]; constructor
        · intro _; exact G_wv1.symm
        · intro _; simp [t2_v1_f, SimpleGraph.fromRel_adj]
      · rw [hφv2, hφv0]; constructor
        · intro _; exact G_v0v2.symm
        · intro _; simp [t2_v1_f, SimpleGraph.fromRel_adj]
      · rw [hφv2, hφv1]; constructor
        · intro h; simp [t2_v1_f] at h
        · intro h; exact (G_v1v2_no h.symm).elim
      · rw [hφv2]; constructor
        · intro h; simp [t2_v1_f] at h
        · intro h; exact (G.str.1.irrefl h).elim
      · rw [hφv2, hφv3]; constructor
        · intro h; simp [t2_v1_f] at h
        · intro h; exact (G_v2v3_no h).elim
      · rw [hφv2, hφw]; constructor
        · intro _; exact h_yes_v2.symm
        · intro _; simp [t2_v1_f, SimpleGraph.fromRel_adj]
      · rw [hφv3, hφv0]; constructor
        · intro _; exact G_v0v3.symm
        · intro _; simp [t2_v1_f, SimpleGraph.fromRel_adj]
      · rw [hφv3, hφv1]; constructor
        · intro h; simp [t2_v1_f] at h
        · intro h; exact (G_v1v3_no h.symm).elim
      · rw [hφv3, hφv2]; constructor
        · intro h; simp [t2_v1_f] at h
        · intro h; exact (G_v2v3_no h.symm).elim
      · rw [hφv3]; constructor
        · intro h; simp [t2_v1_f] at h
        · intro h; exact (G.str.1.irrefl h).elim
      · rw [hφv3, hφw]; constructor
        · intro _; exact h_yes_v3.symm
        · intro _; simp [t2_v1_f, SimpleGraph.fromRel_adj]
      · rw [hφw, hφv0]; constructor
        · intro h; simp [t2_v1_f] at h
        · intro h; exact (h_no_v0 h).elim
      · rw [hφw, hφv1]; constructor
        · intro _; exact G_wv1
        · intro _; simp [t2_v1_f, SimpleGraph.fromRel_adj]
      · rw [hφw, hφv2]; constructor
        · intro _; exact h_yes_v2
        · intro _; simp [t2_v1_f, SimpleGraph.fromRel_adj]
      · rw [hφw, hφv3]; constructor
        · intro _; exact h_yes_v3
        · intro _; simp [t2_v1_f, SimpleGraph.fromRel_adj]
      · rw [hφw]; constructor
        · intro h; simp [t2_v1_f] at h
        · intro h; exact (G.str.1.irrefl h).elim
    · funext x
      change t2_v1_f.str.2 (φ x) = G.str.2 x
      rcases x_cases x with hx | hx | hx | hx | hx <;> rw [hx]
      · rw [hφv0, hcol_v0]; rfl
      · rw [hφv1, hcol_v1]; rfl
      · rw [hφv2, hcol_v2]; rfl
      · rw [hφv3, hcol_v3]; rfl
      · rw [hφw, h_w_B]; rfl
  · intro i
    fin_cases i
    · simp [t2_v1_f, Fin.castLE]; exact hφv0
    · simp [t2_v1_f, Fin.castLE]; exact hφv1
    · simp [t2_v1_f, Fin.castLE]; exact hφv2
    · simp [t2_v1_f, Fin.castLE]; exact hφv3

/-! ### σ₂-3.2 case h: v1-side B, leaf-set {v3} → t2_v1_h -/

set_option maxHeartbeats 1600000 in
theorem t2_v1_h_classification (G : GenFlag CG2 thesisType2)
    (h_size : G.size = 5)
    (h_ext : extAdjacency thesisType2 G ⟨1, by decide⟩)
    (h_w_B : G.str.2 (extVertex G h_size) = 1)
    (h_no_v0 : ¬G.str.1.Adj (extVertex G h_size) (G.embedding ⟨0, by decide⟩))
    (h_no_v2 : ¬G.str.1.Adj (extVertex G h_size) (G.embedding ⟨2, by decide⟩))
    (h_yes_v3 : G.str.1.Adj (extVertex G h_size) (G.embedding ⟨3, by decide⟩)) :
    GenFlagIso thesisType2 G t2_v1_h := by
  classical
  set v0 := G.embedding ⟨0, by decide⟩ with hv0
  set v1 := G.embedding ⟨1, by decide⟩ with hv1
  set v2 := G.embedding ⟨2, by decide⟩ with hv2
  set v3 := G.embedding ⟨3, by decide⟩ with hv3
  set w := extVertex G h_size with hw
  have hv01 : v0 ≠ v1 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv02 : v0 ≠ v2 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv03 : v0 ≠ v3 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv12 : v1 ≠ v2 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv13 : v1 ≠ v3 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv23 : v2 ≠ v3 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hw_notin : w ∉ Set.range G.embedding := extVertex_notin_range G h_size
  have hwv0 : w ≠ v0 := fun h => hw_notin ⟨⟨0, by decide⟩, h.symm⟩
  have hwv1 : w ≠ v1 := fun h => hw_notin ⟨⟨1, by decide⟩, h.symm⟩
  have hwv2 : w ≠ v2 := fun h => hw_notin ⟨⟨2, by decide⟩, h.symm⟩
  have hwv3 : w ≠ v3 := fun h => hw_notin ⟨⟨3, by decide⟩, h.symm⟩
  have h_str_eq : (CG2.comap G.embedding G.str).1 = thesisType2.str.1 :=
    congr_arg Prod.fst G.isInduced
  have h_col_eq : ∀ j : Fin thesisType2.size,
      G.str.2 (G.embedding j) = thesisType2.str.2 j := fun j =>
    congr_fun (congr_arg Prod.snd G.isInduced) j
  have G_v0v1 : G.str.1.Adj v0 v1 := by
    have h_sigma : thesisType2.str.1.Adj ⟨0, by decide⟩ ⟨1, by decide⟩ := by
      simp [thesisType2, SimpleGraph.fromRel_adj]
    rw [← h_str_eq] at h_sigma; exact h_sigma
  have G_v0v2 : G.str.1.Adj v0 v2 := by
    have h_sigma : thesisType2.str.1.Adj ⟨0, by decide⟩ ⟨2, by decide⟩ := by
      simp [thesisType2, SimpleGraph.fromRel_adj]
    rw [← h_str_eq] at h_sigma; exact h_sigma
  have G_v0v3 : G.str.1.Adj v0 v3 := by
    have h_sigma : thesisType2.str.1.Adj ⟨0, by decide⟩ ⟨3, by decide⟩ := by
      simp [thesisType2, SimpleGraph.fromRel_adj]
    rw [← h_str_eq] at h_sigma; exact h_sigma
  have G_v1v2_no : ¬G.str.1.Adj v1 v2 := by
    intro h
    have h' : (CG2.comap G.embedding G.str).1.Adj ⟨1, by decide⟩ ⟨2, by decide⟩ := h
    rw [h_str_eq] at h'
    simp [thesisType2, SimpleGraph.fromRel_adj] at h'
  have G_v1v3_no : ¬G.str.1.Adj v1 v3 := by
    intro h
    have h' : (CG2.comap G.embedding G.str).1.Adj ⟨1, by decide⟩ ⟨3, by decide⟩ := h
    rw [h_str_eq] at h'
    simp [thesisType2, SimpleGraph.fromRel_adj] at h'
  have G_v2v3_no : ¬G.str.1.Adj v2 v3 := by
    intro h
    have h' : (CG2.comap G.embedding G.str).1.Adj ⟨2, by decide⟩ ⟨3, by decide⟩ := h
    rw [h_str_eq] at h'
    simp [thesisType2, SimpleGraph.fromRel_adj] at h'
  obtain ⟨v_ext, hv_ext_notin, hv_ext_adj⟩ := h_ext
  have hv_ext_eq : v_ext = w := extVertex_unique G h_size v_ext hv_ext_notin
  subst hv_ext_eq
  have G_wv1 : G.str.1.Adj w v1 := by rw [hv1]; exact hv_ext_adj
  have hcol_v0 : G.str.2 v0 = 1 := by rw [hv0, h_col_eq]; simp [thesisType2]
  have hcol_v1 : G.str.2 v1 = 0 := by rw [hv1, h_col_eq]; simp [thesisType2]
  have hcol_v2 : G.str.2 v2 = 0 := by rw [hv2, h_col_eq]; simp [thesisType2]
  have hcol_v3 : G.str.2 v3 = 0 := by rw [hv3, h_col_eq]; simp [thesisType2]
  let φ_fn : Fin G.size → Fin 5 := fun x =>
    if x = v0 then ⟨0, by decide⟩
    else if x = v1 then ⟨1, by decide⟩
    else if x = v2 then ⟨2, by decide⟩
    else if x = v3 then ⟨3, by decide⟩
    else ⟨4, by decide⟩
  have φv0 : φ_fn v0 = ⟨0, by decide⟩ := by simp [φ_fn]
  have φv1 : φ_fn v1 = ⟨1, by decide⟩ := by
    simp only [φ_fn]; rw [if_neg hv01.symm]; simp
  have φv2 : φ_fn v2 = ⟨2, by decide⟩ := by
    simp only [φ_fn]; rw [if_neg hv02.symm, if_neg hv12.symm]; simp
  have φv3 : φ_fn v3 = ⟨3, by decide⟩ := by
    simp only [φ_fn]
    rw [if_neg hv03.symm, if_neg hv13.symm, if_neg hv23.symm]; simp
  have φw : φ_fn w = ⟨4, by decide⟩ := by
    simp only [φ_fn]
    rw [if_neg hwv0, if_neg hwv1, if_neg hwv2, if_neg hwv3]
  have x_cases : ∀ x : Fin G.size, x = v0 ∨ x = v1 ∨ x = v2 ∨ x = v3 ∨ x = w := by
    intro x
    by_cases h0 : x = v0
    · exact Or.inl h0
    by_cases h1 : x = v1
    · exact Or.inr (Or.inl h1)
    by_cases h2 : x = v2
    · exact Or.inr (Or.inr (Or.inl h2))
    by_cases h3 : x = v3
    · exact Or.inr (Or.inr (Or.inr (Or.inl h3)))
    right; right; right; right
    apply extVertex_unique G h_size
    rintro ⟨⟨j, hj⟩, hj_eq⟩
    have hjlt : j < 4 := hj
    have hsize : thesisType2.size = 4 := rfl
    interval_cases j
    · exact h0 hj_eq.symm
    · exact h1 hj_eq.symm
    · exact h2 hj_eq.symm
    · exact h3 hj_eq.symm
  have φ_inj : Function.Injective φ_fn := by
    intro x y hxy
    rcases x_cases x with hx | hx | hx | hx | hx <;>
    rcases x_cases y with hy | hy | hy | hy | hy <;>
      subst hx <;> subst hy <;>
      first
      | rfl
      | (exfalso
         try rw [φv0] at hxy
         try rw [φv1] at hxy
         try rw [φv2] at hxy
         try rw [φv3] at hxy
         try rw [φw] at hxy
         exact absurd hxy (by decide))
  have hcard : Fintype.card (Fin G.size) = Fintype.card (Fin 5) := by
    rw [Fintype.card_fin, Fintype.card_fin, h_size]
  have φ_bij : Function.Bijective φ_fn :=
    (Fintype.bijective_iff_injective_and_card φ_fn).mpr ⟨φ_inj, hcard⟩
  let φ : Fin G.size ≃ Fin t2_v1_h.size := Equiv.ofBijective φ_fn φ_bij
  have hφv0 : φ v0 = ⟨0, by decide⟩ := φv0
  have hφv1 : φ v1 = ⟨1, by decide⟩ := φv1
  have hφv2 : φ v2 = ⟨2, by decide⟩ := φv2
  have hφv3 : φ v3 = ⟨3, by decide⟩ := φv3
  have hφw : φ w = ⟨4, by decide⟩ := φw
  refine ⟨φ, ?_, ?_⟩
  · apply Prod.ext
    · ext u v
      change (t2_v1_h.str.1.comap (φ : Fin G.size → Fin 5)).Adj u v ↔ G.str.1.Adj u v
      simp only [SimpleGraph.comap_adj]
      rcases x_cases u with hu | hu | hu | hu | hu <;>
      rcases x_cases v with hv | hv | hv | hv | hv <;>
        rw [hu, hv]
      · rw [hφv0]; constructor
        · intro h; simp [t2_v1_h] at h
        · intro h; exact (G.str.1.irrefl h).elim
      · rw [hφv0, hφv1]; constructor
        · intro _; exact G_v0v1
        · intro _; simp [t2_v1_h, SimpleGraph.fromRel_adj]
      · rw [hφv0, hφv2]; constructor
        · intro _; exact G_v0v2
        · intro _; simp [t2_v1_h, SimpleGraph.fromRel_adj]
      · rw [hφv0, hφv3]; constructor
        · intro _; exact G_v0v3
        · intro _; simp [t2_v1_h, SimpleGraph.fromRel_adj]
      · rw [hφv0, hφw]; constructor
        · intro h; simp [t2_v1_h] at h
        · intro h; exact (h_no_v0 h.symm).elim
      · rw [hφv1, hφv0]; constructor
        · intro _; exact G_v0v1.symm
        · intro _; simp [t2_v1_h, SimpleGraph.fromRel_adj]
      · rw [hφv1]; constructor
        · intro h; simp [t2_v1_h] at h
        · intro h; exact (G.str.1.irrefl h).elim
      · rw [hφv1, hφv2]; constructor
        · intro h; simp [t2_v1_h] at h
        · intro h; exact (G_v1v2_no h).elim
      · rw [hφv1, hφv3]; constructor
        · intro h; simp [t2_v1_h] at h
        · intro h; exact (G_v1v3_no h).elim
      · rw [hφv1, hφw]; constructor
        · intro _; exact G_wv1.symm
        · intro _; simp [t2_v1_h, SimpleGraph.fromRel_adj]
      · rw [hφv2, hφv0]; constructor
        · intro _; exact G_v0v2.symm
        · intro _; simp [t2_v1_h, SimpleGraph.fromRel_adj]
      · rw [hφv2, hφv1]; constructor
        · intro h; simp [t2_v1_h] at h
        · intro h; exact (G_v1v2_no h.symm).elim
      · rw [hφv2]; constructor
        · intro h; simp [t2_v1_h] at h
        · intro h; exact (G.str.1.irrefl h).elim
      · rw [hφv2, hφv3]; constructor
        · intro h; simp [t2_v1_h] at h
        · intro h; exact (G_v2v3_no h).elim
      · rw [hφv2, hφw]; constructor
        · intro h; simp [t2_v1_h] at h
        · intro h; exact (h_no_v2 h.symm).elim
      · rw [hφv3, hφv0]; constructor
        · intro _; exact G_v0v3.symm
        · intro _; simp [t2_v1_h, SimpleGraph.fromRel_adj]
      · rw [hφv3, hφv1]; constructor
        · intro h; simp [t2_v1_h] at h
        · intro h; exact (G_v1v3_no h.symm).elim
      · rw [hφv3, hφv2]; constructor
        · intro h; simp [t2_v1_h] at h
        · intro h; exact (G_v2v3_no h.symm).elim
      · rw [hφv3]; constructor
        · intro h; simp [t2_v1_h] at h
        · intro h; exact (G.str.1.irrefl h).elim
      · rw [hφv3, hφw]; constructor
        · intro _; exact h_yes_v3.symm
        · intro _; simp [t2_v1_h, SimpleGraph.fromRel_adj]
      · rw [hφw, hφv0]; constructor
        · intro h; simp [t2_v1_h] at h
        · intro h; exact (h_no_v0 h).elim
      · rw [hφw, hφv1]; constructor
        · intro _; exact G_wv1
        · intro _; simp [t2_v1_h, SimpleGraph.fromRel_adj]
      · rw [hφw, hφv2]; constructor
        · intro h; simp [t2_v1_h] at h
        · intro h; exact (h_no_v2 h).elim
      · rw [hφw, hφv3]; constructor
        · intro _; exact h_yes_v3
        · intro _; simp [t2_v1_h, SimpleGraph.fromRel_adj]
      · rw [hφw]; constructor
        · intro h; simp [t2_v1_h] at h
        · intro h; exact (G.str.1.irrefl h).elim
    · funext x
      change t2_v1_h.str.2 (φ x) = G.str.2 x
      rcases x_cases x with hx | hx | hx | hx | hx <;> rw [hx]
      · rw [hφv0, hcol_v0]; rfl
      · rw [hφv1, hcol_v1]; rfl
      · rw [hφv2, hcol_v2]; rfl
      · rw [hφv3, hcol_v3]; rfl
      · rw [hφw, h_w_B]; rfl
  · intro i
    fin_cases i
    · simp [t2_v1_h, Fin.castLE]; exact hφv0
    · simp [t2_v1_h, Fin.castLE]; exact hφv1
    · simp [t2_v1_h, Fin.castLE]; exact hφv2
    · simp [t2_v1_h, Fin.castLE]; exact hφv3

/-! ### σ₂-3.3: extAdj-v0 dichotomy (thesisType2)

For any size-5 thesisType2-flag class `cls` with `extAdjacencyClass cls v0`,
EITHER `cls = ⟦t2_v0⟧` OR `phi.eval cls.out.forget = 0`. The BRRB extractor
`t2_extAdj_v0_BRRB_constraints` gives all 4 forcing constraints directly
(no further case-split). -/
theorem t2_extAdj_v0_dichotomy
    (cls : GenFlagClass CG2 thesisType2)
    (h_size : cls.out.size = 5)
    (h_extAdj : extAdjacencyClass thesisType2 cls ⟨0, by decide⟩)
    (phi : GenLimitFunctional CG2 (GenFlagType.empty CG2)
      brrbGenGraphClass brrbGenDelta) :
    cls = GenFlagClass.mk t2_v0 ∨
    phi.eval cls.out.forget = 0 := by
  classical
  have h_ext : extAdjacency thesisType2 cls.out ⟨0, by decide⟩ := h_extAdj
  by_cases h_BB : ∃ u v : Fin cls.out.size,
      cls.out.str.2 u = 1 ∧ cls.out.str.2 v = 1 ∧ cls.out.str.1.Adj u v
  · right
    exact eval_zero_of_adj_black phi cls.out.forget h_BB
  by_cases h_tri : ∃ u v w : Fin cls.out.size,
      cls.out.str.1.Adj u v ∧ cls.out.str.1.Adj v w ∧ cls.out.str.1.Adj u w
  · right
    exact eval_zero_of_triangle phi cls.out.forget h_tri
  obtain ⟨h_w_R, h_no_v1, h_no_v2, h_no_v3⟩ :=
    t2_extAdj_v0_BRRB_constraints cls.out h_size h_ext h_BB h_tri
  left
  have hiso := t2_v0_classification cls.out h_size h_ext h_w_R h_no_v1 h_no_v2 h_no_v3
  have hmk : GenFlagClass.mk cls.out = GenFlagClass.mk t2_v0 :=
    Quotient.sound hiso
  rw [← Quotient.out_eq cls]; exact hmk

/-! ### σ₂-3.3: extAdj-v1 dichotomy (thesisType2)

For any size-5 thesisType2-flag class `cls` with `extAdjacencyClass cls v1`,
EITHER `cls` is iso to one of the 8 v1-side ext witnesses, OR
`phi.eval cls.out.forget = 0`. After ruling out BB-edge / triangle and
extracting `¬w-v0`, case-split on color of w (R or B) and (w-v2, w-v3). -/
set_option maxHeartbeats 800000 in
theorem t2_extAdj_v1_dichotomy
    (cls : GenFlagClass CG2 thesisType2)
    (h_size : cls.out.size = 5)
    (h_extAdj : extAdjacencyClass thesisType2 cls ⟨1, by decide⟩)
    (phi : GenLimitFunctional CG2 (GenFlagType.empty CG2)
      brrbGenGraphClass brrbGenDelta) :
    cls = GenFlagClass.mk t2_v1_a ∨
    cls = GenFlagClass.mk t2_v1_b ∨
    cls = GenFlagClass.mk t2_v1_c ∨
    cls = GenFlagClass.mk t2_v1_g ∨
    cls = GenFlagClass.mk t2_v1_d ∨
    cls = GenFlagClass.mk t2_v1_e ∨
    cls = GenFlagClass.mk t2_v1_f ∨
    cls = GenFlagClass.mk t2_v1_h ∨
    phi.eval cls.out.forget = 0 := by
  classical
  have h_ext : extAdjacency thesisType2 cls.out ⟨1, by decide⟩ := h_extAdj
  by_cases h_BB : ∃ u v : Fin cls.out.size,
      cls.out.str.2 u = 1 ∧ cls.out.str.2 v = 1 ∧ cls.out.str.1.Adj u v
  · right; right; right; right; right; right; right; right
    exact eval_zero_of_adj_black phi cls.out.forget h_BB
  by_cases h_tri : ∃ u v w : Fin cls.out.size,
      cls.out.str.1.Adj u v ∧ cls.out.str.1.Adj v w ∧ cls.out.str.1.Adj u w
  · right; right; right; right; right; right; right; right
    exact eval_zero_of_triangle phi cls.out.forget h_tri
  have h_no_v0 := t2_extAdj_v1_BRRB_not_adj_v0 cls.out h_size h_ext h_BB h_tri
  set w := extVertex cls.out h_size with hw_def
  set v2 := cls.out.embedding ⟨2, by decide⟩ with hv2_def
  set v3 := cls.out.embedding ⟨3, by decide⟩ with hv3_def
  have hcol_lt : (cls.out.str.2 w).val < 2 := (cls.out.str.2 w).isLt
  interval_cases h_w_col : (cls.out.str.2 w).val
  · -- w coloured R (col=0)
    have h_w_R : cls.out.str.2 w = 0 := Fin.ext h_w_col
    by_cases h_v2 : cls.out.str.1.Adj w v2
    · by_cases h_v3 : cls.out.str.1.Adj w v3
      · -- (R, T, T) → t2_v1_c
        right; right; left
        have hiso := t2_v1_c_classification cls.out h_size h_ext h_w_R h_no_v0 h_v2 h_v3
        have hmk : GenFlagClass.mk cls.out = GenFlagClass.mk t2_v1_c :=
          Quotient.sound hiso
        rw [← Quotient.out_eq cls]; exact hmk
      · -- (R, T, F) → t2_v1_b
        right; left
        have hiso := t2_v1_b_classification cls.out h_size h_ext h_w_R h_no_v0 h_v2 h_v3
        have hmk : GenFlagClass.mk cls.out = GenFlagClass.mk t2_v1_b :=
          Quotient.sound hiso
        rw [← Quotient.out_eq cls]; exact hmk
    · by_cases h_v3 : cls.out.str.1.Adj w v3
      · -- (R, F, T) → t2_v1_g
        right; right; right; left
        have hiso := t2_v1_g_classification cls.out h_size h_ext h_w_R h_no_v0 h_v2 h_v3
        have hmk : GenFlagClass.mk cls.out = GenFlagClass.mk t2_v1_g :=
          Quotient.sound hiso
        rw [← Quotient.out_eq cls]; exact hmk
      · -- (R, F, F) → t2_v1_a
        left
        have hiso := t2_v1_a_classification cls.out h_size h_ext h_w_R h_no_v0 h_v2 h_v3
        have hmk : GenFlagClass.mk cls.out = GenFlagClass.mk t2_v1_a :=
          Quotient.sound hiso
        rw [← Quotient.out_eq cls]; exact hmk
  · -- w coloured B (col=1)
    have h_w_B : cls.out.str.2 w = 1 := Fin.ext h_w_col
    by_cases h_v2 : cls.out.str.1.Adj w v2
    · by_cases h_v3 : cls.out.str.1.Adj w v3
      · -- (B, T, T) → t2_v1_f
        right; right; right; right; right; right; left
        have hiso := t2_v1_f_classification cls.out h_size h_ext h_w_B h_no_v0 h_v2 h_v3
        have hmk : GenFlagClass.mk cls.out = GenFlagClass.mk t2_v1_f :=
          Quotient.sound hiso
        rw [← Quotient.out_eq cls]; exact hmk
      · -- (B, T, F) → t2_v1_e
        right; right; right; right; right; left
        have hiso := t2_v1_e_classification cls.out h_size h_ext h_w_B h_no_v0 h_v2 h_v3
        have hmk : GenFlagClass.mk cls.out = GenFlagClass.mk t2_v1_e :=
          Quotient.sound hiso
        rw [← Quotient.out_eq cls]; exact hmk
    · by_cases h_v3 : cls.out.str.1.Adj w v3
      · -- (B, F, T) → t2_v1_h
        right; right; right; right; right; right; right; left
        have hiso := t2_v1_h_classification cls.out h_size h_ext h_w_B h_no_v0 h_v2 h_v3
        have hmk : GenFlagClass.mk cls.out = GenFlagClass.mk t2_v1_h :=
          Quotient.sound hiso
        rw [← Quotient.out_eq cls]; exact hmk
      · -- (B, F, F) → t2_v1_d
        right; right; right; right; left
        have hiso := t2_v1_d_classification cls.out h_size h_ext h_w_B h_no_v0 h_v2 h_v3
        have hmk : GenFlagClass.mk cls.out = GenFlagClass.mk t2_v1_d :=
          Quotient.sound hiso
        rw [← Quotient.out_eq cls]; exact hmk

/-! ### σ₅-3: BRRB constraint extractors

Extract structural constraints on the ext vertex w of a thesisType5-flag G
from BRRB hypotheses (no BB-edge, no triangle) + extAdj at the cert-pair side.

- v2-side: w is R (since v2=B, w-v2 BB-edge would form) AND w not adj v0
  (since v0-v2 is a σ-edge, w-v0-v2 would be a triangle).
- v0-side: w not adj v1 AND w not adj v2 (σ-edges v0-v1, v0-v2 would each
  form a triangle with w-v0-vᵢ). No colour constraint on w. -/

/-- v2-side BRRB constraints: w is R and w is not adjacent to v0. -/
theorem t5_extAdj_v2_BRRB_w_R_not_adj_v0
    (G : GenFlag CG2 thesisType5) (h_size : G.size = 5)
    (h_ext : extAdjacency thesisType5 G ⟨2, by decide⟩)
    (h_no_BB : ¬∃ u v : Fin G.size,
      G.str.2 u = 1 ∧ G.str.2 v = 1 ∧ G.str.1.Adj u v)
    (h_no_tri : ¬∃ u v w : Fin G.size,
      G.str.1.Adj u v ∧ G.str.1.Adj v w ∧ G.str.1.Adj u w) :
    G.str.2 (extVertex G h_size) = 0 ∧
    ¬G.str.1.Adj (extVertex G h_size) (G.embedding ⟨0, by decide⟩) := by
  set w := extVertex G h_size with hw_def
  obtain ⟨v, hv_notin, hv_adj_v2⟩ := h_ext
  have hv_eq : v = w := extVertex_unique G h_size v hv_notin
  subst hv_eq
  set v0 := G.embedding ⟨0, by decide⟩ with hv0
  set v2 := G.embedding ⟨2, by decide⟩ with hv2
  have hcomap : (CG2.comap G.embedding G.str).1 = thesisType5.str.1 :=
    congr_arg Prod.fst G.isInduced
  -- v2 has σ-colour 1 (= B) by isInduced
  have hcol_v2 : G.str.2 v2 = 1 := by
    have h1 : (CG2.comap G.embedding G.str).2 ⟨2, by decide⟩ = thesisType5.str.2 ⟨2, by decide⟩ :=
      congr_fun (congr_arg Prod.snd G.isInduced) ⟨2, by decide⟩
    have h2 : G.str.2 (G.embedding ⟨2, by decide⟩) = thesisType5.str.2 ⟨2, by decide⟩ := h1
    rw [hv2, h2]; simp [thesisType5]
  -- v0-v2 is a σ-edge → in G.
  have hv0_adj_v2 : G.str.1.Adj v0 v2 := by
    have h_sigma : thesisType5.str.1.Adj ⟨0, by decide⟩ ⟨2, by decide⟩ := by
      simp [thesisType5, SimpleGraph.fromRel_adj]
    rw [← hcomap] at h_sigma; exact h_sigma
  refine ⟨?_, ?_⟩
  · by_contra hwc
    have hwc1 : G.str.2 w = 1 := by
      have hlt : (G.str.2 w).val < 2 := (G.str.2 w).isLt
      interval_cases h : (G.str.2 w).val
      · exfalso; apply hwc; exact Fin.ext h
      · exact Fin.ext h
    apply h_no_BB
    refine ⟨w, v2, hwc1, hcol_v2, ?_⟩
    rw [hv2] at hv_adj_v2; exact hv_adj_v2
  · intro h_w_v0
    apply h_no_tri
    -- triangle v0-v2-w: v0-v2 (σ), v2-w (extAdj), v0-w (assumed)
    refine ⟨v0, v2, w, hv0_adj_v2, ?_, h_w_v0.symm⟩
    rw [hv2] at hv_adj_v2; exact hv_adj_v2.symm

/-! ### σ₅-3 case 1: classification for w=R adj v2 only

Given the BRRB constraints from `t5_extAdj_v2_BRRB_w_R_not_adj_v0` plus the
case 1 hypotheses (w not adjacent to v1 or v3), the σ-flag G is forced to
be σ-iso to `t5_v2_a` (P₄ with extra v2-w edge, w R). -/

set_option maxHeartbeats 1600000 in
-- Increased heartbeats: 25-case graph dispatch with simp [t5_v2_a] in each branch.
/-- Case 1 of σ₅-3: any size-5 thesisType5-flag G with extAdj-v2, w coloured
    R, and w not adjacent to v0, v1, v3 is σ-iso to the canonical witness
    `t5_v2_a` (the only adjacency of w is to v2, which is forced by extAdj-v2). -/
theorem t5_v2_a_classification (G : GenFlag CG2 thesisType5)
    (h_size : G.size = 5)
    (h_ext : extAdjacency thesisType5 G ⟨2, by decide⟩)
    (h_w_R : G.str.2 (extVertex G h_size) = 0)
    (h_no_v0 : ¬G.str.1.Adj (extVertex G h_size) (G.embedding ⟨0, by decide⟩))
    (h_no_v1 : ¬G.str.1.Adj (extVertex G h_size) (G.embedding ⟨1, by decide⟩))
    (h_no_v3 : ¬G.str.1.Adj (extVertex G h_size) (G.embedding ⟨3, by decide⟩)) :
    GenFlagIso thesisType5 G t5_v2_a := by
  classical
  set v0 := G.embedding ⟨0, by decide⟩ with hv0
  set v1 := G.embedding ⟨1, by decide⟩ with hv1
  set v2 := G.embedding ⟨2, by decide⟩ with hv2
  set v3 := G.embedding ⟨3, by decide⟩ with hv3
  set w := extVertex G h_size with hw
  have hv01 : v0 ≠ v1 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv02 : v0 ≠ v2 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv03 : v0 ≠ v3 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv12 : v1 ≠ v2 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv13 : v1 ≠ v3 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv23 : v2 ≠ v3 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hw_notin : w ∉ Set.range G.embedding := extVertex_notin_range G h_size
  have hwv0 : w ≠ v0 := fun h => hw_notin ⟨⟨0, by decide⟩, h.symm⟩
  have hwv1 : w ≠ v1 := fun h => hw_notin ⟨⟨1, by decide⟩, h.symm⟩
  have hwv2 : w ≠ v2 := fun h => hw_notin ⟨⟨2, by decide⟩, h.symm⟩
  have hwv3 : w ≠ v3 := fun h => hw_notin ⟨⟨3, by decide⟩, h.symm⟩
  have h_str_eq : (CG2.comap G.embedding G.str).1 = thesisType5.str.1 :=
    congr_arg Prod.fst G.isInduced
  have h_col_eq : ∀ j : Fin thesisType5.size,
      G.str.2 (G.embedding j) = thesisType5.str.2 j := fun j =>
    congr_fun (congr_arg Prod.snd G.isInduced) j
  -- σ-edges of thesisType5: 0-1, 0-2, 1-3.
  have G_v0v1 : G.str.1.Adj v0 v1 := by
    have h_sigma : thesisType5.str.1.Adj ⟨0, by decide⟩ ⟨1, by decide⟩ := by
      simp [thesisType5, SimpleGraph.fromRel_adj]
    rw [← h_str_eq] at h_sigma; exact h_sigma
  have G_v0v2 : G.str.1.Adj v0 v2 := by
    have h_sigma : thesisType5.str.1.Adj ⟨0, by decide⟩ ⟨2, by decide⟩ := by
      simp [thesisType5, SimpleGraph.fromRel_adj]
    rw [← h_str_eq] at h_sigma; exact h_sigma
  have G_v1v3 : G.str.1.Adj v1 v3 := by
    have h_sigma : thesisType5.str.1.Adj ⟨1, by decide⟩ ⟨3, by decide⟩ := by
      simp [thesisType5, SimpleGraph.fromRel_adj]
    rw [← h_str_eq] at h_sigma; exact h_sigma
  -- σ-non-edges of thesisType5: 0-3, 1-2, 2-3.
  have G_v0v3_no : ¬G.str.1.Adj v0 v3 := by
    intro h
    have h' : (CG2.comap G.embedding G.str).1.Adj ⟨0, by decide⟩ ⟨3, by decide⟩ := h
    rw [h_str_eq] at h'
    simp [thesisType5, SimpleGraph.fromRel_adj] at h'
  have G_v1v2_no : ¬G.str.1.Adj v1 v2 := by
    intro h
    have h' : (CG2.comap G.embedding G.str).1.Adj ⟨1, by decide⟩ ⟨2, by decide⟩ := h
    rw [h_str_eq] at h'
    simp [thesisType5, SimpleGraph.fromRel_adj] at h'
  have G_v2v3_no : ¬G.str.1.Adj v2 v3 := by
    intro h
    have h' : (CG2.comap G.embedding G.str).1.Adj ⟨2, by decide⟩ ⟨3, by decide⟩ := h
    rw [h_str_eq] at h'
    simp [thesisType5, SimpleGraph.fromRel_adj] at h'
  obtain ⟨v_ext, hv_ext_notin, hv_ext_adj⟩ := h_ext
  have hv_ext_eq : v_ext = w := extVertex_unique G h_size v_ext hv_ext_notin
  subst hv_ext_eq
  have G_wv2 : G.str.1.Adj w v2 := by rw [hv2]; exact hv_ext_adj
  have hcol_v0 : G.str.2 v0 = 0 := by rw [hv0, h_col_eq]; simp [thesisType5]
  have hcol_v1 : G.str.2 v1 = 0 := by rw [hv1, h_col_eq]; simp [thesisType5]
  have hcol_v2 : G.str.2 v2 = 1 := by rw [hv2, h_col_eq]; simp [thesisType5]
  have hcol_v3 : G.str.2 v3 = 1 := by rw [hv3, h_col_eq]; simp [thesisType5]
  -- Define φ : Fin G.size ≃ Fin 5 mapping vᵢ ↦ ⟨i,_⟩, w ↦ ⟨4,_⟩
  let φ_fn : Fin G.size → Fin 5 := fun x =>
    if x = v0 then ⟨0, by decide⟩
    else if x = v1 then ⟨1, by decide⟩
    else if x = v2 then ⟨2, by decide⟩
    else if x = v3 then ⟨3, by decide⟩
    else ⟨4, by decide⟩
  have φv0 : φ_fn v0 = ⟨0, by decide⟩ := by simp [φ_fn]
  have φv1 : φ_fn v1 = ⟨1, by decide⟩ := by
    simp only [φ_fn]; rw [if_neg hv01.symm]; simp
  have φv2 : φ_fn v2 = ⟨2, by decide⟩ := by
    simp only [φ_fn]; rw [if_neg hv02.symm, if_neg hv12.symm]; simp
  have φv3 : φ_fn v3 = ⟨3, by decide⟩ := by
    simp only [φ_fn]
    rw [if_neg hv03.symm, if_neg hv13.symm, if_neg hv23.symm]; simp
  have φw : φ_fn w = ⟨4, by decide⟩ := by
    simp only [φ_fn]
    rw [if_neg hwv0, if_neg hwv1, if_neg hwv2, if_neg hwv3]
  have x_cases : ∀ x : Fin G.size, x = v0 ∨ x = v1 ∨ x = v2 ∨ x = v3 ∨ x = w := by
    intro x
    by_cases h0 : x = v0
    · exact Or.inl h0
    by_cases h1 : x = v1
    · exact Or.inr (Or.inl h1)
    by_cases h2 : x = v2
    · exact Or.inr (Or.inr (Or.inl h2))
    by_cases h3 : x = v3
    · exact Or.inr (Or.inr (Or.inr (Or.inl h3)))
    right; right; right; right
    apply extVertex_unique G h_size
    rintro ⟨⟨j, hj⟩, hj_eq⟩
    have hjlt : j < 4 := hj
    have hsize : thesisType5.size = 4 := rfl
    interval_cases j
    · exact h0 hj_eq.symm
    · exact h1 hj_eq.symm
    · exact h2 hj_eq.symm
    · exact h3 hj_eq.symm
  have φ_inj : Function.Injective φ_fn := by
    intro x y hxy
    rcases x_cases x with hx | hx | hx | hx | hx <;>
    rcases x_cases y with hy | hy | hy | hy | hy <;>
      subst hx <;> subst hy <;>
      first
      | rfl
      | (exfalso
         try rw [φv0] at hxy
         try rw [φv1] at hxy
         try rw [φv2] at hxy
         try rw [φv3] at hxy
         try rw [φw] at hxy
         exact absurd hxy (by decide))
  have hcard : Fintype.card (Fin G.size) = Fintype.card (Fin 5) := by
    rw [Fintype.card_fin, Fintype.card_fin, h_size]
  have φ_bij : Function.Bijective φ_fn :=
    (Fintype.bijective_iff_injective_and_card φ_fn).mpr ⟨φ_inj, hcard⟩
  let φ : Fin G.size ≃ Fin t5_v2_a.size := Equiv.ofBijective φ_fn φ_bij
  have hφv0 : φ v0 = ⟨0, by decide⟩ := φv0
  have hφv1 : φ v1 = ⟨1, by decide⟩ := φv1
  have hφv2 : φ v2 = ⟨2, by decide⟩ := φv2
  have hφv3 : φ v3 = ⟨3, by decide⟩ := φv3
  have hφw : φ w = ⟨4, by decide⟩ := φw
  refine ⟨φ, ?_, ?_⟩
  · -- Structure equality: CG2.comap φ t5_v2_a.str = G.str
    apply Prod.ext
    · -- Graph component
      ext u v
      change (t5_v2_a.str.1.comap (φ : Fin G.size → Fin 5)).Adj u v ↔ G.str.1.Adj u v
      simp only [SimpleGraph.comap_adj]
      rcases x_cases u with hu | hu | hu | hu | hu <;>
      rcases x_cases v with hv | hv | hv | hv | hv <;>
        rw [hu, hv]
      -- 25 goals, dispatched by edge type:
      -- (v0,v0) self-loop
      · rw [hφv0]; constructor
        · intro h; simp [t5_v2_a] at h
        · intro h; exact (G.str.1.irrefl h).elim
      -- (v0,v1) edge
      · rw [hφv0, hφv1]; constructor
        · intro _; exact G_v0v1
        · intro _; simp [t5_v2_a, SimpleGraph.fromRel_adj]
      -- (v0,v2) edge
      · rw [hφv0, hφv2]; constructor
        · intro _; exact G_v0v2
        · intro _; simp [t5_v2_a, SimpleGraph.fromRel_adj]
      -- (v0,v3) non-edge
      · rw [hφv0, hφv3]; constructor
        · intro h; simp [t5_v2_a] at h
        · intro h; exact (G_v0v3_no h).elim
      -- (v0,w) non-edge
      · rw [hφv0, hφw]; constructor
        · intro h; simp [t5_v2_a] at h
        · intro h; exact (h_no_v0 h.symm).elim
      -- (v1,v0) edge
      · rw [hφv1, hφv0]; constructor
        · intro _; exact G_v0v1.symm
        · intro _; simp [t5_v2_a, SimpleGraph.fromRel_adj]
      -- (v1,v1) self-loop
      · rw [hφv1]; constructor
        · intro h; simp [t5_v2_a] at h
        · intro h; exact (G.str.1.irrefl h).elim
      -- (v1,v2) non-edge
      · rw [hφv1, hφv2]; constructor
        · intro h; simp [t5_v2_a] at h
        · intro h; exact (G_v1v2_no h).elim
      -- (v1,v3) edge
      · rw [hφv1, hφv3]; constructor
        · intro _; exact G_v1v3
        · intro _; simp [t5_v2_a, SimpleGraph.fromRel_adj]
      -- (v1,w) non-edge
      · rw [hφv1, hφw]; constructor
        · intro h; simp [t5_v2_a] at h
        · intro h; exact (h_no_v1 h.symm).elim
      -- (v2,v0) edge
      · rw [hφv2, hφv0]; constructor
        · intro _; exact G_v0v2.symm
        · intro _; simp [t5_v2_a, SimpleGraph.fromRel_adj]
      -- (v2,v1) non-edge
      · rw [hφv2, hφv1]; constructor
        · intro h; simp [t5_v2_a] at h
        · intro h; exact (G_v1v2_no h.symm).elim
      -- (v2,v2) self-loop
      · rw [hφv2]; constructor
        · intro h; simp [t5_v2_a] at h
        · intro h; exact (G.str.1.irrefl h).elim
      -- (v2,v3) non-edge
      · rw [hφv2, hφv3]; constructor
        · intro h; simp [t5_v2_a] at h
        · intro h; exact (G_v2v3_no h).elim
      -- (v2,w) edge (extAdj v2-w)
      · rw [hφv2, hφw]; constructor
        · intro _; exact G_wv2.symm
        · intro _; simp [t5_v2_a, SimpleGraph.fromRel_adj]
      -- (v3,v0) non-edge
      · rw [hφv3, hφv0]; constructor
        · intro h; simp [t5_v2_a] at h
        · intro h; exact (G_v0v3_no h.symm).elim
      -- (v3,v1) edge
      · rw [hφv3, hφv1]; constructor
        · intro _; exact G_v1v3.symm
        · intro _; simp [t5_v2_a, SimpleGraph.fromRel_adj]
      -- (v3,v2) non-edge
      · rw [hφv3, hφv2]; constructor
        · intro h; simp [t5_v2_a] at h
        · intro h; exact (G_v2v3_no h.symm).elim
      -- (v3,v3) self-loop
      · rw [hφv3]; constructor
        · intro h; simp [t5_v2_a] at h
        · intro h; exact (G.str.1.irrefl h).elim
      -- (v3,w) non-edge
      · rw [hφv3, hφw]; constructor
        · intro h; simp [t5_v2_a] at h
        · intro h; exact (h_no_v3 h.symm).elim
      -- (w,v0) non-edge
      · rw [hφw, hφv0]; constructor
        · intro h; simp [t5_v2_a] at h
        · intro h; exact (h_no_v0 h).elim
      -- (w,v1) non-edge
      · rw [hφw, hφv1]; constructor
        · intro h; simp [t5_v2_a] at h
        · intro h; exact (h_no_v1 h).elim
      -- (w,v2) edge
      · rw [hφw, hφv2]; constructor
        · intro _; exact G_wv2
        · intro _; simp [t5_v2_a, SimpleGraph.fromRel_adj]
      -- (w,v3) non-edge
      · rw [hφw, hφv3]; constructor
        · intro h; simp [t5_v2_a] at h
        · intro h; exact (h_no_v3 h).elim
      -- (w,w) self-loop
      · rw [hφw]; constructor
        · intro h; simp [t5_v2_a] at h
        · intro h; exact (G.str.1.irrefl h).elim
    · -- Colour component
      funext x
      change t5_v2_a.str.2 (φ x) = G.str.2 x
      rcases x_cases x with hx | hx | hx | hx | hx <;> rw [hx]
      · rw [hφv0, hcol_v0]; rfl
      · rw [hφv1, hcol_v1]; rfl
      · rw [hφv2, hcol_v2]; rfl
      · rw [hφv3, hcol_v3]; rfl
      · rw [hφw, h_w_R]; rfl
  · -- σ-compatibility: φ ∘ G.embedding = t5_v2_a.embedding
    intro i
    fin_cases i
    · simp [t5_v2_a, Fin.castLE]; exact hφv0
    · simp [t5_v2_a, Fin.castLE]; exact hφv1
    · simp [t5_v2_a, Fin.castLE]; exact hφv2
    · simp [t5_v2_a, Fin.castLE]; exact hφv3

/-! ### σ₅-3 case 2: classification for w=R adj v1, v2 only -/

set_option maxHeartbeats 1600000 in
/-- Case 2 of σ₅-3: any size-5 thesisType5-flag G with extAdj-v2, w coloured R,
    w not adjacent to v0 or v3, w adjacent to v1, is σ-iso to `t5_v2_b`. -/
theorem t5_v2_b_classification (G : GenFlag CG2 thesisType5)
    (h_size : G.size = 5)
    (h_ext : extAdjacency thesisType5 G ⟨2, by decide⟩)
    (h_w_R : G.str.2 (extVertex G h_size) = 0)
    (h_no_v0 : ¬G.str.1.Adj (extVertex G h_size) (G.embedding ⟨0, by decide⟩))
    (h_yes_v1 : G.str.1.Adj (extVertex G h_size) (G.embedding ⟨1, by decide⟩))
    (h_no_v3 : ¬G.str.1.Adj (extVertex G h_size) (G.embedding ⟨3, by decide⟩)) :
    GenFlagIso thesisType5 G t5_v2_b := by
  classical
  set v0 := G.embedding ⟨0, by decide⟩ with hv0
  set v1 := G.embedding ⟨1, by decide⟩ with hv1
  set v2 := G.embedding ⟨2, by decide⟩ with hv2
  set v3 := G.embedding ⟨3, by decide⟩ with hv3
  set w := extVertex G h_size with hw
  have hv01 : v0 ≠ v1 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv02 : v0 ≠ v2 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv03 : v0 ≠ v3 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv12 : v1 ≠ v2 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv13 : v1 ≠ v3 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv23 : v2 ≠ v3 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hw_notin : w ∉ Set.range G.embedding := extVertex_notin_range G h_size
  have hwv0 : w ≠ v0 := fun h => hw_notin ⟨⟨0, by decide⟩, h.symm⟩
  have hwv1 : w ≠ v1 := fun h => hw_notin ⟨⟨1, by decide⟩, h.symm⟩
  have hwv2 : w ≠ v2 := fun h => hw_notin ⟨⟨2, by decide⟩, h.symm⟩
  have hwv3 : w ≠ v3 := fun h => hw_notin ⟨⟨3, by decide⟩, h.symm⟩
  have h_str_eq : (CG2.comap G.embedding G.str).1 = thesisType5.str.1 :=
    congr_arg Prod.fst G.isInduced
  have h_col_eq : ∀ j : Fin thesisType5.size,
      G.str.2 (G.embedding j) = thesisType5.str.2 j := fun j =>
    congr_fun (congr_arg Prod.snd G.isInduced) j
  have G_v0v1 : G.str.1.Adj v0 v1 := by
    have h_sigma : thesisType5.str.1.Adj ⟨0, by decide⟩ ⟨1, by decide⟩ := by
      simp [thesisType5, SimpleGraph.fromRel_adj]
    rw [← h_str_eq] at h_sigma; exact h_sigma
  have G_v0v2 : G.str.1.Adj v0 v2 := by
    have h_sigma : thesisType5.str.1.Adj ⟨0, by decide⟩ ⟨2, by decide⟩ := by
      simp [thesisType5, SimpleGraph.fromRel_adj]
    rw [← h_str_eq] at h_sigma; exact h_sigma
  have G_v1v3 : G.str.1.Adj v1 v3 := by
    have h_sigma : thesisType5.str.1.Adj ⟨1, by decide⟩ ⟨3, by decide⟩ := by
      simp [thesisType5, SimpleGraph.fromRel_adj]
    rw [← h_str_eq] at h_sigma; exact h_sigma
  have G_v0v3_no : ¬G.str.1.Adj v0 v3 := by
    intro h
    have h' : (CG2.comap G.embedding G.str).1.Adj ⟨0, by decide⟩ ⟨3, by decide⟩ := h
    rw [h_str_eq] at h'
    simp [thesisType5, SimpleGraph.fromRel_adj] at h'
  have G_v1v2_no : ¬G.str.1.Adj v1 v2 := by
    intro h
    have h' : (CG2.comap G.embedding G.str).1.Adj ⟨1, by decide⟩ ⟨2, by decide⟩ := h
    rw [h_str_eq] at h'
    simp [thesisType5, SimpleGraph.fromRel_adj] at h'
  have G_v2v3_no : ¬G.str.1.Adj v2 v3 := by
    intro h
    have h' : (CG2.comap G.embedding G.str).1.Adj ⟨2, by decide⟩ ⟨3, by decide⟩ := h
    rw [h_str_eq] at h'
    simp [thesisType5, SimpleGraph.fromRel_adj] at h'
  obtain ⟨v_ext, hv_ext_notin, hv_ext_adj⟩ := h_ext
  have hv_ext_eq : v_ext = w := extVertex_unique G h_size v_ext hv_ext_notin
  subst hv_ext_eq
  have G_wv2 : G.str.1.Adj w v2 := by rw [hv2]; exact hv_ext_adj
  have hcol_v0 : G.str.2 v0 = 0 := by rw [hv0, h_col_eq]; simp [thesisType5]
  have hcol_v1 : G.str.2 v1 = 0 := by rw [hv1, h_col_eq]; simp [thesisType5]
  have hcol_v2 : G.str.2 v2 = 1 := by rw [hv2, h_col_eq]; simp [thesisType5]
  have hcol_v3 : G.str.2 v3 = 1 := by rw [hv3, h_col_eq]; simp [thesisType5]
  let φ_fn : Fin G.size → Fin 5 := fun x =>
    if x = v0 then ⟨0, by decide⟩
    else if x = v1 then ⟨1, by decide⟩
    else if x = v2 then ⟨2, by decide⟩
    else if x = v3 then ⟨3, by decide⟩
    else ⟨4, by decide⟩
  have φv0 : φ_fn v0 = ⟨0, by decide⟩ := by simp [φ_fn]
  have φv1 : φ_fn v1 = ⟨1, by decide⟩ := by
    simp only [φ_fn]; rw [if_neg hv01.symm]; simp
  have φv2 : φ_fn v2 = ⟨2, by decide⟩ := by
    simp only [φ_fn]; rw [if_neg hv02.symm, if_neg hv12.symm]; simp
  have φv3 : φ_fn v3 = ⟨3, by decide⟩ := by
    simp only [φ_fn]
    rw [if_neg hv03.symm, if_neg hv13.symm, if_neg hv23.symm]; simp
  have φw : φ_fn w = ⟨4, by decide⟩ := by
    simp only [φ_fn]
    rw [if_neg hwv0, if_neg hwv1, if_neg hwv2, if_neg hwv3]
  have x_cases : ∀ x : Fin G.size, x = v0 ∨ x = v1 ∨ x = v2 ∨ x = v3 ∨ x = w := by
    intro x
    by_cases h0 : x = v0
    · exact Or.inl h0
    by_cases h1 : x = v1
    · exact Or.inr (Or.inl h1)
    by_cases h2 : x = v2
    · exact Or.inr (Or.inr (Or.inl h2))
    by_cases h3 : x = v3
    · exact Or.inr (Or.inr (Or.inr (Or.inl h3)))
    right; right; right; right
    apply extVertex_unique G h_size
    rintro ⟨⟨j, hj⟩, hj_eq⟩
    have hjlt : j < 4 := hj
    have hsize : thesisType5.size = 4 := rfl
    interval_cases j
    · exact h0 hj_eq.symm
    · exact h1 hj_eq.symm
    · exact h2 hj_eq.symm
    · exact h3 hj_eq.symm
  have φ_inj : Function.Injective φ_fn := by
    intro x y hxy
    rcases x_cases x with hx | hx | hx | hx | hx <;>
    rcases x_cases y with hy | hy | hy | hy | hy <;>
      subst hx <;> subst hy <;>
      first
      | rfl
      | (exfalso
         try rw [φv0] at hxy
         try rw [φv1] at hxy
         try rw [φv2] at hxy
         try rw [φv3] at hxy
         try rw [φw] at hxy
         exact absurd hxy (by decide))
  have hcard : Fintype.card (Fin G.size) = Fintype.card (Fin 5) := by
    rw [Fintype.card_fin, Fintype.card_fin, h_size]
  have φ_bij : Function.Bijective φ_fn :=
    (Fintype.bijective_iff_injective_and_card φ_fn).mpr ⟨φ_inj, hcard⟩
  let φ : Fin G.size ≃ Fin t5_v2_b.size := Equiv.ofBijective φ_fn φ_bij
  have hφv0 : φ v0 = ⟨0, by decide⟩ := φv0
  have hφv1 : φ v1 = ⟨1, by decide⟩ := φv1
  have hφv2 : φ v2 = ⟨2, by decide⟩ := φv2
  have hφv3 : φ v3 = ⟨3, by decide⟩ := φv3
  have hφw : φ w = ⟨4, by decide⟩ := φw
  refine ⟨φ, ?_, ?_⟩
  · apply Prod.ext
    · ext u v
      change (t5_v2_b.str.1.comap (φ : Fin G.size → Fin 5)).Adj u v ↔ G.str.1.Adj u v
      simp only [SimpleGraph.comap_adj]
      rcases x_cases u with hu | hu | hu | hu | hu <;>
      rcases x_cases v with hv | hv | hv | hv | hv <;>
        rw [hu, hv]
      · rw [hφv0]; constructor
        · intro h; simp [t5_v2_b] at h
        · intro h; exact (G.str.1.irrefl h).elim
      · rw [hφv0, hφv1]; constructor
        · intro _; exact G_v0v1
        · intro _; simp [t5_v2_b, SimpleGraph.fromRel_adj]
      · rw [hφv0, hφv2]; constructor
        · intro _; exact G_v0v2
        · intro _; simp [t5_v2_b, SimpleGraph.fromRel_adj]
      · rw [hφv0, hφv3]; constructor
        · intro h; simp [t5_v2_b] at h
        · intro h; exact (G_v0v3_no h).elim
      · rw [hφv0, hφw]; constructor
        · intro h; simp [t5_v2_b] at h
        · intro h; exact (h_no_v0 h.symm).elim
      · rw [hφv1, hφv0]; constructor
        · intro _; exact G_v0v1.symm
        · intro _; simp [t5_v2_b, SimpleGraph.fromRel_adj]
      · rw [hφv1]; constructor
        · intro h; simp [t5_v2_b] at h
        · intro h; exact (G.str.1.irrefl h).elim
      · rw [hφv1, hφv2]; constructor
        · intro h; simp [t5_v2_b] at h
        · intro h; exact (G_v1v2_no h).elim
      · rw [hφv1, hφv3]; constructor
        · intro _; exact G_v1v3
        · intro _; simp [t5_v2_b, SimpleGraph.fromRel_adj]
      · rw [hφv1, hφw]; constructor
        · intro _; exact h_yes_v1.symm
        · intro _; simp [t5_v2_b, SimpleGraph.fromRel_adj]
      · rw [hφv2, hφv0]; constructor
        · intro _; exact G_v0v2.symm
        · intro _; simp [t5_v2_b, SimpleGraph.fromRel_adj]
      · rw [hφv2, hφv1]; constructor
        · intro h; simp [t5_v2_b] at h
        · intro h; exact (G_v1v2_no h.symm).elim
      · rw [hφv2]; constructor
        · intro h; simp [t5_v2_b] at h
        · intro h; exact (G.str.1.irrefl h).elim
      · rw [hφv2, hφv3]; constructor
        · intro h; simp [t5_v2_b] at h
        · intro h; exact (G_v2v3_no h).elim
      · rw [hφv2, hφw]; constructor
        · intro _; exact G_wv2.symm
        · intro _; simp [t5_v2_b, SimpleGraph.fromRel_adj]
      · rw [hφv3, hφv0]; constructor
        · intro h; simp [t5_v2_b] at h
        · intro h; exact (G_v0v3_no h.symm).elim
      · rw [hφv3, hφv1]; constructor
        · intro _; exact G_v1v3.symm
        · intro _; simp [t5_v2_b, SimpleGraph.fromRel_adj]
      · rw [hφv3, hφv2]; constructor
        · intro h; simp [t5_v2_b] at h
        · intro h; exact (G_v2v3_no h.symm).elim
      · rw [hφv3]; constructor
        · intro h; simp [t5_v2_b] at h
        · intro h; exact (G.str.1.irrefl h).elim
      · rw [hφv3, hφw]; constructor
        · intro h; simp [t5_v2_b] at h
        · intro h; exact (h_no_v3 h.symm).elim
      · rw [hφw, hφv0]; constructor
        · intro h; simp [t5_v2_b] at h
        · intro h; exact (h_no_v0 h).elim
      · rw [hφw, hφv1]; constructor
        · intro _; exact h_yes_v1
        · intro _; simp [t5_v2_b, SimpleGraph.fromRel_adj]
      · rw [hφw, hφv2]; constructor
        · intro _; exact G_wv2
        · intro _; simp [t5_v2_b, SimpleGraph.fromRel_adj]
      · rw [hφw, hφv3]; constructor
        · intro h; simp [t5_v2_b] at h
        · intro h; exact (h_no_v3 h).elim
      · rw [hφw]; constructor
        · intro h; simp [t5_v2_b] at h
        · intro h; exact (G.str.1.irrefl h).elim
    · funext x
      change t5_v2_b.str.2 (φ x) = G.str.2 x
      rcases x_cases x with hx | hx | hx | hx | hx <;> rw [hx]
      · rw [hφv0, hcol_v0]; rfl
      · rw [hφv1, hcol_v1]; rfl
      · rw [hφv2, hcol_v2]; rfl
      · rw [hφv3, hcol_v3]; rfl
      · rw [hφw, h_w_R]; rfl
  · intro i
    fin_cases i
    · simp [t5_v2_b, Fin.castLE]; exact hφv0
    · simp [t5_v2_b, Fin.castLE]; exact hφv1
    · simp [t5_v2_b, Fin.castLE]; exact hφv2
    · simp [t5_v2_b, Fin.castLE]; exact hφv3

/-! ### σ₅-3 case 3: classification for w=R adj v2, v3 only (5-cycle) -/

set_option maxHeartbeats 1600000 in
/-- Case 3 of σ₅-3: any size-5 thesisType5-flag G with extAdj-v2, w coloured R,
    w not adjacent to v0 or v1, w adjacent to v3, is σ-iso to `t5_v2_c`. -/
theorem t5_v2_c_classification (G : GenFlag CG2 thesisType5)
    (h_size : G.size = 5)
    (h_ext : extAdjacency thesisType5 G ⟨2, by decide⟩)
    (h_w_R : G.str.2 (extVertex G h_size) = 0)
    (h_no_v0 : ¬G.str.1.Adj (extVertex G h_size) (G.embedding ⟨0, by decide⟩))
    (h_no_v1 : ¬G.str.1.Adj (extVertex G h_size) (G.embedding ⟨1, by decide⟩))
    (h_yes_v3 : G.str.1.Adj (extVertex G h_size) (G.embedding ⟨3, by decide⟩)) :
    GenFlagIso thesisType5 G t5_v2_c := by
  classical
  set v0 := G.embedding ⟨0, by decide⟩ with hv0
  set v1 := G.embedding ⟨1, by decide⟩ with hv1
  set v2 := G.embedding ⟨2, by decide⟩ with hv2
  set v3 := G.embedding ⟨3, by decide⟩ with hv3
  set w := extVertex G h_size with hw
  have hv01 : v0 ≠ v1 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv02 : v0 ≠ v2 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv03 : v0 ≠ v3 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv12 : v1 ≠ v2 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv13 : v1 ≠ v3 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv23 : v2 ≠ v3 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hw_notin : w ∉ Set.range G.embedding := extVertex_notin_range G h_size
  have hwv0 : w ≠ v0 := fun h => hw_notin ⟨⟨0, by decide⟩, h.symm⟩
  have hwv1 : w ≠ v1 := fun h => hw_notin ⟨⟨1, by decide⟩, h.symm⟩
  have hwv2 : w ≠ v2 := fun h => hw_notin ⟨⟨2, by decide⟩, h.symm⟩
  have hwv3 : w ≠ v3 := fun h => hw_notin ⟨⟨3, by decide⟩, h.symm⟩
  have h_str_eq : (CG2.comap G.embedding G.str).1 = thesisType5.str.1 :=
    congr_arg Prod.fst G.isInduced
  have h_col_eq : ∀ j : Fin thesisType5.size,
      G.str.2 (G.embedding j) = thesisType5.str.2 j := fun j =>
    congr_fun (congr_arg Prod.snd G.isInduced) j
  have G_v0v1 : G.str.1.Adj v0 v1 := by
    have h_sigma : thesisType5.str.1.Adj ⟨0, by decide⟩ ⟨1, by decide⟩ := by
      simp [thesisType5, SimpleGraph.fromRel_adj]
    rw [← h_str_eq] at h_sigma; exact h_sigma
  have G_v0v2 : G.str.1.Adj v0 v2 := by
    have h_sigma : thesisType5.str.1.Adj ⟨0, by decide⟩ ⟨2, by decide⟩ := by
      simp [thesisType5, SimpleGraph.fromRel_adj]
    rw [← h_str_eq] at h_sigma; exact h_sigma
  have G_v1v3 : G.str.1.Adj v1 v3 := by
    have h_sigma : thesisType5.str.1.Adj ⟨1, by decide⟩ ⟨3, by decide⟩ := by
      simp [thesisType5, SimpleGraph.fromRel_adj]
    rw [← h_str_eq] at h_sigma; exact h_sigma
  have G_v0v3_no : ¬G.str.1.Adj v0 v3 := by
    intro h
    have h' : (CG2.comap G.embedding G.str).1.Adj ⟨0, by decide⟩ ⟨3, by decide⟩ := h
    rw [h_str_eq] at h'
    simp [thesisType5, SimpleGraph.fromRel_adj] at h'
  have G_v1v2_no : ¬G.str.1.Adj v1 v2 := by
    intro h
    have h' : (CG2.comap G.embedding G.str).1.Adj ⟨1, by decide⟩ ⟨2, by decide⟩ := h
    rw [h_str_eq] at h'
    simp [thesisType5, SimpleGraph.fromRel_adj] at h'
  have G_v2v3_no : ¬G.str.1.Adj v2 v3 := by
    intro h
    have h' : (CG2.comap G.embedding G.str).1.Adj ⟨2, by decide⟩ ⟨3, by decide⟩ := h
    rw [h_str_eq] at h'
    simp [thesisType5, SimpleGraph.fromRel_adj] at h'
  obtain ⟨v_ext, hv_ext_notin, hv_ext_adj⟩ := h_ext
  have hv_ext_eq : v_ext = w := extVertex_unique G h_size v_ext hv_ext_notin
  subst hv_ext_eq
  have G_wv2 : G.str.1.Adj w v2 := by rw [hv2]; exact hv_ext_adj
  have hcol_v0 : G.str.2 v0 = 0 := by rw [hv0, h_col_eq]; simp [thesisType5]
  have hcol_v1 : G.str.2 v1 = 0 := by rw [hv1, h_col_eq]; simp [thesisType5]
  have hcol_v2 : G.str.2 v2 = 1 := by rw [hv2, h_col_eq]; simp [thesisType5]
  have hcol_v3 : G.str.2 v3 = 1 := by rw [hv3, h_col_eq]; simp [thesisType5]
  let φ_fn : Fin G.size → Fin 5 := fun x =>
    if x = v0 then ⟨0, by decide⟩
    else if x = v1 then ⟨1, by decide⟩
    else if x = v2 then ⟨2, by decide⟩
    else if x = v3 then ⟨3, by decide⟩
    else ⟨4, by decide⟩
  have φv0 : φ_fn v0 = ⟨0, by decide⟩ := by simp [φ_fn]
  have φv1 : φ_fn v1 = ⟨1, by decide⟩ := by
    simp only [φ_fn]; rw [if_neg hv01.symm]; simp
  have φv2 : φ_fn v2 = ⟨2, by decide⟩ := by
    simp only [φ_fn]; rw [if_neg hv02.symm, if_neg hv12.symm]; simp
  have φv3 : φ_fn v3 = ⟨3, by decide⟩ := by
    simp only [φ_fn]
    rw [if_neg hv03.symm, if_neg hv13.symm, if_neg hv23.symm]; simp
  have φw : φ_fn w = ⟨4, by decide⟩ := by
    simp only [φ_fn]
    rw [if_neg hwv0, if_neg hwv1, if_neg hwv2, if_neg hwv3]
  have x_cases : ∀ x : Fin G.size, x = v0 ∨ x = v1 ∨ x = v2 ∨ x = v3 ∨ x = w := by
    intro x
    by_cases h0 : x = v0
    · exact Or.inl h0
    by_cases h1 : x = v1
    · exact Or.inr (Or.inl h1)
    by_cases h2 : x = v2
    · exact Or.inr (Or.inr (Or.inl h2))
    by_cases h3 : x = v3
    · exact Or.inr (Or.inr (Or.inr (Or.inl h3)))
    right; right; right; right
    apply extVertex_unique G h_size
    rintro ⟨⟨j, hj⟩, hj_eq⟩
    have hjlt : j < 4 := hj
    have hsize : thesisType5.size = 4 := rfl
    interval_cases j
    · exact h0 hj_eq.symm
    · exact h1 hj_eq.symm
    · exact h2 hj_eq.symm
    · exact h3 hj_eq.symm
  have φ_inj : Function.Injective φ_fn := by
    intro x y hxy
    rcases x_cases x with hx | hx | hx | hx | hx <;>
    rcases x_cases y with hy | hy | hy | hy | hy <;>
      subst hx <;> subst hy <;>
      first
      | rfl
      | (exfalso
         try rw [φv0] at hxy
         try rw [φv1] at hxy
         try rw [φv2] at hxy
         try rw [φv3] at hxy
         try rw [φw] at hxy
         exact absurd hxy (by decide))
  have hcard : Fintype.card (Fin G.size) = Fintype.card (Fin 5) := by
    rw [Fintype.card_fin, Fintype.card_fin, h_size]
  have φ_bij : Function.Bijective φ_fn :=
    (Fintype.bijective_iff_injective_and_card φ_fn).mpr ⟨φ_inj, hcard⟩
  let φ : Fin G.size ≃ Fin t5_v2_c.size := Equiv.ofBijective φ_fn φ_bij
  have hφv0 : φ v0 = ⟨0, by decide⟩ := φv0
  have hφv1 : φ v1 = ⟨1, by decide⟩ := φv1
  have hφv2 : φ v2 = ⟨2, by decide⟩ := φv2
  have hφv3 : φ v3 = ⟨3, by decide⟩ := φv3
  have hφw : φ w = ⟨4, by decide⟩ := φw
  refine ⟨φ, ?_, ?_⟩
  · apply Prod.ext
    · ext u v
      change (t5_v2_c.str.1.comap (φ : Fin G.size → Fin 5)).Adj u v ↔ G.str.1.Adj u v
      simp only [SimpleGraph.comap_adj]
      rcases x_cases u with hu | hu | hu | hu | hu <;>
      rcases x_cases v with hv | hv | hv | hv | hv <;>
        rw [hu, hv]
      · rw [hφv0]; constructor
        · intro h; simp [t5_v2_c] at h
        · intro h; exact (G.str.1.irrefl h).elim
      · rw [hφv0, hφv1]; constructor
        · intro _; exact G_v0v1
        · intro _; simp [t5_v2_c, SimpleGraph.fromRel_adj]
      · rw [hφv0, hφv2]; constructor
        · intro _; exact G_v0v2
        · intro _; simp [t5_v2_c, SimpleGraph.fromRel_adj]
      · rw [hφv0, hφv3]; constructor
        · intro h; simp [t5_v2_c] at h
        · intro h; exact (G_v0v3_no h).elim
      · rw [hφv0, hφw]; constructor
        · intro h; simp [t5_v2_c] at h
        · intro h; exact (h_no_v0 h.symm).elim
      · rw [hφv1, hφv0]; constructor
        · intro _; exact G_v0v1.symm
        · intro _; simp [t5_v2_c, SimpleGraph.fromRel_adj]
      · rw [hφv1]; constructor
        · intro h; simp [t5_v2_c] at h
        · intro h; exact (G.str.1.irrefl h).elim
      · rw [hφv1, hφv2]; constructor
        · intro h; simp [t5_v2_c] at h
        · intro h; exact (G_v1v2_no h).elim
      · rw [hφv1, hφv3]; constructor
        · intro _; exact G_v1v3
        · intro _; simp [t5_v2_c, SimpleGraph.fromRel_adj]
      · rw [hφv1, hφw]; constructor
        · intro h; simp [t5_v2_c] at h
        · intro h; exact (h_no_v1 h.symm).elim
      · rw [hφv2, hφv0]; constructor
        · intro _; exact G_v0v2.symm
        · intro _; simp [t5_v2_c, SimpleGraph.fromRel_adj]
      · rw [hφv2, hφv1]; constructor
        · intro h; simp [t5_v2_c] at h
        · intro h; exact (G_v1v2_no h.symm).elim
      · rw [hφv2]; constructor
        · intro h; simp [t5_v2_c] at h
        · intro h; exact (G.str.1.irrefl h).elim
      · rw [hφv2, hφv3]; constructor
        · intro h; simp [t5_v2_c] at h
        · intro h; exact (G_v2v3_no h).elim
      · rw [hφv2, hφw]; constructor
        · intro _; exact G_wv2.symm
        · intro _; simp [t5_v2_c, SimpleGraph.fromRel_adj]
      · rw [hφv3, hφv0]; constructor
        · intro h; simp [t5_v2_c] at h
        · intro h; exact (G_v0v3_no h.symm).elim
      · rw [hφv3, hφv1]; constructor
        · intro _; exact G_v1v3.symm
        · intro _; simp [t5_v2_c, SimpleGraph.fromRel_adj]
      · rw [hφv3, hφv2]; constructor
        · intro h; simp [t5_v2_c] at h
        · intro h; exact (G_v2v3_no h.symm).elim
      · rw [hφv3]; constructor
        · intro h; simp [t5_v2_c] at h
        · intro h; exact (G.str.1.irrefl h).elim
      · rw [hφv3, hφw]; constructor
        · intro _; exact h_yes_v3.symm
        · intro _; simp [t5_v2_c, SimpleGraph.fromRel_adj]
      · rw [hφw, hφv0]; constructor
        · intro h; simp [t5_v2_c] at h
        · intro h; exact (h_no_v0 h).elim
      · rw [hφw, hφv1]; constructor
        · intro h; simp [t5_v2_c] at h
        · intro h; exact (h_no_v1 h).elim
      · rw [hφw, hφv2]; constructor
        · intro _; exact G_wv2
        · intro _; simp [t5_v2_c, SimpleGraph.fromRel_adj]
      · rw [hφw, hφv3]; constructor
        · intro _; exact h_yes_v3
        · intro _; simp [t5_v2_c, SimpleGraph.fromRel_adj]
      · rw [hφw]; constructor
        · intro h; simp [t5_v2_c] at h
        · intro h; exact (G.str.1.irrefl h).elim
    · funext x
      change t5_v2_c.str.2 (φ x) = G.str.2 x
      rcases x_cases x with hx | hx | hx | hx | hx <;> rw [hx]
      · rw [hφv0, hcol_v0]; rfl
      · rw [hφv1, hcol_v1]; rfl
      · rw [hφv2, hcol_v2]; rfl
      · rw [hφv3, hcol_v3]; rfl
      · rw [hφw, h_w_R]; rfl
  · intro i
    fin_cases i
    · simp [t5_v2_c, Fin.castLE]; exact hφv0
    · simp [t5_v2_c, Fin.castLE]; exact hφv1
    · simp [t5_v2_c, Fin.castLE]; exact hφv2
    · simp [t5_v2_c, Fin.castLE]; exact hφv3

/-- v0-side BRRB constraints: w is not adj v1 and not adj v2. -/
theorem t5_extAdj_v0_BRRB_no_v1_v2
    (G : GenFlag CG2 thesisType5) (h_size : G.size = 5)
    (h_ext : extAdjacency thesisType5 G ⟨0, by decide⟩)
    (_h_no_BB : ¬∃ u v : Fin G.size,
      G.str.2 u = 1 ∧ G.str.2 v = 1 ∧ G.str.1.Adj u v)
    (h_no_tri : ¬∃ u v w : Fin G.size,
      G.str.1.Adj u v ∧ G.str.1.Adj v w ∧ G.str.1.Adj u w) :
    ¬G.str.1.Adj (extVertex G h_size) (G.embedding ⟨1, by decide⟩) ∧
    ¬G.str.1.Adj (extVertex G h_size) (G.embedding ⟨2, by decide⟩) := by
  set w := extVertex G h_size with hw_def
  obtain ⟨v, hv_notin, hv_adj_v0⟩ := h_ext
  have hv_eq : v = w := extVertex_unique G h_size v hv_notin
  subst hv_eq
  set v0 := G.embedding ⟨0, by decide⟩ with hv0
  set v1 := G.embedding ⟨1, by decide⟩ with hv1
  set v2 := G.embedding ⟨2, by decide⟩ with hv2
  have hcomap : (CG2.comap G.embedding G.str).1 = thesisType5.str.1 :=
    congr_arg Prod.fst G.isInduced
  have hv0_adj_v1 : G.str.1.Adj v0 v1 := by
    have h_sigma : thesisType5.str.1.Adj ⟨0, by decide⟩ ⟨1, by decide⟩ := by
      simp [thesisType5, SimpleGraph.fromRel_adj]
    rw [← hcomap] at h_sigma; exact h_sigma
  have hv0_adj_v2 : G.str.1.Adj v0 v2 := by
    have h_sigma : thesisType5.str.1.Adj ⟨0, by decide⟩ ⟨2, by decide⟩ := by
      simp [thesisType5, SimpleGraph.fromRel_adj]
    rw [← hcomap] at h_sigma; exact h_sigma
  have hv_adj_v0' : G.str.1.Adj w v0 := by rw [hv0]; exact hv_adj_v0
  refine ⟨?_, ?_⟩
  · intro h_w_v1
    apply h_no_tri
    refine ⟨v0, v1, w, hv0_adj_v1, h_w_v1.symm, hv_adj_v0'.symm⟩
  · intro h_w_v2
    apply h_no_tri
    refine ⟨v0, v2, w, hv0_adj_v2, h_w_v2.symm, hv_adj_v0'.symm⟩

/-! ### σ₅-3 case 4: classification for w=R adj v0 only -/

set_option maxHeartbeats 1600000 in
/-- Case 4 of σ₅-3: any size-5 thesisType5-flag G with extAdj-v0, w coloured R,
    w not adjacent to v1, v2, v3, is σ-iso to `t5_v0_R_a`. -/
theorem t5_v0_R_a_classification (G : GenFlag CG2 thesisType5)
    (h_size : G.size = 5)
