      rcases x_cases x with hx | hx | hx | hx | hx <;> rw [hx]
      · rw [hφv0, hcol_v0]; rfl
      · rw [hφv1, hcol_v1]; rfl
      · rw [hφv2, hcol_v2]; rfl
      · rw [hφv3, hcol_v3]; rfl
      · rw [hφw, h_w_R]; rfl
  · intro i
    fin_cases i
    · simp [t5_v0_R_a, Fin.castLE]; exact hφv0
    · simp [t5_v0_R_a, Fin.castLE]; exact hφv1
    · simp [t5_v0_R_a, Fin.castLE]; exact hφv2
    · simp [t5_v0_R_a, Fin.castLE]; exact hφv3

/-! ### σ₅-3 case 5: classification for w=R adj v0, v3 only -/

set_option maxHeartbeats 1600000 in
/-- Case 5 of σ₅-3: any size-5 thesisType5-flag G with extAdj-v0, w coloured R,
    w not adjacent to v1, v2, w adjacent to v3, is σ-iso to `t5_v0_R_b`. -/
theorem t5_v0_R_b_classification (G : GenFlag CG2 thesisType5)
    (h_size : G.size = 5)
    (h_ext : extAdjacency thesisType5 G ⟨0, by decide⟩)
    (h_w_R : G.str.2 (extVertex G h_size) = 0)
    (h_no_v1 : ¬G.str.1.Adj (extVertex G h_size) (G.embedding ⟨1, by decide⟩))
    (h_no_v2 : ¬G.str.1.Adj (extVertex G h_size) (G.embedding ⟨2, by decide⟩))
    (h_yes_v3 : G.str.1.Adj (extVertex G h_size) (G.embedding ⟨3, by decide⟩)) :
    GenFlagIso thesisType5 G t5_v0_R_b := by
  classical
  set v0 := G.embedding ⟨0, by decide⟩ with hv0
  set v1 := G.embedding ⟨1, by decide⟩ with hv1
  set v2 := G.embedding ⟨2, by decide⟩ with hv2
  set v3 := G.embedding ⟨3, by decide⟩ with hv3
  set w := extVertex G h_size with hw
  have hv01 : v0 ≠ v1 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv02 : v0 ≠ v2 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv03 : v0 ≠ v3 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv12 : v1 ≠ v2 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv13 : v1 ≠ v3 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv23 : v2 ≠ v3 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hw_notin : w ∉ Set.range G.embedding := extVertex_notin_range G h_size
  have hwv0 : w ≠ v0 := fun h => hw_notin ⟨⟨0, by decide⟩, h.symm⟩
  have hwv1 : w ≠ v1 := fun h => hw_notin ⟨⟨1, by decide⟩, h.symm⟩
  have hwv2 : w ≠ v2 := fun h => hw_notin ⟨⟨2, by decide⟩, h.symm⟩
  have hwv3 : w ≠ v3 := fun h => hw_notin ⟨⟨3, by decide⟩, h.symm⟩
  have h_str_eq : (CG2.comap G.embedding G.str).1 = thesisType5.str.1 :=
    congr_arg Prod.fst G.isInduced
  have h_col_eq : ∀ j : Fin thesisType5.size,
      G.str.2 (G.embedding j) = thesisType5.str.2 j := fun j =>
    congr_fun (congr_arg Prod.snd G.isInduced) j
  have G_v0v1 : G.str.1.Adj v0 v1 := by
    have h_sigma : thesisType5.str.1.Adj ⟨0, by decide⟩ ⟨1, by decide⟩ := by
      simp [thesisType5, SimpleGraph.fromRel_adj]
    rw [← h_str_eq] at h_sigma; exact h_sigma
  have G_v0v2 : G.str.1.Adj v0 v2 := by
    have h_sigma : thesisType5.str.1.Adj ⟨0, by decide⟩ ⟨2, by decide⟩ := by
      simp [thesisType5, SimpleGraph.fromRel_adj]
    rw [← h_str_eq] at h_sigma; exact h_sigma
  have G_v1v3 : G.str.1.Adj v1 v3 := by
    have h_sigma : thesisType5.str.1.Adj ⟨1, by decide⟩ ⟨3, by decide⟩ := by
      simp [thesisType5, SimpleGraph.fromRel_adj]
    rw [← h_str_eq] at h_sigma; exact h_sigma
  have G_v0v3_no : ¬G.str.1.Adj v0 v3 := by
    intro h
    have h' : (CG2.comap G.embedding G.str).1.Adj ⟨0, by decide⟩ ⟨3, by decide⟩ := h
    rw [h_str_eq] at h'
    simp [thesisType5, SimpleGraph.fromRel_adj] at h'
  have G_v1v2_no : ¬G.str.1.Adj v1 v2 := by
    intro h
    have h' : (CG2.comap G.embedding G.str).1.Adj ⟨1, by decide⟩ ⟨2, by decide⟩ := h
    rw [h_str_eq] at h'
    simp [thesisType5, SimpleGraph.fromRel_adj] at h'
  have G_v2v3_no : ¬G.str.1.Adj v2 v3 := by
    intro h
    have h' : (CG2.comap G.embedding G.str).1.Adj ⟨2, by decide⟩ ⟨3, by decide⟩ := h
    rw [h_str_eq] at h'
    simp [thesisType5, SimpleGraph.fromRel_adj] at h'
  obtain ⟨v_ext, hv_ext_notin, hv_ext_adj⟩ := h_ext
  have hv_ext_eq : v_ext = w := extVertex_unique G h_size v_ext hv_ext_notin
  subst hv_ext_eq
  have G_wv0 : G.str.1.Adj w v0 := by rw [hv0]; exact hv_ext_adj
  have hcol_v0 : G.str.2 v0 = 0 := by rw [hv0, h_col_eq]; simp [thesisType5]
  have hcol_v1 : G.str.2 v1 = 0 := by rw [hv1, h_col_eq]; simp [thesisType5]
  have hcol_v2 : G.str.2 v2 = 1 := by rw [hv2, h_col_eq]; simp [thesisType5]
  have hcol_v3 : G.str.2 v3 = 1 := by rw [hv3, h_col_eq]; simp [thesisType5]
  let φ_fn : Fin G.size → Fin 5 := fun x =>
    if x = v0 then ⟨0, by decide⟩
    else if x = v1 then ⟨1, by decide⟩
    else if x = v2 then ⟨2, by decide⟩
    else if x = v3 then ⟨3, by decide⟩
    else ⟨4, by decide⟩
  have φv0 : φ_fn v0 = ⟨0, by decide⟩ := by simp [φ_fn]
  have φv1 : φ_fn v1 = ⟨1, by decide⟩ := by
    simp only [φ_fn]; rw [if_neg hv01.symm]; simp
  have φv2 : φ_fn v2 = ⟨2, by decide⟩ := by
    simp only [φ_fn]; rw [if_neg hv02.symm, if_neg hv12.symm]; simp
  have φv3 : φ_fn v3 = ⟨3, by decide⟩ := by
    simp only [φ_fn]
    rw [if_neg hv03.symm, if_neg hv13.symm, if_neg hv23.symm]; simp
  have φw : φ_fn w = ⟨4, by decide⟩ := by
    simp only [φ_fn]
    rw [if_neg hwv0, if_neg hwv1, if_neg hwv2, if_neg hwv3]
  have x_cases : ∀ x : Fin G.size, x = v0 ∨ x = v1 ∨ x = v2 ∨ x = v3 ∨ x = w := by
    intro x
    by_cases h0 : x = v0
    · exact Or.inl h0
    by_cases h1 : x = v1
    · exact Or.inr (Or.inl h1)
    by_cases h2 : x = v2
    · exact Or.inr (Or.inr (Or.inl h2))
    by_cases h3 : x = v3
    · exact Or.inr (Or.inr (Or.inr (Or.inl h3)))
    right; right; right; right
    apply extVertex_unique G h_size
    rintro ⟨⟨j, hj⟩, hj_eq⟩
    have hjlt : j < 4 := hj
    have hsize : thesisType5.size = 4 := rfl
    interval_cases j
    · exact h0 hj_eq.symm
    · exact h1 hj_eq.symm
    · exact h2 hj_eq.symm
    · exact h3 hj_eq.symm
  have φ_inj : Function.Injective φ_fn := by
    intro x y hxy
    rcases x_cases x with hx | hx | hx | hx | hx <;>
    rcases x_cases y with hy | hy | hy | hy | hy <;>
      subst hx <;> subst hy <;>
      first
      | rfl
      | (exfalso
         try rw [φv0] at hxy
         try rw [φv1] at hxy
         try rw [φv2] at hxy
         try rw [φv3] at hxy
         try rw [φw] at hxy
         exact absurd hxy (by decide))
  have hcard : Fintype.card (Fin G.size) = Fintype.card (Fin 5) := by
    rw [Fintype.card_fin, Fintype.card_fin, h_size]
  have φ_bij : Function.Bijective φ_fn :=
    (Fintype.bijective_iff_injective_and_card φ_fn).mpr ⟨φ_inj, hcard⟩
  let φ : Fin G.size ≃ Fin t5_v0_R_b.size := Equiv.ofBijective φ_fn φ_bij
  have hφv0 : φ v0 = ⟨0, by decide⟩ := φv0
  have hφv1 : φ v1 = ⟨1, by decide⟩ := φv1
  have hφv2 : φ v2 = ⟨2, by decide⟩ := φv2
  have hφv3 : φ v3 = ⟨3, by decide⟩ := φv3
  have hφw : φ w = ⟨4, by decide⟩ := φw
  refine ⟨φ, ?_, ?_⟩
  · apply Prod.ext
    · ext u v
      change (t5_v0_R_b.str.1.comap (φ : Fin G.size → Fin 5)).Adj u v ↔ G.str.1.Adj u v
      simp only [SimpleGraph.comap_adj]
      rcases x_cases u with hu | hu | hu | hu | hu <;>
      rcases x_cases v with hv | hv | hv | hv | hv <;>
        rw [hu, hv]
      · rw [hφv0]; constructor
        · intro h; simp [t5_v0_R_b] at h
        · intro h; exact (G.str.1.irrefl h).elim
      · rw [hφv0, hφv1]; constructor
        · intro _; exact G_v0v1
        · intro _; simp [t5_v0_R_b, SimpleGraph.fromRel_adj]
      · rw [hφv0, hφv2]; constructor
        · intro _; exact G_v0v2
        · intro _; simp [t5_v0_R_b, SimpleGraph.fromRel_adj]
      · rw [hφv0, hφv3]; constructor
        · intro h; simp [t5_v0_R_b] at h
        · intro h; exact (G_v0v3_no h).elim
      · rw [hφv0, hφw]; constructor
        · intro _; exact G_wv0.symm
        · intro _; simp [t5_v0_R_b, SimpleGraph.fromRel_adj]
      · rw [hφv1, hφv0]; constructor
        · intro _; exact G_v0v1.symm
        · intro _; simp [t5_v0_R_b, SimpleGraph.fromRel_adj]
      · rw [hφv1]; constructor
        · intro h; simp [t5_v0_R_b] at h
        · intro h; exact (G.str.1.irrefl h).elim
      · rw [hφv1, hφv2]; constructor
        · intro h; simp [t5_v0_R_b] at h
        · intro h; exact (G_v1v2_no h).elim
      · rw [hφv1, hφv3]; constructor
        · intro _; exact G_v1v3
        · intro _; simp [t5_v0_R_b, SimpleGraph.fromRel_adj]
      · rw [hφv1, hφw]; constructor
        · intro h; simp [t5_v0_R_b] at h
        · intro h; exact (h_no_v1 h.symm).elim
      · rw [hφv2, hφv0]; constructor
        · intro _; exact G_v0v2.symm
        · intro _; simp [t5_v0_R_b, SimpleGraph.fromRel_adj]
      · rw [hφv2, hφv1]; constructor
        · intro h; simp [t5_v0_R_b] at h
        · intro h; exact (G_v1v2_no h.symm).elim
      · rw [hφv2]; constructor
        · intro h; simp [t5_v0_R_b] at h
        · intro h; exact (G.str.1.irrefl h).elim
      · rw [hφv2, hφv3]; constructor
        · intro h; simp [t5_v0_R_b] at h
        · intro h; exact (G_v2v3_no h).elim
      · rw [hφv2, hφw]; constructor
        · intro h; simp [t5_v0_R_b] at h
        · intro h; exact (h_no_v2 h.symm).elim
      · rw [hφv3, hφv0]; constructor
        · intro h; simp [t5_v0_R_b] at h
        · intro h; exact (G_v0v3_no h.symm).elim
      · rw [hφv3, hφv1]; constructor
        · intro _; exact G_v1v3.symm
        · intro _; simp [t5_v0_R_b, SimpleGraph.fromRel_adj]
      · rw [hφv3, hφv2]; constructor
        · intro h; simp [t5_v0_R_b] at h
        · intro h; exact (G_v2v3_no h.symm).elim
      · rw [hφv3]; constructor
        · intro h; simp [t5_v0_R_b] at h
        · intro h; exact (G.str.1.irrefl h).elim
      · rw [hφv3, hφw]; constructor
        · intro _; exact h_yes_v3.symm
        · intro _; simp [t5_v0_R_b, SimpleGraph.fromRel_adj]
      · rw [hφw, hφv0]; constructor
        · intro _; exact G_wv0
        · intro _; simp [t5_v0_R_b, SimpleGraph.fromRel_adj]
      · rw [hφw, hφv1]; constructor
        · intro h; simp [t5_v0_R_b] at h
        · intro h; exact (h_no_v1 h).elim
      · rw [hφw, hφv2]; constructor
        · intro h; simp [t5_v0_R_b] at h
        · intro h; exact (h_no_v2 h).elim
      · rw [hφw, hφv3]; constructor
        · intro _; exact h_yes_v3
        · intro _; simp [t5_v0_R_b, SimpleGraph.fromRel_adj]
      · rw [hφw]; constructor
        · intro h; simp [t5_v0_R_b] at h
        · intro h; exact (G.str.1.irrefl h).elim
    · funext x
      change t5_v0_R_b.str.2 (φ x) = G.str.2 x
      rcases x_cases x with hx | hx | hx | hx | hx <;> rw [hx]
      · rw [hφv0, hcol_v0]; rfl
      · rw [hφv1, hcol_v1]; rfl
      · rw [hφv2, hcol_v2]; rfl
      · rw [hφv3, hcol_v3]; rfl
      · rw [hφw, h_w_R]; rfl
  · intro i
    fin_cases i
    · simp [t5_v0_R_b, Fin.castLE]; exact hφv0
    · simp [t5_v0_R_b, Fin.castLE]; exact hφv1
    · simp [t5_v0_R_b, Fin.castLE]; exact hφv2
    · simp [t5_v0_R_b, Fin.castLE]; exact hφv3

/-! ### σ₅-3 case 6: classification for w=B adj v0 only -/

set_option maxHeartbeats 1600000 in
/-- Case 6 of σ₅-3: any size-5 thesisType5-flag G with extAdj-v0, w coloured B,
    w not adjacent to v1, v2, v3, is σ-iso to `t5_v0_B`. -/
theorem t5_v0_B_classification (G : GenFlag CG2 thesisType5)
    (h_size : G.size = 5)
    (h_ext : extAdjacency thesisType5 G ⟨0, by decide⟩)
    (h_w_B : G.str.2 (extVertex G h_size) = 1)
    (h_no_v1 : ¬G.str.1.Adj (extVertex G h_size) (G.embedding ⟨1, by decide⟩))
    (h_no_v2 : ¬G.str.1.Adj (extVertex G h_size) (G.embedding ⟨2, by decide⟩))
    (h_no_v3 : ¬G.str.1.Adj (extVertex G h_size) (G.embedding ⟨3, by decide⟩)) :
    GenFlagIso thesisType5 G t5_v0_B := by
  classical
  set v0 := G.embedding ⟨0, by decide⟩ with hv0
  set v1 := G.embedding ⟨1, by decide⟩ with hv1
  set v2 := G.embedding ⟨2, by decide⟩ with hv2
  set v3 := G.embedding ⟨3, by decide⟩ with hv3
  set w := extVertex G h_size with hw
  have hv01 : v0 ≠ v1 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv02 : v0 ≠ v2 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv03 : v0 ≠ v3 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv12 : v1 ≠ v2 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv13 : v1 ≠ v3 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv23 : v2 ≠ v3 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hw_notin : w ∉ Set.range G.embedding := extVertex_notin_range G h_size
  have hwv0 : w ≠ v0 := fun h => hw_notin ⟨⟨0, by decide⟩, h.symm⟩
  have hwv1 : w ≠ v1 := fun h => hw_notin ⟨⟨1, by decide⟩, h.symm⟩
  have hwv2 : w ≠ v2 := fun h => hw_notin ⟨⟨2, by decide⟩, h.symm⟩
  have hwv3 : w ≠ v3 := fun h => hw_notin ⟨⟨3, by decide⟩, h.symm⟩
  have h_str_eq : (CG2.comap G.embedding G.str).1 = thesisType5.str.1 :=
    congr_arg Prod.fst G.isInduced
  have h_col_eq : ∀ j : Fin thesisType5.size,
      G.str.2 (G.embedding j) = thesisType5.str.2 j := fun j =>
    congr_fun (congr_arg Prod.snd G.isInduced) j
  have G_v0v1 : G.str.1.Adj v0 v1 := by
    have h_sigma : thesisType5.str.1.Adj ⟨0, by decide⟩ ⟨1, by decide⟩ := by
      simp [thesisType5, SimpleGraph.fromRel_adj]
    rw [← h_str_eq] at h_sigma; exact h_sigma
  have G_v0v2 : G.str.1.Adj v0 v2 := by
    have h_sigma : thesisType5.str.1.Adj ⟨0, by decide⟩ ⟨2, by decide⟩ := by
      simp [thesisType5, SimpleGraph.fromRel_adj]
    rw [← h_str_eq] at h_sigma; exact h_sigma
  have G_v1v3 : G.str.1.Adj v1 v3 := by
    have h_sigma : thesisType5.str.1.Adj ⟨1, by decide⟩ ⟨3, by decide⟩ := by
      simp [thesisType5, SimpleGraph.fromRel_adj]
    rw [← h_str_eq] at h_sigma; exact h_sigma
  have G_v0v3_no : ¬G.str.1.Adj v0 v3 := by
    intro h
    have h' : (CG2.comap G.embedding G.str).1.Adj ⟨0, by decide⟩ ⟨3, by decide⟩ := h
    rw [h_str_eq] at h'
    simp [thesisType5, SimpleGraph.fromRel_adj] at h'
  have G_v1v2_no : ¬G.str.1.Adj v1 v2 := by
    intro h
    have h' : (CG2.comap G.embedding G.str).1.Adj ⟨1, by decide⟩ ⟨2, by decide⟩ := h
    rw [h_str_eq] at h'
    simp [thesisType5, SimpleGraph.fromRel_adj] at h'
  have G_v2v3_no : ¬G.str.1.Adj v2 v3 := by
    intro h
    have h' : (CG2.comap G.embedding G.str).1.Adj ⟨2, by decide⟩ ⟨3, by decide⟩ := h
    rw [h_str_eq] at h'
    simp [thesisType5, SimpleGraph.fromRel_adj] at h'
  obtain ⟨v_ext, hv_ext_notin, hv_ext_adj⟩ := h_ext
  have hv_ext_eq : v_ext = w := extVertex_unique G h_size v_ext hv_ext_notin
  subst hv_ext_eq
  have G_wv0 : G.str.1.Adj w v0 := by rw [hv0]; exact hv_ext_adj
  have hcol_v0 : G.str.2 v0 = 0 := by rw [hv0, h_col_eq]; simp [thesisType5]
  have hcol_v1 : G.str.2 v1 = 0 := by rw [hv1, h_col_eq]; simp [thesisType5]
  have hcol_v2 : G.str.2 v2 = 1 := by rw [hv2, h_col_eq]; simp [thesisType5]
  have hcol_v3 : G.str.2 v3 = 1 := by rw [hv3, h_col_eq]; simp [thesisType5]
  let φ_fn : Fin G.size → Fin 5 := fun x =>
    if x = v0 then ⟨0, by decide⟩
    else if x = v1 then ⟨1, by decide⟩
    else if x = v2 then ⟨2, by decide⟩
    else if x = v3 then ⟨3, by decide⟩
    else ⟨4, by decide⟩
  have φv0 : φ_fn v0 = ⟨0, by decide⟩ := by simp [φ_fn]
  have φv1 : φ_fn v1 = ⟨1, by decide⟩ := by
    simp only [φ_fn]; rw [if_neg hv01.symm]; simp
  have φv2 : φ_fn v2 = ⟨2, by decide⟩ := by
    simp only [φ_fn]; rw [if_neg hv02.symm, if_neg hv12.symm]; simp
  have φv3 : φ_fn v3 = ⟨3, by decide⟩ := by
    simp only [φ_fn]
    rw [if_neg hv03.symm, if_neg hv13.symm, if_neg hv23.symm]; simp
  have φw : φ_fn w = ⟨4, by decide⟩ := by
    simp only [φ_fn]
    rw [if_neg hwv0, if_neg hwv1, if_neg hwv2, if_neg hwv3]
  have x_cases : ∀ x : Fin G.size, x = v0 ∨ x = v1 ∨ x = v2 ∨ x = v3 ∨ x = w := by
    intro x
    by_cases h0 : x = v0
    · exact Or.inl h0
    by_cases h1 : x = v1
    · exact Or.inr (Or.inl h1)
    by_cases h2 : x = v2
    · exact Or.inr (Or.inr (Or.inl h2))
    by_cases h3 : x = v3
    · exact Or.inr (Or.inr (Or.inr (Or.inl h3)))
    right; right; right; right
    apply extVertex_unique G h_size
    rintro ⟨⟨j, hj⟩, hj_eq⟩
    have hjlt : j < 4 := hj
    have hsize : thesisType5.size = 4 := rfl
    interval_cases j
    · exact h0 hj_eq.symm
    · exact h1 hj_eq.symm
    · exact h2 hj_eq.symm
    · exact h3 hj_eq.symm
  have φ_inj : Function.Injective φ_fn := by
    intro x y hxy
    rcases x_cases x with hx | hx | hx | hx | hx <;>
    rcases x_cases y with hy | hy | hy | hy | hy <;>
      subst hx <;> subst hy <;>
      first
      | rfl
      | (exfalso
         try rw [φv0] at hxy
         try rw [φv1] at hxy
         try rw [φv2] at hxy
         try rw [φv3] at hxy
         try rw [φw] at hxy
         exact absurd hxy (by decide))
  have hcard : Fintype.card (Fin G.size) = Fintype.card (Fin 5) := by
    rw [Fintype.card_fin, Fintype.card_fin, h_size]
  have φ_bij : Function.Bijective φ_fn :=
    (Fintype.bijective_iff_injective_and_card φ_fn).mpr ⟨φ_inj, hcard⟩
  let φ : Fin G.size ≃ Fin t5_v0_B.size := Equiv.ofBijective φ_fn φ_bij
  have hφv0 : φ v0 = ⟨0, by decide⟩ := φv0
  have hφv1 : φ v1 = ⟨1, by decide⟩ := φv1
  have hφv2 : φ v2 = ⟨2, by decide⟩ := φv2
  have hφv3 : φ v3 = ⟨3, by decide⟩ := φv3
  have hφw : φ w = ⟨4, by decide⟩ := φw
  refine ⟨φ, ?_, ?_⟩
  · apply Prod.ext
    · ext u v
      change (t5_v0_B.str.1.comap (φ : Fin G.size → Fin 5)).Adj u v ↔ G.str.1.Adj u v
      simp only [SimpleGraph.comap_adj]
      rcases x_cases u with hu | hu | hu | hu | hu <;>
      rcases x_cases v with hv | hv | hv | hv | hv <;>
        rw [hu, hv]
      · rw [hφv0]; constructor
        · intro h; simp [t5_v0_B] at h
        · intro h; exact (G.str.1.irrefl h).elim
      · rw [hφv0, hφv1]; constructor
        · intro _; exact G_v0v1
        · intro _; simp [t5_v0_B, SimpleGraph.fromRel_adj]
      · rw [hφv0, hφv2]; constructor
        · intro _; exact G_v0v2
        · intro _; simp [t5_v0_B, SimpleGraph.fromRel_adj]
      · rw [hφv0, hφv3]; constructor
        · intro h; simp [t5_v0_B] at h
        · intro h; exact (G_v0v3_no h).elim
      · rw [hφv0, hφw]; constructor
        · intro _; exact G_wv0.symm
        · intro _; simp [t5_v0_B, SimpleGraph.fromRel_adj]
      · rw [hφv1, hφv0]; constructor
        · intro _; exact G_v0v1.symm
        · intro _; simp [t5_v0_B, SimpleGraph.fromRel_adj]
      · rw [hφv1]; constructor
        · intro h; simp [t5_v0_B] at h
        · intro h; exact (G.str.1.irrefl h).elim
      · rw [hφv1, hφv2]; constructor
        · intro h; simp [t5_v0_B] at h
        · intro h; exact (G_v1v2_no h).elim
      · rw [hφv1, hφv3]; constructor
        · intro _; exact G_v1v3
        · intro _; simp [t5_v0_B, SimpleGraph.fromRel_adj]
      · rw [hφv1, hφw]; constructor
        · intro h; simp [t5_v0_B] at h
        · intro h; exact (h_no_v1 h.symm).elim
      · rw [hφv2, hφv0]; constructor
        · intro _; exact G_v0v2.symm
        · intro _; simp [t5_v0_B, SimpleGraph.fromRel_adj]
      · rw [hφv2, hφv1]; constructor
        · intro h; simp [t5_v0_B] at h
        · intro h; exact (G_v1v2_no h.symm).elim
      · rw [hφv2]; constructor
        · intro h; simp [t5_v0_B] at h
        · intro h; exact (G.str.1.irrefl h).elim
      · rw [hφv2, hφv3]; constructor
        · intro h; simp [t5_v0_B] at h
        · intro h; exact (G_v2v3_no h).elim
      · rw [hφv2, hφw]; constructor
        · intro h; simp [t5_v0_B] at h
        · intro h; exact (h_no_v2 h.symm).elim
      · rw [hφv3, hφv0]; constructor
        · intro h; simp [t5_v0_B] at h
        · intro h; exact (G_v0v3_no h.symm).elim
      · rw [hφv3, hφv1]; constructor
        · intro _; exact G_v1v3.symm
        · intro _; simp [t5_v0_B, SimpleGraph.fromRel_adj]
      · rw [hφv3, hφv2]; constructor
        · intro h; simp [t5_v0_B] at h
        · intro h; exact (G_v2v3_no h.symm).elim
      · rw [hφv3]; constructor
        · intro h; simp [t5_v0_B] at h
        · intro h; exact (G.str.1.irrefl h).elim
      · rw [hφv3, hφw]; constructor
        · intro h; simp [t5_v0_B] at h
        · intro h; exact (h_no_v3 h.symm).elim
      · rw [hφw, hφv0]; constructor
        · intro _; exact G_wv0
        · intro _; simp [t5_v0_B, SimpleGraph.fromRel_adj]
      · rw [hφw, hφv1]; constructor
        · intro h; simp [t5_v0_B] at h
        · intro h; exact (h_no_v1 h).elim
      · rw [hφw, hφv2]; constructor
        · intro h; simp [t5_v0_B] at h
        · intro h; exact (h_no_v2 h).elim
      · rw [hφw, hφv3]; constructor
        · intro h; simp [t5_v0_B] at h
        · intro h; exact (h_no_v3 h).elim
      · rw [hφw]; constructor
        · intro h; simp [t5_v0_B] at h
        · intro h; exact (G.str.1.irrefl h).elim
    · funext x
      change t5_v0_B.str.2 (φ x) = G.str.2 x
      rcases x_cases x with hx | hx | hx | hx | hx <;> rw [hx]
      · rw [hφv0, hcol_v0]; rfl
      · rw [hφv1, hcol_v1]; rfl
      · rw [hφv2, hcol_v2]; rfl
      · rw [hφv3, hcol_v3]; rfl
      · rw [hφw, h_w_B]; rfl
  · intro i
    fin_cases i
    · simp [t5_v0_B, Fin.castLE]; exact hφv0
    · simp [t5_v0_B, Fin.castLE]; exact hφv1
    · simp [t5_v0_B, Fin.castLE]; exact hφv2
    · simp [t5_v0_B, Fin.castLE]; exact hφv3

/-! ### σ₁-4-E.2: σ-side positivity for `extSum v1 - extSum v0`

For BRRB, both `extSum thesisType1 ⟨1⟩` and `extSum thesisType1 ⟨0⟩` evaluate
to 1 at any regular σ-functional ψ (via `extSum_eval_one`). Hence their
difference evaluates to 0, giving the σ-side positivity required by
`sigma_nonneg_template_perfunc_weakened` (hypothesis #2). The locality side is
discharged uniformly via `genIsLocalFlag_extAdj_BRRB`. -/

set_option maxHeartbeats 1000000 in
/-- **Generic σ-positivity (= 0)** at the BRRB class: for any σ, indices i, j,
    regular σ-functional, `ψ.evalAlg(extSum σ i - extSum σ j) = 0`. Each
    `extSum σ k` evaluates to 1 at a regular functional (via `extSum_eval_one`);
    difference is 0. The σ₁..σ₅ cases all reduce to this. -/
theorem extSum_diff_psi_eq_zero (σ : GenFlagType CG2) (i j : Fin σ.size)
    (ψ : GenLimitFunctional CG2 σ brrbGenGraphClass brrbGenDelta)
    (h_reg_psi : ∀ k, ∀ v : Fin (ψ.seq.seq k).size,
      (Finset.univ.filter ((ψ.seq.seq k).str.1.Adj v)).card =
        brrbGenDelta (ψ.seq.seq k).forget) :
    ψ.evalAlg (extSum σ i - extSum σ j) = 0 := by
  have h_Δ_to_inf : Filter.Tendsto
      (fun k => brrbGenDelta (ψ.seq.seq (ψ.sub k)).forget)
      Filter.atTop Filter.atTop :=
    (ψ.seq.increasing.comp ψ.sub_strictMono).tendsto_atTop
  have h_local_generic : ∀ (σ' : GenFlagType CG2) (i' : Fin σ'.size),
      ∀ cls ∈ ((genClassesOfSize CG2 σ'
        (σ'.size + 1) (Nat.le_succ _)).filter
        (fun cls => extAdjacencyClass σ' cls i')),
      GenIsLocalFlag σ' cls.out brrbGenGraphClass brrbGenDelta := by
    intro σ' i' cls hcls
    rw [Finset.mem_filter] at hcls
    obtain ⟨h_mem, h_adjCls⟩ := hcls
    have hsize : cls.out.size = σ'.size + 1 :=
      genClassesOfSize_out_size h_mem
    have h_adj : extAdjacency σ' cls.out i' := h_adjCls
    exact genIsLocalFlag_extAdj_BRRB hsize h_adj
  have h_v_i := extSum_eval_one σ ψ i (h_local_generic σ i) h_reg_psi h_Δ_to_inf
  have h_v_j := extSum_eval_one σ ψ j (h_local_generic σ j) h_reg_psi h_Δ_to_inf
  rw [sub_eq_add_neg, ← neg_one_smul ℝ (extSum σ j),
      GenLimitFunctional.evalAlg_add, GenLimitFunctional.evalAlg_smul,
      h_v_i, h_v_j]
  ring

/-- σ-side positivity for σ₁-4-E: at any regular σ-functional ψ over the BRRB
    class, `ψ.evalAlg(extSum_v1 - extSum_v0) = 0`. Specialisation of
    `extSum_diff_psi_eq_zero`. -/
theorem sigma1_extSum_diff_psi_eq_zero
    (ψ : GenLimitFunctional CG2 thesisType1 brrbGenGraphClass brrbGenDelta)
    (h_reg_psi : ∀ k, ∀ v : Fin (ψ.seq.seq k).size,
      (Finset.univ.filter ((ψ.seq.seq k).str.1.Adj v)).card =
        brrbGenDelta (ψ.seq.seq k).forget) :
    ψ.evalAlg (extSum thesisType1 ⟨1, by decide⟩
      - extSum thesisType1 ⟨0, by decide⟩) = 0 :=
  extSum_diff_psi_eq_zero thesisType1 ⟨1, by decide⟩ ⟨0, by decide⟩ ψ h_reg_psi

/-! ### σ₁-4-E.3.1: extAdj-v1 dichotomy

For any size-5 thesisType1-flag class `cls` with `extAdjacencyClass cls v1`, and
any BRRB ∅-functional `phi`, EITHER `cls` is iso to one of the 4 ext witnesses
`{t1_v1_a, t1_v1_b, t1_v1_c, t1_v1_d}`, OR `phi.eval cls.out.forget = 0`.

Proof: case-split on whether `cls.out` has a BB-edge or triangle. If yes,
`eval_zero_of_adj_black` / `eval_zero_of_triangle` gives the eval-zero branch.
Otherwise extract BRRB-compatible constraints via `t1_extAdj_v1_BRRB_w_R_not_adj_v0`,
then case-split on (w-v2, w-v3) ∈ {T,F}² and dispatch to the matching
`t1_v1_*_classification`. -/
theorem t1_extAdj_v1_dichotomy
    (cls : GenFlagClass CG2 thesisType1)
    (h_size : cls.out.size = 5)
    (h_extAdj : extAdjacencyClass thesisType1 cls ⟨1, by decide⟩)
    (phi : GenLimitFunctional CG2 (GenFlagType.empty CG2)
      brrbGenGraphClass brrbGenDelta) :
    cls = GenFlagClass.mk t1_v1_a ∨
    cls = GenFlagClass.mk t1_v1_b ∨
    cls = GenFlagClass.mk t1_v1_c ∨
    cls = GenFlagClass.mk t1_v1_d ∨
    phi.eval cls.out.forget = 0 := by
  classical
  have h_ext : extAdjacency thesisType1 cls.out ⟨1, by decide⟩ := h_extAdj
  by_cases h_BB : ∃ u v : Fin cls.out.size,
      cls.out.str.2 u = 1 ∧ cls.out.str.2 v = 1 ∧ cls.out.str.1.Adj u v
  · -- BB-edge in cls.out → phi.eval cls.out.forget = 0
    right; right; right; right
    exact eval_zero_of_adj_black phi cls.out.forget h_BB
  by_cases h_tri : ∃ u v w : Fin cls.out.size,
      cls.out.str.1.Adj u v ∧ cls.out.str.1.Adj v w ∧ cls.out.str.1.Adj u w
  · -- Triangle in cls.out → phi.eval cls.out.forget = 0
    right; right; right; right
    exact eval_zero_of_triangle phi cls.out.forget h_tri
  -- BRRB-compatible: extract the constraints w=R and ¬w-v0 from σ-side reasoning.
  have h_BRRB := t1_extAdj_v1_BRRB_w_R_not_adj_v0 cls.out h_size h_ext h_BB h_tri
  obtain ⟨h_w_R, h_no_v0⟩ := h_BRRB
  -- Case-split on (w-v2, w-v3) ∈ {T,F}², dispatch to the matching classification.
  by_cases h_v2 : cls.out.str.1.Adj (extVertex cls.out h_size)
      (cls.out.embedding ⟨2, by decide⟩)
  · by_cases h_v3 : cls.out.str.1.Adj (extVertex cls.out h_size)
        (cls.out.embedding ⟨3, by decide⟩)
    · -- (T, T) → t1_v1_d
      right; right; right; left
      have hiso := t1_v1_d_classification cls.out h_size h_ext h_w_R h_no_v0 h_v2 h_v3
      have hmk : GenFlagClass.mk cls.out = GenFlagClass.mk t1_v1_d :=
        Quotient.sound hiso
      rw [← Quotient.out_eq cls]; exact hmk
    · -- (T, F) → t1_v1_b (w adj v1, v2)
      right; left
      have hiso := t1_v1_b_classification cls.out h_size h_ext h_w_R h_no_v0 h_v2 h_v3
      have hmk : GenFlagClass.mk cls.out = GenFlagClass.mk t1_v1_b :=
        Quotient.sound hiso
      rw [← Quotient.out_eq cls]; exact hmk
  · by_cases h_v3 : cls.out.str.1.Adj (extVertex cls.out h_size)
        (cls.out.embedding ⟨3, by decide⟩)
    · -- (F, T) → t1_v1_c (w adj v1, v3)
      right; right; left
      have hiso := t1_v1_c_classification cls.out h_size h_ext h_w_R h_no_v0 h_v2 h_v3
      have hmk : GenFlagClass.mk cls.out = GenFlagClass.mk t1_v1_c :=
        Quotient.sound hiso
      rw [← Quotient.out_eq cls]; exact hmk
    · -- (F, F) → t1_v1_a (w adj v1 only)
      left
      have hiso := t1_v1_a_classification cls.out h_size h_ext h_w_R h_no_v0 h_v2 h_v3
      have hmk : GenFlagClass.mk cls.out = GenFlagClass.mk t1_v1_a :=
        Quotient.sound hiso
      rw [← Quotient.out_eq cls]; exact hmk

/-! ### σ₁-4-E.3.2: extAdj-v0 dichotomy

For any size-5 thesisType1-flag class `cls` with `extAdjacencyClass cls v0`, and
any BRRB ∅-functional `phi`, EITHER `cls` is iso to one of the 2 ext witnesses
`{t1_v0_R, t1_v0_B}`, OR `phi.eval cls.out.forget = 0`.

Proof structure mirrors `t1_extAdj_v1_dichotomy`. After ruling out BB-edge
and triangle, `t1_extAdj_v0_BRRB_no_v1_v2_v3` gives ¬(w adj v1, v2, v3),
so the only adjacency of w is to v0 (forced by extAdj-v0). The case-split
is on the colour of w: R → `t1_v0_R`, B → `t1_v0_B`. -/
theorem t1_extAdj_v0_dichotomy
    (cls : GenFlagClass CG2 thesisType1)
    (h_size : cls.out.size = 5)
    (h_extAdj : extAdjacencyClass thesisType1 cls ⟨0, by decide⟩)
    (phi : GenLimitFunctional CG2 (GenFlagType.empty CG2)
      brrbGenGraphClass brrbGenDelta) :
    cls = GenFlagClass.mk t1_v0_R ∨
    cls = GenFlagClass.mk t1_v0_B ∨
    phi.eval cls.out.forget = 0 := by
  classical
  have h_ext : extAdjacency thesisType1 cls.out ⟨0, by decide⟩ := h_extAdj
  by_cases h_BB : ∃ u v : Fin cls.out.size,
      cls.out.str.2 u = 1 ∧ cls.out.str.2 v = 1 ∧ cls.out.str.1.Adj u v
  · right; right
    exact eval_zero_of_adj_black phi cls.out.forget h_BB
  by_cases h_tri : ∃ u v w : Fin cls.out.size,
      cls.out.str.1.Adj u v ∧ cls.out.str.1.Adj v w ∧ cls.out.str.1.Adj u w
  · right; right
    exact eval_zero_of_triangle phi cls.out.forget h_tri
  -- BRRB-compatible: extract ¬(w adj v1), ¬(w adj v2), ¬(w adj v3).
  obtain ⟨h_no_v1, h_no_v2, h_no_v3⟩ :=
    t1_extAdj_v0_BRRB_no_v1_v2_v3 cls.out h_size h_ext h_BB h_tri
  -- Case-split on w's colour. Since CG2 colours are Fin 2 = {0, 1},
  -- either w is R (col=0) or B (col=1).
  have hcol_lt : (cls.out.str.2 (extVertex cls.out h_size)).val < 2 :=
    (cls.out.str.2 (extVertex cls.out h_size)).isLt
  interval_cases h_w_col : (cls.out.str.2 (extVertex cls.out h_size)).val
  · -- w coloured R (col=0)
    left
    have h_w_R : cls.out.str.2 (extVertex cls.out h_size) = 0 := Fin.ext h_w_col
    have hiso := t1_v0_R_classification cls.out h_size h_ext h_w_R h_no_v1 h_no_v2 h_no_v3
    have hmk : GenFlagClass.mk cls.out = GenFlagClass.mk t1_v0_R :=
      Quotient.sound hiso
    rw [← Quotient.out_eq cls]; exact hmk
  · -- w coloured B (col=1)
    right; left
    have h_w_B : cls.out.str.2 (extVertex cls.out h_size) = 1 := Fin.ext h_w_col
    have hiso := t1_v0_B_classification cls.out h_size h_ext h_w_B h_no_v1 h_no_v2 h_no_v3
    have hmk : GenFlagClass.mk cls.out = GenFlagClass.mk t1_v0_B :=
      Quotient.sound hiso
    rw [← Quotient.out_eq cls]; exact hmk

/-! ### σ₅-3.4: extAdj-v2 dichotomy (thesisType5)

For any size-5 thesisType5-flag class `cls` with `extAdjacencyClass cls v2`, and
any BRRB ∅-functional `phi`, EITHER `cls` is iso to one of the 3 v2-side ext
witnesses `{t5_v2_a, t5_v2_b, t5_v2_c}`, OR `phi.eval cls.out.forget = 0`.

Proof structure mirrors `t1_extAdj_v1_dichotomy`. After ruling out BB-edge
and triangle, `t5_extAdj_v2_BRRB_w_R_not_adj_v0` gives `w_R` and `¬w-v0`.
Case-split on (w-v1, w-v3): the (T,T) case forces a v1-w-v3 triangle (since
v1-v3 is a thesisType5 σ-edge), contradicting the no-triangle hypothesis. -/
theorem t5_extAdj_v2_dichotomy
    (cls : GenFlagClass CG2 thesisType5)
    (h_size : cls.out.size = 5)
    (h_extAdj : extAdjacencyClass thesisType5 cls ⟨2, by decide⟩)
    (phi : GenLimitFunctional CG2 (GenFlagType.empty CG2)
      brrbGenGraphClass brrbGenDelta) :
    cls = GenFlagClass.mk t5_v2_a ∨
    cls = GenFlagClass.mk t5_v2_b ∨
    cls = GenFlagClass.mk t5_v2_c ∨
    phi.eval cls.out.forget = 0 := by
  classical
  have h_ext : extAdjacency thesisType5 cls.out ⟨2, by decide⟩ := h_extAdj
  by_cases h_BB : ∃ u v : Fin cls.out.size,
      cls.out.str.2 u = 1 ∧ cls.out.str.2 v = 1 ∧ cls.out.str.1.Adj u v
  · right; right; right
    exact eval_zero_of_adj_black phi cls.out.forget h_BB
  by_cases h_tri : ∃ u v w : Fin cls.out.size,
      cls.out.str.1.Adj u v ∧ cls.out.str.1.Adj v w ∧ cls.out.str.1.Adj u w
  · right; right; right
    exact eval_zero_of_triangle phi cls.out.forget h_tri
  have h_BRRB := t5_extAdj_v2_BRRB_w_R_not_adj_v0 cls.out h_size h_ext h_BB h_tri
  obtain ⟨h_w_R, h_no_v0⟩ := h_BRRB
  set w := extVertex cls.out h_size with hw_def
  set v1 := cls.out.embedding ⟨1, by decide⟩ with hv1_def
  set v3 := cls.out.embedding ⟨3, by decide⟩ with hv3_def
  have hcomap : (CG2.comap cls.out.embedding cls.out.str).1 = thesisType5.str.1 :=
    congr_arg Prod.fst cls.out.isInduced
  have G_v1v3 : cls.out.str.1.Adj v1 v3 := by
    have h_sigma : thesisType5.str.1.Adj ⟨1, by decide⟩ ⟨3, by decide⟩ := by
      simp [thesisType5, SimpleGraph.fromRel_adj]
    rw [← hcomap] at h_sigma; exact h_sigma
  by_cases h_v1 : cls.out.str.1.Adj w v1
  · by_cases h_v3 : cls.out.str.1.Adj w v3
    · -- (T, T): forms triangle w-v1-v3 (with v1-v3 σ-edge), contradicting h_tri
      exfalso
      apply h_tri
      exact ⟨w, v1, v3, h_v1, G_v1v3, h_v3⟩
    · -- (T, F) → t5_v2_b
      right; left
      have hiso := t5_v2_b_classification cls.out h_size h_ext h_w_R h_no_v0 h_v1 h_v3
      have hmk : GenFlagClass.mk cls.out = GenFlagClass.mk t5_v2_b :=
        Quotient.sound hiso
      rw [← Quotient.out_eq cls]; exact hmk
  · by_cases h_v3 : cls.out.str.1.Adj w v3
    · -- (F, T) → t5_v2_c
      right; right; left
      have hiso := t5_v2_c_classification cls.out h_size h_ext h_w_R h_no_v0 h_v1 h_v3
      have hmk : GenFlagClass.mk cls.out = GenFlagClass.mk t5_v2_c :=
        Quotient.sound hiso
      rw [← Quotient.out_eq cls]; exact hmk
    · -- (F, F) → t5_v2_a
      left
      have hiso := t5_v2_a_classification cls.out h_size h_ext h_w_R h_no_v0 h_v1 h_v3
      have hmk : GenFlagClass.mk cls.out = GenFlagClass.mk t5_v2_a :=
        Quotient.sound hiso
      rw [← Quotient.out_eq cls]; exact hmk

/-! ### σ₅-3.5: extAdj-v0 dichotomy (thesisType5)

For any size-5 thesisType5-flag class `cls` with `extAdjacencyClass cls v0`, and
any BRRB ∅-functional `phi`, EITHER `cls` is iso to one of the 3 v0-side ext
witnesses `{t5_v0_R_a, t5_v0_R_b, t5_v0_B}`, OR `phi.eval cls.out.forget = 0`.

Proof: rule out BB-edge / triangle, then `t5_extAdj_v0_BRRB_no_v1_v2` gives
¬w-v1 ∧ ¬w-v2. Case-split on colour of w (R/B) and adjacency w-v3. The
(B, T) case is ruled out by h_BB (v3 is B in thesisType5). -/
theorem t5_extAdj_v0_dichotomy
    (cls : GenFlagClass CG2 thesisType5)
    (h_size : cls.out.size = 5)
    (h_extAdj : extAdjacencyClass thesisType5 cls ⟨0, by decide⟩)
    (phi : GenLimitFunctional CG2 (GenFlagType.empty CG2)
      brrbGenGraphClass brrbGenDelta) :
    cls = GenFlagClass.mk t5_v0_R_a ∨
    cls = GenFlagClass.mk t5_v0_R_b ∨
    cls = GenFlagClass.mk t5_v0_B ∨
    phi.eval cls.out.forget = 0 := by
  classical
  have h_ext : extAdjacency thesisType5 cls.out ⟨0, by decide⟩ := h_extAdj
  by_cases h_BB : ∃ u v : Fin cls.out.size,
      cls.out.str.2 u = 1 ∧ cls.out.str.2 v = 1 ∧ cls.out.str.1.Adj u v
  · right; right; right
    exact eval_zero_of_adj_black phi cls.out.forget h_BB
  by_cases h_tri : ∃ u v w : Fin cls.out.size,
      cls.out.str.1.Adj u v ∧ cls.out.str.1.Adj v w ∧ cls.out.str.1.Adj u w
  · right; right; right
    exact eval_zero_of_triangle phi cls.out.forget h_tri
  obtain ⟨h_no_v1, h_no_v2⟩ :=
    t5_extAdj_v0_BRRB_no_v1_v2 cls.out h_size h_ext h_BB h_tri
  set w := extVertex cls.out h_size with hw_def
  set v3 := cls.out.embedding ⟨3, by decide⟩ with hv3_def
  have h_col_eq : ∀ j : Fin thesisType5.size,
      cls.out.str.2 (cls.out.embedding j) = thesisType5.str.2 j := fun j =>
    congr_fun (congr_arg Prod.snd cls.out.isInduced) j
  have hcol_v3 : cls.out.str.2 v3 = 1 := by
    rw [hv3_def, h_col_eq]; simp [thesisType5]
  have hcol_lt : (cls.out.str.2 w).val < 2 := (cls.out.str.2 w).isLt
  interval_cases h_w_col : (cls.out.str.2 w).val
  · -- w coloured R (col=0)
    have h_w_R : cls.out.str.2 w = 0 := Fin.ext h_w_col
    by_cases h_v3 : cls.out.str.1.Adj w v3
    · -- (R, T) → t5_v0_R_b
      right; left
      have hiso := t5_v0_R_b_classification cls.out h_size h_ext h_w_R h_no_v1 h_no_v2 h_v3
      have hmk : GenFlagClass.mk cls.out = GenFlagClass.mk t5_v0_R_b :=
        Quotient.sound hiso
      rw [← Quotient.out_eq cls]; exact hmk
    · -- (R, F) → t5_v0_R_a
      left
      have hiso := t5_v0_R_a_classification cls.out h_size h_ext h_w_R h_no_v1 h_no_v2 h_v3
      have hmk : GenFlagClass.mk cls.out = GenFlagClass.mk t5_v0_R_a :=
        Quotient.sound hiso
      rw [← Quotient.out_eq cls]; exact hmk
  · -- w coloured B (col=1)
    have h_w_B : cls.out.str.2 w = 1 := Fin.ext h_w_col
    by_cases h_v3 : cls.out.str.1.Adj w v3
    · -- (B, T): w and v3 are both B and adjacent → BB-edge, contradicting h_BB
      exfalso
      apply h_BB
      exact ⟨w, v3, h_w_B, hcol_v3, h_v3⟩
    · -- (B, F) → t5_v0_B
      right; right; left
      have hiso := t5_v0_B_classification cls.out h_size h_ext h_w_B h_no_v1 h_no_v2 h_v3
      have hmk : GenFlagClass.mk cls.out = GenFlagClass.mk t5_v0_B :=
        Quotient.sound hiso
      rw [← Quotient.out_eq cls]; exact hmk

/-! ### σ₁-4-E.3.3: filter-membership dichotomy + outside-witnessSet helpers

These take `cls ∈ filter` directly, doing `genClassesOfSize_out_size`-equivalent
size derivation via simp-unfolding and Quotient iso. Hosting this here (rather
than in SdpEvaluation) keeps the recursion-heavy elaboration in a clean context,
where it compiles. The outside_zero variants further wrap the dichotomy and
discharge non-witness cases, parameterised by an external `witnessSet` and
membership hypotheses, so the SdpEvaluation call site only does a top-level
function application (no generic-cls unification). -/

set_option maxHeartbeats 32000000 in
set_option maxRecDepth 4000 in
set_option linter.constructorNameAsVariable false in
/-- Outside-witnessSet contribution lemma for v1-side. Given a witnessSet
    containing the 4 v1-witness classes, every cls in the v1-extAdj filter
    that is NOT in witnessSet has zero contribution to the extSum eval, because
    the dichotomy forces cls into one of the 4 witnesses (contradiction) or
    `phi.eval cls.out.forget = 0`.
    Inlines the size-derivation + dichotomy to avoid wrapper-application
    recursion blow-up at the `rcases ... from_filter ...` site. -/
theorem t1_v1_extSum_outside_witnessSet_zero
    (phi : GenLimitFunctional CG2 (GenFlagType.empty CG2)
      brrbGenGraphClass brrbGenDelta)
    (witnessSet : Finset (GenFlagClass CG2 thesisType1))
    (h_a : GenFlagClass.mk t1_v1_a ∈ witnessSet)
    (h_b : GenFlagClass.mk t1_v1_b ∈ witnessSet)
    (h_c : GenFlagClass.mk t1_v1_c ∈ witnessSet)
    (h_d : GenFlagClass.mk t1_v1_d ∈ witnessSet) :
    ∀ cls ∈ ((genClassesOfSize CG2 thesisType1
        (thesisType1.size + 1) (Nat.le_succ _)).filter
        (fun cls => extAdjacencyClass thesisType1 cls ⟨1, by decide⟩)),
        cls ∉ witnessSet →
        (extSum thesisType1 ⟨1, by decide⟩) cls *
          (genNormalisationFactor thesisType1 cls.out *
            phi.eval cls.out.forget) = 0 := by
  intro cls hcls_filter hcls_notin
  -- Inlined dichotomy_from_filter: simp-unfold + Quotient iso → h_size, then
  -- apply the underlying t1_extAdj_v1_dichotomy directly.
  simp only [Finset.mem_filter, genClassesOfSize, Finset.mem_image,
    Finset.mem_univ, true_and] at hcls_filter
  obtain ⟨⟨p, h_eq⟩, h_adj⟩ := hcls_filter
  have h_size : cls.out.size = 5 := by
    have hiso : (Quotient.out cls : GenFlag CG2 thesisType1) ≈
        ⟨thesisType1.size + 1, p.1, p.2.1, p.2.2, Nat.le_succ _⟩ := by
      rw [← h_eq]
      exact Quotient.exact (Quotient.out_eq _)
    exact genFlagIso_size_eq hiso
  rcases t1_extAdj_v1_dichotomy cls h_size h_adj phi
    with ha | hb | hc | hd | hzero
  · exfalso; apply hcls_notin; rw [ha]; exact h_a
  · exfalso; apply hcls_notin; rw [hb]; exact h_b
  · exfalso; apply hcls_notin; rw [hc]; exact h_c
  · exfalso; apply hcls_notin; rw [hd]; exact h_d
  · rw [hzero, mul_zero, mul_zero]

set_option maxHeartbeats 32000000 in
set_option maxRecDepth 4000 in
set_option linter.constructorNameAsVariable false in
/-- Outside-witnessSet contribution lemma for v0-side. Same pattern as v1 with
    2 witnesses (R, B) instead of 4. Inlines the dichotomy to avoid
    wrapper-application recursion blow-up. -/
