    · have hv_eq : v = (⟨3, by decide⟩ : Fin 4) := Fin.ext hv
      rw [hv_eq, hs3]; exact h_col_3

/-! ### Universal σ-position-3 helper for size-4 cases

`size4_sigma3_swap03_iso` is the analogue of `size4_sigma1_swap01_iso` for the
σ-vertex at G-position 3. Uses φ = swap(0,3). G-pos-3 ↦ T-pos-0 (σ),
G-pos-0 ↦ T-pos-3, G-pos-1 and G-pos-2 fixed. -/

/-- Universal σ-position-3 iso for size-4 σ-flags via leaf swap(0,3). -/
private theorem size4_sigma3_swap03_iso
    (G_str T_str : CG2.Str 4)
    (G_emb T_emb : Fin vertexBlackType.size ↪ Fin 4)
    (G_isInd : CG2.comap G_emb G_str = vertexBlackType.str)
    (T_isInd : CG2.comap T_emb T_str = vertexBlackType.str)
    (G_hsize T_hsize : vertexBlackType.size ≤ 4)
    (h_emb_G : (G_emb ⟨0, Nat.zero_lt_one⟩).val = 3)
    (h_emb_T : (T_emb ⟨0, Nat.zero_lt_one⟩).val = 0)
    -- φ : 0 ↔ 3, 1 fixed, 2 fixed.
    -- G(0,1) ↔ T(3,1), G(0,2) ↔ T(3,2), G(0,3) ↔ T(3,0),
    -- G(1,2) ↔ T(1,2), G(1,3) ↔ T(1,0), G(2,3) ↔ T(2,0).
    (h_adj_01 : G_str.1.Adj ⟨0, by decide⟩ ⟨1, by decide⟩ ↔
                T_str.1.Adj ⟨3, by decide⟩ ⟨1, by decide⟩)
    (h_adj_02 : G_str.1.Adj ⟨0, by decide⟩ ⟨2, by decide⟩ ↔
                T_str.1.Adj ⟨3, by decide⟩ ⟨2, by decide⟩)
    (h_adj_03 : G_str.1.Adj ⟨0, by decide⟩ ⟨3, by decide⟩ ↔
                T_str.1.Adj ⟨3, by decide⟩ ⟨0, by decide⟩)
    (h_adj_12 : G_str.1.Adj ⟨1, by decide⟩ ⟨2, by decide⟩ ↔
                T_str.1.Adj ⟨1, by decide⟩ ⟨2, by decide⟩)
    (h_adj_13 : G_str.1.Adj ⟨1, by decide⟩ ⟨3, by decide⟩ ↔
                T_str.1.Adj ⟨1, by decide⟩ ⟨0, by decide⟩)
    (h_adj_23 : G_str.1.Adj ⟨2, by decide⟩ ⟨3, by decide⟩ ↔
                T_str.1.Adj ⟨2, by decide⟩ ⟨0, by decide⟩)
    -- Colours: G(0) = T(3), G(1) = T(1), G(2) = T(2).
    (h_col_0 : G_str.2 ⟨0, by decide⟩ = T_str.2 ⟨3, by decide⟩)
    (h_col_1 : G_str.2 ⟨1, by decide⟩ = T_str.2 ⟨1, by decide⟩)
    (h_col_2 : G_str.2 ⟨2, by decide⟩ = T_str.2 ⟨2, by decide⟩) :
    GenFlagIso vertexBlackType
      (⟨4, G_str, G_emb, G_isInd, G_hsize⟩ : GenFlag CG2 vertexBlackType)
      (⟨4, T_str, T_emb, T_isInd, T_hsize⟩ : GenFlag CG2 vertexBlackType) := by
  classical
  have hT_emb_zero : T_emb (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) =
      (⟨0, (by decide : (0:ℕ) < 4)⟩ : Fin 4) := Fin.ext h_emb_T
  apply size4_iso_via_perm G_str T_str G_emb T_emb G_isInd T_isInd G_hsize T_hsize
    hT_emb_zero (Equiv.swap (⟨0, by decide⟩ : Fin 4) ⟨3, by decide⟩)
  · have hG_emb_eq : G_emb (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) =
        (⟨3, by decide⟩ : Fin 4) := Fin.ext h_emb_G
    rw [hG_emb_eq]
    rw [Equiv.swap_apply_right]
  · -- h_adj
    intro u v
    have h01 : ((⟨0, by decide⟩ : Fin 4) : Fin 4) ≠ (⟨1, by decide⟩ : Fin 4) := by decide
    have h02 : ((⟨0, by decide⟩ : Fin 4) : Fin 4) ≠ (⟨2, by decide⟩ : Fin 4) := by decide
    have h13 : ((⟨1, by decide⟩ : Fin 4) : Fin 4) ≠ (⟨3, by decide⟩ : Fin 4) := by decide
    have h23 : ((⟨2, by decide⟩ : Fin 4) : Fin 4) ≠ (⟨3, by decide⟩ : Fin 4) := by decide
    have hs0 : Equiv.swap (⟨0, by decide⟩ : Fin 4) ⟨3, by decide⟩ ⟨0, by decide⟩
        = (⟨3, by decide⟩ : Fin 4) := Equiv.swap_apply_left _ _
    have hs1 : Equiv.swap (⟨0, by decide⟩ : Fin 4) ⟨3, by decide⟩ ⟨1, by decide⟩
        = (⟨1, by decide⟩ : Fin 4) := Equiv.swap_apply_of_ne_of_ne h01.symm h13
    have hs2 : Equiv.swap (⟨0, by decide⟩ : Fin 4) ⟨3, by decide⟩ ⟨2, by decide⟩
        = (⟨2, by decide⟩ : Fin 4) := Equiv.swap_apply_of_ne_of_ne h02.symm h23
    have hs3 : Equiv.swap (⟨0, by decide⟩ : Fin 4) ⟨3, by decide⟩ ⟨3, by decide⟩
        = (⟨0, by decide⟩ : Fin 4) := Equiv.swap_apply_right _ _
    rcases fin4_val_cases u with hu | hu | hu | hu <;>
      rcases fin4_val_cases v with hv | hv | hv | hv <;>
      first
      | (have hu_eq : u = (⟨0, by decide⟩ : Fin 4) := Fin.ext hu
         have hv_eq : v = (⟨0, by decide⟩ : Fin 4) := Fin.ext hv
         rw [hu_eq, hv_eq, hs0]
         constructor <;> intro hadj <;> exact absurd hadj (SimpleGraph.irrefl _))
      | (have hu_eq : u = (⟨1, by decide⟩ : Fin 4) := Fin.ext hu
         have hv_eq : v = (⟨1, by decide⟩ : Fin 4) := Fin.ext hv
         rw [hu_eq, hv_eq, hs1]
         constructor <;> intro hadj <;> exact absurd hadj (SimpleGraph.irrefl _))
      | (have hu_eq : u = (⟨2, by decide⟩ : Fin 4) := Fin.ext hu
         have hv_eq : v = (⟨2, by decide⟩ : Fin 4) := Fin.ext hv
         rw [hu_eq, hv_eq, hs2]
         constructor <;> intro hadj <;> exact absurd hadj (SimpleGraph.irrefl _))
      | (have hu_eq : u = (⟨3, by decide⟩ : Fin 4) := Fin.ext hu
         have hv_eq : v = (⟨3, by decide⟩ : Fin 4) := Fin.ext hv
         rw [hu_eq, hv_eq, hs3]
         constructor <;> intro hadj <;> exact absurd hadj (SimpleGraph.irrefl _))
      | (have hu_eq : u = (⟨0, by decide⟩ : Fin 4) := Fin.ext hu
         have hv_eq : v = (⟨1, by decide⟩ : Fin 4) := Fin.ext hv
         rw [hu_eq, hv_eq, hs0, hs1]; exact h_adj_01)
      | (have hu_eq : u = (⟨0, by decide⟩ : Fin 4) := Fin.ext hu
         have hv_eq : v = (⟨2, by decide⟩ : Fin 4) := Fin.ext hv
         rw [hu_eq, hv_eq, hs0, hs2]; exact h_adj_02)
      | (have hu_eq : u = (⟨0, by decide⟩ : Fin 4) := Fin.ext hu
         have hv_eq : v = (⟨3, by decide⟩ : Fin 4) := Fin.ext hv
         rw [hu_eq, hv_eq, hs0, hs3]; exact h_adj_03)
      | (have hu_eq : u = (⟨1, by decide⟩ : Fin 4) := Fin.ext hu
         have hv_eq : v = (⟨0, by decide⟩ : Fin 4) := Fin.ext hv
         rw [hu_eq, hv_eq, hs1, hs0,
             SimpleGraph.adj_comm (G := G_str.1),
             SimpleGraph.adj_comm (G := T_str.1)]; exact h_adj_01)
      | (have hu_eq : u = (⟨2, by decide⟩ : Fin 4) := Fin.ext hu
         have hv_eq : v = (⟨0, by decide⟩ : Fin 4) := Fin.ext hv
         rw [hu_eq, hv_eq, hs2, hs0,
             SimpleGraph.adj_comm (G := G_str.1),
             SimpleGraph.adj_comm (G := T_str.1)]; exact h_adj_02)
      | (have hu_eq : u = (⟨3, by decide⟩ : Fin 4) := Fin.ext hu
         have hv_eq : v = (⟨0, by decide⟩ : Fin 4) := Fin.ext hv
         rw [hu_eq, hv_eq, hs3, hs0,
             SimpleGraph.adj_comm (G := G_str.1),
             SimpleGraph.adj_comm (G := T_str.1)]; exact h_adj_03)
      | (have hu_eq : u = (⟨1, by decide⟩ : Fin 4) := Fin.ext hu
         have hv_eq : v = (⟨2, by decide⟩ : Fin 4) := Fin.ext hv
         rw [hu_eq, hv_eq, hs1, hs2]; exact h_adj_12)
      | (have hu_eq : u = (⟨2, by decide⟩ : Fin 4) := Fin.ext hu
         have hv_eq : v = (⟨1, by decide⟩ : Fin 4) := Fin.ext hv
         rw [hu_eq, hv_eq, hs2, hs1,
             SimpleGraph.adj_comm (G := G_str.1),
             SimpleGraph.adj_comm (G := T_str.1)]; exact h_adj_12)
      | (have hu_eq : u = (⟨1, by decide⟩ : Fin 4) := Fin.ext hu
         have hv_eq : v = (⟨3, by decide⟩ : Fin 4) := Fin.ext hv
         rw [hu_eq, hv_eq, hs1, hs3]; exact h_adj_13)
      | (have hu_eq : u = (⟨3, by decide⟩ : Fin 4) := Fin.ext hu
         have hv_eq : v = (⟨1, by decide⟩ : Fin 4) := Fin.ext hv
         rw [hu_eq, hv_eq, hs3, hs1,
             SimpleGraph.adj_comm (G := G_str.1),
             SimpleGraph.adj_comm (G := T_str.1)]; exact h_adj_13)
      | (have hu_eq : u = (⟨2, by decide⟩ : Fin 4) := Fin.ext hu
         have hv_eq : v = (⟨3, by decide⟩ : Fin 4) := Fin.ext hv
         rw [hu_eq, hv_eq, hs2, hs3]; exact h_adj_23)
      | (have hu_eq : u = (⟨3, by decide⟩ : Fin 4) := Fin.ext hu
         have hv_eq : v = (⟨2, by decide⟩ : Fin 4) := Fin.ext hv
         rw [hu_eq, hv_eq, hs3, hs2,
             SimpleGraph.adj_comm (G := G_str.1),
             SimpleGraph.adj_comm (G := T_str.1)]; exact h_adj_23)
  · -- h_col
    intro v
    have h01 : ((⟨0, by decide⟩ : Fin 4) : Fin 4) ≠ (⟨1, by decide⟩ : Fin 4) := by decide
    have h02 : ((⟨0, by decide⟩ : Fin 4) : Fin 4) ≠ (⟨2, by decide⟩ : Fin 4) := by decide
    have h13 : ((⟨1, by decide⟩ : Fin 4) : Fin 4) ≠ (⟨3, by decide⟩ : Fin 4) := by decide
    have h23 : ((⟨2, by decide⟩ : Fin 4) : Fin 4) ≠ (⟨3, by decide⟩ : Fin 4) := by decide
    have hs0 : Equiv.swap (⟨0, by decide⟩ : Fin 4) ⟨3, by decide⟩ ⟨0, by decide⟩
        = (⟨3, by decide⟩ : Fin 4) := Equiv.swap_apply_left _ _
    have hs1 : Equiv.swap (⟨0, by decide⟩ : Fin 4) ⟨3, by decide⟩ ⟨1, by decide⟩
        = (⟨1, by decide⟩ : Fin 4) := Equiv.swap_apply_of_ne_of_ne h01.symm h13
    have hs2 : Equiv.swap (⟨0, by decide⟩ : Fin 4) ⟨3, by decide⟩ ⟨2, by decide⟩
        = (⟨2, by decide⟩ : Fin 4) := Equiv.swap_apply_of_ne_of_ne h02.symm h23
    have hs3 : Equiv.swap (⟨0, by decide⟩ : Fin 4) ⟨3, by decide⟩ ⟨3, by decide⟩
        = (⟨0, by decide⟩ : Fin 4) := Equiv.swap_apply_right _ _
    rcases fin4_val_cases v with hv | hv | hv | hv
    · have hv_eq : v = (⟨0, by decide⟩ : Fin 4) := Fin.ext hv
      rw [hv_eq, hs0]; exact h_col_0
    · have hv_eq : v = (⟨1, by decide⟩ : Fin 4) := Fin.ext hv
      rw [hv_eq, hs1]; exact h_col_1
    · have hv_eq : v = (⟨2, by decide⟩ : Fin 4) := Fin.ext hv
      rw [hv_eq, hs2]; exact h_col_2
    · have hv_eq : v = (⟨3, by decide⟩ : Fin 4) := Fin.ext hv
      rw [hv_eq, hs3]
      have hG := size4_sigma_col_eq_one G_str G_emb G_isInd
      have hT := size4_sigma_col_eq_one T_str T_emb T_isInd
      have hG_emb_eq : G_emb (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) =
          (⟨3, by decide⟩ : Fin 4) := Fin.ext h_emb_G
      have hT_emb_eq : T_emb (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) =
          (⟨0, by decide⟩ : Fin 4) := Fin.ext h_emb_T
      rw [hG_emb_eq] at hG; rw [hT_emb_eq] at hT
      rw [hG, hT]

