    (hemb_val : (F_emb ⟨0, Nat.zero_lt_one⟩).val = 1)
    (hgraph : F_str.1 = vbExtBlack.str.1)
    (hcol0 : F_str.2 ⟨0, Nat.zero_lt_two⟩ = 1) :
    GenFlagIso vertexBlackType
      (⟨2, F_str, F_emb, F_isInd, F_hsize⟩ : GenFlag CG2 vertexBlackType) vbExtBlack := by
  classical
  refine ⟨Equiv.swap (⟨0, Nat.zero_lt_two⟩ : Fin 2) ⟨1, Nat.one_lt_two⟩, ?_, ?_⟩
  · change CG2.comap (Equiv.swap (⟨0, Nat.zero_lt_two⟩ : Fin 2) ⟨1, Nat.one_lt_two⟩)
      vbExtBlack.str = F_str
    apply Prod.ext
    · -- Graph: same as before, swap on the (0,1) edge graph yields itself
      change vbExtBlack.str.1.comap (Equiv.swap _ _) = F_str.1
      rw [hgraph]
      ext u v
      change vbExtBlack.str.1.Adj _ _ ↔ vbExtBlack.str.1.Adj _ _
      constructor <;> intro hadj
      · rcases (fin2_adj_iff (Equiv.swap (⟨0, Nat.zero_lt_two⟩ : Fin 2)
          ⟨1, Nat.one_lt_two⟩ u) (Equiv.swap _ _ v)).mp hadj with ⟨h_or, _⟩
        rw [fin2_adj_iff]
        refine ⟨?_, vbExtBlack_adj_01⟩
        rcases h_or with ⟨hu, hv⟩ | ⟨hu, hv⟩
        · right
          refine ⟨?_, ?_⟩
          · have : u = (⟨1, Nat.one_lt_two⟩ : Fin 2) := by
              have h_swap_u : Equiv.swap (⟨0, Nat.zero_lt_two⟩ : Fin 2) ⟨1, Nat.one_lt_two⟩ u =
                ⟨0, Nat.zero_lt_two⟩ := Fin.ext hu
              have := congr_arg (Equiv.swap (⟨0, Nat.zero_lt_two⟩ : Fin 2) ⟨1, Nat.one_lt_two⟩)
                h_swap_u
              simp [Equiv.swap_apply_left] at this
              exact this
            rw [this]
          · have : v = (⟨0, Nat.zero_lt_two⟩ : Fin 2) := by
              have h_swap_v : Equiv.swap (⟨0, Nat.zero_lt_two⟩ : Fin 2) ⟨1, Nat.one_lt_two⟩ v =
                ⟨1, Nat.one_lt_two⟩ := Fin.ext hv
              have := congr_arg (Equiv.swap (⟨0, Nat.zero_lt_two⟩ : Fin 2) ⟨1, Nat.one_lt_two⟩)
                h_swap_v
              simp [Equiv.swap_apply_right] at this
              exact this
            rw [this]
        · left
          refine ⟨?_, ?_⟩
          · have : u = (⟨0, Nat.zero_lt_two⟩ : Fin 2) := by
              have h_swap_u : Equiv.swap (⟨0, Nat.zero_lt_two⟩ : Fin 2) ⟨1, Nat.one_lt_two⟩ u =
                ⟨1, Nat.one_lt_two⟩ := Fin.ext hu
              have := congr_arg (Equiv.swap (⟨0, Nat.zero_lt_two⟩ : Fin 2) ⟨1, Nat.one_lt_two⟩)
                h_swap_u
              simp [Equiv.swap_apply_right] at this
              exact this
            rw [this]
          · have : v = (⟨1, Nat.one_lt_two⟩ : Fin 2) := by
              have h_swap_v : Equiv.swap (⟨0, Nat.zero_lt_two⟩ : Fin 2) ⟨1, Nat.one_lt_two⟩ v =
                ⟨0, Nat.zero_lt_two⟩ := Fin.ext hv
              have := congr_arg (Equiv.swap (⟨0, Nat.zero_lt_two⟩ : Fin 2) ⟨1, Nat.one_lt_two⟩)
                h_swap_v
              simp [Equiv.swap_apply_left] at this
              exact this
            rw [this]
      · rcases (fin2_adj_iff u v).mp hadj with ⟨h_or, _⟩
        rw [fin2_adj_iff]
        refine ⟨?_, vbExtBlack_adj_01⟩
        rcases h_or with ⟨hu, hv⟩ | ⟨hu, hv⟩
        · right
          refine ⟨?_, ?_⟩
          · have h_eq : u = (⟨0, Nat.zero_lt_two⟩ : Fin 2) := Fin.ext hu
            rw [h_eq]; simp [Equiv.swap_apply_left]
          · have h_eq : v = (⟨1, Nat.one_lt_two⟩ : Fin 2) := Fin.ext hv
            rw [h_eq]; simp [Equiv.swap_apply_right]
        · left
          refine ⟨?_, ?_⟩
          · have h_eq : u = (⟨1, Nat.one_lt_two⟩ : Fin 2) := Fin.ext hu
            rw [h_eq]; simp [Equiv.swap_apply_right]
          · have h_eq : v = (⟨0, Nat.zero_lt_two⟩ : Fin 2) := Fin.ext hv
            rw [h_eq]; simp [Equiv.swap_apply_left]
    · -- Colour: vbExtBlack.str.2 ∘ swap = F_str.2.
      -- vbExtBlack.str.2 is constant 1, so swap doesn't change anything.
      change vbExtBlack.str.2 ∘ (Equiv.swap (⟨0, Nat.zero_lt_two⟩ : Fin 2) ⟨1, Nat.one_lt_two⟩) =
        F_str.2
      funext v
      have hv : v.val = 0 ∨ v.val = 1 := fin2_eq_zero_or_one v
      rcases hv with h0 | h1
      · have hv_eq : v = (⟨0, Nat.zero_lt_two⟩ : Fin 2) := Fin.ext h0
        rw [hv_eq]
        change vbExtBlack.str.2 (Equiv.swap (⟨0, Nat.zero_lt_two⟩ : Fin 2)
