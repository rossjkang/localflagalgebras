          (show (⟨0, by decide⟩ : Fin 4) ≠ ⟨3, by decide⟩ by decide)]
  have hp3 : φ (⟨3, by decide⟩ : Fin 4) = (⟨2, by decide⟩ : Fin 4) := by
    change Equiv.swap (⟨2, by decide⟩ : Fin 4) ⟨3, by decide⟩
