         rw [hu_eq, hv_eq, hs1]
         constructor <;> intro hadj <;> exact absurd hadj (SimpleGraph.irrefl _))
      | (have hu_eq : u = (⟨2, by decide⟩ : Fin 4) := Fin.ext hu
         have hv_eq : v = (⟨2, by decide⟩ : Fin 4) := Fin.ext hv
         rw [hu_eq, hv_eq, hs2]
         constructor <;> intro hadj <;> exact absurd hadj (SimpleGraph.irrefl _))
      | (have hu_eq : u = (⟨3, by decide⟩ : Fin 4) := Fin.ext hu
