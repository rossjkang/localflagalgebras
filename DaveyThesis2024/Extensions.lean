/-! ### σ-position-1 helpers via composite with 3-cycles on T-leaves

Two additional σ-position-1 helpers for cases where neither a single transposition
nor identity suffices on the T-leaf frame: composing `swap(0,1)` (the σ-vertex
alignment swap) with a 3-cycle on T-positions {1, 2, 3}.

- `size4_sigma1_swap01_cycle123_iso` — T-leaf perm = (1 2 3): T-pos 1↦2, 2↦3, 3↦1.
  Composite φ = swap(0,1) ∘ cycle(1,2,3) maps 0↦2, 1↦0, 2↦3, 3↦1.
- `size4_sigma1_swap01_cycle132_iso` — T-leaf perm = (1 3 2): T-pos 1↦3, 2↦1, 3↦2.
  Composite φ = swap(0,1) ∘ cycle(1,3,2) maps 0↦3, 1↦0, 2↦1, 3↦2. -/

/-- σ-position-1 non-canonical iso via composite φ = swap(0,1) ∘ cycle(1,2,3). -/
private theorem size4_sigma1_swap01_cycle123_iso
    (G_str T_str : CG2.Str 4)
    (G_emb T_emb : Fin vertexBlackType.size ↪ Fin 4)
    (G_isInd : CG2.comap G_emb G_str = vertexBlackType.str)
    (T_isInd : CG2.comap T_emb T_str = vertexBlackType.str)
    (G_hsize T_hsize : vertexBlackType.size ≤ 4)
    (h_emb_G : (G_emb ⟨0, Nat.zero_lt_one⟩).val = 1)
    (h_emb_T : (T_emb ⟨0, Nat.zero_lt_one⟩).val = 0)
    -- φ : 0↦2, 1↦0, 2↦3, 3↦1.
    (h_adj_01 : G_str.1.Adj ⟨0, by decide⟩ ⟨1, by decide⟩ ↔
                T_str.1.Adj ⟨2, by decide⟩ ⟨0, by decide⟩)
    (h_adj_02 : G_str.1.Adj ⟨0, by decide⟩ ⟨2, by decide⟩ ↔
                T_str.1.Adj ⟨2, by decide⟩ ⟨3, by decide⟩)
    (h_adj_03 : G_str.1.Adj ⟨0, by decide⟩ ⟨3, by decide⟩ ↔
                T_str.1.Adj ⟨2, by decide⟩ ⟨1, by decide⟩)
    (h_adj_12 : G_str.1.Adj ⟨1, by decide⟩ ⟨2, by decide⟩ ↔
                T_str.1.Adj ⟨0, by decide⟩ ⟨3, by decide⟩)
    (h_adj_13 : G_str.1.Adj ⟨1, by decide⟩ ⟨3, by decide⟩ ↔
                T_str.1.Adj ⟨0, by decide⟩ ⟨1, by decide⟩)
    (h_adj_23 : G_str.1.Adj ⟨2, by decide⟩ ⟨3, by decide⟩ ↔
                T_str.1.Adj ⟨3, by decide⟩ ⟨1, by decide⟩)
    -- Colours: G(0) = T(2), G(2) = T(3), G(3) = T(1).
    (h_col_0 : G_str.2 ⟨0, by decide⟩ = T_str.2 ⟨2, by decide⟩)
    (h_col_2 : G_str.2 ⟨2, by decide⟩ = T_str.2 ⟨3, by decide⟩)
    (h_col_3 : G_str.2 ⟨3, by decide⟩ = T_str.2 ⟨1, by decide⟩) :
    GenFlagIso vertexBlackType
      (⟨4, G_str, G_emb, G_isInd, G_hsize⟩ : GenFlag CG2 vertexBlackType)
      (⟨4, T_str, T_emb, T_isInd, T_hsize⟩ : GenFlag CG2 vertexBlackType) := by
  classical
  -- φ values: 0↦2, 1↦0, 2↦3, 3↦1.
  -- Built as swap(0,1).trans(swap(2,3).trans(swap(1,2))).
  let φ : Fin 4 ≃ Fin 4 :=
    (Equiv.swap (⟨0, by decide⟩ : Fin 4) ⟨1, by decide⟩).trans
      ((Equiv.swap (⟨2, by decide⟩ : Fin 4) ⟨3, by decide⟩).trans
        (Equiv.swap (⟨1, by decide⟩ : Fin 4) ⟨2, by decide⟩))
  have hp0 : φ (⟨0, by decide⟩ : Fin 4) = (⟨2, by decide⟩ : Fin 4) := by
    change Equiv.swap (⟨1, by decide⟩ : Fin 4) ⟨2, by decide⟩
        (Equiv.swap (⟨2, by decide⟩ : Fin 4) ⟨3, by decide⟩
          (Equiv.swap (⟨0, by decide⟩ : Fin 4) ⟨1, by decide⟩ ⟨0, by decide⟩))
        = (⟨2, by decide⟩ : Fin 4)
    rw [Equiv.swap_apply_left,
        Equiv.swap_apply_of_ne_of_ne
          (show (⟨1, by decide⟩ : Fin 4) ≠ ⟨2, by decide⟩ by decide)
          (show (⟨1, by decide⟩ : Fin 4) ≠ ⟨3, by decide⟩ by decide),
        Equiv.swap_apply_left]
  have hp1 : φ (⟨1, by decide⟩ : Fin 4) = (⟨0, by decide⟩ : Fin 4) := by
    change Equiv.swap (⟨1, by decide⟩ : Fin 4) ⟨2, by decide⟩
        (Equiv.swap (⟨2, by decide⟩ : Fin 4) ⟨3, by decide⟩
          (Equiv.swap (⟨0, by decide⟩ : Fin 4) ⟨1, by decide⟩ ⟨1, by decide⟩))
        = (⟨0, by decide⟩ : Fin 4)
    rw [Equiv.swap_apply_right,
        Equiv.swap_apply_of_ne_of_ne
          (show (⟨0, by decide⟩ : Fin 4) ≠ ⟨2, by decide⟩ by decide)
          (show (⟨0, by decide⟩ : Fin 4) ≠ ⟨3, by decide⟩ by decide),
        Equiv.swap_apply_of_ne_of_ne
          (show (⟨0, by decide⟩ : Fin 4) ≠ ⟨1, by decide⟩ by decide)
          (show (⟨0, by decide⟩ : Fin 4) ≠ ⟨2, by decide⟩ by decide)]
  have hp2 : φ (⟨2, by decide⟩ : Fin 4) = (⟨3, by decide⟩ : Fin 4) := by
    change Equiv.swap (⟨1, by decide⟩ : Fin 4) ⟨2, by decide⟩
        (Equiv.swap (⟨2, by decide⟩ : Fin 4) ⟨3, by decide⟩
          (Equiv.swap (⟨0, by decide⟩ : Fin 4) ⟨1, by decide⟩ ⟨2, by decide⟩))
        = (⟨3, by decide⟩ : Fin 4)
    rw [Equiv.swap_apply_of_ne_of_ne
          (show (⟨2, by decide⟩ : Fin 4) ≠ ⟨0, by decide⟩ by decide)
          (show (⟨2, by decide⟩ : Fin 4) ≠ ⟨1, by decide⟩ by decide),
        Equiv.swap_apply_left,
        Equiv.swap_apply_of_ne_of_ne
          (show (⟨3, by decide⟩ : Fin 4) ≠ ⟨1, by decide⟩ by decide)
          (show (⟨3, by decide⟩ : Fin 4) ≠ ⟨2, by decide⟩ by decide)]
  have hp3 : φ (⟨3, by decide⟩ : Fin 4) = (⟨1, by decide⟩ : Fin 4) := by
    change Equiv.swap (⟨1, by decide⟩ : Fin 4) ⟨2, by decide⟩
        (Equiv.swap (⟨2, by decide⟩ : Fin 4) ⟨3, by decide⟩
          (Equiv.swap (⟨0, by decide⟩ : Fin 4) ⟨1, by decide⟩ ⟨3, by decide⟩))
        = (⟨1, by decide⟩ : Fin 4)
    rw [Equiv.swap_apply_of_ne_of_ne
          (show (⟨3, by decide⟩ : Fin 4) ≠ ⟨0, by decide⟩ by decide)
          (show (⟨3, by decide⟩ : Fin 4) ≠ ⟨1, by decide⟩ by decide),
        Equiv.swap_apply_right,
        Equiv.swap_apply_right]
  apply size4_sigma1_iso_via_leafperm G_str T_str G_emb T_emb G_isInd T_isInd
    G_hsize T_hsize h_emb_G h_emb_T φ hp1
  · intro u v
    rcases fin4_val_cases u with hu | hu | hu | hu <;>
      rcases fin4_val_cases v with hv | hv | hv | hv <;>
      first
      | (have hu_eq : u = (⟨0, by decide⟩ : Fin 4) := Fin.ext hu
         have hv_eq : v = (⟨0, by decide⟩ : Fin 4) := Fin.ext hv
         rw [hu_eq, hv_eq, hp0]
         constructor <;> intro hadj <;> exact absurd hadj (SimpleGraph.irrefl _))
      | (have hu_eq : u = (⟨1, by decide⟩ : Fin 4) := Fin.ext hu
         have hv_eq : v = (⟨1, by decide⟩ : Fin 4) := Fin.ext hv
         rw [hu_eq, hv_eq, hp1]
         constructor <;> intro hadj <;> exact absurd hadj (SimpleGraph.irrefl _))
      | (have hu_eq : u = (⟨2, by decide⟩ : Fin 4) := Fin.ext hu
         have hv_eq : v = (⟨2, by decide⟩ : Fin 4) := Fin.ext hv
         rw [hu_eq, hv_eq, hp2]
         constructor <;> intro hadj <;> exact absurd hadj (SimpleGraph.irrefl _))
      | (have hu_eq : u = (⟨3, by decide⟩ : Fin 4) := Fin.ext hu
         have hv_eq : v = (⟨3, by decide⟩ : Fin 4) := Fin.ext hv
         rw [hu_eq, hv_eq, hp3]
         constructor <;> intro hadj <;> exact absurd hadj (SimpleGraph.irrefl _))
      | (have hu_eq : u = (⟨0, by decide⟩ : Fin 4) := Fin.ext hu
         have hv_eq : v = (⟨1, by decide⟩ : Fin 4) := Fin.ext hv
         rw [hu_eq, hv_eq, hp0, hp1]; exact h_adj_01)
      | (have hu_eq : u = (⟨0, by decide⟩ : Fin 4) := Fin.ext hu
         have hv_eq : v = (⟨2, by decide⟩ : Fin 4) := Fin.ext hv
         rw [hu_eq, hv_eq, hp0, hp2]; exact h_adj_02)
      | (have hu_eq : u = (⟨0, by decide⟩ : Fin 4) := Fin.ext hu
         have hv_eq : v = (⟨3, by decide⟩ : Fin 4) := Fin.ext hv
         rw [hu_eq, hv_eq, hp0, hp3]; exact h_adj_03)
      | (have hu_eq : u = (⟨1, by decide⟩ : Fin 4) := Fin.ext hu
         have hv_eq : v = (⟨0, by decide⟩ : Fin 4) := Fin.ext hv
         rw [hu_eq, hv_eq, hp1, hp0,
             SimpleGraph.adj_comm (G := G_str.1),
             SimpleGraph.adj_comm (G := T_str.1)]; exact h_adj_01)
      | (have hu_eq : u = (⟨2, by decide⟩ : Fin 4) := Fin.ext hu
         have hv_eq : v = (⟨0, by decide⟩ : Fin 4) := Fin.ext hv
         rw [hu_eq, hv_eq, hp2, hp0,
             SimpleGraph.adj_comm (G := G_str.1),
             SimpleGraph.adj_comm (G := T_str.1)]; exact h_adj_02)
      | (have hu_eq : u = (⟨3, by decide⟩ : Fin 4) := Fin.ext hu
         have hv_eq : v = (⟨0, by decide⟩ : Fin 4) := Fin.ext hv
         rw [hu_eq, hv_eq, hp3, hp0,
             SimpleGraph.adj_comm (G := G_str.1),
             SimpleGraph.adj_comm (G := T_str.1)]; exact h_adj_03)
      | (have hu_eq : u = (⟨1, by decide⟩ : Fin 4) := Fin.ext hu
         have hv_eq : v = (⟨2, by decide⟩ : Fin 4) := Fin.ext hv
         rw [hu_eq, hv_eq, hp1, hp2]; exact h_adj_12)
      | (have hu_eq : u = (⟨2, by decide⟩ : Fin 4) := Fin.ext hu
         have hv_eq : v = (⟨1, by decide⟩ : Fin 4) := Fin.ext hv
         rw [hu_eq, hv_eq, hp2, hp1,
             SimpleGraph.adj_comm (G := G_str.1),
             SimpleGraph.adj_comm (G := T_str.1)]; exact h_adj_12)
      | (have hu_eq : u = (⟨1, by decide⟩ : Fin 4) := Fin.ext hu
         have hv_eq : v = (⟨3, by decide⟩ : Fin 4) := Fin.ext hv
         rw [hu_eq, hv_eq, hp1, hp3]; exact h_adj_13)
      | (have hu_eq : u = (⟨3, by decide⟩ : Fin 4) := Fin.ext hu
         have hv_eq : v = (⟨1, by decide⟩ : Fin 4) := Fin.ext hv
         rw [hu_eq, hv_eq, hp3, hp1,
             SimpleGraph.adj_comm (G := G_str.1),
             SimpleGraph.adj_comm (G := T_str.1)]; exact h_adj_13)
      | (have hu_eq : u = (⟨2, by decide⟩ : Fin 4) := Fin.ext hu
         have hv_eq : v = (⟨3, by decide⟩ : Fin 4) := Fin.ext hv
