          (Equiv.swap (⟨0, by decide⟩ : Fin 4) ⟨2, by decide⟩ ⟨3, by decide⟩))
        = (⟨2, by decide⟩ : Fin 4)
    rw [Equiv.swap_apply_of_ne_of_ne
          (show (⟨3, by decide⟩ : Fin 4) ≠ ⟨0, by decide⟩ by decide)
          (show (⟨3, by decide⟩ : Fin 4) ≠ ⟨2, by decide⟩ by decide),
        Equiv.swap_apply_of_ne_of_ne
          (show (⟨3, by decide⟩ : Fin 4) ≠ ⟨1, by decide⟩ by decide)
          (show (⟨3, by decide⟩ : Fin 4) ≠ ⟨2, by decide⟩ by decide),
        Equiv.swap_apply_right]
  apply size4_sigma2_iso_via_leafperm G_str T_str G_emb T_emb G_isInd T_isInd
