/-- `genAveragingAlg σ` distributes over negation. -/
theorem genAveragingAlg_neg {σ : GenFlagType CG2} (v : GenFlagAlg CG2 σ) :
    genAveragingAlg σ (-v) = -genAveragingAlg σ v := by
  rw [show (-v : GenFlagAlg CG2 σ) = (-1 : ℝ) • v by rw [neg_one_smul]]
  rw [genAveragingAlg_smul, neg_smul, one_smul]

/-- `ψ.evalAlg` distributes over negation. -/
