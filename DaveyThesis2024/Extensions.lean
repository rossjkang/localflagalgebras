/-! ### Master classification: `any_size4_extAdjAll_iso`

Any size-4 σ-flag at vertexBlackType where the σ-vertex is adjacent to all
three non-σ vertices is iso to one of the 20 named `vbExt3_*` flags. Proof:
case-split on the position of the σ-vertex (`G.embedding ⟨0,_⟩` ∈ {0,1,2,3})
and dispatch to the appropriate `any_size4_sigmaN_extAdjAll_iso`. -/

set_option maxHeartbeats 4000000 in
-- 4 σ-position branches × 20 disjuncts each → high heartbeat budget for
-- the final `tauto` rearranging the disjunction in each branch.
/-- Master classification: any size-4 σ-flag at `vertexBlackType` where the
    σ-vertex is adjacent to the three non-σ vertices is iso to one of the
    20 canonical `vbExt3_*` flags. -/
theorem any_size4_extAdjAll_iso (G : GenFlag CG2 vertexBlackType) (hsize : G.size = 4)
    (hadj_all : ∀ v : Fin G.size, v ≠ G.embedding ⟨0, Nat.zero_lt_one⟩ →
                 G.str.1.Adj (G.embedding ⟨0, Nat.zero_lt_one⟩) v) :
    GenFlagIso vertexBlackType G vbExt3_RRR_e0 ∨
    GenFlagIso vertexBlackType G vbExt3_RRR_e1 ∨
    GenFlagIso vertexBlackType G vbExt3_RRR_e2 ∨
    GenFlagIso vertexBlackType G vbExt3_RRR_e3 ∨
    GenFlagIso vertexBlackType G vbExt3_BBB_e0 ∨
    GenFlagIso vertexBlackType G vbExt3_BBB_e1 ∨
    GenFlagIso vertexBlackType G vbExt3_BBB_e2 ∨
    GenFlagIso vertexBlackType G vbExt3_BBB_e3 ∨
    GenFlagIso vertexBlackType G vbExt3_RRB_e0 ∨
    GenFlagIso vertexBlackType G vbExt3_RRB_e1_RR ∨
    GenFlagIso vertexBlackType G vbExt3_RRB_e1_RB ∨
    GenFlagIso vertexBlackType G vbExt3_RRB_e2_RRRB ∨
    GenFlagIso vertexBlackType G vbExt3_RRB_e2_RBRB ∨
    GenFlagIso vertexBlackType G vbExt3_RRB_e3 ∨
    GenFlagIso vertexBlackType G vbExt3_RBB_e0 ∨
    GenFlagIso vertexBlackType G vbExt3_RBB_e1_RB ∨
    GenFlagIso vertexBlackType G vbExt3_RBB_e1_BB ∨
    GenFlagIso vertexBlackType G vbExt3_RBB_e2_RBBB ∨
    GenFlagIso vertexBlackType G vbExt3_RBB_e2_RBRB ∨
    GenFlagIso vertexBlackType G vbExt3_RBB_e3 := by
  rcases G with ⟨size, G_str, G_emb, G_isInd, G_hsize⟩
  -- hsize : size = 4
  subst hsize
  -- Case-split on the position of the σ-vertex.
  rcases fin4_val_cases (G_emb ⟨0, Nat.zero_lt_one⟩) with hp0 | hp1 | hp2 | hp3
  · -- σ-position 0: dispatch to any_size4_sigma0_extAdjAll_iso.
    exact any_size4_sigma0_extAdjAll_iso G_str G_emb G_isInd G_hsize hp0 hadj_all
  · -- σ-position 1: dispatch to any_size4_sigma1_extAdjAll_iso.
    exact any_size4_sigma1_extAdjAll_iso G_str G_emb G_isInd G_hsize hp1 hadj_all
  · -- σ-position 2: dispatch to any_size4_sigma2_extAdjAll_iso.
    exact any_size4_sigma2_extAdjAll_iso G_str G_emb G_isInd G_hsize hp2 hadj_all
  · -- σ-position 3: dispatch to any_size4_sigma3_extAdjAll_iso.
    exact any_size4_sigma3_extAdjAll_iso G_str G_emb G_isInd G_hsize hp3 hadj_all

/-! ### Eval-level corollary: σ-flags iso to BRRB-forbidden flags evaluate to 0

For any size-4 σ-flag `G` with σ adjacent to all 3 leaves, if `G` is not iso to
`vbExt3_RRR_e0`, then `G` is iso to one of the 19 BRRB-forbidden classes, and
hence `psi.evalAlg (single G) = 0` for any BRRB σ-functional `psi`.

This is an eval-level corollary of the master classification theorem
`any_size4_extAdjAll_iso`. It is the central building block for closing the
v5 size-4 conditional `evalAlg_vbExt3_RRR_e0_eq_one_of_decomp`. -/

/-- `IsForbidden` is preserved under flag isomorphism: if `F₁` is iso to `F₂`
    and `F₂` is forbidden, then `F₁` is forbidden (induced count is iso-invariant). -/
theorem IsForbidden_of_iso {σ : GenFlagType CG2} {F₁ F₂ : GenFlag CG2 σ}
    {𝒢 : GenFlag CG2 (GenFlagType.empty CG2) → Prop}
    (hiso : GenFlagIso σ F₁ F₂)
    (h_forbidden : IsForbidden σ F₂ 𝒢) :
    IsForbidden σ F₁ 𝒢 := by
  intro G hG
  rw [genInducedCount_flagIso hiso]
  exact h_forbidden G hG

/-- Eval-level transport for forbidden flags: if `F` is iso to a forbidden
    flag `F'`, then `psi.evalAlg (single F) = 0`. -/
theorem evalAlg_single_zero_of_iso_forbidden
    {F F' : GenFlag CG2 vertexBlackType}
    (hiso : GenFlagIso vertexBlackType F F')
    (h_forbidden : IsForbidden vertexBlackType F' brrbGenGraphClass)
    (psi : GenLimitFunctional CG2 vertexBlackType brrbGenGraphClass brrbGenDelta) :
    psi.evalAlg (GenFlagAlg.single F) = 0 :=
  evalAlg_single_zero_of_forbidden (IsForbidden_of_iso hiso h_forbidden) psi

/-- **Eval-level dichotomy via master classification**: for any size-4 σ-flag
    `G` whose σ-vertex is adjacent to all three non-σ vertices, either
    `psi.evalAlg (single G) = psi.evalAlg (single vbExt3_RRR_e0)` (the unique
    BRRB-locally-feasible class), or `psi.evalAlg (single G) = 0` (G iso to
    one of the 19 BRRB-forbidden classes).

    Proof: invoke `any_size4_extAdjAll_iso`. The first disjunct gives the
    iso to `vbExt3_RRR_e0`, hence the eval equality via `eval_iso`. Each of
    the 19 remaining disjuncts gives an iso to a forbidden class, hence
    eval = 0 via `evalAlg_single_zero_of_iso_forbidden`. -/
theorem evalAlg_single_size4_extAdjAll_dichotomy
    (G : GenFlag CG2 vertexBlackType) (hsize : G.size = 4)
    (hadj_all : ∀ v : Fin G.size, v ≠ G.embedding ⟨0, Nat.zero_lt_one⟩ →
                 G.str.1.Adj (G.embedding ⟨0, Nat.zero_lt_one⟩) v)
    (psi : GenLimitFunctional CG2 vertexBlackType brrbGenGraphClass brrbGenDelta) :
    psi.evalAlg (GenFlagAlg.single G) =
      psi.evalAlg (GenFlagAlg.single vbExt3_RRR_e0) ∨
    psi.evalAlg (GenFlagAlg.single G) = 0 := by
  rcases any_size4_extAdjAll_iso G hsize hadj_all with
    h | h | h | h | h | h | h | h | h | h | h | h | h | h | h | h | h | h | h | h
  · -- iso to vbExt3_RRR_e0
    left
    rw [GenLimitFunctional.evalAlg_single, GenLimitFunctional.evalAlg_single,
        psi.eval_iso _ _ h]
  all_goals right
  · exact evalAlg_single_zero_of_iso_forbidden h vbExt3_RRR_e1_isForbidden_brrb psi
  · exact evalAlg_single_zero_of_iso_forbidden h vbExt3_RRR_e2_isForbidden_brrb psi
  · exact evalAlg_single_zero_of_iso_forbidden h vbExt3_RRR_e3_isForbidden_brrb psi
  · exact evalAlg_single_zero_of_iso_forbidden h vbExt3_BBB_e0_isForbidden_brrb psi
  · exact evalAlg_single_zero_of_iso_forbidden h vbExt3_BBB_e1_isForbidden_brrb psi
  · exact evalAlg_single_zero_of_iso_forbidden h vbExt3_BBB_e2_isForbidden_brrb psi
  · exact evalAlg_single_zero_of_iso_forbidden h vbExt3_BBB_e3_isForbidden_brrb psi
  · exact evalAlg_single_zero_of_iso_forbidden h vbExt3_RRB_e0_isForbidden_brrb psi
  · exact evalAlg_single_zero_of_iso_forbidden h vbExt3_RRB_e1_RR_isForbidden_brrb psi
  · exact evalAlg_single_zero_of_iso_forbidden h vbExt3_RRB_e1_RB_isForbidden_brrb psi
  · exact evalAlg_single_zero_of_iso_forbidden h vbExt3_RRB_e2_RRRB_isForbidden_brrb psi
  · exact evalAlg_single_zero_of_iso_forbidden h vbExt3_RRB_e2_RBRB_isForbidden_brrb psi
  · exact evalAlg_single_zero_of_iso_forbidden h vbExt3_RRB_e3_isForbidden_brrb psi
  · exact evalAlg_single_zero_of_iso_forbidden h vbExt3_RBB_e0_isForbidden_brrb psi
  · exact evalAlg_single_zero_of_iso_forbidden h vbExt3_RBB_e1_RB_isForbidden_brrb psi
  · exact evalAlg_single_zero_of_iso_forbidden h vbExt3_RBB_e1_BB_isForbidden_brrb psi
  · exact evalAlg_single_zero_of_iso_forbidden h vbExt3_RBB_e2_RBBB_isForbidden_brrb psi
  · exact evalAlg_single_zero_of_iso_forbidden h vbExt3_RBB_e2_RBRB_isForbidden_brrb psi
  · exact evalAlg_single_zero_of_iso_forbidden h vbExt3_RBB_e3_isForbidden_brrb psi

/-! ### Sharper dichotomy: either `cls = ⟦RRR_e0⟧` or `psi.evalAlg = 0`

The dichotomy `evalAlg_single_size4_extAdjAll_dichotomy` gives "iso to RRR_e0
or eval = 0". The "iso to RRR_e0" disjunct via `mk_eq` upgrades to
`cls = ⟦vbExt3_RRR_e0⟧`. This sharper form is exactly what we need to compute
`psi.evalAlg(extPow ... 3)` via the Finsupp.sum decomposition. -/

/-- **Sharper dichotomy at the class level**: for any class `cls` whose
    representative `cls.out` is size-4 with σ-vertex adjacent to all 3 leaves,
    either `cls = ⟦vbExt3_RRR_e0⟧` (in which case `psi.evalAlg(single cls.out) =
    psi.evalAlg(single vbExt3_RRR_e0)`), or `psi.evalAlg(single cls.out) = 0`.

    Proof: invoke `any_size4_extAdjAll_iso` on `cls.out`. The first disjunct
    gives `GenFlagIso vbType cls.out vbExt3_RRR_e0`, hence by
    `Quotient.out_eq` and `GenFlagClass.mk_eq`, `cls = mk cls.out = mk RRR_e0`.
    The remaining 19 disjuncts each give iso to a forbidden class, hence eval
    = 0. -/
theorem evalAlg_single_size4_extAdjAll_dichotomy_sharp
    (cls : GenFlagClass CG2 vertexBlackType)
    (hsize : cls.out.size = 4)
    (hadj_all : ∀ v : Fin cls.out.size, v ≠ cls.out.embedding ⟨0, Nat.zero_lt_one⟩ →
                 cls.out.str.1.Adj (cls.out.embedding ⟨0, Nat.zero_lt_one⟩) v)
    (psi : GenLimitFunctional CG2 vertexBlackType brrbGenGraphClass brrbGenDelta) :
    cls = GenFlagClass.mk vbExt3_RRR_e0 ∨
    psi.evalAlg (GenFlagAlg.single cls.out) = 0 := by
  rcases any_size4_extAdjAll_iso cls.out hsize hadj_all with
    h | h | h | h | h | h | h | h | h | h | h | h | h | h | h | h | h | h | h | h
  · -- iso to vbExt3_RRR_e0: upgrade to class equality
    left
    have hmk : GenFlagClass.mk cls.out = GenFlagClass.mk vbExt3_RRR_e0 :=
      (GenFlagClass.mk_eq _ _).mpr h
    rw [← Quotient.out_eq cls]; exact hmk
  all_goals right
  · exact evalAlg_single_zero_of_iso_forbidden h vbExt3_RRR_e1_isForbidden_brrb psi
  · exact evalAlg_single_zero_of_iso_forbidden h vbExt3_RRR_e2_isForbidden_brrb psi
  · exact evalAlg_single_zero_of_iso_forbidden h vbExt3_RRR_e3_isForbidden_brrb psi
  · exact evalAlg_single_zero_of_iso_forbidden h vbExt3_BBB_e0_isForbidden_brrb psi
  · exact evalAlg_single_zero_of_iso_forbidden h vbExt3_BBB_e1_isForbidden_brrb psi
  · exact evalAlg_single_zero_of_iso_forbidden h vbExt3_BBB_e2_isForbidden_brrb psi
  · exact evalAlg_single_zero_of_iso_forbidden h vbExt3_BBB_e3_isForbidden_brrb psi
  · exact evalAlg_single_zero_of_iso_forbidden h vbExt3_RRB_e0_isForbidden_brrb psi
  · exact evalAlg_single_zero_of_iso_forbidden h vbExt3_RRB_e1_RR_isForbidden_brrb psi
  · exact evalAlg_single_zero_of_iso_forbidden h vbExt3_RRB_e1_RB_isForbidden_brrb psi
  · exact evalAlg_single_zero_of_iso_forbidden h vbExt3_RRB_e2_RRRB_isForbidden_brrb psi
  · exact evalAlg_single_zero_of_iso_forbidden h vbExt3_RRB_e2_RBRB_isForbidden_brrb psi
  · exact evalAlg_single_zero_of_iso_forbidden h vbExt3_RRB_e3_isForbidden_brrb psi
  · exact evalAlg_single_zero_of_iso_forbidden h vbExt3_RBB_e0_isForbidden_brrb psi
  · exact evalAlg_single_zero_of_iso_forbidden h vbExt3_RBB_e1_RB_isForbidden_brrb psi
  · exact evalAlg_single_zero_of_iso_forbidden h vbExt3_RBB_e1_BB_isForbidden_brrb psi
  · exact evalAlg_single_zero_of_iso_forbidden h vbExt3_RBB_e2_RBBB_isForbidden_brrb psi
  · exact evalAlg_single_zero_of_iso_forbidden h vbExt3_RBB_e2_RBRB_isForbidden_brrb psi
  · exact evalAlg_single_zero_of_iso_forbidden h vbExt3_RBB_e3_isForbidden_brrb psi

/-! ### Support property: `extAdjAll` lifts through joint-density positivity

For any pair `(F, F')` of σ-flags both having "σ-vertex adjacent to all non-σ
vertices", any class `cls` in the support of `genLocalFlagProduct F F'` (of
size `F.size + F'.size - σ.size`) inherits the same property.

The proof uses `gen_joint_pos_witness`: positivity of joint density gives
embeddings `e₁ : F → cls.out`, `e₂ : F' → cls.out` overlapping exactly on
σ-image and covering `cls.out`. Each non-σ vertex of `cls.out` is in the image
of `e₁` or `e₂`. Since both `F` and `F'` have σ adjacent to all non-σ, the
image carries this property to `cls.out`. -/

/-- **Flag-level extAdjAll predicate**: σ-vertex adjacent to all non-σ vertices. -/
def ExtAdjAll {σ : GenFlagType CG2} (F : GenFlag CG2 σ) (i : Fin σ.size) : Prop :=
  ∀ v : Fin F.size, v ∉ Set.range F.embedding →
    F.str.1.Adj (F.embedding i) v

/-- `ExtAdjAll` is iso-invariant. -/
theorem ExtAdjAll_iso_invariant {σ : GenFlagType CG2} {F F' : GenFlag CG2 σ}
    (h : GenFlagIso σ F F') (i : Fin σ.size) :
    ExtAdjAll F i ↔ ExtAdjAll F' i := by
  obtain ⟨φ, hstr, hcompat⟩ := h
  have hadj_iff : ∀ u v : Fin F.size,
      F.str.1.Adj u v ↔ F'.str.1.Adj (φ u) (φ v) := by
    intro u v
    have h1 : F.str.1 = (CG2.comap φ F'.str).1 := by rw [hstr]
    rw [h1]; rfl
  constructor
  · intro hF v' hv'_notin
    -- v' = φ (φ.symm v'); φ.symm v' ∉ Range F.embedding (else φ v' would be in Range F'.emb)
    have h_phi_symm_notin : φ.symm v' ∉ Set.range F.embedding := by
      intro ⟨j, hj⟩
      apply hv'_notin
      refine ⟨j, ?_⟩
      have : φ (F.embedding j) = F'.embedding j := hcompat j
      rw [← this, hj]; simp
    have hF_adj := hF (φ.symm v') h_phi_symm_notin
    rw [(hadj_iff _ _)] at hF_adj
    rw [hcompat i] at hF_adj
    have heq : φ (φ.symm v') = v' := by simp
    rw [heq] at hF_adj
    exact hF_adj
  · intro hF' v hv_notin
    have h_phi_v_notin : φ v ∉ Set.range F'.embedding := by
      intro ⟨j, hj⟩
      apply hv_notin
      refine ⟨j, ?_⟩
      have hcompat_j : φ (F.embedding j) = F'.embedding j := hcompat j
      apply φ.injective; rw [hcompat_j]; exact hj
    have hF'_adj := hF' (φ v) h_phi_v_notin
    rw [← hcompat i] at hF'_adj
    rw [← hadj_iff (F.embedding i) v] at hF'_adj
    exact hF'_adj

/-- Class-level lift of `ExtAdjAll` (iso-invariant via `ExtAdjAll_iso_invariant`). -/
def ExtAdjAllClass {σ : GenFlagType CG2} (cls : GenFlagClass CG2 σ)
    (i : Fin σ.size) : Prop :=
  ExtAdjAll cls.out i

/-- The 6 size-3 σ-flags `vbExt2_*` all satisfy `ExtAdjAll` at position 0. -/
private theorem vbExt2_RR_indep_extAdjAll :
    ExtAdjAll vbExt2_RR_indep (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) := by
  intro v hv_notin
  -- v ∉ Range emb means v ≠ ⟨0,_⟩ (emb is constant ⟨0,_⟩).
  have h_v_ne_zero : v.val ≠ 0 := by
    intro h_eq
    apply hv_notin
    exact ⟨⟨0, Nat.zero_lt_one⟩, by ext; exact h_eq.symm⟩
  -- emb ⟨0,_⟩ = ⟨0, _⟩ : Fin 3
  have h_emb : vbExt2_RR_indep.embedding (⟨0, Nat.zero_lt_one⟩ : Fin 1) =
      (⟨0, by omega⟩ : Fin 3) := rfl
  rw [h_emb]
  -- v.val ∈ {1, 2}
  rcases fin3_val_cases v with hv0 | hv1 | hv2
  · exact absurd hv0 h_v_ne_zero
  · -- v = ⟨1, _⟩, adj 0-1 holds
    have hv : v = (⟨1, by omega⟩ : Fin 3) := Fin.ext hv1
    rw [hv]
    change (SimpleGraph.fromRel _).Adj _ _
    simp [SimpleGraph.fromRel_adj]
  · -- v = ⟨2, _⟩, adj 0-2 holds
    have hv : v = (⟨2, by omega⟩ : Fin 3) := Fin.ext hv2
    rw [hv]
    change (SimpleGraph.fromRel _).Adj _ _
    simp [SimpleGraph.fromRel_adj]

