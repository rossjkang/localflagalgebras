    (h_adj_12 : G_str.1.Adj ⟨1, by decide⟩ ⟨2, by decide⟩ ↔
                T_str.1.Adj ⟨0, by decide⟩ ⟨1, by decide⟩)
    (h_adj_13 : G_str.1.Adj ⟨1, by decide⟩ ⟨3, by decide⟩ ↔
                T_str.1.Adj ⟨0, by decide⟩ ⟨3, by decide⟩)
    (h_adj_23 : G_str.1.Adj ⟨2, by decide⟩ ⟨3, by decide⟩ ↔
                T_str.1.Adj ⟨1, by decide⟩ ⟨3, by decide⟩)
    -- Colours: G(0) = T(2), G(2) = T(1), G(3) = T(3).
    (h_col_0 : G_str.2 ⟨0, by decide⟩ = T_str.2 ⟨2, by decide⟩)
    (h_col_2 : G_str.2 ⟨2, by decide⟩ = T_str.2 ⟨1, by decide⟩)
    (h_col_3 : G_str.2 ⟨3, by decide⟩ = T_str.2 ⟨3, by decide⟩) :
    GenFlagIso vertexBlackType
      (⟨4, G_str, G_emb, G_isInd, G_hsize⟩ : GenFlag CG2 vertexBlackType)
      (⟨4, T_str, T_emb, T_isInd, T_hsize⟩ : GenFlag CG2 vertexBlackType) := by
  classical
  have h01 : ((⟨0, by decide⟩ : Fin 4) : Fin 4) ≠ (⟨1, by decide⟩ : Fin 4) := by decide
  have h02 : ((⟨0, by decide⟩ : Fin 4) : Fin 4) ≠ (⟨2, by decide⟩ : Fin 4) := by decide
  have h03 : ((⟨0, by decide⟩ : Fin 4) : Fin 4) ≠ (⟨3, by decide⟩ : Fin 4) := by decide
  have h13 : ((⟨1, by decide⟩ : Fin 4) : Fin 4) ≠ (⟨3, by decide⟩ : Fin 4) := by decide
  have h23 : ((⟨2, by decide⟩ : Fin 4) : Fin 4) ≠ (⟨3, by decide⟩ : Fin 4) := by decide
  -- φ values: 0↦2, 1↦0, 2↦1, 3↦3.
  let φ : Fin 4 ≃ Fin 4 :=
    (Equiv.swap (⟨0, by decide⟩ : Fin 4) ⟨1, by decide⟩).trans
      (Equiv.swap (⟨1, by decide⟩ : Fin 4) ⟨2, by decide⟩)
  have hp0 : φ (⟨0, by decide⟩ : Fin 4) = (⟨2, by decide⟩ : Fin 4) := by
    change Equiv.swap (⟨1, by decide⟩ : Fin 4) ⟨2, by decide⟩
        (Equiv.swap (⟨0, by decide⟩ : Fin 4) ⟨1, by decide⟩ ⟨0, by decide⟩) = _
    rw [Equiv.swap_apply_left]
    exact Equiv.swap_apply_left _ _
  have hp1 : φ (⟨1, by decide⟩ : Fin 4) = (⟨0, by decide⟩ : Fin 4) := by
    change Equiv.swap (⟨1, by decide⟩ : Fin 4) ⟨2, by decide⟩
        (Equiv.swap (⟨0, by decide⟩ : Fin 4) ⟨1, by decide⟩ ⟨1, by decide⟩) = _
    rw [Equiv.swap_apply_right]
    exact Equiv.swap_apply_of_ne_of_ne h01 h02
  have hp2 : φ (⟨2, by decide⟩ : Fin 4) = (⟨1, by decide⟩ : Fin 4) := by
    change Equiv.swap (⟨1, by decide⟩ : Fin 4) ⟨2, by decide⟩
        (Equiv.swap (⟨0, by decide⟩ : Fin 4) ⟨1, by decide⟩ ⟨2, by decide⟩) = _
    rw [Equiv.swap_apply_of_ne_of_ne h02.symm (Fin.ne_of_val_ne (by decide))]
    exact Equiv.swap_apply_right _ _
  have hp3 : φ (⟨3, by decide⟩ : Fin 4) = (⟨3, by decide⟩ : Fin 4) := by
    change Equiv.swap (⟨1, by decide⟩ : Fin 4) ⟨2, by decide⟩
        (Equiv.swap (⟨0, by decide⟩ : Fin 4) ⟨1, by decide⟩ ⟨3, by decide⟩) = _
    rw [Equiv.swap_apply_of_ne_of_ne h03.symm h13.symm]
    exact Equiv.swap_apply_of_ne_of_ne h13.symm h23.symm
  apply size4_sigma1_iso_via_leafperm G_str T_str G_emb T_emb G_isInd T_isInd
    G_hsize T_hsize h_emb_G h_emb_T φ hp1
  · intro u v
    rcases fin4_val_cases u with hu | hu | hu | hu <;>
      rcases fin4_val_cases v with hv | hv | hv | hv <;>
      first
      | (have hu_eq : u = (⟨0, by decide⟩ : Fin 4) := Fin.ext hu
         have hv_eq : v = (⟨0, by decide⟩ : Fin 4) := Fin.ext hv
         rw [hu_eq, hv_eq, hp0]
         constructor <;> intro hadj <;> exact absurd hadj (SimpleGraph.irrefl _))
      | (have hu_eq : u = (⟨1, by decide⟩ : Fin 4) := Fin.ext hu
         have hv_eq : v = (⟨1, by decide⟩ : Fin 4) := Fin.ext hv
         rw [hu_eq, hv_eq, hp1]
         constructor <;> intro hadj <;> exact absurd hadj (SimpleGraph.irrefl _))
      | (have hu_eq : u = (⟨2, by decide⟩ : Fin 4) := Fin.ext hu
         have hv_eq : v = (⟨2, by decide⟩ : Fin 4) := Fin.ext hv
         rw [hu_eq, hv_eq, hp2]
         constructor <;> intro hadj <;> exact absurd hadj (SimpleGraph.irrefl _))
      | (have hu_eq : u = (⟨3, by decide⟩ : Fin 4) := Fin.ext hu
         have hv_eq : v = (⟨3, by decide⟩ : Fin 4) := Fin.ext hv
         rw [hu_eq, hv_eq, hp3]
         constructor <;> intro hadj <;> exact absurd hadj (SimpleGraph.irrefl _))
      | (have hu_eq : u = (⟨0, by decide⟩ : Fin 4) := Fin.ext hu
         have hv_eq : v = (⟨1, by decide⟩ : Fin 4) := Fin.ext hv
         rw [hu_eq, hv_eq, hp0, hp1]; exact h_adj_01)
      | (have hu_eq : u = (⟨0, by decide⟩ : Fin 4) := Fin.ext hu
         have hv_eq : v = (⟨2, by decide⟩ : Fin 4) := Fin.ext hv
         rw [hu_eq, hv_eq, hp0, hp2]; exact h_adj_02)
      | (have hu_eq : u = (⟨0, by decide⟩ : Fin 4) := Fin.ext hu
         have hv_eq : v = (⟨3, by decide⟩ : Fin 4) := Fin.ext hv
         rw [hu_eq, hv_eq, hp0, hp3]; exact h_adj_03)
      | (have hu_eq : u = (⟨1, by decide⟩ : Fin 4) := Fin.ext hu
         have hv_eq : v = (⟨0, by decide⟩ : Fin 4) := Fin.ext hv
         rw [hu_eq, hv_eq, hp1, hp0,
             SimpleGraph.adj_comm (G := G_str.1),
             SimpleGraph.adj_comm (G := T_str.1)]; exact h_adj_01)
      | (have hu_eq : u = (⟨2, by decide⟩ : Fin 4) := Fin.ext hu
         have hv_eq : v = (⟨0, by decide⟩ : Fin 4) := Fin.ext hv
         rw [hu_eq, hv_eq, hp2, hp0,
             SimpleGraph.adj_comm (G := G_str.1),
             SimpleGraph.adj_comm (G := T_str.1)]; exact h_adj_02)
      | (have hu_eq : u = (⟨3, by decide⟩ : Fin 4) := Fin.ext hu
         have hv_eq : v = (⟨0, by decide⟩ : Fin 4) := Fin.ext hv
         rw [hu_eq, hv_eq, hp3, hp0,
             SimpleGraph.adj_comm (G := G_str.1),
             SimpleGraph.adj_comm (G := T_str.1)]; exact h_adj_03)
      | (have hu_eq : u = (⟨1, by decide⟩ : Fin 4) := Fin.ext hu
         have hv_eq : v = (⟨2, by decide⟩ : Fin 4) := Fin.ext hv
         rw [hu_eq, hv_eq, hp1, hp2]; exact h_adj_12)
      | (have hu_eq : u = (⟨2, by decide⟩ : Fin 4) := Fin.ext hu
         have hv_eq : v = (⟨1, by decide⟩ : Fin 4) := Fin.ext hv
         rw [hu_eq, hv_eq, hp2, hp1,
             SimpleGraph.adj_comm (G := G_str.1),
             SimpleGraph.adj_comm (G := T_str.1)]; exact h_adj_12)
      | (have hu_eq : u = (⟨1, by decide⟩ : Fin 4) := Fin.ext hu
         have hv_eq : v = (⟨3, by decide⟩ : Fin 4) := Fin.ext hv
         rw [hu_eq, hv_eq, hp1, hp3]; exact h_adj_13)
      | (have hu_eq : u = (⟨3, by decide⟩ : Fin 4) := Fin.ext hu
         have hv_eq : v = (⟨1, by decide⟩ : Fin 4) := Fin.ext hv
         rw [hu_eq, hv_eq, hp3, hp1,
