/-! ### Nonzero joint counts: explicit construction

For the (extSum)·(extSum) expansion at vertexBlackType, we now construct the
nonzero joint counts explicitly. There are 8 such counts, all encoding
embeddings of vbExtRed/vbExtBlack into one of the 6 size-3 σ-flag classes.
-/

/-- Generic 2→3 embedding by val-injection (vertex i in Fin 2 ↦ vertex i in Fin 3).
    Used as the canonical embedding for vbExtRed/vbExtBlack into the size-3 flags
    where the leaf maps to vertex 1. -/
private def fin2to3_id : Fin 2 → Fin 3 :=
  fun x => ⟨x.val, by have h : x.val < 2 := x.isLt; omega⟩

/-- Generic 2→3 embedding sending ⟨0⟩ ↦ ⟨0⟩ and ⟨1⟩ ↦ ⟨2⟩.
    Used for vbExtRed/vbExtBlack into size-3 flags where the leaf maps to vertex 2. -/
private def fin2to3_skip : Fin 2 → Fin 3 :=
  fun x => if x.val = 0 then ⟨0, by decide⟩ else ⟨2, by decide⟩

private theorem fin2to3_id_inj : Function.Injective fin2to3_id := by
  intro a b h
  have hv : a.val = b.val := by
    have := congr_arg Fin.val h
    simpa [fin2to3_id] using this
  exact Fin.ext hv

private theorem fin2to3_id_zero : fin2to3_id (⟨0, by decide⟩ : Fin 2) = (⟨0, by decide⟩ : Fin 3) :=
  rfl

private theorem fin2to3_id_one : fin2to3_id (⟨1, by decide⟩ : Fin 2) = (⟨1, by decide⟩ : Fin 3) :=
  rfl

private theorem fin2to3_skip_inj : Function.Injective fin2to3_skip := by
  intro a b h
  unfold fin2to3_skip at h
  rcases fin2_eq_zero_or_one a with ha | ha <;> rcases fin2_eq_zero_or_one b with hb | hb
  · exact Fin.ext (ha.trans hb.symm)
  · simp [ha, hb] at h
  · simp [ha, hb] at h
  · exact Fin.ext (ha.trans hb.symm)

private theorem fin2to3_skip_zero : fin2to3_skip (⟨0, by decide⟩ : Fin 2) = (⟨0, by decide⟩ : Fin 3) :=
  rfl

private theorem fin2to3_skip_one : fin2to3_skip (⟨1, by decide⟩ : Fin 2) = (⟨2, by decide⟩ : Fin 3) :=
  rfl

/-- Canonical embedding vbExtRed → vbExt2_RB_indep mapping ⟨1⟩ ↦ ⟨1⟩
    (the unique red leaf in RB_indep). -/
noncomputable def vbExtRed_to_vbExt2_RB_indep_canon :
    GenInducedEmbedding CG2 vertexBlackType vbExtRed vbExt2_RB_indep where
  toFun := fin2to3_id
  injective := fin2to3_id_inj
  isInduced := by
    apply Prod.ext
    · -- Graph: both have edge {0,1} only.
      ext u v
      change vbExt2_RB_indep.str.1.Adj (fin2to3_id u) (fin2to3_id v) ↔
        vbExtRed.str.1.Adj u v
      rcases fin2_eq_zero_or_one u with hu | hu <;>
        rcases fin2_eq_zero_or_one v with hv | hv
      · have hu' : u = (⟨0, by decide⟩ : Fin 2) := Fin.ext hu
        have hv' : v = (⟨0, by decide⟩ : Fin 2) := Fin.ext hv
        rw [hu', hv', fin2to3_id_zero]
        simp [vbExt2_RB_indep, vbExtRed]
      · have hu' : u = (⟨0, by decide⟩ : Fin 2) := Fin.ext hu
        have hv' : v = (⟨1, by decide⟩ : Fin 2) := Fin.ext hv
        rw [hu', hv', fin2to3_id_zero, fin2to3_id_one]
        simp [vbExt2_RB_indep, vbExtRed, SimpleGraph.fromRel_adj]
      · have hu' : u = (⟨1, by decide⟩ : Fin 2) := Fin.ext hu
        have hv' : v = (⟨0, by decide⟩ : Fin 2) := Fin.ext hv
        rw [hu', hv', fin2to3_id_zero, fin2to3_id_one]
        simp [vbExt2_RB_indep, vbExtRed, SimpleGraph.fromRel_adj]
      · have hu' : u = (⟨1, by decide⟩ : Fin 2) := Fin.ext hu
        have hv' : v = (⟨1, by decide⟩ : Fin 2) := Fin.ext hv
        rw [hu', hv', fin2to3_id_one]
        simp [vbExt2_RB_indep, vbExtRed]
    · -- Colour: vertex 0 → vertex 0 (both black=1), vertex 1 → vertex 1 (both red=0).
      funext v
      rcases fin2_eq_zero_or_one v with hv | hv
      · have hv' : v = (⟨0, by decide⟩ : Fin 2) := Fin.ext hv
        rw [hv']
        change vbExt2_RB_indep.str.2 (fin2to3_id (⟨0, by decide⟩ : Fin 2)) =
          vbExtRed.str.2 (⟨0, by decide⟩ : Fin 2)
        rw [fin2to3_id_zero]
        decide
      · have hv' : v = (⟨1, by decide⟩ : Fin 2) := Fin.ext hv
        rw [hv']
        change vbExt2_RB_indep.str.2 (fin2to3_id (⟨1, by decide⟩ : Fin 2)) =
          vbExtRed.str.2 (⟨1, by decide⟩ : Fin 2)
        rw [fin2to3_id_one]
        decide
  compat := fun i => by
    have hi : i = (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) := by
      obtain ⟨v, hv⟩ := i
      have h_size : vertexBlackType.size = 1 := rfl
      have hv' : v < 1 := h_size ▸ hv
      have : v = 0 := by omega
      ext; exact this
    rw [hi]
    have h1 : vbExtRed.embedding (⟨0, Nat.zero_lt_one⟩ : Fin 1) =
        (⟨0, by decide⟩ : Fin 2) := rfl
    have h2 : vbExt2_RB_indep.embedding (⟨0, Nat.zero_lt_one⟩ : Fin 1) =
        (⟨0, by decide⟩ : Fin 3) := rfl
    rw [h1, h2, fin2to3_id_zero]

/-- Canonical embedding vbExtRed → vbExt2_RB_edge mapping ⟨1⟩ ↦ ⟨1⟩ (red leaf). -/
noncomputable def vbExtRed_to_vbExt2_RB_edge_canon :
    GenInducedEmbedding CG2 vertexBlackType vbExtRed vbExt2_RB_edge where
  toFun := fin2to3_id
  injective := fin2to3_id_inj
  isInduced := by
    apply Prod.ext
    · ext u v
      change vbExt2_RB_edge.str.1.Adj (fin2to3_id u) (fin2to3_id v) ↔
        vbExtRed.str.1.Adj u v
      rcases fin2_eq_zero_or_one u with hu | hu <;>
        rcases fin2_eq_zero_or_one v with hv | hv
      all_goals first
        | (have hu' : u = (⟨0, by decide⟩ : Fin 2) := Fin.ext hu
           have hv' : v = (⟨0, by decide⟩ : Fin 2) := Fin.ext hv
           rw [hu', hv', fin2to3_id_zero]
           simp [vbExt2_RB_edge, vbExtRed])
        | (have hu' : u = (⟨0, by decide⟩ : Fin 2) := Fin.ext hu
           have hv' : v = (⟨1, by decide⟩ : Fin 2) := Fin.ext hv
           rw [hu', hv', fin2to3_id_zero, fin2to3_id_one]
           simp [vbExt2_RB_edge, vbExtRed, SimpleGraph.fromRel_adj])
        | (have hu' : u = (⟨1, by decide⟩ : Fin 2) := Fin.ext hu
           have hv' : v = (⟨0, by decide⟩ : Fin 2) := Fin.ext hv
           rw [hu', hv', fin2to3_id_zero, fin2to3_id_one]
           simp [vbExt2_RB_edge, vbExtRed, SimpleGraph.fromRel_adj])
        | (have hu' : u = (⟨1, by decide⟩ : Fin 2) := Fin.ext hu
           have hv' : v = (⟨1, by decide⟩ : Fin 2) := Fin.ext hv
           rw [hu', hv', fin2to3_id_one]
           simp [vbExt2_RB_edge, vbExtRed])
    · funext v
      rcases fin2_eq_zero_or_one v with hv | hv
      · have hv' : v = (⟨0, by decide⟩ : Fin 2) := Fin.ext hv
        rw [hv']
        change vbExt2_RB_edge.str.2 (fin2to3_id (⟨0, by decide⟩ : Fin 2)) =
          vbExtRed.str.2 (⟨0, by decide⟩ : Fin 2)
        rw [fin2to3_id_zero]; decide
      · have hv' : v = (⟨1, by decide⟩ : Fin 2) := Fin.ext hv
        rw [hv']
        change vbExt2_RB_edge.str.2 (fin2to3_id (⟨1, by decide⟩ : Fin 2)) =
          vbExtRed.str.2 (⟨1, by decide⟩ : Fin 2)
        rw [fin2to3_id_one]; decide
  compat := fun i => by
    have hi : i = (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) := by
      obtain ⟨v, hv⟩ := i
      have h_size : vertexBlackType.size = 1 := rfl
      have hv' : v < 1 := h_size ▸ hv
      have : v = 0 := by omega
      ext; exact this
    rw [hi]
    have h1 : vbExtRed.embedding (⟨0, Nat.zero_lt_one⟩ : Fin 1) =
        (⟨0, by decide⟩ : Fin 2) := rfl
    have h2 : vbExt2_RB_edge.embedding (⟨0, Nat.zero_lt_one⟩ : Fin 1) =
        (⟨0, by decide⟩ : Fin 3) := rfl
    rw [h1, h2, fin2to3_id_zero]

/-- Canonical embedding vbExtBlack → vbExt2_RB_indep mapping ⟨1⟩ ↦ ⟨2⟩ (black leaf). -/
noncomputable def vbExtBlack_to_vbExt2_RB_indep_canon :
