  -- Step 6: the coefficient at ⟦RRRR_e0⟧ is 1 by hypothesis.
  rw [h_coeff] at h_pow_eval
  rw [one_mul] at h_pow_eval
  rw [GenLimitFunctional.evalAlg_single]
