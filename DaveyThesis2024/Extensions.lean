        · intro h; simp [t3_v1_d] at h
        · intro h; exact (G.str.1.irrefl h).elim
      · rw [hφv0, hφv1]; constructor
        · intro _; exact G_v0v1
        · intro _; simp [t3_v1_d, SimpleGraph.fromRel_adj]
      · rw [hφv0, hφv2]; constructor
        · intro _; exact G_v0v2
        · intro _; simp [t3_v1_d, SimpleGraph.fromRel_adj]
      · rw [hφv0, hφv3]; constructor
        · intro h; simp [t3_v1_d] at h
        · intro h; exact (G_v0v3_no h).elim
      · rw [hφv0, hφw]; constructor
        · intro h; simp [t3_v1_d] at h
        · intro h; exact (h_no_v0 h.symm).elim
      · rw [hφv1, hφv0]; constructor
        · intro _; exact G_v0v1.symm
        · intro _; simp [t3_v1_d, SimpleGraph.fromRel_adj]
      · rw [hφv1]; constructor
        · intro h; simp [t3_v1_d] at h
        · intro h; exact (G.str.1.irrefl h).elim
      · rw [hφv1, hφv2]; constructor
        · intro h; simp [t3_v1_d] at h
        · intro h; exact (G_v1v2_no h).elim
      · rw [hφv1, hφv3]; constructor
        · intro _; exact G_v1v3
        · intro _; simp [t3_v1_d, SimpleGraph.fromRel_adj]
      · rw [hφv1, hφw]; constructor
        · intro _; exact G_wv1.symm
        · intro _; simp [t3_v1_d, SimpleGraph.fromRel_adj]
      · rw [hφv2, hφv0]; constructor
        · intro _; exact G_v0v2.symm
        · intro _; simp [t3_v1_d, SimpleGraph.fromRel_adj]
      · rw [hφv2, hφv1]; constructor
        · intro h; simp [t3_v1_d] at h
        · intro h; exact (G_v1v2_no h.symm).elim
      · rw [hφv2]; constructor
        · intro h; simp [t3_v1_d] at h
        · intro h; exact (G.str.1.irrefl h).elim
      · rw [hφv2, hφv3]; constructor
        · intro h; simp [t3_v1_d] at h
        · intro h; exact (G_v2v3_no h).elim
      · rw [hφv2, hφw]; constructor
        · intro _; exact h_yes_v2.symm
        · intro _; simp [t3_v1_d, SimpleGraph.fromRel_adj]
      · rw [hφv3, hφv0]; constructor
        · intro h; simp [t3_v1_d] at h
        · intro h; exact (G_v0v3_no h.symm).elim
      · rw [hφv3, hφv1]; constructor
        · intro _; exact G_v1v3.symm
        · intro _; simp [t3_v1_d, SimpleGraph.fromRel_adj]
      · rw [hφv3, hφv2]; constructor
        · intro h; simp [t3_v1_d] at h
        · intro h; exact (G_v2v3_no h.symm).elim
      · rw [hφv3]; constructor
        · intro h; simp [t3_v1_d] at h
        · intro h; exact (G.str.1.irrefl h).elim
      · rw [hφv3, hφw]; constructor
        · intro h; simp [t3_v1_d] at h
        · intro h; exact (h_no_v3 h.symm).elim
      · rw [hφw, hφv0]; constructor
        · intro h; simp [t3_v1_d] at h
        · intro h; exact (h_no_v0 h).elim
      · rw [hφw, hφv1]; constructor
        · intro _; exact G_wv1
        · intro _; simp [t3_v1_d, SimpleGraph.fromRel_adj]
      · rw [hφw, hφv2]; constructor
        · intro _; exact h_yes_v2
        · intro _; simp [t3_v1_d, SimpleGraph.fromRel_adj]
      · rw [hφw, hφv3]; constructor
        · intro h; simp [t3_v1_d] at h
        · intro h; exact (h_no_v3 h).elim
      · rw [hφw]; constructor
        · intro h; simp [t3_v1_d] at h
        · intro h; exact (G.str.1.irrefl h).elim
    · funext x
      change t3_v1_d.str.2 (φ x) = G.str.2 x
      rcases x_cases x with hx | hx | hx | hx | hx <;> rw [hx]
      · rw [hφv0, hcol_v0]; rfl
      · rw [hφv1, hcol_v1]; rfl
      · rw [hφv2, hcol_v2]; rfl
      · rw [hφv3, hcol_v3]; rfl
      · rw [hφw, h_w_B]; rfl
  · intro i
    fin_cases i
    · simp [t3_v1_d, Fin.castLE]; exact hφv0
    · simp [t3_v1_d, Fin.castLE]; exact hφv1
    · simp [t3_v1_d, Fin.castLE]; exact hφv2
    · simp [t3_v1_d, Fin.castLE]; exact hφv3

/-! ### σ₃-3.3: extAdj-v0 dichotomy (thesisType3)

For any size-5 thesisType3-flag class `cls` with `extAdjacencyClass cls v0`,
EITHER `cls = ⟦t3_v0_a⟧` OR `cls = ⟦t3_v0_b⟧` OR `phi.eval cls.out.forget = 0`.
After ruling out BB-edge / triangle, BRRB constraints give w R, ¬w-v1, ¬w-v2;
case-split on `w-v3`. -/
theorem t3_extAdj_v0_dichotomy
    (cls : GenFlagClass CG2 thesisType3)
    (h_size : cls.out.size = 5)
    (h_extAdj : extAdjacencyClass thesisType3 cls ⟨0, by decide⟩)
    (phi : GenLimitFunctional CG2 (GenFlagType.empty CG2)
      brrbGenGraphClass brrbGenDelta) :
    cls = GenFlagClass.mk t3_v0_a ∨
    cls = GenFlagClass.mk t3_v0_b ∨
    phi.eval cls.out.forget = 0 := by
  classical
  have h_ext : extAdjacency thesisType3 cls.out ⟨0, by decide⟩ := h_extAdj
  by_cases h_BB : ∃ u v : Fin cls.out.size,
      cls.out.str.2 u = 1 ∧ cls.out.str.2 v = 1 ∧ cls.out.str.1.Adj u v
  · right; right
    exact eval_zero_of_adj_black phi cls.out.forget h_BB
  by_cases h_tri : ∃ u v w : Fin cls.out.size,
      cls.out.str.1.Adj u v ∧ cls.out.str.1.Adj v w ∧ cls.out.str.1.Adj u w
  · right; right
    exact eval_zero_of_triangle phi cls.out.forget h_tri
  obtain ⟨h_w_R, h_no_v1, h_no_v2⟩ :=
    t3_extAdj_v0_BRRB_constraints cls.out h_size h_ext h_BB h_tri
  set w := extVertex cls.out h_size with hw_def
  set v3 := cls.out.embedding ⟨3, by decide⟩ with hv3_def
  by_cases h_v3 : cls.out.str.1.Adj w v3
  · right; left
    have hiso := t3_v0_b_classification cls.out h_size h_ext h_w_R h_no_v1 h_no_v2 h_v3
    have hmk : GenFlagClass.mk cls.out = GenFlagClass.mk t3_v0_b :=
      Quotient.sound hiso
    rw [← Quotient.out_eq cls]; exact hmk
  · left
    have hiso := t3_v0_a_classification cls.out h_size h_ext h_w_R h_no_v1 h_no_v2 h_v3
    have hmk : GenFlagClass.mk cls.out = GenFlagClass.mk t3_v0_a :=
      Quotient.sound hiso
    rw [← Quotient.out_eq cls]; exact hmk

/-! ### σ₃-3.3: extAdj-v1 dichotomy (thesisType3)

For any size-5 thesisType3-flag class `cls` with `extAdjacencyClass cls v1`,
EITHER `cls` is iso to one of the 4 v1-side ext witnesses, OR
`phi.eval cls.out.forget = 0`. After ruling out BB-edge / triangle and
extracting `¬w-v0`, `¬w-v3`, case-split on color of w (R or B) and (w-v2). -/
set_option maxHeartbeats 800000 in
theorem t3_extAdj_v1_dichotomy
    (cls : GenFlagClass CG2 thesisType3)
    (h_size : cls.out.size = 5)
    (h_extAdj : extAdjacencyClass thesisType3 cls ⟨1, by decide⟩)
    (phi : GenLimitFunctional CG2 (GenFlagType.empty CG2)
      brrbGenGraphClass brrbGenDelta) :
    cls = GenFlagClass.mk t3_v1_a ∨
    cls = GenFlagClass.mk t3_v1_b ∨
    cls = GenFlagClass.mk t3_v1_c ∨
    cls = GenFlagClass.mk t3_v1_d ∨
    phi.eval cls.out.forget = 0 := by
  classical
  have h_ext : extAdjacency thesisType3 cls.out ⟨1, by decide⟩ := h_extAdj
  by_cases h_BB : ∃ u v : Fin cls.out.size,
      cls.out.str.2 u = 1 ∧ cls.out.str.2 v = 1 ∧ cls.out.str.1.Adj u v
  · right; right; right; right
    exact eval_zero_of_adj_black phi cls.out.forget h_BB
  by_cases h_tri : ∃ u v w : Fin cls.out.size,
      cls.out.str.1.Adj u v ∧ cls.out.str.1.Adj v w ∧ cls.out.str.1.Adj u w
  · right; right; right; right
    exact eval_zero_of_triangle phi cls.out.forget h_tri
  obtain ⟨h_no_v0, h_no_v3⟩ :=
    t3_extAdj_v1_BRRB_constraints cls.out h_size h_ext h_BB h_tri
  set w := extVertex cls.out h_size with hw_def
  set v2 := cls.out.embedding ⟨2, by decide⟩ with hv2_def
  have hcol_lt : (cls.out.str.2 w).val < 2 := (cls.out.str.2 w).isLt
  interval_cases h_w_col : (cls.out.str.2 w).val
  · have h_w_R : cls.out.str.2 w = 0 := Fin.ext h_w_col
    by_cases h_v2 : cls.out.str.1.Adj w v2
    · right; left
      have hiso := t3_v1_b_classification cls.out h_size h_ext h_w_R h_no_v0 h_v2 h_no_v3
      have hmk : GenFlagClass.mk cls.out = GenFlagClass.mk t3_v1_b :=
        Quotient.sound hiso
      rw [← Quotient.out_eq cls]; exact hmk
    · left
      have hiso := t3_v1_a_classification cls.out h_size h_ext h_w_R h_no_v0 h_v2 h_no_v3
      have hmk : GenFlagClass.mk cls.out = GenFlagClass.mk t3_v1_a :=
        Quotient.sound hiso
      rw [← Quotient.out_eq cls]; exact hmk
  · have h_w_B : cls.out.str.2 w = 1 := Fin.ext h_w_col
    by_cases h_v2 : cls.out.str.1.Adj w v2
    · right; right; right; left
      have hiso := t3_v1_d_classification cls.out h_size h_ext h_w_B h_no_v0 h_v2 h_no_v3
      have hmk : GenFlagClass.mk cls.out = GenFlagClass.mk t3_v1_d :=
        Quotient.sound hiso
      rw [← Quotient.out_eq cls]; exact hmk
    · right; right; left
      have hiso := t3_v1_c_classification cls.out h_size h_ext h_w_B h_no_v0 h_v2 h_no_v3
      have hmk : GenFlagClass.mk cls.out = GenFlagClass.mk t3_v1_c :=
        Quotient.sound hiso
      rw [← Quotient.out_eq cls]; exact hmk

/-! ### σ₂-3: BRRB constraint extractors (thesisType2)

- v0-side: w must be R (since v0=B, w-v0 BB-edge would form). w not adj
  v1, v2, v3 (σ-edges 0-1, 0-2, 0-3 each form a triangle w-v0-vᵢ).
- v1-side: w not adj v0 (σ-edge 0-1 forms triangle w-v0-v1). No colour
  constraint on w. -/

/-- v0-side BRRB constraints: w is R AND not adjacent to v1, v2, v3. -/
theorem t2_extAdj_v0_BRRB_constraints
    (G : GenFlag CG2 thesisType2) (h_size : G.size = 5)
    (h_ext : extAdjacency thesisType2 G ⟨0, by decide⟩)
    (h_no_BB : ¬∃ u v : Fin G.size,
      G.str.2 u = 1 ∧ G.str.2 v = 1 ∧ G.str.1.Adj u v)
    (h_no_tri : ¬∃ u v w : Fin G.size,
      G.str.1.Adj u v ∧ G.str.1.Adj v w ∧ G.str.1.Adj u w) :
    G.str.2 (extVertex G h_size) = 0 ∧
    ¬G.str.1.Adj (extVertex G h_size) (G.embedding ⟨1, by decide⟩) ∧
    ¬G.str.1.Adj (extVertex G h_size) (G.embedding ⟨2, by decide⟩) ∧
    ¬G.str.1.Adj (extVertex G h_size) (G.embedding ⟨3, by decide⟩) := by
  set w := extVertex G h_size with hw_def
  obtain ⟨v, hv_notin, hv_adj_v0⟩ := h_ext
  have hv_eq : v = w := extVertex_unique G h_size v hv_notin
  subst hv_eq
  set v0 := G.embedding ⟨0, by decide⟩ with hv0
  set v1 := G.embedding ⟨1, by decide⟩ with hv1
  set v2 := G.embedding ⟨2, by decide⟩ with hv2
  set v3 := G.embedding ⟨3, by decide⟩ with hv3
  have hcomap : (CG2.comap G.embedding G.str).1 = thesisType2.str.1 :=
    congr_arg Prod.fst G.isInduced
  have h_col_eq : ∀ j : Fin thesisType2.size,
      G.str.2 (G.embedding j) = thesisType2.str.2 j := fun j =>
    congr_fun (congr_arg Prod.snd G.isInduced) j
  have hcol_v0 : G.str.2 v0 = 1 := by
    rw [hv0, h_col_eq]; simp [thesisType2]
  have hv0_adj_v1 : G.str.1.Adj v0 v1 := by
    have h_sigma : thesisType2.str.1.Adj ⟨0, by decide⟩ ⟨1, by decide⟩ := by
      simp [thesisType2, SimpleGraph.fromRel_adj]
    rw [← hcomap] at h_sigma; exact h_sigma
  have hv0_adj_v2 : G.str.1.Adj v0 v2 := by
    have h_sigma : thesisType2.str.1.Adj ⟨0, by decide⟩ ⟨2, by decide⟩ := by
      simp [thesisType2, SimpleGraph.fromRel_adj]
    rw [← hcomap] at h_sigma; exact h_sigma
  have hv0_adj_v3 : G.str.1.Adj v0 v3 := by
    have h_sigma : thesisType2.str.1.Adj ⟨0, by decide⟩ ⟨3, by decide⟩ := by
      simp [thesisType2, SimpleGraph.fromRel_adj]
    rw [← hcomap] at h_sigma; exact h_sigma
  have hv_adj_v0' : G.str.1.Adj w v0 := by rw [hv0]; exact hv_adj_v0
  refine ⟨?_, ?_, ?_, ?_⟩
  · -- w is R: if w were B, then w-v0 BB-edge.
    by_contra hwc
    have hwc1 : G.str.2 w = 1 := by
      have hlt : (G.str.2 w).val < 2 := (G.str.2 w).isLt
      interval_cases h : (G.str.2 w).val
      · exfalso; apply hwc; exact Fin.ext h
      · exact Fin.ext h
    apply h_no_BB
    refine ⟨w, v0, hwc1, hcol_v0, hv_adj_v0'⟩
  · intro h_w_v1
    apply h_no_tri
    refine ⟨v0, v1, w, hv0_adj_v1, h_w_v1.symm, hv_adj_v0'.symm⟩
  · intro h_w_v2
    apply h_no_tri
    refine ⟨v0, v2, w, hv0_adj_v2, h_w_v2.symm, hv_adj_v0'.symm⟩
  · intro h_w_v3
    apply h_no_tri
    refine ⟨v0, v3, w, hv0_adj_v3, h_w_v3.symm, hv_adj_v0'.symm⟩

/-- v1-side BRRB constraint: w is not adjacent to v0. -/
theorem t2_extAdj_v1_BRRB_not_adj_v0
    (G : GenFlag CG2 thesisType2) (h_size : G.size = 5)
    (h_ext : extAdjacency thesisType2 G ⟨1, by decide⟩)
    (_h_no_BB : ¬∃ u v : Fin G.size,
      G.str.2 u = 1 ∧ G.str.2 v = 1 ∧ G.str.1.Adj u v)
    (h_no_tri : ¬∃ u v w : Fin G.size,
      G.str.1.Adj u v ∧ G.str.1.Adj v w ∧ G.str.1.Adj u w) :
    ¬G.str.1.Adj (extVertex G h_size) (G.embedding ⟨0, by decide⟩) := by
  set w := extVertex G h_size with hw_def
  obtain ⟨v, hv_notin, hv_adj_v1⟩ := h_ext
  have hv_eq : v = w := extVertex_unique G h_size v hv_notin
  subst hv_eq
  set v0 := G.embedding ⟨0, by decide⟩ with hv0
  set v1 := G.embedding ⟨1, by decide⟩ with hv1
  have hcomap : (CG2.comap G.embedding G.str).1 = thesisType2.str.1 :=
    congr_arg Prod.fst G.isInduced
  have hv0_adj_v1 : G.str.1.Adj v0 v1 := by
    have h_sigma : thesisType2.str.1.Adj ⟨0, by decide⟩ ⟨1, by decide⟩ := by
      simp [thesisType2, SimpleGraph.fromRel_adj]
    rw [← hcomap] at h_sigma; exact h_sigma
  have hv_adj_v1' : G.str.1.Adj w v1 := by rw [hv1]; exact hv_adj_v1
  intro h_w_v0
  apply h_no_tri
  refine ⟨v0, v1, w, hv0_adj_v1, hv_adj_v1'.symm, h_w_v0.symm⟩

/-! ### σ₂-3.2 case 0: v0-side classification (unique witness t2_v0) -/

set_option maxHeartbeats 1600000 in
/-- v0-side: any size-5 thesisType2-flag G with extAdj-v0, w R, and w not adj
    v1, v2, v3 is σ-iso to `t2_v0` (K_{1,4} centred at v0=B). -/
theorem t2_v0_classification (G : GenFlag CG2 thesisType2)
    (h_size : G.size = 5)
    (h_ext : extAdjacency thesisType2 G ⟨0, by decide⟩)
    (h_w_R : G.str.2 (extVertex G h_size) = 0)
    (h_no_v1 : ¬G.str.1.Adj (extVertex G h_size) (G.embedding ⟨1, by decide⟩))
    (h_no_v2 : ¬G.str.1.Adj (extVertex G h_size) (G.embedding ⟨2, by decide⟩))
    (h_no_v3 : ¬G.str.1.Adj (extVertex G h_size) (G.embedding ⟨3, by decide⟩)) :
    GenFlagIso thesisType2 G t2_v0 := by
  classical
  set v0 := G.embedding ⟨0, by decide⟩ with hv0
  set v1 := G.embedding ⟨1, by decide⟩ with hv1
  set v2 := G.embedding ⟨2, by decide⟩ with hv2
  set v3 := G.embedding ⟨3, by decide⟩ with hv3
  set w := extVertex G h_size with hw
  have hv01 : v0 ≠ v1 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv02 : v0 ≠ v2 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv03 : v0 ≠ v3 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv12 : v1 ≠ v2 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv13 : v1 ≠ v3 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv23 : v2 ≠ v3 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hw_notin : w ∉ Set.range G.embedding := extVertex_notin_range G h_size
  have hwv0 : w ≠ v0 := fun h => hw_notin ⟨⟨0, by decide⟩, h.symm⟩
  have hwv1 : w ≠ v1 := fun h => hw_notin ⟨⟨1, by decide⟩, h.symm⟩
  have hwv2 : w ≠ v2 := fun h => hw_notin ⟨⟨2, by decide⟩, h.symm⟩
  have hwv3 : w ≠ v3 := fun h => hw_notin ⟨⟨3, by decide⟩, h.symm⟩
  have h_str_eq : (CG2.comap G.embedding G.str).1 = thesisType2.str.1 :=
    congr_arg Prod.fst G.isInduced
  have h_col_eq : ∀ j : Fin thesisType2.size,
      G.str.2 (G.embedding j) = thesisType2.str.2 j := fun j =>
    congr_fun (congr_arg Prod.snd G.isInduced) j
  -- σ-edges of thesisType2: 0-1, 0-2, 0-3.
  have G_v0v1 : G.str.1.Adj v0 v1 := by
    have h_sigma : thesisType2.str.1.Adj ⟨0, by decide⟩ ⟨1, by decide⟩ := by
      simp [thesisType2, SimpleGraph.fromRel_adj]
    rw [← h_str_eq] at h_sigma; exact h_sigma
  have G_v0v2 : G.str.1.Adj v0 v2 := by
    have h_sigma : thesisType2.str.1.Adj ⟨0, by decide⟩ ⟨2, by decide⟩ := by
      simp [thesisType2, SimpleGraph.fromRel_adj]
    rw [← h_str_eq] at h_sigma; exact h_sigma
  have G_v0v3 : G.str.1.Adj v0 v3 := by
    have h_sigma : thesisType2.str.1.Adj ⟨0, by decide⟩ ⟨3, by decide⟩ := by
      simp [thesisType2, SimpleGraph.fromRel_adj]
    rw [← h_str_eq] at h_sigma; exact h_sigma
  -- σ-non-edges of thesisType2: 1-2, 1-3, 2-3.
  have G_v1v2_no : ¬G.str.1.Adj v1 v2 := by
    intro h
    have h' : (CG2.comap G.embedding G.str).1.Adj ⟨1, by decide⟩ ⟨2, by decide⟩ := h
    rw [h_str_eq] at h'
    simp [thesisType2, SimpleGraph.fromRel_adj] at h'
  have G_v1v3_no : ¬G.str.1.Adj v1 v3 := by
    intro h
    have h' : (CG2.comap G.embedding G.str).1.Adj ⟨1, by decide⟩ ⟨3, by decide⟩ := h
    rw [h_str_eq] at h'
    simp [thesisType2, SimpleGraph.fromRel_adj] at h'
  have G_v2v3_no : ¬G.str.1.Adj v2 v3 := by
    intro h
    have h' : (CG2.comap G.embedding G.str).1.Adj ⟨2, by decide⟩ ⟨3, by decide⟩ := h
    rw [h_str_eq] at h'
    simp [thesisType2, SimpleGraph.fromRel_adj] at h'
  obtain ⟨v_ext, hv_ext_notin, hv_ext_adj⟩ := h_ext
  have hv_ext_eq : v_ext = w := extVertex_unique G h_size v_ext hv_ext_notin
  subst hv_ext_eq
  have G_wv0 : G.str.1.Adj w v0 := by rw [hv0]; exact hv_ext_adj
  have hcol_v0 : G.str.2 v0 = 1 := by rw [hv0, h_col_eq]; simp [thesisType2]
  have hcol_v1 : G.str.2 v1 = 0 := by rw [hv1, h_col_eq]; simp [thesisType2]
  have hcol_v2 : G.str.2 v2 = 0 := by rw [hv2, h_col_eq]; simp [thesisType2]
  have hcol_v3 : G.str.2 v3 = 0 := by rw [hv3, h_col_eq]; simp [thesisType2]
  let φ_fn : Fin G.size → Fin 5 := fun x =>
    if x = v0 then ⟨0, by decide⟩
    else if x = v1 then ⟨1, by decide⟩
    else if x = v2 then ⟨2, by decide⟩
    else if x = v3 then ⟨3, by decide⟩
    else ⟨4, by decide⟩
  have φv0 : φ_fn v0 = ⟨0, by decide⟩ := by simp [φ_fn]
  have φv1 : φ_fn v1 = ⟨1, by decide⟩ := by
    simp only [φ_fn]; rw [if_neg hv01.symm]; simp
  have φv2 : φ_fn v2 = ⟨2, by decide⟩ := by
    simp only [φ_fn]; rw [if_neg hv02.symm, if_neg hv12.symm]; simp
  have φv3 : φ_fn v3 = ⟨3, by decide⟩ := by
