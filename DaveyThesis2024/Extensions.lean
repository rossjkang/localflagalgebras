    (h_adj_23 : G_str.1.Adj ⟨2, by decide⟩ ⟨3, by decide⟩ ↔
                T_str.1.Adj ⟨1, by decide⟩ ⟨2, by decide⟩)
    -- Colours: G(0) = T(3), G(2) = T(1), G(3) = T(2).
    (h_col_0 : G_str.2 ⟨0, by decide⟩ = T_str.2 ⟨3, by decide⟩)
    (h_col_2 : G_str.2 ⟨2, by decide⟩ = T_str.2 ⟨1, by decide⟩)
    (h_col_3 : G_str.2 ⟨3, by decide⟩ = T_str.2 ⟨2, by decide⟩) :
    GenFlagIso vertexBlackType
      (⟨4, G_str, G_emb, G_isInd, G_hsize⟩ : GenFlag CG2 vertexBlackType)
      (⟨4, T_str, T_emb, T_isInd, T_hsize⟩ : GenFlag CG2 vertexBlackType) := by
  classical
  -- φ values: 0↦3, 1↦0, 2↦1, 3↦2.
  -- Built as swap(0,1).trans(swap(1,3).trans(swap(1,2))).
  let φ : Fin 4 ≃ Fin 4 :=
    (Equiv.swap (⟨0, by decide⟩ : Fin 4) ⟨1, by decide⟩).trans
      ((Equiv.swap (⟨1, by decide⟩ : Fin 4) ⟨3, by decide⟩).trans
        (Equiv.swap (⟨1, by decide⟩ : Fin 4) ⟨2, by decide⟩))
  have hp0 : φ (⟨0, by decide⟩ : Fin 4) = (⟨3, by decide⟩ : Fin 4) := by
    change Equiv.swap (⟨1, by decide⟩ : Fin 4) ⟨2, by decide⟩
        (Equiv.swap (⟨1, by decide⟩ : Fin 4) ⟨3, by decide⟩
          (Equiv.swap (⟨0, by decide⟩ : Fin 4) ⟨1, by decide⟩ ⟨0, by decide⟩))
        = (⟨3, by decide⟩ : Fin 4)
    rw [Equiv.swap_apply_left,
        Equiv.swap_apply_left,
        Equiv.swap_apply_of_ne_of_ne
          (show (⟨3, by decide⟩ : Fin 4) ≠ ⟨1, by decide⟩ by decide)
          (show (⟨3, by decide⟩ : Fin 4) ≠ ⟨2, by decide⟩ by decide)]
  have hp1 : φ (⟨1, by decide⟩ : Fin 4) = (⟨0, by decide⟩ : Fin 4) := by
