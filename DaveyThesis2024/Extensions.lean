/-! ### σ₁-4-C scaffolding: BRRB constraints on size-5 thesisType1-flags

For an extension flag F of `thesisType1` (σ has K_{1,3} at v0=R with v1=B leaf),
the BRRB constraints (triangle-free, black-independent) plus extAdj-v1 force
the ext vertex w to:
- Have colour R (else BB-edge with v1=B σ-vertex).
- Not be adjacent to v0 (else triangle v0-v1-w via σ-edge v0-v1).

These extracted constraints are inputs to the 4-case classification in σ₁-4-C. -/

/-- BRRB + extAdj-v1 constraints on the ext vertex of a thesisType1-flag.
    Returns: w has colour 0 (R) AND w is not adjacent to G.embedding ⟨0,_⟩. -/
theorem t1_extAdj_v1_BRRB_w_R_not_adj_v0
    (G : GenFlag CG2 thesisType1) (h_size : G.size = 5)
    (h_ext : extAdjacency thesisType1 G ⟨1, by decide⟩)
    (h_no_BB : ¬∃ u v : Fin G.size,
      G.str.2 u = 1 ∧ G.str.2 v = 1 ∧ G.str.1.Adj u v)
    (h_no_tri : ¬∃ u v w : Fin G.size,
      G.str.1.Adj u v ∧ G.str.1.Adj v w ∧ G.str.1.Adj u w) :
    G.str.2 (extVertex G h_size) = 0 ∧
    ¬G.str.1.Adj (extVertex G h_size) (G.embedding ⟨0, by decide⟩) := by
  -- Extract w := extVertex G and its adjacency to v1.
  set w := extVertex G h_size with hw_def
  obtain ⟨v, hv_notin, hv_adj_v1⟩ := h_ext
  have hv_eq : v = w := extVertex_unique G h_size v hv_notin
  subst hv_eq
  -- σ-image vertices: G.embedding ⟨0,_⟩ = v0, G.embedding ⟨1,_⟩ = v1.
  set v0 := G.embedding ⟨0, by decide⟩ with hv0
  set v1 := G.embedding ⟨1, by decide⟩ with hv1
  -- v1 has σ-colour 1 (= B) by isInduced
  have hcol_v1 : G.str.2 v1 = 1 := by
    have h1 : (CG2.comap G.embedding G.str).2 ⟨1, by decide⟩ = thesisType1.str.2 ⟨1, by decide⟩ :=
      congr_fun (congr_arg Prod.snd G.isInduced) ⟨1, by decide⟩
    have h2 : G.str.2 (G.embedding ⟨1, by decide⟩) = thesisType1.str.2 ⟨1, by decide⟩ := h1
    rw [hv1, h2]; simp [thesisType1]
  -- v0 adj v1 in σ → v0 adj v1 in G (via isInduced)
  have hv0_adj_v1 : G.str.1.Adj v0 v1 := by
    have hcomap : (CG2.comap G.embedding G.str).1 = thesisType1.str.1 := by
      have := congr_arg Prod.fst G.isInduced; exact this
    have h_sigma : thesisType1.str.1.Adj ⟨0, by decide⟩ ⟨1, by decide⟩ := by
      simp [thesisType1, SimpleGraph.fromRel_adj]
    rw [← hcomap] at h_sigma; exact h_sigma
  -- Constraint 1: w has colour 0 (R)
  refine ⟨?_, ?_⟩
  · by_contra hwc
    -- w.col ≠ 0, so since col ∈ Fin 2, w.col = 1.
    have hwc1 : G.str.2 w = 1 := by
      have hlt : (G.str.2 w).val < 2 := (G.str.2 w).isLt
      interval_cases h : (G.str.2 w).val
      · exfalso; apply hwc; exact Fin.ext h
      · exact Fin.ext h
    apply h_no_BB
    refine ⟨w, v1, hwc1, hcol_v1, ?_⟩
    rw [hv1] at hv_adj_v1; exact hv_adj_v1
  · intro h_w_v0
    apply h_no_tri
    refine ⟨v0, v1, w, hv0_adj_v1, ?_, h_w_v0.symm⟩
    rw [hv1] at hv_adj_v1; exact hv_adj_v1.symm

/-! ### σ₁-4-C case 1: classification for w=R, w not adj v0/v2/v3

Given the BRRB constraints from `t1_extAdj_v1_BRRB_w_R_not_adj_v0` plus the
case 1 hypotheses (w not adjacent to v2 or v3), the σ-flag G is forced to
be σ-iso to `t1_v1_a` (K_{1,3} with extra v1-w edge). -/

set_option maxHeartbeats 1600000 in
-- Increased heartbeats: 25-case graph dispatch with simp [t1_v1_a] in each branch.
/-- Case 1 of σ₁-4-C: any size-5 thesisType1-flag G with extAdj-v1, w coloured
    R, and w not adjacent to v0, v2, v3 is σ-iso to the canonical witness
    `t1_v1_a` (the only adjacency of w is to v1, which is forced by extAdj-v1). -/
theorem t1_v1_a_classification (G : GenFlag CG2 thesisType1)
    (h_size : G.size = 5)
    (h_ext : extAdjacency thesisType1 G ⟨1, by decide⟩)
    (h_w_R : G.str.2 (extVertex G h_size) = 0)
    (h_no_v0 : ¬G.str.1.Adj (extVertex G h_size) (G.embedding ⟨0, by decide⟩))
    (h_no_v2 : ¬G.str.1.Adj (extVertex G h_size) (G.embedding ⟨2, by decide⟩))
    (h_no_v3 : ¬G.str.1.Adj (extVertex G h_size) (G.embedding ⟨3, by decide⟩)) :
    GenFlagIso thesisType1 G t1_v1_a := by
  classical
  set v0 := G.embedding ⟨0, by decide⟩ with hv0
  set v1 := G.embedding ⟨1, by decide⟩ with hv1
  set v2 := G.embedding ⟨2, by decide⟩ with hv2
  set v3 := G.embedding ⟨3, by decide⟩ with hv3
  set w := extVertex G h_size with hw
  have hv01 : v0 ≠ v1 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv02 : v0 ≠ v2 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv03 : v0 ≠ v3 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv12 : v1 ≠ v2 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv13 : v1 ≠ v3 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv23 : v2 ≠ v3 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hw_notin : w ∉ Set.range G.embedding := extVertex_notin_range G h_size
  have hwv0 : w ≠ v0 := fun h => hw_notin ⟨⟨0, by decide⟩, h.symm⟩
  have hwv1 : w ≠ v1 := fun h => hw_notin ⟨⟨1, by decide⟩, h.symm⟩
  have hwv2 : w ≠ v2 := fun h => hw_notin ⟨⟨2, by decide⟩, h.symm⟩
  have hwv3 : w ≠ v3 := fun h => hw_notin ⟨⟨3, by decide⟩, h.symm⟩
  have h_str_eq : (CG2.comap G.embedding G.str).1 = thesisType1.str.1 :=
    congr_arg Prod.fst G.isInduced
  have h_col_eq : ∀ j : Fin thesisType1.size,
      G.str.2 (G.embedding j) = thesisType1.str.2 j := fun j =>
    congr_fun (congr_arg Prod.snd G.isInduced) j
  have G_v0v1 : G.str.1.Adj v0 v1 := by
    have h_sigma : thesisType1.str.1.Adj ⟨0, by decide⟩ ⟨1, by decide⟩ := by
      simp [thesisType1, SimpleGraph.fromRel_adj]
    rw [← h_str_eq] at h_sigma; exact h_sigma
  have G_v0v2 : G.str.1.Adj v0 v2 := by
    have h_sigma : thesisType1.str.1.Adj ⟨0, by decide⟩ ⟨2, by decide⟩ := by
      simp [thesisType1, SimpleGraph.fromRel_adj]
    rw [← h_str_eq] at h_sigma; exact h_sigma
  have G_v0v3 : G.str.1.Adj v0 v3 := by
    have h_sigma : thesisType1.str.1.Adj ⟨0, by decide⟩ ⟨3, by decide⟩ := by
      simp [thesisType1, SimpleGraph.fromRel_adj]
    rw [← h_str_eq] at h_sigma; exact h_sigma
  have G_v1v2_no : ¬G.str.1.Adj v1 v2 := by
    intro h
    have h' : (CG2.comap G.embedding G.str).1.Adj ⟨1, by decide⟩ ⟨2, by decide⟩ := h
    rw [h_str_eq] at h'
    simp [thesisType1, SimpleGraph.fromRel_adj] at h'
  have G_v1v3_no : ¬G.str.1.Adj v1 v3 := by
    intro h
    have h' : (CG2.comap G.embedding G.str).1.Adj ⟨1, by decide⟩ ⟨3, by decide⟩ := h
    rw [h_str_eq] at h'
    simp [thesisType1, SimpleGraph.fromRel_adj] at h'
  have G_v2v3_no : ¬G.str.1.Adj v2 v3 := by
    intro h
    have h' : (CG2.comap G.embedding G.str).1.Adj ⟨2, by decide⟩ ⟨3, by decide⟩ := h
    rw [h_str_eq] at h'
    simp [thesisType1, SimpleGraph.fromRel_adj] at h'
  obtain ⟨v_ext, hv_ext_notin, hv_ext_adj⟩ := h_ext
  have hv_ext_eq : v_ext = w := extVertex_unique G h_size v_ext hv_ext_notin
  subst hv_ext_eq
  have G_wv1 : G.str.1.Adj w v1 := by rw [hv1]; exact hv_ext_adj
  have hcol_v0 : G.str.2 v0 = 0 := by rw [hv0, h_col_eq]; simp [thesisType1]
  have hcol_v1 : G.str.2 v1 = 1 := by rw [hv1, h_col_eq]; simp [thesisType1]
  have hcol_v2 : G.str.2 v2 = 0 := by rw [hv2, h_col_eq]; simp [thesisType1]
  have hcol_v3 : G.str.2 v3 = 0 := by rw [hv3, h_col_eq]; simp [thesisType1]
  -- Define φ : Fin G.size ≃ Fin 5 mapping vᵢ ↦ ⟨i,_⟩, w ↦ ⟨4,_⟩
  let φ_fn : Fin G.size → Fin 5 := fun x =>
    if x = v0 then ⟨0, by decide⟩
    else if x = v1 then ⟨1, by decide⟩
    else if x = v2 then ⟨2, by decide⟩
    else if x = v3 then ⟨3, by decide⟩
    else ⟨4, by decide⟩
  have φv0 : φ_fn v0 = ⟨0, by decide⟩ := by simp [φ_fn]
  have φv1 : φ_fn v1 = ⟨1, by decide⟩ := by
    simp only [φ_fn]; rw [if_neg hv01.symm]; simp
  have φv2 : φ_fn v2 = ⟨2, by decide⟩ := by
    simp only [φ_fn]; rw [if_neg hv02.symm, if_neg hv12.symm]; simp
  have φv3 : φ_fn v3 = ⟨3, by decide⟩ := by
    simp only [φ_fn]
    rw [if_neg hv03.symm, if_neg hv13.symm, if_neg hv23.symm]; simp
  have φw : φ_fn w = ⟨4, by decide⟩ := by
    simp only [φ_fn]
    rw [if_neg hwv0, if_neg hwv1, if_neg hwv2, if_neg hwv3]
  have x_cases : ∀ x : Fin G.size, x = v0 ∨ x = v1 ∨ x = v2 ∨ x = v3 ∨ x = w := by
    intro x
    by_cases h0 : x = v0
    · exact Or.inl h0
    by_cases h1 : x = v1
    · exact Or.inr (Or.inl h1)
    by_cases h2 : x = v2
    · exact Or.inr (Or.inr (Or.inl h2))
    by_cases h3 : x = v3
    · exact Or.inr (Or.inr (Or.inr (Or.inl h3)))
    right; right; right; right
    apply extVertex_unique G h_size
    rintro ⟨⟨j, hj⟩, hj_eq⟩
    have hjlt : j < 4 := hj
    have hsize : thesisType1.size = 4 := rfl
    interval_cases j
    · exact h0 hj_eq.symm
    · exact h1 hj_eq.symm
    · exact h2 hj_eq.symm
    · exact h3 hj_eq.symm
  have φ_inj : Function.Injective φ_fn := by
    intro x y hxy
    rcases x_cases x with hx | hx | hx | hx | hx <;>
    rcases x_cases y with hy | hy | hy | hy | hy <;>
      subst hx <;> subst hy <;>
      first
      | rfl
      | (exfalso
         try rw [φv0] at hxy
         try rw [φv1] at hxy
         try rw [φv2] at hxy
         try rw [φv3] at hxy
         try rw [φw] at hxy
         exact absurd hxy (by decide))
  have hcard : Fintype.card (Fin G.size) = Fintype.card (Fin 5) := by
    rw [Fintype.card_fin, Fintype.card_fin, h_size]
  have φ_bij : Function.Bijective φ_fn :=
    (Fintype.bijective_iff_injective_and_card φ_fn).mpr ⟨φ_inj, hcard⟩
  let φ : Fin G.size ≃ Fin t1_v1_a.size := Equiv.ofBijective φ_fn φ_bij
  have hφv0 : φ v0 = ⟨0, by decide⟩ := φv0
  have hφv1 : φ v1 = ⟨1, by decide⟩ := φv1
  have hφv2 : φ v2 = ⟨2, by decide⟩ := φv2
  have hφv3 : φ v3 = ⟨3, by decide⟩ := φv3
  have hφw : φ w = ⟨4, by decide⟩ := φw
  refine ⟨φ, ?_, ?_⟩
  · -- Structure equality: CG2.comap φ t1_v1_a.str = G.str
    apply Prod.ext
    · -- Graph component
      ext u v
      change (t1_v1_a.str.1.comap (φ : Fin G.size → Fin 5)).Adj u v ↔ G.str.1.Adj u v
      simp only [SimpleGraph.comap_adj]
      rcases x_cases u with hu | hu | hu | hu | hu <;>
      rcases x_cases v with hv | hv | hv | hv | hv <;>
        rw [hu, hv]
      -- 25 goals, dispatched by edge type:
      -- (v0, v0): self-loop
      · rw [hφv0]; constructor
        · intro h; simp [t1_v1_a] at h
        · intro h; exact (G.str.1.irrefl h).elim
      -- (v0, v1): edge
      · rw [hφv0, hφv1]; constructor
        · intro _; exact G_v0v1
        · intro _; simp [t1_v1_a, SimpleGraph.fromRel_adj]
      -- (v0, v2): edge
      · rw [hφv0, hφv2]; constructor
        · intro _; exact G_v0v2
        · intro _; simp [t1_v1_a, SimpleGraph.fromRel_adj]
      -- (v0, v3): edge
      · rw [hφv0, hφv3]; constructor
        · intro _; exact G_v0v3
        · intro _; simp [t1_v1_a, SimpleGraph.fromRel_adj]
      -- (v0, w): non-edge (h_no_v0.symm)
      · rw [hφv0, hφw]; constructor
        · intro h; simp [t1_v1_a] at h
        · intro h; exact (h_no_v0 h.symm).elim
      -- (v1, v0): edge
      · rw [hφv1, hφv0]; constructor
        · intro _; exact G_v0v1.symm
        · intro _; simp [t1_v1_a, SimpleGraph.fromRel_adj]
      -- (v1, v1): self-loop
      · rw [hφv1]; constructor
        · intro h; simp [t1_v1_a] at h
        · intro h; exact (G.str.1.irrefl h).elim
      -- (v1, v2): non-edge
      · rw [hφv1, hφv2]; constructor
        · intro h; simp [t1_v1_a] at h
        · intro h; exact (G_v1v2_no h).elim
      -- (v1, v3): non-edge
      · rw [hφv1, hφv3]; constructor
        · intro h; simp [t1_v1_a] at h
        · intro h; exact (G_v1v3_no h).elim
      -- (v1, w): edge
      · rw [hφv1, hφw]; constructor
        · intro _; exact G_wv1.symm
        · intro _; simp [t1_v1_a, SimpleGraph.fromRel_adj]
      -- (v2, v0): edge
      · rw [hφv2, hφv0]; constructor
        · intro _; exact G_v0v2.symm
        · intro _; simp [t1_v1_a, SimpleGraph.fromRel_adj]
      -- (v2, v1): non-edge
      · rw [hφv2, hφv1]; constructor
        · intro h; simp [t1_v1_a] at h
        · intro h; exact (G_v1v2_no h.symm).elim
      -- (v2, v2): self-loop
      · rw [hφv2]; constructor
        · intro h; simp [t1_v1_a] at h
        · intro h; exact (G.str.1.irrefl h).elim
      -- (v2, v3): non-edge
      · rw [hφv2, hφv3]; constructor
        · intro h; simp [t1_v1_a] at h
        · intro h; exact (G_v2v3_no h).elim
      -- (v2, w): non-edge (h_no_v2.symm)
      · rw [hφv2, hφw]; constructor
        · intro h; simp [t1_v1_a] at h
        · intro h; exact (h_no_v2 h.symm).elim
      -- (v3, v0): edge
      · rw [hφv3, hφv0]; constructor
        · intro _; exact G_v0v3.symm
        · intro _; simp [t1_v1_a, SimpleGraph.fromRel_adj]
      -- (v3, v1): non-edge
      · rw [hφv3, hφv1]; constructor
        · intro h; simp [t1_v1_a] at h
        · intro h; exact (G_v1v3_no h.symm).elim
      -- (v3, v2): non-edge
      · rw [hφv3, hφv2]; constructor
        · intro h; simp [t1_v1_a] at h
        · intro h; exact (G_v2v3_no h.symm).elim
      -- (v3, v3): self-loop
      · rw [hφv3]; constructor
        · intro h; simp [t1_v1_a] at h
        · intro h; exact (G.str.1.irrefl h).elim
      -- (v3, w): non-edge (h_no_v3.symm)
      · rw [hφv3, hφw]; constructor
        · intro h; simp [t1_v1_a] at h
        · intro h; exact (h_no_v3 h.symm).elim
      -- (w, v0): non-edge
      · rw [hφw, hφv0]; constructor
        · intro h; simp [t1_v1_a] at h
        · intro h; exact (h_no_v0 h).elim
      -- (w, v1): edge
      · rw [hφw, hφv1]; constructor
        · intro _; exact G_wv1
        · intro _; simp [t1_v1_a, SimpleGraph.fromRel_adj]
      -- (w, v2): non-edge
      · rw [hφw, hφv2]; constructor
        · intro h; simp [t1_v1_a] at h
        · intro h; exact (h_no_v2 h).elim
      -- (w, v3): non-edge
      · rw [hφw, hφv3]; constructor
        · intro h; simp [t1_v1_a] at h
        · intro h; exact (h_no_v3 h).elim
      -- (w, w): self-loop
      · rw [hφw]; constructor
        · intro h; simp [t1_v1_a] at h
        · intro h; exact (G.str.1.irrefl h).elim
    · -- Colour component
      funext x
      change t1_v1_a.str.2 (φ x) = G.str.2 x
      rcases x_cases x with hx | hx | hx | hx | hx <;> rw [hx]
      · rw [hφv0, hcol_v0]; rfl
      · rw [hφv1, hcol_v1]; rfl
      · rw [hφv2, hcol_v2]; rfl
      · rw [hφv3, hcol_v3]; rfl
      · rw [hφw, h_w_R]; rfl
  · -- σ-compatibility: φ ∘ G.embedding = t1_v1_a.embedding
    intro i
    fin_cases i
    · change φ (G.embedding ⟨0, _⟩) = t1_v1_a.embedding ⟨0, _⟩
      rw [← hv0]; rw [hφv0]; rfl
    · change φ (G.embedding ⟨1, _⟩) = t1_v1_a.embedding ⟨1, _⟩
      rw [← hv1]; rw [hφv1]; rfl
    · change φ (G.embedding ⟨2, _⟩) = t1_v1_a.embedding ⟨2, _⟩
      rw [← hv2]; rw [hφv2]; rfl
    · change φ (G.embedding ⟨3, _⟩) = t1_v1_a.embedding ⟨3, _⟩
      rw [← hv3]; rw [hφv3]; rfl

set_option maxHeartbeats 1600000 in
-- Increased heartbeats: 25-case graph dispatch with simp [t1_v1_b] in each branch.
/-- Case 2 of σ₁-4-C: any size-5 thesisType1-flag G with extAdj-v1, w coloured
    R, w not adjacent to v0/v3, and w adjacent to v2 is σ-iso to the canonical
    witness `t1_v1_b` (adjacencies of w are to v1 and v2). -/
theorem t1_v1_b_classification (G : GenFlag CG2 thesisType1)
    (h_size : G.size = 5)
    (h_ext : extAdjacency thesisType1 G ⟨1, by decide⟩)
    (h_w_R : G.str.2 (extVertex G h_size) = 0)
    (h_no_v0 : ¬G.str.1.Adj (extVertex G h_size) (G.embedding ⟨0, by decide⟩))
    (h_v2 : G.str.1.Adj (extVertex G h_size) (G.embedding ⟨2, by decide⟩))
    (h_no_v3 : ¬G.str.1.Adj (extVertex G h_size) (G.embedding ⟨3, by decide⟩)) :
    GenFlagIso thesisType1 G t1_v1_b := by
  classical
  set v0 := G.embedding ⟨0, by decide⟩ with hv0
  set v1 := G.embedding ⟨1, by decide⟩ with hv1
  set v2 := G.embedding ⟨2, by decide⟩ with hv2
  set v3 := G.embedding ⟨3, by decide⟩ with hv3
  set w := extVertex G h_size with hw
  have hv01 : v0 ≠ v1 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv02 : v0 ≠ v2 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv03 : v0 ≠ v3 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv12 : v1 ≠ v2 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv13 : v1 ≠ v3 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv23 : v2 ≠ v3 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hw_notin : w ∉ Set.range G.embedding := extVertex_notin_range G h_size
  have hwv0 : w ≠ v0 := fun h => hw_notin ⟨⟨0, by decide⟩, h.symm⟩
  have hwv1 : w ≠ v1 := fun h => hw_notin ⟨⟨1, by decide⟩, h.symm⟩
  have hwv2 : w ≠ v2 := fun h => hw_notin ⟨⟨2, by decide⟩, h.symm⟩
  have hwv3 : w ≠ v3 := fun h => hw_notin ⟨⟨3, by decide⟩, h.symm⟩
  have h_str_eq : (CG2.comap G.embedding G.str).1 = thesisType1.str.1 :=
    congr_arg Prod.fst G.isInduced
  have h_col_eq : ∀ j : Fin thesisType1.size,
      G.str.2 (G.embedding j) = thesisType1.str.2 j := fun j =>
    congr_fun (congr_arg Prod.snd G.isInduced) j
  have G_v0v1 : G.str.1.Adj v0 v1 := by
    have h_sigma : thesisType1.str.1.Adj ⟨0, by decide⟩ ⟨1, by decide⟩ := by
      simp [thesisType1, SimpleGraph.fromRel_adj]
    rw [← h_str_eq] at h_sigma; exact h_sigma
  have G_v0v2 : G.str.1.Adj v0 v2 := by
    have h_sigma : thesisType1.str.1.Adj ⟨0, by decide⟩ ⟨2, by decide⟩ := by
      simp [thesisType1, SimpleGraph.fromRel_adj]
    rw [← h_str_eq] at h_sigma; exact h_sigma
  have G_v0v3 : G.str.1.Adj v0 v3 := by
    have h_sigma : thesisType1.str.1.Adj ⟨0, by decide⟩ ⟨3, by decide⟩ := by
      simp [thesisType1, SimpleGraph.fromRel_adj]
    rw [← h_str_eq] at h_sigma; exact h_sigma
  have G_v1v2_no : ¬G.str.1.Adj v1 v2 := by
    intro h
    have h' : (CG2.comap G.embedding G.str).1.Adj ⟨1, by decide⟩ ⟨2, by decide⟩ := h
    rw [h_str_eq] at h'
    simp [thesisType1, SimpleGraph.fromRel_adj] at h'
  have G_v1v3_no : ¬G.str.1.Adj v1 v3 := by
    intro h
    have h' : (CG2.comap G.embedding G.str).1.Adj ⟨1, by decide⟩ ⟨3, by decide⟩ := h
    rw [h_str_eq] at h'
    simp [thesisType1, SimpleGraph.fromRel_adj] at h'
  have G_v2v3_no : ¬G.str.1.Adj v2 v3 := by
    intro h
    have h' : (CG2.comap G.embedding G.str).1.Adj ⟨2, by decide⟩ ⟨3, by decide⟩ := h
    rw [h_str_eq] at h'
    simp [thesisType1, SimpleGraph.fromRel_adj] at h'
  obtain ⟨v_ext, hv_ext_notin, hv_ext_adj⟩ := h_ext
  have hv_ext_eq : v_ext = w := extVertex_unique G h_size v_ext hv_ext_notin
  subst hv_ext_eq
  have G_wv1 : G.str.1.Adj w v1 := by rw [hv1]; exact hv_ext_adj
  have G_wv2 : G.str.1.Adj w v2 := by rw [hv2]; exact h_v2
  have hcol_v0 : G.str.2 v0 = 0 := by rw [hv0, h_col_eq]; simp [thesisType1]
  have hcol_v1 : G.str.2 v1 = 1 := by rw [hv1, h_col_eq]; simp [thesisType1]
  have hcol_v2 : G.str.2 v2 = 0 := by rw [hv2, h_col_eq]; simp [thesisType1]
  have hcol_v3 : G.str.2 v3 = 0 := by rw [hv3, h_col_eq]; simp [thesisType1]
  -- Define φ : Fin G.size ≃ Fin 5 mapping vᵢ ↦ ⟨i,_⟩, w ↦ ⟨4,_⟩
  let φ_fn : Fin G.size → Fin 5 := fun x =>
    if x = v0 then ⟨0, by decide⟩
    else if x = v1 then ⟨1, by decide⟩
    else if x = v2 then ⟨2, by decide⟩
    else if x = v3 then ⟨3, by decide⟩
    else ⟨4, by decide⟩
  have φv0 : φ_fn v0 = ⟨0, by decide⟩ := by simp [φ_fn]
  have φv1 : φ_fn v1 = ⟨1, by decide⟩ := by
    simp only [φ_fn]; rw [if_neg hv01.symm]; simp
  have φv2 : φ_fn v2 = ⟨2, by decide⟩ := by
    simp only [φ_fn]; rw [if_neg hv02.symm, if_neg hv12.symm]; simp
  have φv3 : φ_fn v3 = ⟨3, by decide⟩ := by
    simp only [φ_fn]
    rw [if_neg hv03.symm, if_neg hv13.symm, if_neg hv23.symm]; simp
  have φw : φ_fn w = ⟨4, by decide⟩ := by
    simp only [φ_fn]
    rw [if_neg hwv0, if_neg hwv1, if_neg hwv2, if_neg hwv3]
  have x_cases : ∀ x : Fin G.size, x = v0 ∨ x = v1 ∨ x = v2 ∨ x = v3 ∨ x = w := by
    intro x
    by_cases h0 : x = v0
    · exact Or.inl h0
    by_cases h1 : x = v1
    · exact Or.inr (Or.inl h1)
    by_cases h2 : x = v2
    · exact Or.inr (Or.inr (Or.inl h2))
    by_cases h3 : x = v3
    · exact Or.inr (Or.inr (Or.inr (Or.inl h3)))
    right; right; right; right
    apply extVertex_unique G h_size
    rintro ⟨⟨j, hj⟩, hj_eq⟩
    have hjlt : j < 4 := hj
    have hsize : thesisType1.size = 4 := rfl
    interval_cases j
    · exact h0 hj_eq.symm
    · exact h1 hj_eq.symm
    · exact h2 hj_eq.symm
    · exact h3 hj_eq.symm
  have φ_inj : Function.Injective φ_fn := by
    intro x y hxy
    rcases x_cases x with hx | hx | hx | hx | hx <;>
    rcases x_cases y with hy | hy | hy | hy | hy <;>
      subst hx <;> subst hy <;>
      first
      | rfl
      | (exfalso
         try rw [φv0] at hxy
         try rw [φv1] at hxy
         try rw [φv2] at hxy
         try rw [φv3] at hxy
         try rw [φw] at hxy
         exact absurd hxy (by decide))
  have hcard : Fintype.card (Fin G.size) = Fintype.card (Fin 5) := by
    rw [Fintype.card_fin, Fintype.card_fin, h_size]
  have φ_bij : Function.Bijective φ_fn :=
    (Fintype.bijective_iff_injective_and_card φ_fn).mpr ⟨φ_inj, hcard⟩
  let φ : Fin G.size ≃ Fin t1_v1_b.size := Equiv.ofBijective φ_fn φ_bij
  have hφv0 : φ v0 = ⟨0, by decide⟩ := φv0
  have hφv1 : φ v1 = ⟨1, by decide⟩ := φv1
  have hφv2 : φ v2 = ⟨2, by decide⟩ := φv2
  have hφv3 : φ v3 = ⟨3, by decide⟩ := φv3
  have hφw : φ w = ⟨4, by decide⟩ := φw
  refine ⟨φ, ?_, ?_⟩
  · -- Structure equality: CG2.comap φ t1_v1_b.str = G.str
    apply Prod.ext
    · -- Graph component
      ext u v
      change (t1_v1_b.str.1.comap (φ : Fin G.size → Fin 5)).Adj u v ↔ G.str.1.Adj u v
      simp only [SimpleGraph.comap_adj]
      rcases x_cases u with hu | hu | hu | hu | hu <;>
      rcases x_cases v with hv | hv | hv | hv | hv <;>
        rw [hu, hv]
      -- 25 goals, dispatched by edge type:
      -- (v0, v0): self-loop
      · rw [hφv0]; constructor
        · intro h; simp [t1_v1_b] at h
        · intro h; exact (G.str.1.irrefl h).elim
      -- (v0, v1): edge
      · rw [hφv0, hφv1]; constructor
        · intro _; exact G_v0v1
        · intro _; simp [t1_v1_b, SimpleGraph.fromRel_adj]
      -- (v0, v2): edge
      · rw [hφv0, hφv2]; constructor
        · intro _; exact G_v0v2
        · intro _; simp [t1_v1_b, SimpleGraph.fromRel_adj]
      -- (v0, v3): edge
      · rw [hφv0, hφv3]; constructor
        · intro _; exact G_v0v3
        · intro _; simp [t1_v1_b, SimpleGraph.fromRel_adj]
      -- (v0, w): non-edge (h_no_v0.symm)
      · rw [hφv0, hφw]; constructor
        · intro h; simp [t1_v1_b] at h
        · intro h; exact (h_no_v0 h.symm).elim
      -- (v1, v0): edge
      · rw [hφv1, hφv0]; constructor
        · intro _; exact G_v0v1.symm
        · intro _; simp [t1_v1_b, SimpleGraph.fromRel_adj]
      -- (v1, v1): self-loop
      · rw [hφv1]; constructor
        · intro h; simp [t1_v1_b] at h
        · intro h; exact (G.str.1.irrefl h).elim
      -- (v1, v2): non-edge
      · rw [hφv1, hφv2]; constructor
        · intro h; simp [t1_v1_b] at h
        · intro h; exact (G_v1v2_no h).elim
      -- (v1, v3): non-edge
      · rw [hφv1, hφv3]; constructor
        · intro h; simp [t1_v1_b] at h
        · intro h; exact (G_v1v3_no h).elim
      -- (v1, w): edge
      · rw [hφv1, hφw]; constructor
        · intro _; exact G_wv1.symm
        · intro _; simp [t1_v1_b, SimpleGraph.fromRel_adj]
      -- (v2, v0): edge
      · rw [hφv2, hφv0]; constructor
        · intro _; exact G_v0v2.symm
        · intro _; simp [t1_v1_b, SimpleGraph.fromRel_adj]
      -- (v2, v1): non-edge
      · rw [hφv2, hφv1]; constructor
        · intro h; simp [t1_v1_b] at h
        · intro h; exact (G_v1v2_no h.symm).elim
      -- (v2, v2): self-loop
      · rw [hφv2]; constructor
        · intro h; simp [t1_v1_b] at h
        · intro h; exact (G.str.1.irrefl h).elim
      -- (v2, v3): non-edge
      · rw [hφv2, hφv3]; constructor
        · intro h; simp [t1_v1_b] at h
        · intro h; exact (G_v2v3_no h).elim
      -- (v2, w): edge (case 2: w adj v2)
      · rw [hφv2, hφw]; constructor
        · intro _; exact G_wv2.symm
        · intro _; simp [t1_v1_b, SimpleGraph.fromRel_adj]
      -- (v3, v0): edge
      · rw [hφv3, hφv0]; constructor
        · intro _; exact G_v0v3.symm
        · intro _; simp [t1_v1_b, SimpleGraph.fromRel_adj]
      -- (v3, v1): non-edge
      · rw [hφv3, hφv1]; constructor
        · intro h; simp [t1_v1_b] at h
        · intro h; exact (G_v1v3_no h.symm).elim
      -- (v3, v2): non-edge
      · rw [hφv3, hφv2]; constructor
        · intro h; simp [t1_v1_b] at h
        · intro h; exact (G_v2v3_no h.symm).elim
      -- (v3, v3): self-loop
      · rw [hφv3]; constructor
        · intro h; simp [t1_v1_b] at h
        · intro h; exact (G.str.1.irrefl h).elim
      -- (v3, w): non-edge (h_no_v3.symm)
      · rw [hφv3, hφw]; constructor
        · intro h; simp [t1_v1_b] at h
        · intro h; exact (h_no_v3 h.symm).elim
      -- (w, v0): non-edge
      · rw [hφw, hφv0]; constructor
        · intro h; simp [t1_v1_b] at h
        · intro h; exact (h_no_v0 h).elim
      -- (w, v1): edge
      · rw [hφw, hφv1]; constructor
        · intro _; exact G_wv1
        · intro _; simp [t1_v1_b, SimpleGraph.fromRel_adj]
      -- (w, v2): edge (case 2: w adj v2)
      · rw [hφw, hφv2]; constructor
        · intro _; exact G_wv2
        · intro _; simp [t1_v1_b, SimpleGraph.fromRel_adj]
      -- (w, v3): non-edge
      · rw [hφw, hφv3]; constructor
        · intro h; simp [t1_v1_b] at h
        · intro h; exact (h_no_v3 h).elim
      -- (w, w): self-loop
      · rw [hφw]; constructor
        · intro h; simp [t1_v1_b] at h
        · intro h; exact (G.str.1.irrefl h).elim
    · -- Colour component
      funext x
      change t1_v1_b.str.2 (φ x) = G.str.2 x
      rcases x_cases x with hx | hx | hx | hx | hx <;> rw [hx]
      · rw [hφv0, hcol_v0]; rfl
      · rw [hφv1, hcol_v1]; rfl
      · rw [hφv2, hcol_v2]; rfl
      · rw [hφv3, hcol_v3]; rfl
      · rw [hφw, h_w_R]; rfl
  · -- σ-compatibility: φ ∘ G.embedding = t1_v1_b.embedding
    intro i
    fin_cases i
    · change φ (G.embedding ⟨0, _⟩) = t1_v1_b.embedding ⟨0, _⟩
      rw [← hv0]; rw [hφv0]; rfl
    · change φ (G.embedding ⟨1, _⟩) = t1_v1_b.embedding ⟨1, _⟩
      rw [← hv1]; rw [hφv1]; rfl
    · change φ (G.embedding ⟨2, _⟩) = t1_v1_b.embedding ⟨2, _⟩
      rw [← hv2]; rw [hφv2]; rfl
    · change φ (G.embedding ⟨3, _⟩) = t1_v1_b.embedding ⟨3, _⟩
      rw [← hv3]; rw [hφv3]; rfl

set_option maxHeartbeats 1600000 in
-- Increased heartbeats: 25-case graph dispatch with simp [t1_v1_c] in each branch.
/-- Case 3 of σ₁-4-C: any size-5 thesisType1-flag G with extAdj-v1, w coloured
    R, w not adjacent to v0/v2, and w adjacent to v3 is σ-iso to the canonical
    witness `t1_v1_c` (adjacencies of w are to v1 and v3). -/
theorem t1_v1_c_classification (G : GenFlag CG2 thesisType1)
    (h_size : G.size = 5)
    (h_ext : extAdjacency thesisType1 G ⟨1, by decide⟩)
    (h_w_R : G.str.2 (extVertex G h_size) = 0)
    (h_no_v0 : ¬G.str.1.Adj (extVertex G h_size) (G.embedding ⟨0, by decide⟩))
    (h_no_v2 : ¬G.str.1.Adj (extVertex G h_size) (G.embedding ⟨2, by decide⟩))
    (h_v3 : G.str.1.Adj (extVertex G h_size) (G.embedding ⟨3, by decide⟩)) :
    GenFlagIso thesisType1 G t1_v1_c := by
  classical
  set v0 := G.embedding ⟨0, by decide⟩ with hv0
  set v1 := G.embedding ⟨1, by decide⟩ with hv1
  set v2 := G.embedding ⟨2, by decide⟩ with hv2
  set v3 := G.embedding ⟨3, by decide⟩ with hv3
  set w := extVertex G h_size with hw
  have hv01 : v0 ≠ v1 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv02 : v0 ≠ v2 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv03 : v0 ≠ v3 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv12 : v1 ≠ v2 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv13 : v1 ≠ v3 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hv23 : v2 ≠ v3 := fun h => by
    have := G.embedding.injective h; simp [Fin.ext_iff] at this
  have hw_notin : w ∉ Set.range G.embedding := extVertex_notin_range G h_size
  have hwv0 : w ≠ v0 := fun h => hw_notin ⟨⟨0, by decide⟩, h.symm⟩
  have hwv1 : w ≠ v1 := fun h => hw_notin ⟨⟨1, by decide⟩, h.symm⟩
  have hwv2 : w ≠ v2 := fun h => hw_notin ⟨⟨2, by decide⟩, h.symm⟩
  have hwv3 : w ≠ v3 := fun h => hw_notin ⟨⟨3, by decide⟩, h.symm⟩
  have h_str_eq : (CG2.comap G.embedding G.str).1 = thesisType1.str.1 :=
    congr_arg Prod.fst G.isInduced
  have h_col_eq : ∀ j : Fin thesisType1.size,
      G.str.2 (G.embedding j) = thesisType1.str.2 j := fun j =>
    congr_fun (congr_arg Prod.snd G.isInduced) j
  have G_v0v1 : G.str.1.Adj v0 v1 := by
    have h_sigma : thesisType1.str.1.Adj ⟨0, by decide⟩ ⟨1, by decide⟩ := by
      simp [thesisType1, SimpleGraph.fromRel_adj]
    rw [← h_str_eq] at h_sigma; exact h_sigma
  have G_v0v2 : G.str.1.Adj v0 v2 := by
    have h_sigma : thesisType1.str.1.Adj ⟨0, by decide⟩ ⟨2, by decide⟩ := by
      simp [thesisType1, SimpleGraph.fromRel_adj]
    rw [← h_str_eq] at h_sigma; exact h_sigma
  have G_v0v3 : G.str.1.Adj v0 v3 := by
    have h_sigma : thesisType1.str.1.Adj ⟨0, by decide⟩ ⟨3, by decide⟩ := by
      simp [thesisType1, SimpleGraph.fromRel_adj]
    rw [← h_str_eq] at h_sigma; exact h_sigma
  have G_v1v2_no : ¬G.str.1.Adj v1 v2 := by
    intro h
    have h' : (CG2.comap G.embedding G.str).1.Adj ⟨1, by decide⟩ ⟨2, by decide⟩ := h
    rw [h_str_eq] at h'
    simp [thesisType1, SimpleGraph.fromRel_adj] at h'
  have G_v1v3_no : ¬G.str.1.Adj v1 v3 := by
    intro h
    have h' : (CG2.comap G.embedding G.str).1.Adj ⟨1, by decide⟩ ⟨3, by decide⟩ := h
    rw [h_str_eq] at h'
    simp [thesisType1, SimpleGraph.fromRel_adj] at h'
  have G_v2v3_no : ¬G.str.1.Adj v2 v3 := by
    intro h
    have h' : (CG2.comap G.embedding G.str).1.Adj ⟨2, by decide⟩ ⟨3, by decide⟩ := h
    rw [h_str_eq] at h'
    simp [thesisType1, SimpleGraph.fromRel_adj] at h'
  obtain ⟨v_ext, hv_ext_notin, hv_ext_adj⟩ := h_ext
  have hv_ext_eq : v_ext = w := extVertex_unique G h_size v_ext hv_ext_notin
  subst hv_ext_eq
  have G_wv1 : G.str.1.Adj w v1 := by rw [hv1]; exact hv_ext_adj
  have G_wv3 : G.str.1.Adj w v3 := by rw [hv3]; exact h_v3
  have hcol_v0 : G.str.2 v0 = 0 := by rw [hv0, h_col_eq]; simp [thesisType1]
  have hcol_v1 : G.str.2 v1 = 1 := by rw [hv1, h_col_eq]; simp [thesisType1]
  have hcol_v2 : G.str.2 v2 = 0 := by rw [hv2, h_col_eq]; simp [thesisType1]
  have hcol_v3 : G.str.2 v3 = 0 := by rw [hv3, h_col_eq]; simp [thesisType1]
  -- Define φ : Fin G.size ≃ Fin 5 mapping vᵢ ↦ ⟨i,_⟩, w ↦ ⟨4,_⟩
  let φ_fn : Fin G.size → Fin 5 := fun x =>
    if x = v0 then ⟨0, by decide⟩
    else if x = v1 then ⟨1, by decide⟩
    else if x = v2 then ⟨2, by decide⟩
    else if x = v3 then ⟨3, by decide⟩
    else ⟨4, by decide⟩
  have φv0 : φ_fn v0 = ⟨0, by decide⟩ := by simp [φ_fn]
  have φv1 : φ_fn v1 = ⟨1, by decide⟩ := by
    simp only [φ_fn]; rw [if_neg hv01.symm]; simp
  have φv2 : φ_fn v2 = ⟨2, by decide⟩ := by
    simp only [φ_fn]; rw [if_neg hv02.symm, if_neg hv12.symm]; simp
  have φv3 : φ_fn v3 = ⟨3, by decide⟩ := by
    simp only [φ_fn]
    rw [if_neg hv03.symm, if_neg hv13.symm, if_neg hv23.symm]; simp
  have φw : φ_fn w = ⟨4, by decide⟩ := by
    simp only [φ_fn]
    rw [if_neg hwv0, if_neg hwv1, if_neg hwv2, if_neg hwv3]
