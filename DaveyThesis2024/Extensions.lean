/-! ### Pairwise non-isomorphism of size-3 σ-flag classes

The 6 size-3 σ-flag classes vbExt2_RB_indep, vbExt2_RB_edge, vbExt2_RR_indep,
vbExt2_RR_edge, vbExt2_BB_indep, vbExt2_BB_edge are pairwise non-isomorphic.
Distinguishing invariants:
- Number of black (colour=1) vertices: RB has 2, RR has 1, BB has 3.
- Edge count: indep variants have 2 edges, edge variants have 3.

These give 6 choose 2 = 15 non-iso pairs.
-/

/-- σ-compat for any iso between vbExt2 flags forces φ ⟨0,_⟩ = ⟨0,_⟩. -/
private lemma vbExt2_iso_phi_zero {F F' : GenFlag CG2 vertexBlackType}
    (hF_size : F.size = 3) (hF'_size : F'.size = 3)
    (hF_emb_zero : F.embedding (⟨0, Nat.zero_lt_one⟩ : Fin 1) =
      (⟨0, hF_size ▸ by decide⟩ : Fin F.size))
    (hF'_emb_zero : F'.embedding (⟨0, Nat.zero_lt_one⟩ : Fin 1) =
      (⟨0, hF'_size ▸ by decide⟩ : Fin F'.size))
    (φ : Fin F.size ≃ Fin F'.size)
    (hcompat : ∀ i : Fin vertexBlackType.size, φ (F.embedding i) = F'.embedding i) :
    φ (⟨0, hF_size ▸ by decide⟩ : Fin F.size) =
      (⟨0, hF'_size ▸ by decide⟩ : Fin F'.size) := by
  have h := hcompat (⟨0, Nat.zero_lt_one⟩ : Fin 1)
  rw [hF_emb_zero, hF'_emb_zero] at h
  exact h

/-- Colour preservation: an iso F ≃ F' gives F'.str.2 (φ v) = F.str.2 v. -/
private lemma vbExt2_iso_colour_pres {F F' : GenFlag CG2 vertexBlackType}
    (φ : Fin F.size ≃ Fin F'.size)
    (hstr : CG2.comap (⇑φ) F'.str = F.str)
    (v : Fin F.size) : F'.str.2 (φ v) = F.str.2 v := by
  -- (CG2.comap φ F'.str).2 v = F.str.2 v from hstr; LHS = F'.str.2 (φ v).
  exact congr_arg (fun s : CG2.Str F.size => s.2 v) hstr

/-- Adjacency preservation: an iso F ≃ F' gives F'.str.1.Adj (φ u) (φ v) ↔
    F.str.1.Adj u v. -/
private lemma vbExt2_iso_adj_pres {F F' : GenFlag CG2 vertexBlackType}
    (φ : Fin F.size ≃ Fin F'.size)
    (hstr : CG2.comap (⇑φ) F'.str = F.str)
    (u v : Fin F.size) : F'.str.1.Adj (φ u) (φ v) ↔ F.str.1.Adj u v := by
  exact Iff.of_eq (congr_arg (fun s : CG2.Str F.size => s.1.Adj u v) hstr)

/-- For any iso F ≃ F', the colour-c vertex sets have equal cardinality. -/
private lemma vbExt2_iso_colourCount_eq {F F' : GenFlag CG2 vertexBlackType}
    (h : GenFlagIso vertexBlackType F F') (c : Fin 2) :
    Fintype.card { v : Fin F.size // F.str.2 v = c } =
    Fintype.card { v : Fin F'.size // F'.str.2 v = c } := by
  obtain ⟨φ, hstr, _⟩ := h
  apply Fintype.card_congr
  refine {
    toFun := fun ⟨v, hv⟩ => ⟨φ v, ?_⟩
    invFun := fun ⟨v, hv⟩ => ⟨φ.symm v, ?_⟩
    left_inv := fun ⟨v, _⟩ => Subtype.ext (φ.symm_apply_apply v)
    right_inv := fun ⟨v, _⟩ => Subtype.ext (φ.apply_symm_apply v) }
  · rw [vbExt2_iso_colour_pres φ hstr v]; exact hv
  · have := vbExt2_iso_colour_pres φ hstr (φ.symm v)
    rw [Equiv.apply_symm_apply] at this
    rw [← this]; exact hv

/-- Black count of vbExt2_RB_indep is 2. -/
private lemma vbExt2_RB_indep_blackCount :
    Fintype.card { v : Fin vbExt2_RB_indep.size //
      vbExt2_RB_indep.str.2 v = (1 : Fin 2) } = 2 := by
  change Fintype.card { v : Fin 3 //
    (if v.val = 0 then (1 : Fin 2) else if v.val = 1 then 0 else 1) = 1 } = 2
  decide

/-- Black count of vbExt2_RB_edge is 2. -/
private lemma vbExt2_RB_edge_blackCount :
    Fintype.card { v : Fin vbExt2_RB_edge.size //
      vbExt2_RB_edge.str.2 v = (1 : Fin 2) } = 2 := by
  change Fintype.card { v : Fin 3 //
    (if v.val = 0 then (1 : Fin 2) else if v.val = 1 then 0 else 1) = 1 } = 2
  decide

/-- Black count of vbExt2_RR_indep is 1. -/
private lemma vbExt2_RR_indep_blackCount :
    Fintype.card { v : Fin vbExt2_RR_indep.size //
      vbExt2_RR_indep.str.2 v = (1 : Fin 2) } = 1 := by
  change Fintype.card { v : Fin 3 // (if v.val = 0 then (1 : Fin 2) else 0) = 1 } = 1
  decide

/-- Black count of vbExt2_RR_edge is 1. -/
private lemma vbExt2_RR_edge_blackCount :
    Fintype.card { v : Fin vbExt2_RR_edge.size //
      vbExt2_RR_edge.str.2 v = (1 : Fin 2) } = 1 := by
