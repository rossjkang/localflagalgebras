/-- jointCount(vbExtRed, vbExtBlack, vbExt2_RB_indep) = 1: the canonical
    pair (red leaf at ⟨1⟩, black leaf at ⟨2⟩) is the only joint embedding pair. -/
theorem genJointCount_vbExtRed_vbExtBlack_vbExt2_RB_indep :
    genJointCount CG2 vertexBlackType vbExtRed vbExtBlack vbExt2_RB_indep = 1 := by
  unfold genJointCount
  rw [Fintype.card_eq_one_iff]
  -- Construct the canonical pair.
  refine ⟨⟨⟨vbExtRed_to_vbExt2_RB_indep_canon, vbExtBlack_to_vbExt2_RB_indep_canon⟩, ?_, ?_⟩, ?_⟩
  · -- Overlap: ∀ i, (i ∈ range e₁ ∧ i ∈ range e₂) ↔ i ∈ range G.embedding
    intro i
    rcases fin3_val_cases i with h0 | h1 | h2
    · -- i = ⟨0⟩: in both ranges; in G.embedding range.
      have hi : i = (⟨0, by decide⟩ : Fin 3) := Fin.ext h0
      rw [hi]
      constructor
      · intro _
        exact ⟨⟨0, Nat.zero_lt_one⟩, rfl⟩
      · intro _
        refine ⟨⟨⟨0, by decide⟩, ?_⟩, ⟨⟨0, by decide⟩, ?_⟩⟩
        · change fin2to3_id (⟨0, by decide⟩ : Fin 2) = (⟨0, by decide⟩ : Fin 3)
          exact fin2to3_id_zero
        · change fin2to3_skip (⟨0, by decide⟩ : Fin 2) = (⟨0, by decide⟩ : Fin 3)
          exact fin2to3_skip_zero
    · -- i = ⟨1⟩: in e₁ range (via fin2to3_id ⟨1⟩ = ⟨1⟩); not in e₂ (skip skips it); not in G emb.
      have hi : i = (⟨1, by decide⟩ : Fin 3) := Fin.ext h1
      rw [hi]
      constructor
      · -- both ranges include ⟨1⟩? e₂ doesn't.
        rintro ⟨_, ⟨j, hj⟩⟩
        exfalso
        rcases fin2_eq_zero_or_one j with hj0 | hj1
        · have : j = (⟨0, by decide⟩ : Fin 2) := Fin.ext hj0
          rw [this] at hj
          have h_eq : fin2to3_skip (⟨0, by decide⟩ : Fin 2) = (⟨1, by decide⟩ : Fin 3) := hj
          rw [fin2to3_skip_zero] at h_eq
          exact absurd h_eq (by decide)
        · have : j = (⟨1, by decide⟩ : Fin 2) := Fin.ext hj1
          rw [this] at hj
          have h_eq : fin2to3_skip (⟨1, by decide⟩ : Fin 2) = (⟨1, by decide⟩ : Fin 3) := hj
          rw [fin2to3_skip_one] at h_eq
          exact absurd h_eq (by decide)
      · rintro ⟨j, hj⟩
        exfalso
        have h_emb : vbExt2_RB_indep.embedding j = (⟨0, by decide⟩ : Fin 3) := rfl
        rw [h_emb] at hj
        have : (1 : ℕ) = 0 := congr_arg Fin.val hj.symm
        omega
    · -- i = ⟨2⟩: in e₂ range; not in e₁ (id maps to {0,1}); not in G emb.
      have hi : i = (⟨2, by decide⟩ : Fin 3) := Fin.ext h2
      rw [hi]
      constructor
      · rintro ⟨⟨j, hj⟩, _⟩
        exfalso
        rcases fin2_eq_zero_or_one j with hj0 | hj1
        · have : j = (⟨0, by decide⟩ : Fin 2) := Fin.ext hj0
          rw [this] at hj
          have h_eq : fin2to3_id (⟨0, by decide⟩ : Fin 2) = (⟨2, by decide⟩ : Fin 3) := hj
          rw [fin2to3_id_zero] at h_eq
          exact absurd h_eq (by decide)
        · have : j = (⟨1, by decide⟩ : Fin 2) := Fin.ext hj1
          rw [this] at hj
          have h_eq : fin2to3_id (⟨1, by decide⟩ : Fin 2) = (⟨2, by decide⟩ : Fin 3) := hj
          rw [fin2to3_id_one] at h_eq
          exact absurd h_eq (by decide)
      · rintro ⟨j, hj⟩
        exfalso
        have h_emb : vbExt2_RB_indep.embedding j = (⟨0, by decide⟩ : Fin 3) := rfl
        rw [h_emb] at hj
        have : (2 : ℕ) = 0 := congr_arg Fin.val hj.symm
        omega
  · -- Cover: ∀ i, i ∈ range e₁ ∨ i ∈ range e₂.
    intro i
    rcases fin3_val_cases i with h0 | h1 | h2
    · left
      have hi : i = (⟨0, by decide⟩ : Fin 3) := Fin.ext h0
      rw [hi]
      exact ⟨⟨0, by decide⟩, fin2to3_id_zero⟩
    · left
      have hi : i = (⟨1, by decide⟩ : Fin 3) := Fin.ext h1
      rw [hi]
      exact ⟨⟨1, by decide⟩, fin2to3_id_one⟩
    · right
      have hi : i = (⟨2, by decide⟩ : Fin 3) := Fin.ext h2
      rw [hi]
      exact ⟨⟨1, by decide⟩, fin2to3_skip_one⟩
  · -- Uniqueness: every joint pair equals the canonical.
    rintro ⟨⟨e₁, e₂⟩, _hover, _hcover⟩
    have h_e1_zero : e₁.toFun (⟨0, by decide⟩ : Fin 2) = (⟨0, by decide⟩ : Fin 3) := by
      rw [vbExtRed_emb_zero e₁, vbExt2_RB_indep_emb_zero]
    have h_e1_one : e₁.toFun (⟨1, by decide⟩ : Fin 2) = (⟨1, by decide⟩ : Fin 3) :=
      vbExtRed_to_vbExt2_RB_indep_leaf_unique e₁
    have h_e2_zero : e₂.toFun (⟨0, by decide⟩ : Fin 2) = (⟨0, by decide⟩ : Fin 3) := by
      rw [vbExtBlack_emb_zero e₂, vbExt2_RB_indep_emb_zero]
    have h_e2_one : e₂.toFun (⟨1, by decide⟩ : Fin 2) = (⟨2, by decide⟩ : Fin 3) :=
      vbExtBlack_to_vbExt2_RB_indep_leaf_unique e₂
    -- Show toFun equality on each component.
    have h_e1_eq : e₁ = vbExtRed_to_vbExt2_RB_indep_canon := by
      obtain ⟨f₁, finj₁, find₁, fcompat₁⟩ := e₁
      congr 1
      funext x
      rcases fin2_eq_zero_or_one x with hx | hx
      · have hx' : x = (⟨0, by decide⟩ : Fin 2) := Fin.ext hx
        rw [hx']
        change f₁ (⟨0, by decide⟩ : Fin 2) = fin2to3_id (⟨0, by decide⟩ : Fin 2)
        rw [fin2to3_id_zero]
        exact h_e1_zero
      · have hx' : x = (⟨1, by decide⟩ : Fin 2) := Fin.ext hx
        rw [hx']
        change f₁ (⟨1, by decide⟩ : Fin 2) = fin2to3_id (⟨1, by decide⟩ : Fin 2)
        rw [fin2to3_id_one]
        exact h_e1_one
    have h_e2_eq : e₂ = vbExtBlack_to_vbExt2_RB_indep_canon := by
      obtain ⟨f₂, finj₂, find₂, fcompat₂⟩ := e₂
      congr 1
      funext x
      rcases fin2_eq_zero_or_one x with hx | hx
      · have hx' : x = (⟨0, by decide⟩ : Fin 2) := Fin.ext hx
        rw [hx']
        change f₂ (⟨0, by decide⟩ : Fin 2) = fin2to3_skip (⟨0, by decide⟩ : Fin 2)
        rw [fin2to3_skip_zero]
        exact h_e2_zero
      · have hx' : x = (⟨1, by decide⟩ : Fin 2) := Fin.ext hx
