  vertexRedFlag_forget_aut

/-- `extSum σ i` is in the σ-cone (always ≥ 0 in any σ-functional).

    Proof: extSum is a finite sum of Aut(F) · single F with Aut > 0, and
    each ψ.evalAlg(single F) = ψ.eval(F) ≥ 0 (`nonneg_on_flags`). -/
theorem extSum_isPositive (σ : GenFlagType CG2)
    {𝒢 : GenGraphClass CG2} {Δ : GenGraphParam CG2} (i : Fin σ.size) :
    (extSum σ i).isPositive 𝒢 Δ := by
  intro ψ
  -- ψ.evalAlg (extSum σ i) = Σ_cls (extSum σ i)(cls) * ψ.eval cls.out
  change 0 ≤ genEvalAlgOf ψ.eval (extSum σ i)
  unfold genEvalAlgOf
  -- For each cls in support, value is Aut(cls.out) ≥ 0 and eval ≥ 0
  apply Finsupp.sum_nonneg
  intro cls _
  exact mul_nonneg (extSum_apply_nonneg σ i cls) (ψ.nonneg_on_flags _)

