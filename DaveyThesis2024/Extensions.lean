/-! ### Specific size-2 σ-flags at vertexBlackType (for B₁ enumeration)

The two non-trivial extension flags at vertexBlackType (with edge between the
σ-vertex and the new vertex):
- `vbExtRed`: vertex 1 is red (the local one in BRRB context)
- `vbExtBlack`: vertex 1 is black (non-local in BRRB by black-indep) -/

/-- Size-2 σ-flag at vertexBlackType: edge between vertex 0 (black, σ) and
    vertex 1 (red), with no other edges. -/
noncomputable def vbExtRed : GenFlag CG2 vertexBlackType where
  size := 2
  str := (SimpleGraph.fromRel
    (fun u v : Fin 2 => (u.val = 0 ∧ v.val = 1) ∨ (u.val = 1 ∧ v.val = 0)),
    fun v : Fin 2 => if v.val = 0 then 1 else 0)
  embedding := ⟨fun _ => (⟨0, by omega⟩ : Fin 2),
    fun a b _ => by
      have : a.val < 1 := a.isLt
      have : b.val < 1 := b.isLt
      ext; omega⟩
  isInduced := by
    -- comap of canonical 1-vertex embedding 0 ↦ 0 gives σ.str = (⊥, const 1).
    have h_eq : ((SimpleGraph.fromRel
        (fun u v : Fin 2 => (u.val = 0 ∧ v.val = 1) ∨ (u.val = 1 ∧ v.val = 0))).comap
        (fun (i : Fin 1) => (⟨0, by omega⟩ : Fin 2)),
        (fun v : Fin 2 => if v.val = 0 then (1 : Fin 2) else 0) ∘
          (fun (i : Fin 1) => (⟨0, by omega⟩ : Fin 2)))
        = ((⊥ : SimpleGraph (Fin 1)), fun _ : Fin 1 => (1 : Fin 2)) := by
      ext
      · simp [SimpleGraph.comap, SimpleGraph.fromRel]
      · rfl
    exact h_eq
  hsize := by change 1 ≤ 2; omega

/-- Size-2 σ-flag at vertexBlackType: edge between vertex 0 (black) and
    vertex 1 (black). NOT local in BRRB (black-indep forbids black-black edges). -/
noncomputable def vbExtBlack : GenFlag CG2 vertexBlackType where
  size := 2
  str := (SimpleGraph.fromRel
    (fun u v : Fin 2 => (u.val = 0 ∧ v.val = 1) ∨ (u.val = 1 ∧ v.val = 0)),
    fun _ : Fin 2 => 1)
  embedding := ⟨fun _ => (⟨0, by omega⟩ : Fin 2),
    fun a b _ => by
      have : a.val < 1 := a.isLt
      have : b.val < 1 := b.isLt
      ext; omega⟩
  isInduced := by
    have h_eq : ((SimpleGraph.fromRel
        (fun u v : Fin 2 => (u.val = 0 ∧ v.val = 1) ∨ (u.val = 1 ∧ v.val = 0))).comap
        (fun (i : Fin 1) => (⟨0, by omega⟩ : Fin 2)),
        (fun _ : Fin 2 => (1 : Fin 2)) ∘
          (fun (i : Fin 1) => (⟨0, by omega⟩ : Fin 2)))
        = ((⊥ : SimpleGraph (Fin 1)), fun _ : Fin 1 => (1 : Fin 2)) := by
      ext
      · simp [SimpleGraph.comap, SimpleGraph.fromRel]
      · rfl
    exact h_eq
  hsize := by change 1 ≤ 2; omega

@[simp] theorem vbExtRed_size : vbExtRed.size = 2 := rfl
@[simp] theorem vbExtBlack_size : vbExtBlack.size = 2 := rfl

theorem vbExtRed_extAdjacency :
    extAdjacency vertexBlackType vbExtRed ⟨0, by change 0 < 1; omega⟩ := by
  refine ⟨⟨1, by change 1 < 2; omega⟩, ?_, ?_⟩
  · -- ⟨1, _⟩ ∉ Set.range vbExtRed.embedding
    intro ⟨j, hj⟩
    have hval : (1 : ℕ) = 0 := by
      have h_eq := hj.symm
      rw [show vbExtRed.embedding j = (⟨0, by omega⟩ : Fin 2) from rfl] at h_eq
      exact congr_arg Fin.val h_eq
    omega
  · -- vbExtRed.str.1.Adj ⟨1, _⟩ ⟨0, _⟩
    change (SimpleGraph.fromRel
      (fun u v : Fin 2 => (u.val = 0 ∧ v.val = 1) ∨ (u.val = 1 ∧ v.val = 0))).Adj
      ⟨1, by show 1 < 2; omega⟩
      (vbExtRed.embedding ⟨0, by change 0 < 1; omega⟩)
    rw [show vbExtRed.embedding ⟨0, by change 0 < 1; omega⟩ = (⟨0, by omega⟩ : Fin 2) from rfl]
    simp [SimpleGraph.fromRel]

/-- Helper: in Fin 2, an element is either ⟨0, _⟩ or ⟨1, _⟩. -/
private theorem fin2_eq_zero_or_one (x : Fin 2) :
    x.val = 0 ∨ x.val = 1 := by
  have hlt : x.val < 2 := x.isLt
  omega

/-- vbExtRed and vbExtBlack are NOT isomorphic as σ-flags.

    Proof outline: σ-compatibility forces any iso φ to map vertex 0 ↦ 0.
    By injectivity on Fin 2, φ also maps 1 ↦ 1. Hence comap φ vbExtBlack.str
    has colour at vertex 1 equal to vbExtBlack's colour at 1 (= 1, black).
    But vbExtRed.str.2 at vertex 1 = 0 (red). Contradicts comap equality. -/
theorem vbExtRed_not_iso_vbExtBlack :
    ¬GenFlagIso vertexBlackType vbExtRed vbExtBlack := by
  rintro ⟨φ, hstr, hcompat⟩
  -- σ-compatibility: φ ⟨0,_⟩ = ⟨0,_⟩ (since both embeddings send 0 ↦ 0).
  have h_phi_zero : φ (⟨0, Nat.zero_lt_two⟩ : Fin 2) =
      (⟨0, Nat.zero_lt_two⟩ : Fin 2) := by
    have h := hcompat (⟨0, Nat.zero_lt_one⟩ : Fin 1)
    exact h
  -- φ ⟨1, _⟩ ≠ ⟨0, _⟩ (else φ not injective)
  have h_phi_one_ne_zero :
      φ (⟨1, Nat.one_lt_two⟩ : Fin 2) ≠ (⟨0, Nat.zero_lt_two⟩ : Fin 2) := by
    intro h_eq
    have heq2 : (⟨1, Nat.one_lt_two⟩ : Fin 2) = ⟨0, Nat.zero_lt_two⟩ := by
      apply φ.injective
      rw [h_eq, h_phi_zero]
    have hval : (1 : ℕ) = 0 := congr_arg Fin.val heq2
    omega
  -- Hence φ ⟨1, _⟩ = ⟨1, _⟩.
  have h_phi_one : φ (⟨1, Nat.one_lt_two⟩ : Fin 2) =
      (⟨1, Nat.one_lt_two⟩ : Fin 2) := by
    rcases fin2_eq_zero_or_one (φ (⟨1, Nat.one_lt_two⟩ : Fin 2)) with h | h
    · exfalso; apply h_phi_one_ne_zero; ext; exact h
    · ext; exact h
  -- Compare colours at vertex 1: comap φ vbExtBlack.str = vbExtRed.str.
  have h_col : (CG2.comap φ vbExtBlack.str).2 (⟨1, Nat.one_lt_two⟩ : Fin 2) =
      vbExtRed.str.2 (⟨1, Nat.one_lt_two⟩ : Fin 2) := by
    rw [hstr]
  have hLHS : (CG2.comap φ vbExtBlack.str).2
      (⟨1, Nat.one_lt_two⟩ : Fin 2) = 1 := by
    change vbExtBlack.str.2 (φ (⟨1, Nat.one_lt_two⟩ : Fin 2)) = 1
    rw [h_phi_one]; rfl
  have hRHS : vbExtRed.str.2 (⟨1, Nat.one_lt_two⟩ : Fin 2) = 0 := by
    change (if (1 : ℕ) = 0 then (1 : Fin 2) else (0 : Fin 2)) = 0
    simp
  -- h_col says they're equal. So 1 = 0 in Fin 2, contradiction.
  rw [hLHS, hRHS] at h_col
  exact absurd h_col (by decide)

theorem vbExtBlack_extAdjacency_early :
    extAdjacency vertexBlackType vbExtBlack ⟨0, by change 0 < 1; omega⟩ := by
  refine ⟨⟨1, by change 1 < 2; omega⟩, ?_, ?_⟩
  · intro ⟨j, hj⟩
    have hval : (1 : ℕ) = 0 := by
      have h_eq := hj.symm
      rw [show vbExtBlack.embedding j = (⟨0, by omega⟩ : Fin 2) from rfl] at h_eq
      exact congr_arg Fin.val h_eq
    omega
  · change (SimpleGraph.fromRel
      (fun u v : Fin 2 => (u.val = 0 ∧ v.val = 1) ∨ (u.val = 1 ∧ v.val = 0))).Adj
      ⟨1, by show 1 < 2; omega⟩
      (vbExtBlack.embedding ⟨0, by change 0 < 1; omega⟩)
    rw [show vbExtBlack.embedding ⟨0, by change 0 < 1; omega⟩ = (⟨0, by omega⟩ : Fin 2) from rfl]
    simp [SimpleGraph.fromRel]

