      · have hu' : u = (⟨1, by decide⟩ : Fin 2) := Fin.ext hu
        have hv' : v = (⟨1, by decide⟩ : Fin 2) := Fin.ext hv
        rw [hu', hv', fin2to3_skip_one]
        simp [vbExt2_RB_indep, vbExtBlack]
    · funext v
