        vbExtBlack.str.1.Adj u v
      rcases fin2_eq_zero_or_one u with hu | hu <;>
        rcases fin2_eq_zero_or_one v with hv | hv
      · have hu' : u = (⟨0, by decide⟩ : Fin 2) := Fin.ext hu
        have hv' : v = (⟨0, by decide⟩ : Fin 2) := Fin.ext hv
        rw [hu', hv', fin2to3_id_zero]
        simp [vbExt2_BB_edge, vbExtBlack]
      · have hu' : u = (⟨0, by decide⟩ : Fin 2) := Fin.ext hu
        have hv' : v = (⟨1, by decide⟩ : Fin 2) := Fin.ext hv
        rw [hu', hv', fin2to3_id_zero, fin2to3_id_one]
        simp [vbExt2_BB_edge, vbExtBlack, SimpleGraph.fromRel_adj]
      · have hu' : u = (⟨1, by decide⟩ : Fin 2) := Fin.ext hu
        have hv' : v = (⟨0, by decide⟩ : Fin 2) := Fin.ext hv
        rw [hu', hv', fin2to3_id_zero, fin2to3_id_one]
        simp [vbExt2_BB_edge, vbExtBlack, SimpleGraph.fromRel_adj]
      · have hu' : u = (⟨1, by decide⟩ : Fin 2) := Fin.ext hu
        have hv' : v = (⟨1, by decide⟩ : Fin 2) := Fin.ext hv
        rw [hu', hv', fin2to3_id_one]
        simp [vbExt2_BB_edge, vbExtBlack]
    · funext v
      rcases fin2_eq_zero_or_one v with hv | hv
      · have hv' : v = (⟨0, by decide⟩ : Fin 2) := Fin.ext hv
        rw [hv']
        change vbExt2_BB_edge.str.2 (fin2to3_id (⟨0, by decide⟩ : Fin 2)) =
          vbExtBlack.str.2 (⟨0, by decide⟩ : Fin 2)
        rw [fin2to3_id_zero]; decide
      · have hv' : v = (⟨1, by decide⟩ : Fin 2) := Fin.ext hv
        rw [hv']
        change vbExt2_BB_edge.str.2 (fin2to3_id (⟨1, by decide⟩ : Fin 2)) =
