/-! ### Universal σ-position-0 helpers via leaf transpositions

The three helpers below extend `size4_sigma0_id_iso` to non-canonical leaf
configurations: when G's leaves are permuted relative to T's canonical layout,
applying a transposition on {1,2,3} (which fixes 0 = σ) realigns them.

- `size4_sigma0_swap23_iso` — ψ = swap(2,3): used when G's edges/colours sit at
  position 3 where T expects them at 2 (or vice versa).
- `size4_sigma0_swap13_iso` — ψ = swap(1,3).
- `size4_sigma0_swap12_iso` — ψ = swap(1,2).

Each is structurally identical to `size4_sigma0_id_iso` but with the adjacency
biconditionals stated under the corresponding ψ-relabeling, and likewise for
the leaf colour equations. -/

/-- Universal σ-position-0 iso for size-4 σ-flags via ψ = swap(2,3). -/
private theorem size4_sigma0_swap23_iso
    (G_str T_str : CG2.Str 4)
    (G_emb T_emb : Fin vertexBlackType.size ↪ Fin 4)
    (G_isInd : CG2.comap G_emb G_str = vertexBlackType.str)
    (T_isInd : CG2.comap T_emb T_str = vertexBlackType.str)
    (G_hsize T_hsize : vertexBlackType.size ≤ 4)
    (h_emb_G : (G_emb ⟨0, Nat.zero_lt_one⟩).val = 0)
    (h_emb_T : (T_emb ⟨0, Nat.zero_lt_one⟩).val = 0)
    -- ψ : 0 fixed, 1 fixed, 2 ↔ 3.
    -- G(0,1) ↔ T(0,1), G(0,2) ↔ T(0,3), G(0,3) ↔ T(0,2),
    -- G(1,2) ↔ T(1,3), G(1,3) ↔ T(1,2), G(2,3) ↔ T(3,2).
    (h_adj_01 : G_str.1.Adj ⟨0, by decide⟩ ⟨1, by decide⟩ ↔
                T_str.1.Adj ⟨0, by decide⟩ ⟨1, by decide⟩)
    (h_adj_02 : G_str.1.Adj ⟨0, by decide⟩ ⟨2, by decide⟩ ↔
                T_str.1.Adj ⟨0, by decide⟩ ⟨3, by decide⟩)
    (h_adj_03 : G_str.1.Adj ⟨0, by decide⟩ ⟨3, by decide⟩ ↔
                T_str.1.Adj ⟨0, by decide⟩ ⟨2, by decide⟩)
    (h_adj_12 : G_str.1.Adj ⟨1, by decide⟩ ⟨2, by decide⟩ ↔
                T_str.1.Adj ⟨1, by decide⟩ ⟨3, by decide⟩)
    (h_adj_13 : G_str.1.Adj ⟨1, by decide⟩ ⟨3, by decide⟩ ↔
                T_str.1.Adj ⟨1, by decide⟩ ⟨2, by decide⟩)
    (h_adj_23 : G_str.1.Adj ⟨2, by decide⟩ ⟨3, by decide⟩ ↔
                T_str.1.Adj ⟨3, by decide⟩ ⟨2, by decide⟩)
    -- Colours: G(1) = T(1), G(2) = T(3), G(3) = T(2).
    (h_col_1 : G_str.2 ⟨1, by decide⟩ = T_str.2 ⟨1, by decide⟩)
    (h_col_2 : G_str.2 ⟨2, by decide⟩ = T_str.2 ⟨3, by decide⟩)
    (h_col_3 : G_str.2 ⟨3, by decide⟩ = T_str.2 ⟨2, by decide⟩) :
    GenFlagIso vertexBlackType
      (⟨4, G_str, G_emb, G_isInd, G_hsize⟩ : GenFlag CG2 vertexBlackType)
      (⟨4, T_str, T_emb, T_isInd, T_hsize⟩ : GenFlag CG2 vertexBlackType) := by
  classical
  have h02 : ((⟨0, by decide⟩ : Fin 4) : Fin 4) ≠ (⟨2, by decide⟩ : Fin 4) := by decide
  have h03 : ((⟨0, by decide⟩ : Fin 4) : Fin 4) ≠ (⟨3, by decide⟩ : Fin 4) := by decide
  have h12 : ((⟨1, by decide⟩ : Fin 4) : Fin 4) ≠ (⟨2, by decide⟩ : Fin 4) := by decide
  have h13 : ((⟨1, by decide⟩ : Fin 4) : Fin 4) ≠ (⟨3, by decide⟩ : Fin 4) := by decide
  have hs0 : Equiv.swap (⟨2, by decide⟩ : Fin 4) ⟨3, by decide⟩ ⟨0, by decide⟩
      = (⟨0, by decide⟩ : Fin 4) := Equiv.swap_apply_of_ne_of_ne h02 h03
  have hs1 : Equiv.swap (⟨2, by decide⟩ : Fin 4) ⟨3, by decide⟩ ⟨1, by decide⟩
      = (⟨1, by decide⟩ : Fin 4) := Equiv.swap_apply_of_ne_of_ne h12 h13
  have hs2 : Equiv.swap (⟨2, by decide⟩ : Fin 4) ⟨3, by decide⟩ ⟨2, by decide⟩
      = (⟨3, by decide⟩ : Fin 4) := Equiv.swap_apply_left _ _
  have hs3 : Equiv.swap (⟨2, by decide⟩ : Fin 4) ⟨3, by decide⟩ ⟨3, by decide⟩
      = (⟨2, by decide⟩ : Fin 4) := Equiv.swap_apply_right _ _
  apply size4_sigma0_iso_via_leafperm G_str T_str G_emb T_emb G_isInd T_isInd
    G_hsize T_hsize h_emb_G h_emb_T (Equiv.swap (⟨2, by decide⟩ : Fin 4) ⟨3, by decide⟩) hs0
  · intro u v
    rcases fin4_val_cases u with hu | hu | hu | hu <;>
