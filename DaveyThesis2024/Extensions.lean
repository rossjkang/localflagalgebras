/-! ### σ-position-0 iso for vbExt3_RRR_e0 (canonical case)

Demonstrates the workflow: a σ-pos-0 σ-flag with all-red leaves and no
leaf-leaf edges is iso to `vbExt3_RRR_e0` via the identity permutation. -/

/-- Specialised σ-position-0 helper that bypasses the generic leaf-permutation
    interface, since all 3 leaves have the same colour and we use ψ = id. -/
private theorem size4_sigma0_RRR_e0_iso
    (G_str : CG2.Str 4)
    (G_emb : Fin vertexBlackType.size ↪ Fin 4)
    (G_isInd : CG2.comap G_emb G_str = vertexBlackType.str)
    (G_hsize : vertexBlackType.size ≤ 4)
    (h_emb_G : (G_emb ⟨0, Nat.zero_lt_one⟩).val = 0)
    (h_adj_01 : G_str.1.Adj (⟨0, by decide⟩ : Fin 4) (⟨1, by decide⟩ : Fin 4))
    (h_adj_02 : G_str.1.Adj (⟨0, by decide⟩ : Fin 4) (⟨2, by decide⟩ : Fin 4))
    (h_adj_03 : G_str.1.Adj (⟨0, by decide⟩ : Fin 4) (⟨3, by decide⟩ : Fin 4))
    (h_col_1 : G_str.2 (⟨1, by decide⟩ : Fin 4) = 0)
    (h_col_2 : G_str.2 (⟨2, by decide⟩ : Fin 4) = 0)
    (h_col_3 : G_str.2 (⟨3, by decide⟩ : Fin 4) = 0)
    (h_nadj_12 : ¬ G_str.1.Adj (⟨1, by decide⟩ : Fin 4) (⟨2, by decide⟩ : Fin 4))
    (h_nadj_13 : ¬ G_str.1.Adj (⟨1, by decide⟩ : Fin 4) (⟨3, by decide⟩ : Fin 4))
    (h_nadj_23 : ¬ G_str.1.Adj (⟨2, by decide⟩ : Fin 4) (⟨3, by decide⟩ : Fin 4)) :
    GenFlagIso vertexBlackType
      (⟨4, G_str, G_emb, G_isInd, G_hsize⟩ : GenFlag CG2 vertexBlackType)
      vbExt3_RRR_e0 := by
  apply size4_iso_via_perm G_str vbExt3_RRR_e0.str
    G_emb vbExt3_RRR_e0.embedding G_isInd vbExt3_RRR_e0.isInduced
    G_hsize vbExt3_RRR_e0.hsize (by rfl) (Equiv.refl (Fin 4))
  · -- φ(G_emb ⟨0,_⟩) = ⟨0,_⟩
    change (G_emb ⟨0, Nat.zero_lt_one⟩) = (⟨0, by decide⟩ : Fin 4)
    exact Fin.ext h_emb_G
  · -- Adjacency match: G.Adj u v ↔ T.Adj u v.
    intro u v
