/-- `Fin 4 → Fin 5` skipping index 0, i.e. `c ↦ ⟨c.val + 1, _⟩`. Used to map
    leaf-indices in `vbExt3_RRR_e0`/`vbExt4_RRRR_e0` to their positions. -/
private def fin4_skip0 : Fin 4 → Fin 5 :=
  fun x => ⟨x.val + 1, by have h : x.val < 4 := x.isLt; omega⟩

@[simp] private theorem fin4_skip0_zero :
    fin4_skip0 (⟨0, by decide⟩ : Fin 4) = (⟨1, by decide⟩ : Fin 5) := rfl

@[simp] private theorem fin4_skip0_one :
    fin4_skip0 (⟨1, by decide⟩ : Fin 4) = (⟨2, by decide⟩ : Fin 5) := rfl

@[simp] private theorem fin4_skip0_two :
    fin4_skip0 (⟨2, by decide⟩ : Fin 4) = (⟨3, by decide⟩ : Fin 5) := rfl

@[simp] private theorem fin4_skip0_three :
    fin4_skip0 (⟨3, by decide⟩ : Fin 4) = (⟨4, by decide⟩ : Fin 5) := rfl

private theorem fin4_skip0_inj : Function.Injective fin4_skip0 := by
  intro a b h
  have hv : a.val + 1 = b.val + 1 := congr_arg Fin.val h
  exact Fin.ext (Nat.add_right_cancel hv)

private theorem fin4_skip0_ne_zero (i : Fin 4) :
    fin4_skip0 i ≠ (⟨0, by decide⟩ : Fin 5) := by
  intro h
  have : (i.val + 1 : ℕ) = 0 := congr_arg Fin.val h
  omega

private def fin4_skip0_inv (v : Fin 5) (_hv : v.val ≠ 0) : Fin 4 :=
  ⟨v.val - 1, by have h : v.val < 5 := v.isLt; omega⟩

private theorem fin4_skip0_inv_apply (c : Fin 4) :
    fin4_skip0_inv (fin4_skip0 c) (by simp [fin4_skip0]) = c := by
  apply Fin.ext
  change (c.val + 1) - 1 = c.val
  omega

private theorem fin4_skip0_apply_inv (v : Fin 5) (hv : v.val ≠ 0) :
    fin4_skip0 (fin4_skip0_inv v hv) = v := by
  apply Fin.ext
  change (v.val - 1) + 1 = v.val
  have hpos : 0 < v.val := Nat.pos_of_ne_zero hv
  omega

/-! #### Canonical embeddings into `vbExt4_RRRR_e0`

For each value `c : Fin 4`, the canonical `vbExtRed → vbExt4_RRRR_e0` placing
the red leaf at `fin4_skip0 c` (positions 1, 2, 3, or 4 in Fin 5).

For each ordered triple `(a, b, c) : Fin 4 × Fin 4 × Fin 4` with all distinct,
the canonical `vbExt3_RRR_e0 → vbExt4_RRRR_e0` placing the 3 red leaves at
`fin4_skip0 a, fin4_skip0 b, fin4_skip0 c`. -/

/-- Map `Fin 2 → Fin 5` sending ⟨0⟩ → ⟨0⟩ (σ), ⟨1⟩ → fin4_skip0 c. -/
private def red_leaf_to_5 (c : Fin 4) : Fin 2 → Fin 5 :=
  fun x => if x.val = 0 then (⟨0, by decide⟩ : Fin 5) else fin4_skip0 c

private theorem red_leaf_to_5_zero (c : Fin 4) :
    red_leaf_to_5 c (⟨0, by decide⟩ : Fin 2) = (⟨0, by decide⟩ : Fin 5) := rfl

private theorem red_leaf_to_5_one (c : Fin 4) :
    red_leaf_to_5 c (⟨1, by decide⟩ : Fin 2) = fin4_skip0 c := rfl

private theorem red_leaf_to_5_inj (c : Fin 4) :
    Function.Injective (red_leaf_to_5 c) := by
  intro a b h
  rcases fin2_eq_zero_or_one a with ha | ha <;> rcases fin2_eq_zero_or_one b with hb | hb
  · exact Fin.ext (ha.trans hb.symm)
  · exfalso
    have ha' : a = (⟨0, by decide⟩ : Fin 2) := Fin.ext ha
    have hb' : b = (⟨1, by decide⟩ : Fin 2) := Fin.ext hb
    rw [ha', hb', red_leaf_to_5_zero, red_leaf_to_5_one] at h
    exact fin4_skip0_ne_zero c h.symm
  · exfalso
    have ha' : a = (⟨1, by decide⟩ : Fin 2) := Fin.ext ha
    have hb' : b = (⟨0, by decide⟩ : Fin 2) := Fin.ext hb
    rw [ha', hb', red_leaf_to_5_one, red_leaf_to_5_zero] at h
    exact fin4_skip0_ne_zero c h
  · exact Fin.ext (ha.trans hb.symm)

/-- vbExt4_RRRR_e0 has the (0, fin4_skip0 c) edge for any c : Fin 4. -/
private theorem vbExt4_RRRR_e0_adj_0_skip (c : Fin 4) :
