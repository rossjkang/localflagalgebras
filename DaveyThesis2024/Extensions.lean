/-! ### Colour facts for the 6 vbExt2_* targets

Pointwise colour values. -/

private theorem vbExt2_RR_indep_col (v : Fin 3) :
    vbExt2_RR_indep.str.2 v = if v.val = 0 then (1 : Fin 2) else 0 := rfl

private theorem vbExt2_RR_edge_col (v : Fin 3) :
    vbExt2_RR_edge.str.2 v = if v.val = 0 then (1 : Fin 2) else 0 := rfl

private theorem vbExt2_RB_indep_col (v : Fin 3) :
    vbExt2_RB_indep.str.2 v =
      if v.val = 0 then (1 : Fin 2) else if v.val = 1 then 0 else 1 := rfl

private theorem vbExt2_RB_edge_col (v : Fin 3) :
    vbExt2_RB_edge.str.2 v =
      if v.val = 0 then (1 : Fin 2) else if v.val = 1 then 0 else 1 := rfl

private theorem vbExt2_BB_indep_col (v : Fin 3) :
    vbExt2_BB_indep.str.2 v = (1 : Fin 2) := rfl

private theorem vbExt2_BB_edge_col (v : Fin 3) :
    vbExt2_BB_edge.str.2 v = (1 : Fin 2) := rfl

/-! ### Master classification theorem

Any size-3 σ-flag at vertexBlackType where the σ-vertex is adjacent to BOTH
non-σ vertices is iso to one of the 6 `vbExt2_*` flags. -/

/-- Helper: from the σ-flag's induction structure, the σ-vertex has colour 1.
    Specifically, `G.str.2 (G.embedding ⟨0,_⟩) = 1`. -/
private theorem size3_sigma_col_eq_one
    (G_str : CG2.Str 3) (G_emb : Fin vertexBlackType.size ↪ Fin 3)
    (G_isInd : CG2.comap G_emb G_str = vertexBlackType.str) :
    G_str.2 (G_emb ⟨0, Nat.zero_lt_one⟩) = 1 := by
  have h_col := congr_arg (fun s : CG2.Str vertexBlackType.size =>
    s.2 ⟨0, Nat.zero_lt_one⟩) G_isInd
  exact h_col

/-! ### Generic helper for σ-position-0 case

When `G_emb ⟨0,_⟩ = ⟨0,_⟩`, any iso to a `vbExt2_*` target with σ-vertex at 0
either uses φ = id or φ = swap (1, 2). We provide a streamlined construction
for both options. -/

/-- Generic σ-position-0 iso: φ = id case. The target T has σ at position 0
    and we verify pointwise structural matches at positions 1 and 2. -/
private theorem size3_sigma0_id_iso
    (G_str T_str : CG2.Str 3)
    (G_emb T_emb : Fin vertexBlackType.size ↪ Fin 3)
    (G_isInd : CG2.comap G_emb G_str = vertexBlackType.str)
    (T_isInd : CG2.comap T_emb T_str = vertexBlackType.str)
    (G_hsize T_hsize : vertexBlackType.size ≤ 3)
    (h_emb_G : (G_emb ⟨0, Nat.zero_lt_one⟩).val = 0)
    (h_emb_T : (T_emb ⟨0, Nat.zero_lt_one⟩).val = 0)
    (h_adj_01 : G_str.1.Adj ⟨0, by decide⟩ ⟨1, by decide⟩ ↔
                T_str.1.Adj ⟨0, by decide⟩ ⟨1, by decide⟩)
    (h_adj_02 : G_str.1.Adj ⟨0, by decide⟩ ⟨2, by decide⟩ ↔
                T_str.1.Adj ⟨0, by decide⟩ ⟨2, by decide⟩)
    (h_adj_12 : G_str.1.Adj ⟨1, by decide⟩ ⟨2, by decide⟩ ↔
                T_str.1.Adj ⟨1, by decide⟩ ⟨2, by decide⟩)
    (h_col_1 : G_str.2 ⟨1, by decide⟩ = T_str.2 ⟨1, by decide⟩)
    (h_col_2 : G_str.2 ⟨2, by decide⟩ = T_str.2 ⟨2, by decide⟩) :
    GenFlagIso vertexBlackType
      (⟨3, G_str, G_emb, G_isInd, G_hsize⟩ : GenFlag CG2 vertexBlackType)
      (⟨3, T_str, T_emb, T_isInd, T_hsize⟩ : GenFlag CG2 vertexBlackType) := by
  have hT_emb_zero : T_emb (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) =
      (⟨0, (by decide : (0:ℕ) < 3)⟩ : Fin 3) := Fin.ext h_emb_T
  apply size3_iso_via_perm G_str T_str G_emb T_emb G_isInd T_isInd G_hsize T_hsize
    hT_emb_zero (Equiv.refl (Fin 3))
  · -- φ id maps G_emb ⟨0,_⟩ = ⟨0,_⟩ ↦ ⟨0,_⟩
    change (G_emb ⟨0, Nat.zero_lt_one⟩) = (⟨0, by decide⟩ : Fin 3)
    exact Fin.ext h_emb_G
  · -- h_adj for all u, v: 9 cases
    intro u v
    change G_str.1.Adj u v ↔ T_str.1.Adj u v
    rcases fin3_val_cases u with hu | hu | hu <;>
      rcases fin3_val_cases v with hv | hv | hv
    · have hu_eq : u = (⟨0, by decide⟩ : Fin 3) := Fin.ext hu
      have hv_eq : v = (⟨0, by decide⟩ : Fin 3) := Fin.ext hv
      rw [hu_eq, hv_eq]; constructor <;> intro hadj <;> exact absurd hadj
        (SimpleGraph.irrefl _)
    · have hu_eq : u = (⟨0, by decide⟩ : Fin 3) := Fin.ext hu
      have hv_eq : v = (⟨1, by decide⟩ : Fin 3) := Fin.ext hv
      rw [hu_eq, hv_eq]; exact h_adj_01
    · have hu_eq : u = (⟨0, by decide⟩ : Fin 3) := Fin.ext hu
      have hv_eq : v = (⟨2, by decide⟩ : Fin 3) := Fin.ext hv
      rw [hu_eq, hv_eq]; exact h_adj_02
    · have hu_eq : u = (⟨1, by decide⟩ : Fin 3) := Fin.ext hu
      have hv_eq : v = (⟨0, by decide⟩ : Fin 3) := Fin.ext hv
      rw [hu_eq, hv_eq, SimpleGraph.adj_comm, SimpleGraph.adj_comm (G := T_str.1)]
      exact h_adj_01
    · have hu_eq : u = (⟨1, by decide⟩ : Fin 3) := Fin.ext hu
      have hv_eq : v = (⟨1, by decide⟩ : Fin 3) := Fin.ext hv
      rw [hu_eq, hv_eq]; constructor <;> intro hadj <;> exact absurd hadj
        (SimpleGraph.irrefl _)
    · have hu_eq : u = (⟨1, by decide⟩ : Fin 3) := Fin.ext hu
      have hv_eq : v = (⟨2, by decide⟩ : Fin 3) := Fin.ext hv
      rw [hu_eq, hv_eq]; exact h_adj_12
    · have hu_eq : u = (⟨2, by decide⟩ : Fin 3) := Fin.ext hu
      have hv_eq : v = (⟨0, by decide⟩ : Fin 3) := Fin.ext hv
      rw [hu_eq, hv_eq, SimpleGraph.adj_comm, SimpleGraph.adj_comm (G := T_str.1)]
      exact h_adj_02
    · have hu_eq : u = (⟨2, by decide⟩ : Fin 3) := Fin.ext hu
      have hv_eq : v = (⟨1, by decide⟩ : Fin 3) := Fin.ext hv
      rw [hu_eq, hv_eq, SimpleGraph.adj_comm, SimpleGraph.adj_comm (G := T_str.1)]
      exact h_adj_12
    · have hu_eq : u = (⟨2, by decide⟩ : Fin 3) := Fin.ext hu
      have hv_eq : v = (⟨2, by decide⟩ : Fin 3) := Fin.ext hv
      rw [hu_eq, hv_eq]; constructor <;> intro hadj <;> exact absurd hadj
        (SimpleGraph.irrefl _)
  · -- h_col for all v
    intro v
    change G_str.2 v = T_str.2 v
    rcases fin3_val_cases v with hv | hv | hv
    · have hv_eq : v = (⟨0, by decide⟩ : Fin 3) := Fin.ext hv
      rw [hv_eq]
      -- σ-vertex: both are 1
      have hG := size3_sigma_col_eq_one G_str G_emb G_isInd
      have hT := size3_sigma_col_eq_one T_str T_emb T_isInd
      have hG_emb_eq : G_emb (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) =
          (⟨0, by decide⟩ : Fin 3) := Fin.ext h_emb_G
      have hT_emb_eq : T_emb (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) =
          (⟨0, by decide⟩ : Fin 3) := Fin.ext h_emb_T
      rw [hG_emb_eq] at hG; rw [hT_emb_eq] at hT
      rw [hG, hT]
    · have hv_eq : v = (⟨1, by decide⟩ : Fin 3) := Fin.ext hv
      rw [hv_eq]; exact h_col_1
    · have hv_eq : v = (⟨2, by decide⟩ : Fin 3) := Fin.ext hv
      rw [hv_eq]; exact h_col_2

/-- Generic σ-position-0 iso: φ = swap(1, 2) case. Used when target leaves are
    swapped relative to source. -/
private theorem size3_sigma0_swap12_iso
    (G_str T_str : CG2.Str 3)
    (G_emb T_emb : Fin vertexBlackType.size ↪ Fin 3)
    (G_isInd : CG2.comap G_emb G_str = vertexBlackType.str)
    (T_isInd : CG2.comap T_emb T_str = vertexBlackType.str)
    (G_hsize T_hsize : vertexBlackType.size ≤ 3)
    (h_emb_G : (G_emb ⟨0, Nat.zero_lt_one⟩).val = 0)
    (h_emb_T : (T_emb ⟨0, Nat.zero_lt_one⟩).val = 0)
    -- Adjacency: G's edges (i, j) match T's at (swap i, swap j).
    (h_adj_01_at_02 : G_str.1.Adj ⟨0, by decide⟩ ⟨1, by decide⟩ ↔
                T_str.1.Adj ⟨0, by decide⟩ ⟨2, by decide⟩)
    (h_adj_02_at_01 : G_str.1.Adj ⟨0, by decide⟩ ⟨2, by decide⟩ ↔
                T_str.1.Adj ⟨0, by decide⟩ ⟨1, by decide⟩)
    (h_adj_12 : G_str.1.Adj ⟨1, by decide⟩ ⟨2, by decide⟩ ↔
                T_str.1.Adj ⟨1, by decide⟩ ⟨2, by decide⟩)
    -- Colours: G at v matches T at (swap v).
    (h_col_1_at_2 : G_str.2 ⟨1, by decide⟩ = T_str.2 ⟨2, by decide⟩)
    (h_col_2_at_1 : G_str.2 ⟨2, by decide⟩ = T_str.2 ⟨1, by decide⟩) :
    GenFlagIso vertexBlackType
      (⟨3, G_str, G_emb, G_isInd, G_hsize⟩ : GenFlag CG2 vertexBlackType)
      (⟨3, T_str, T_emb, T_isInd, T_hsize⟩ : GenFlag CG2 vertexBlackType) := by
  classical
  have hT_emb_zero : T_emb (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) =
      (⟨0, (by decide : (0:ℕ) < 3)⟩ : Fin 3) := Fin.ext h_emb_T
  apply size3_iso_via_perm G_str T_str G_emb T_emb G_isInd T_isInd G_hsize T_hsize
    hT_emb_zero (Equiv.swap (⟨1, by decide⟩ : Fin 3) ⟨2, by decide⟩)
  · -- φ swap(1,2) maps G_emb ⟨0,_⟩ = ⟨0,_⟩ ↦ ⟨0,_⟩
    have hG_emb_eq : G_emb (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) =
        (⟨0, by decide⟩ : Fin 3) := Fin.ext h_emb_G
    rw [hG_emb_eq]
    have h01 : ((⟨0, by decide⟩ : Fin 3) : Fin 3) ≠ (⟨1, by decide⟩ : Fin 3) := by decide
    have h02 : ((⟨0, by decide⟩ : Fin 3) : Fin 3) ≠ (⟨2, by decide⟩ : Fin 3) := by decide
    rw [Equiv.swap_apply_of_ne_of_ne h01 h02]
  · -- h_adj
    intro u v
    have h01 : ((⟨0, by decide⟩ : Fin 3) : Fin 3) ≠ (⟨1, by decide⟩ : Fin 3) := by decide
    have h02 : ((⟨0, by decide⟩ : Fin 3) : Fin 3) ≠ (⟨2, by decide⟩ : Fin 3) := by decide
    have hs0 : Equiv.swap (⟨1, by decide⟩ : Fin 3) ⟨2, by decide⟩ ⟨0, by decide⟩
        = (⟨0, by decide⟩ : Fin 3) := Equiv.swap_apply_of_ne_of_ne h01 h02
    have hs1 : Equiv.swap (⟨1, by decide⟩ : Fin 3) ⟨2, by decide⟩ ⟨1, by decide⟩
        = (⟨2, by decide⟩ : Fin 3) := Equiv.swap_apply_left _ _
    have hs2 : Equiv.swap (⟨1, by decide⟩ : Fin 3) ⟨2, by decide⟩ ⟨2, by decide⟩
        = (⟨1, by decide⟩ : Fin 3) := Equiv.swap_apply_right _ _
    rcases fin3_val_cases u with hu | hu | hu <;>
      rcases fin3_val_cases v with hv | hv | hv
    · have hu_eq : u = (⟨0, by decide⟩ : Fin 3) := Fin.ext hu
      have hv_eq : v = (⟨0, by decide⟩ : Fin 3) := Fin.ext hv
      rw [hu_eq, hv_eq, hs0]
      constructor <;> intro hadj <;> exact absurd hadj (SimpleGraph.irrefl _)
    · have hu_eq : u = (⟨0, by decide⟩ : Fin 3) := Fin.ext hu
      have hv_eq : v = (⟨1, by decide⟩ : Fin 3) := Fin.ext hv
      rw [hu_eq, hv_eq, hs0, hs1]; exact h_adj_01_at_02
    · have hu_eq : u = (⟨0, by decide⟩ : Fin 3) := Fin.ext hu
      have hv_eq : v = (⟨2, by decide⟩ : Fin 3) := Fin.ext hv
      rw [hu_eq, hv_eq, hs0, hs2]; exact h_adj_02_at_01
    · have hu_eq : u = (⟨1, by decide⟩ : Fin 3) := Fin.ext hu
      have hv_eq : v = (⟨0, by decide⟩ : Fin 3) := Fin.ext hv
      rw [hu_eq, hv_eq, hs1, hs0,
        SimpleGraph.adj_comm, SimpleGraph.adj_comm (G := T_str.1)]
      exact h_adj_01_at_02
    · have hu_eq : u = (⟨1, by decide⟩ : Fin 3) := Fin.ext hu
      have hv_eq : v = (⟨1, by decide⟩ : Fin 3) := Fin.ext hv
      rw [hu_eq, hv_eq, hs1]
      constructor <;> intro hadj <;> exact absurd hadj (SimpleGraph.irrefl _)
    · -- u = 1, v = 2: φ u = 2, φ v = 1; goal G.Adj 1 2 ↔ T.Adj 2 1
      have hu_eq : u = (⟨1, by decide⟩ : Fin 3) := Fin.ext hu
      have hv_eq : v = (⟨2, by decide⟩ : Fin 3) := Fin.ext hv
      rw [hu_eq, hv_eq, hs1, hs2, SimpleGraph.adj_comm (G := T_str.1)]
      exact h_adj_12
    · have hu_eq : u = (⟨2, by decide⟩ : Fin 3) := Fin.ext hu
      have hv_eq : v = (⟨0, by decide⟩ : Fin 3) := Fin.ext hv
      rw [hu_eq, hv_eq, hs2, hs0,
        SimpleGraph.adj_comm, SimpleGraph.adj_comm (G := T_str.1)]
      exact h_adj_02_at_01
    · -- u = 2, v = 1: φ u = 1, φ v = 2; goal G.Adj 2 1 ↔ T.Adj 1 2
      have hu_eq : u = (⟨2, by decide⟩ : Fin 3) := Fin.ext hu
      have hv_eq : v = (⟨1, by decide⟩ : Fin 3) := Fin.ext hv
      rw [hu_eq, hv_eq, hs2, hs1, SimpleGraph.adj_comm (G := G_str.1)]
      exact h_adj_12
    · have hu_eq : u = (⟨2, by decide⟩ : Fin 3) := Fin.ext hu
      have hv_eq : v = (⟨2, by decide⟩ : Fin 3) := Fin.ext hv
      rw [hu_eq, hv_eq, hs2]
      constructor <;> intro hadj <;> exact absurd hadj (SimpleGraph.irrefl _)
  · -- h_col
    intro v
    have h01 : ((⟨0, by decide⟩ : Fin 3) : Fin 3) ≠ (⟨1, by decide⟩ : Fin 3) := by decide
    have h02 : ((⟨0, by decide⟩ : Fin 3) : Fin 3) ≠ (⟨2, by decide⟩ : Fin 3) := by decide
    have hs0 : Equiv.swap (⟨1, by decide⟩ : Fin 3) ⟨2, by decide⟩ ⟨0, by decide⟩
        = (⟨0, by decide⟩ : Fin 3) := Equiv.swap_apply_of_ne_of_ne h01 h02
    have hs1 : Equiv.swap (⟨1, by decide⟩ : Fin 3) ⟨2, by decide⟩ ⟨1, by decide⟩
        = (⟨2, by decide⟩ : Fin 3) := Equiv.swap_apply_left _ _
    have hs2 : Equiv.swap (⟨1, by decide⟩ : Fin 3) ⟨2, by decide⟩ ⟨2, by decide⟩
        = (⟨1, by decide⟩ : Fin 3) := Equiv.swap_apply_right _ _
    rcases fin3_val_cases v with hv | hv | hv
    · have hv_eq : v = (⟨0, by decide⟩ : Fin 3) := Fin.ext hv
      rw [hv_eq, hs0]
      have hG := size3_sigma_col_eq_one G_str G_emb G_isInd
      have hT := size3_sigma_col_eq_one T_str T_emb T_isInd
      have hG_emb_eq : G_emb (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) =
          (⟨0, by decide⟩ : Fin 3) := Fin.ext h_emb_G
      have hT_emb_eq : T_emb (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) =
          (⟨0, by decide⟩ : Fin 3) := Fin.ext h_emb_T
      rw [hG_emb_eq] at hG; rw [hT_emb_eq] at hT
      rw [hG, hT]
    · have hv_eq : v = (⟨1, by decide⟩ : Fin 3) := Fin.ext hv
      rw [hv_eq, hs1]; exact h_col_1_at_2
    · have hv_eq : v = (⟨2, by decide⟩ : Fin 3) := Fin.ext hv
      rw [hv_eq, hs2]; exact h_col_2_at_1

/-- Generic σ-position-1 iso: φ = swap(0, 1) case. Maps G-pos 1 ↦ T-pos 0
    (swapping G-pos 0 with G-pos 1; G-pos 2 stays).
    Used when G's σ-vertex is at position 1, and G-leaf at 0 ↦ T-leaf at 1,
    G-leaf at 2 ↦ T-leaf at 2. -/
private theorem size3_sigma1_swap01_iso
    (G_str T_str : CG2.Str 3)
    (G_emb T_emb : Fin vertexBlackType.size ↪ Fin 3)
    (G_isInd : CG2.comap G_emb G_str = vertexBlackType.str)
    (T_isInd : CG2.comap T_emb T_str = vertexBlackType.str)
    (G_hsize T_hsize : vertexBlackType.size ≤ 3)
    (h_emb_G : (G_emb ⟨0, Nat.zero_lt_one⟩).val = 1)
    (h_emb_T : (T_emb ⟨0, Nat.zero_lt_one⟩).val = 0)
    -- Edges (G u v ↔ T (φ u) (φ v)) for representative (u, v) pairs.
    -- φ : 0↔1, 2 fixed. So G(0,1) ↔ T(1,0); G(0,2) ↔ T(1,2); G(1,2) ↔ T(0,2).
    (h_adj_01_at_10 : G_str.1.Adj ⟨0, by decide⟩ ⟨1, by decide⟩ ↔
                      T_str.1.Adj ⟨1, by decide⟩ ⟨0, by decide⟩)
    (h_adj_02_at_12 : G_str.1.Adj ⟨0, by decide⟩ ⟨2, by decide⟩ ↔
                      T_str.1.Adj ⟨1, by decide⟩ ⟨2, by decide⟩)
    (h_adj_12_at_02 : G_str.1.Adj ⟨1, by decide⟩ ⟨2, by decide⟩ ↔
                      T_str.1.Adj ⟨0, by decide⟩ ⟨2, by decide⟩)
    -- Colours: G at v matches T at (φ v).
    (h_col_0_at_1 : G_str.2 ⟨0, by decide⟩ = T_str.2 ⟨1, by decide⟩)
    (h_col_2_at_2 : G_str.2 ⟨2, by decide⟩ = T_str.2 ⟨2, by decide⟩) :
    GenFlagIso vertexBlackType
      (⟨3, G_str, G_emb, G_isInd, G_hsize⟩ : GenFlag CG2 vertexBlackType)
      (⟨3, T_str, T_emb, T_isInd, T_hsize⟩ : GenFlag CG2 vertexBlackType) := by
  classical
  have hT_emb_zero : T_emb (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) =
      (⟨0, (by decide : (0:ℕ) < 3)⟩ : Fin 3) := Fin.ext h_emb_T
  apply size3_iso_via_perm G_str T_str G_emb T_emb G_isInd T_isInd G_hsize T_hsize
    hT_emb_zero (Equiv.swap (⟨0, by decide⟩ : Fin 3) ⟨1, by decide⟩)
  · have hG_emb_eq : G_emb (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) =
        (⟨1, by decide⟩ : Fin 3) := Fin.ext h_emb_G
    rw [hG_emb_eq]
    rw [Equiv.swap_apply_right]
  · -- h_adj
    intro u v
    have h12 : ((⟨1, by decide⟩ : Fin 3) : Fin 3) ≠ (⟨2, by decide⟩ : Fin 3) := by decide
    have h02 : ((⟨0, by decide⟩ : Fin 3) : Fin 3) ≠ (⟨2, by decide⟩ : Fin 3) := by decide
    have hs0 : Equiv.swap (⟨0, by decide⟩ : Fin 3) ⟨1, by decide⟩ ⟨0, by decide⟩
        = (⟨1, by decide⟩ : Fin 3) := Equiv.swap_apply_left _ _
    have hs1 : Equiv.swap (⟨0, by decide⟩ : Fin 3) ⟨1, by decide⟩ ⟨1, by decide⟩
        = (⟨0, by decide⟩ : Fin 3) := Equiv.swap_apply_right _ _
    have hs2 : Equiv.swap (⟨0, by decide⟩ : Fin 3) ⟨1, by decide⟩ ⟨2, by decide⟩
        = (⟨2, by decide⟩ : Fin 3) := Equiv.swap_apply_of_ne_of_ne h02.symm h12.symm
    rcases fin3_val_cases u with hu | hu | hu <;>
      rcases fin3_val_cases v with hv | hv | hv
    · have hu_eq : u = (⟨0, by decide⟩ : Fin 3) := Fin.ext hu
      have hv_eq : v = (⟨0, by decide⟩ : Fin 3) := Fin.ext hv
      rw [hu_eq, hv_eq, hs0]
      constructor <;> intro hadj <;> exact absurd hadj (SimpleGraph.irrefl _)
    · have hu_eq : u = (⟨0, by decide⟩ : Fin 3) := Fin.ext hu
      have hv_eq : v = (⟨1, by decide⟩ : Fin 3) := Fin.ext hv
      rw [hu_eq, hv_eq, hs0, hs1]
      exact h_adj_01_at_10
    · have hu_eq : u = (⟨0, by decide⟩ : Fin 3) := Fin.ext hu
      have hv_eq : v = (⟨2, by decide⟩ : Fin 3) := Fin.ext hv
      rw [hu_eq, hv_eq, hs0, hs2]
      exact h_adj_02_at_12
    · -- u=1, v=0: φ u=0, φ v=1. G(1,0) ↔ T(0,1) ↔ T(1,0) (sym) ← h_adj_01_at_10 (swap G side)
      have hu_eq : u = (⟨1, by decide⟩ : Fin 3) := Fin.ext hu
      have hv_eq : v = (⟨0, by decide⟩ : Fin 3) := Fin.ext hv
      rw [hu_eq, hv_eq, hs1, hs0,
        SimpleGraph.adj_comm (G := G_str.1), SimpleGraph.adj_comm (G := T_str.1)]
      exact h_adj_01_at_10
    · have hu_eq : u = (⟨1, by decide⟩ : Fin 3) := Fin.ext hu
      have hv_eq : v = (⟨1, by decide⟩ : Fin 3) := Fin.ext hv
      rw [hu_eq, hv_eq, hs1]
      constructor <;> intro hadj <;> exact absurd hadj (SimpleGraph.irrefl _)
    · -- u=1, v=2: φ u=0, φ v=2. G(1,2) ↔ T(0,2) — exactly h_adj_12_at_02
      have hu_eq : u = (⟨1, by decide⟩ : Fin 3) := Fin.ext hu
      have hv_eq : v = (⟨2, by decide⟩ : Fin 3) := Fin.ext hv
      rw [hu_eq, hv_eq, hs1, hs2]
      exact h_adj_12_at_02
    · -- u=2, v=0: φ u=2, φ v=1. G(2,0) ↔ T(2,1) ↔ T(1,2) (sym) ← h_adj_02_at_12 (swap G side)
      have hu_eq : u = (⟨2, by decide⟩ : Fin 3) := Fin.ext hu
      have hv_eq : v = (⟨0, by decide⟩ : Fin 3) := Fin.ext hv
      rw [hu_eq, hv_eq, hs2, hs0,
        SimpleGraph.adj_comm (G := G_str.1), SimpleGraph.adj_comm (G := T_str.1)]
      exact h_adj_02_at_12
    · -- u=2, v=1: φ u=2, φ v=0. G(2,1) ↔ T(2,0) ↔ T(0,2) (sym) ← h_adj_12_at_02 (swap G side)
      have hu_eq : u = (⟨2, by decide⟩ : Fin 3) := Fin.ext hu
      have hv_eq : v = (⟨1, by decide⟩ : Fin 3) := Fin.ext hv
      rw [hu_eq, hv_eq, hs2, hs1,
        SimpleGraph.adj_comm (G := G_str.1), SimpleGraph.adj_comm (G := T_str.1)]
      exact h_adj_12_at_02
    · have hu_eq : u = (⟨2, by decide⟩ : Fin 3) := Fin.ext hu
      have hv_eq : v = (⟨2, by decide⟩ : Fin 3) := Fin.ext hv
      rw [hu_eq, hv_eq, hs2]
      constructor <;> intro hadj <;> exact absurd hadj (SimpleGraph.irrefl _)
  · -- h_col
    intro v
    have h12 : ((⟨1, by decide⟩ : Fin 3) : Fin 3) ≠ (⟨2, by decide⟩ : Fin 3) := by decide
    have h02 : ((⟨0, by decide⟩ : Fin 3) : Fin 3) ≠ (⟨2, by decide⟩ : Fin 3) := by decide
    have hs0 : Equiv.swap (⟨0, by decide⟩ : Fin 3) ⟨1, by decide⟩ ⟨0, by decide⟩
        = (⟨1, by decide⟩ : Fin 3) := Equiv.swap_apply_left _ _
    have hs1 : Equiv.swap (⟨0, by decide⟩ : Fin 3) ⟨1, by decide⟩ ⟨1, by decide⟩
        = (⟨0, by decide⟩ : Fin 3) := Equiv.swap_apply_right _ _
    have hs2 : Equiv.swap (⟨0, by decide⟩ : Fin 3) ⟨1, by decide⟩ ⟨2, by decide⟩
        = (⟨2, by decide⟩ : Fin 3) := Equiv.swap_apply_of_ne_of_ne h02.symm h12.symm
    rcases fin3_val_cases v with hv | hv | hv
    · have hv_eq : v = (⟨0, by decide⟩ : Fin 3) := Fin.ext hv
      rw [hv_eq, hs0]; exact h_col_0_at_1
    · have hv_eq : v = (⟨1, by decide⟩ : Fin 3) := Fin.ext hv
      rw [hv_eq, hs1]
      have hG := size3_sigma_col_eq_one G_str G_emb G_isInd
      have hT := size3_sigma_col_eq_one T_str T_emb T_isInd
      have hG_emb_eq : G_emb (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) =
          (⟨1, by decide⟩ : Fin 3) := Fin.ext h_emb_G
      have hT_emb_eq : T_emb (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) =
          (⟨0, by decide⟩ : Fin 3) := Fin.ext h_emb_T
      rw [hG_emb_eq] at hG; rw [hT_emb_eq] at hT
      rw [hG, hT]
    · have hv_eq : v = (⟨2, by decide⟩ : Fin 3) := Fin.ext hv
      rw [hv_eq, hs2]; exact h_col_2_at_2

/-- Generic σ-position-1 iso: 3-cycle (1 0 2) case. Maps G-pos 1 ↦ 0, 0 ↦ 2,
    2 ↦ 1. Used when G's σ-vertex is at position 1 with leaves swapped. -/
private theorem size3_sigma1_cycle102_iso
    (G_str T_str : CG2.Str 3)
    (G_emb T_emb : Fin vertexBlackType.size ↪ Fin 3)
    (G_isInd : CG2.comap G_emb G_str = vertexBlackType.str)
    (T_isInd : CG2.comap T_emb T_str = vertexBlackType.str)
    (G_hsize T_hsize : vertexBlackType.size ≤ 3)
    (h_emb_G : (G_emb ⟨0, Nat.zero_lt_one⟩).val = 1)
    (h_emb_T : (T_emb ⟨0, Nat.zero_lt_one⟩).val = 0)
    -- φ : 0 ↦ 2, 1 ↦ 0, 2 ↦ 1.
    (h_adj_01_at_20 : G_str.1.Adj ⟨0, by decide⟩ ⟨1, by decide⟩ ↔
                      T_str.1.Adj ⟨2, by decide⟩ ⟨0, by decide⟩)
    (h_adj_02_at_21 : G_str.1.Adj ⟨0, by decide⟩ ⟨2, by decide⟩ ↔
                      T_str.1.Adj ⟨2, by decide⟩ ⟨1, by decide⟩)
    (h_adj_12_at_01 : G_str.1.Adj ⟨1, by decide⟩ ⟨2, by decide⟩ ↔
                      T_str.1.Adj ⟨0, by decide⟩ ⟨1, by decide⟩)
    (h_col_0_at_2 : G_str.2 ⟨0, by decide⟩ = T_str.2 ⟨2, by decide⟩)
    (h_col_2_at_1 : G_str.2 ⟨2, by decide⟩ = T_str.2 ⟨1, by decide⟩) :
    GenFlagIso vertexBlackType
      (⟨3, G_str, G_emb, G_isInd, G_hsize⟩ : GenFlag CG2 vertexBlackType)
      (⟨3, T_str, T_emb, T_isInd, T_hsize⟩ : GenFlag CG2 vertexBlackType) := by
  classical
  have hT_emb_zero : T_emb (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) =
      (⟨0, (by decide : (0:ℕ) < 3)⟩ : Fin 3) := Fin.ext h_emb_T
  -- φ = swap(0,1) ∘ swap(1,2): 0 ↦ 1 ↦ 2; 1 ↦ 0 ↦ 0; 2 ↦ 2 ↦ 1.
  -- Wait: applied right-to-left: swap(0,1)(swap(1,2) v).
  -- v=0: swap(1,2) gives 0; swap(0,1) gives 1. NO! That's not what we want.
  -- We want 1 ↦ 0. Let me reconsider: φ = swap(1,2) ∘ swap(0,1):
  -- applied as v → swap(0,1) v → swap(1,2) (swap(0,1) v).
  -- v=0: swap(0,1) → 1; swap(1,2) → 2. ✓
  -- v=1: swap(0,1) → 0; swap(1,2) → 0. ✓
  -- v=2: swap(0,1) → 2; swap(1,2) → 1. ✓
  -- So φ = (Equiv.swap 0 1).trans (Equiv.swap 1 2). In Equiv.trans, applied left to right.
  let φ : Fin 3 ≃ Fin 3 := (Equiv.swap (⟨0, by decide⟩ : Fin 3) ⟨1, by decide⟩).trans
                            (Equiv.swap (⟨1, by decide⟩ : Fin 3) ⟨2, by decide⟩)
  apply size3_iso_via_perm G_str T_str G_emb T_emb G_isInd T_isInd G_hsize T_hsize
    hT_emb_zero φ
  · have hG_emb_eq : G_emb (⟨0, Nat.zero_lt_one⟩ : Fin vertexBlackType.size) =
        (⟨1, by decide⟩ : Fin 3) := Fin.ext h_emb_G
    rw [hG_emb_eq]
    change (Equiv.swap (⟨1, by decide⟩ : Fin 3) ⟨2, by decide⟩)
      ((Equiv.swap (⟨0, by decide⟩ : Fin 3) ⟨1, by decide⟩) ⟨1, by decide⟩) = _
    rw [Equiv.swap_apply_right]
    have h01 : ((⟨0, by decide⟩ : Fin 3) : Fin 3) ≠ (⟨1, by decide⟩ : Fin 3) := by decide
    have h02 : ((⟨0, by decide⟩ : Fin 3) : Fin 3) ≠ (⟨2, by decide⟩ : Fin 3) := by decide
