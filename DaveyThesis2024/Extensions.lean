/-- No GenInducedEmbedding from vbExtBlack to vbExt2_RR_indep: vbExtBlack has a
    black leaf at vertex 1 but RR_indep leaves are red. -/
theorem genInducedCount_vbExtBlack_vbExt2_RR_indep_eq_zero :
    genInducedCount CG2 vertexBlackType vbExtBlack vbExt2_RR_indep = 0 := by
  unfold genInducedCount
  rw [Fintype.card_eq_zero_iff]
  refine ⟨fun ⟨f, finj, find, fcompat⟩ => ?_⟩
  have h_phi_0 : f (⟨0, by decide⟩ : Fin 2) = (⟨0, by decide⟩ : Fin 3) :=
    fcompat (⟨0, Nat.zero_lt_one⟩ : Fin 1)
  -- Colour at ⟨1,_⟩: vbExtBlack.str.2 ⟨1,_⟩ = 1, so vbExt2_RR_indep.str.2 (f ⟨1⟩) = 1.
  have h_col : vbExt2_RR_indep.str.2 (f (⟨1, by decide⟩ : Fin 2)) =
      vbExtBlack.str.2 (⟨1, by decide⟩ : Fin 2) :=
    congr_arg (fun s : CG2.Str vbExtBlack.size => s.2 (⟨1, by decide⟩ : Fin 2)) find
  have h_RHS : vbExtBlack.str.2 (⟨1, by decide⟩ : Fin 2) = (1 : Fin 2) := rfl
  rw [h_RHS] at h_col
  -- f ⟨1⟩ has colour 1 in RR_indep. Only ⟨0,_⟩ has colour 1.
  rcases fin3_val_cases (f (⟨1, by decide⟩ : Fin 2)) with h0 | h1 | h2
  · -- f ⟨1⟩ = ⟨0⟩ contradicts injectivity (with f ⟨0⟩ = ⟨0⟩)
    have h_eq : f (⟨1, by decide⟩ : Fin 2) = (⟨0, by decide⟩ : Fin 3) := Fin.ext h0
    have : (⟨1, by decide⟩ : Fin 2) = (⟨0, by decide⟩ : Fin 2) :=
      finj (h_eq.trans h_phi_0.symm)
    have : (1 : ℕ) = 0 := congr_arg Fin.val this
    omega
  · have h_eq : f (⟨1, by decide⟩ : Fin 2) = (⟨1, by decide⟩ : Fin 3) := Fin.ext h1
    rw [h_eq] at h_col
    have : vbExt2_RR_indep.str.2 (⟨1, by decide⟩ : Fin 3) = (0 : Fin 2) := by
      change (if (1 : ℕ) = 0 then (1 : Fin 2) else 0) = 0
      decide
    rw [this] at h_col
    exact absurd h_col (by decide)
  · have h_eq : f (⟨1, by decide⟩ : Fin 2) = (⟨2, by decide⟩ : Fin 3) := Fin.ext h2
    rw [h_eq] at h_col
    have : vbExt2_RR_indep.str.2 (⟨2, by decide⟩ : Fin 3) = (0 : Fin 2) := by
      change (if (2 : ℕ) = 0 then (1 : Fin 2) else 0) = 0
      decide
    rw [this] at h_col
    exact absurd h_col (by decide)

